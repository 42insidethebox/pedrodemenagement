---
interface Node {
  label: string;
  title: string;
  body: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  nodes: Node[];
}

const { eyebrow, title, lead, nodes = [] } = Astro.props as Props;
const visibleNodes = nodes.slice(0, 5);
---

<section class="ps-pipeline">
  <div class="ps-pipeline-copy">
    {eyebrow && <p class="ps-eyebrow">{eyebrow}</p>}
    <h2 class="ps-subtitle">{title}</h2>
    {lead && <p class="ps-lead">{lead}</p>}
  </div>

  <div class="ps-dag-shell" aria-label={title}>
    <div class="ps-dag-grid">
      {
        visibleNodes.map((node, index) => (
          <article class={`ps-dag-node ps-dag-node-${index + 1}`}>
            <span class="ps-dag-label">{node.label}</span>
            <h3>{node.title}</h3>
            <p>{node.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ps-pipeline {
    display: grid;
    gap: 1.3rem;
  }

  .ps-pipeline-copy {
    display: grid;
    gap: 0.7rem;
  }

  .ps-dag-shell {
    position: relative;
    padding: 1.45rem;
    border: 1px solid var(--ps-line);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.76)),
      radial-gradient(circle at top right, var(--ps-haze), transparent 40%);
    box-shadow: 0 28px 55px -45px rgba(17, 24, 39, 0.34);
    overflow: hidden;
  }

  .ps-dag-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(17, 24, 39, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(17, 24, 39, 0.04) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.78), transparent);
    pointer-events: none;
  }

  .ps-dag-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1rem;
    align-items: start;
  }

  .ps-dag-node {
    position: relative;
    min-width: 0;
    padding: 1rem 1rem 1rem 1.05rem;
    border: 1px solid rgba(17, 24, 39, 0.14);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    box-shadow:
      0 18px 34px -28px rgba(17, 24, 39, 0.38),
      inset 0 1px 0 rgba(255, 255, 255, 0.96);
  }

  .ps-dag-node::after {
    content: '';
    position: absolute;
    pointer-events: none;
    opacity: 0.88;
    border-color: rgba(139, 115, 85, 0.64);
    border-style: dashed;
  }

  .ps-dag-node h3 {
    margin: 0 0 0.45rem;
    font-family: var(--ps-font-heading);
    font-size: 1.05rem;
    letter-spacing: -0.03em;
  }

  .ps-dag-node p {
    margin: 0;
    color: var(--ps-muted);
    font-size: 0.94rem;
    line-height: 1.58;
  }

  .ps-dag-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.2rem;
    padding: 0.28rem 0.6rem;
    margin-bottom: 0.75rem;
    border-radius: 999px;
    background: rgba(17, 24, 39, 0.92);
    color: #f9f5ef;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ps-dag-node-1 {
    grid-column: 1 / span 2;
    grid-row: 1;
  }

  .ps-dag-node-2 {
    grid-column: 3 / span 2;
    grid-row: 1;
  }

  .ps-dag-node-3 {
    grid-column: 2 / span 2;
    grid-row: 2;
  }

  .ps-dag-node-4 {
    grid-column: 5 / span 2;
    grid-row: 2;
  }

  .ps-dag-node-5 {
    grid-column: 3 / span 2;
    grid-row: 3;
  }

  .ps-dag-node-1::after {
    top: calc(50% - 1px);
    right: -0.95rem;
    width: 0.95rem;
    border-top-width: 2px;
  }

  .ps-dag-node-2::after {
    left: 34%;
    bottom: -1rem;
    height: 1rem;
    border-left-width: 2px;
  }

  .ps-dag-node-3::after {
    top: calc(50% - 1px);
    right: -1rem;
    width: 1rem;
    border-top-width: 2px;
  }

  .ps-dag-node-4::after {
    left: 30%;
    bottom: -1rem;
    height: 1rem;
    border-left-width: 2px;
  }

  .ps-dag-node-5::after {
    display: none;
  }

  @media (max-width: 980px) {
    .ps-dag-shell {
      padding: 1rem;
    }

    .ps-dag-grid {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .ps-dag-node {
      grid-column: auto;
      grid-row: auto;
    }

    .ps-dag-node::after {
      display: none;
    }
  }
</style>
