---
import Layout from '~/layouts/Layout.astro';
import type { MetaData } from '~/types';
import { ongesGelTheme } from './theme';
import { onglesGelConfig } from './config';

type PageKey = 'home' | 'services' | 'galerie' | 'contact';

interface Props {
  page?: PageKey;
  metadata?: MetaData;
}

const { page = 'home', metadata = {} } = Astro.props as Props;

const base = (path: string) => path || '/';
const nav = [
  { key: 'home',     href: base('/onglesgel'),          label: 'Accueil' },
  { key: 'services', href: base('/onglesgel/services'),  label: 'Tarifs' },
  { key: 'galerie',  href: base('/onglesgel/galerie'),   label: 'Galerie' },
  { key: 'contact',  href: base('/onglesgel/contact'),   label: 'Contact' },
];

const styleVars = {
  '--og-bg':      ongesGelTheme.colors.background,
  '--og-surface': ongesGelTheme.colors.surface,
  '--og-text':    ongesGelTheme.colors.text,
  '--og-muted':   ongesGelTheme.colors.muted,
  '--og-accent':  ongesGelTheme.colors.accent,
  '--og-blush':   ongesGelTheme.colors.accentLight,
  '--og-line':    ongesGelTheme.colors.line,
  '--og-dark':    ongesGelTheme.colors.dark,
  '--og-max':     ongesGelTheme.layout.maxWidth,
  '--og-gap':     ongesGelTheme.layout.sectionGap,
  '--og-heading': ongesGelTheme.typography.heading,
  '--og-body':    ongesGelTheme.typography.body,
};
---

<Layout metadata={metadata} brandKey={ongesGelTheme.brandKey as any} styleVars={styleVars}>
  <div class="og-shell">

    <header class="og-header">
      <a class="og-logo" href={base('/onglesgel')} aria-label="Ongles Gel">
        <span class="og-logo-mark">Ongles Gel</span>
        <span class="og-logo-sep"></span>
        <span class="og-logo-name">Lausanne</span>
      </a>

      <nav class="og-nav" aria-label="Navigation">
        {nav.map((item) => (
          <a class={item.key === page ? 'is-active' : ''} href={item.href}>{item.label}</a>
        ))}
      </nav>

      <div class="og-header-actions">
        <a class="og-btn og-btn-ghost" href={onglesGelConfig.whatsappUrl} target="_blank" rel="noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.52 3.48A11.93 11.93 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.11.55 4.17 1.6 5.99L0 24l6.18-1.62A11.93 11.93 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.48-8.52zm-8.52 18.48a9.9 9.9 0 0 1-5.04-1.37l-.36-.21-3.67.96.98-3.58-.23-.37A9.9 9.9 0 0 1 2.1 12c0-5.46 4.44-9.9 9.9-9.9a9.9 9.9 0 0 1 0 19.8zm5.44-7.4c-.3-.15-1.77-.87-2.04-.97s-.47-.15-.67.15-.77.97-.94 1.17-.35.22-.64.07a8.12 8.12 0 0 1-2.39-1.47 8.98 8.98 0 0 1-1.65-2.05c-.17-.3-.02-.46.13-.6.13-.13.3-.35.44-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52s-.67-1.62-.92-2.22c-.24-.58-.48-.5-.67-.51h-.57c-.2 0-.52.07-.79.37s-1.04 1.02-1.04 2.48 1.07 2.88 1.21 3.08c.15.2 2.1 3.2 5.09 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.89.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
          </svg>
          WhatsApp
        </a>
        <a class="og-btn og-btn-primary" href={onglesGelConfig.bookingUrl} target="_blank" rel="noreferrer">
          Réserver
        </a>
        <button class="og-burger" id="og-burger" aria-label="Menu" aria-expanded="false" type="button">
          <span></span><span></span>
        </button>
      </div>
    </header>

    <!-- Mobile drawer -->
    <div class="og-drawer" id="og-drawer" aria-hidden="true">
      <nav class="og-drawer-nav">
        {nav.map((item) => (
          <a class={item.key === page ? 'is-active' : ''} href={item.href}>{item.label}</a>
        ))}
      </nav>
      <div class="og-drawer-actions">
        <a class="og-btn og-btn-primary" href={onglesGelConfig.bookingUrl} target="_blank" rel="noreferrer">Réserver</a>
        <a class="og-btn og-btn-ghost" href={onglesGelConfig.whatsappUrl} target="_blank" rel="noreferrer">WhatsApp</a>
      </div>
    </div>

    <main class="og-main">
      <slot />
    </main>

    <footer class="og-footer">
      <div class="og-footer-inner">
        <div class="og-footer-brand">
          <span class="og-footer-wordmark">Ongles Gel</span>
          <p class="og-footer-tagline">Studio de pose & nail art à Lausanne.</p>
          <div class="og-footer-ctas">
            <a href={onglesGelConfig.bookingUrl} target="_blank" rel="noreferrer" class="og-btn og-btn-primary">Réserver</a>
            <a href={onglesGelConfig.whatsappUrl} target="_blank" rel="noreferrer" class="og-btn og-btn-ghost">WhatsApp</a>
          </div>
        </div>

        <div class="og-footer-col">
          <p class="og-footer-label">Adresse</p>
          <p>{onglesGelConfig.address}</p>
          <a href={onglesGelConfig.mapLink} target="_blank" rel="noreferrer" class="og-footer-link">Voir sur la carte →</a>
        </div>

        <div class="og-footer-col">
          <p class="og-footer-label">Horaires</p>
          <ul class="og-hours">
            <li><span>Lun</span><span>Fermé</span></li>
            <li><span>Mar–Ven</span><span>09:00 – 19:00</span></li>
            <li><span>Samedi</span><span>09:00 – 17:00</span></li>
            <li><span>Dimanche</span><span>Fermé</span></li>
          </ul>
        </div>

        <div class="og-footer-col">
          <p class="og-footer-label">Contact</p>
          <a href={onglesGelConfig.telHref} target="_blank" rel="noreferrer" class="og-footer-link">{onglesGelConfig.phone}</a>
          <a href={`mailto:${onglesGelConfig.email}`} class="og-footer-link">{onglesGelConfig.email}</a>
        </div>
      </div>
      <div class="og-footer-bottom">
        <span>© {new Date().getFullYear()} Ongles Gel · Lausanne</span>
        <span>onglesgel.ch</span>
      </div>
    </footer>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Manrope:wght@400;500;600&display=swap');

    :global(body) {
      background: var(--og-bg);
      color: var(--og-text);
      font-family: var(--og-body);
      -webkit-font-smoothing: antialiased;
    }

    .og-shell {
      min-height: 100vh;
      background: var(--og-bg);
      color: var(--og-text);
      display: flex;
      flex-direction: column;
    }

    /* ── HEADER ── */
    .og-header {
      position: sticky;
      top: 0;
      z-index: 30;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      padding: 0 2.5rem;
      height: 60px;
      background: color-mix(in srgb, var(--og-bg) 90%, transparent);
      border-bottom: 1px solid var(--og-line);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    .og-logo {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      text-decoration: none;
      color: var(--og-text);
      flex-shrink: 0;
    }
    .og-logo-mark {
      font-family: var(--og-heading);
      font-weight: 400;
      font-style: italic;
      font-size: 1.15rem;
      letter-spacing: 0.02em;
      color: var(--og-accent);
    }
    .og-logo-sep {
      width: 1px;
      height: 14px;
      background: var(--og-line);
    }
    .og-logo-name {
      font-family: var(--og-body);
      font-weight: 500;
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--og-text);
    }

    .og-nav {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .og-nav a {
      text-decoration: none;
      color: var(--og-muted);
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      padding: 0.35rem 0.85rem;
      border-radius: 6px;
      transition: color 130ms ease;
    }
    .og-nav a:hover { color: var(--og-text); }
    .og-nav a.is-active { color: var(--og-accent); font-weight: 600; }

    .og-header-actions {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-shrink: 0;
    }

    /* ── BUTTONS ── */
    .og-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.45rem 1rem;
      border-radius: 999px;
      font-family: var(--og-body);
      font-size: 0.855rem;
      font-weight: 600;
      letter-spacing: 0.01em;
      text-decoration: none;
      transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
    }

    .og-btn-primary {
      background: var(--og-accent);
      color: #fff;
      border: 1.5px solid var(--og-accent);
    }
    .og-btn-primary:hover {
      background: color-mix(in srgb, var(--og-accent) 88%, #1A1612 12%);
    }

    .og-btn-ghost {
      background: transparent;
      color: var(--og-text);
      border: 1.5px solid var(--og-line);
    }
    .og-btn-ghost:hover {
      border-color: color-mix(in srgb, var(--og-text) 25%, transparent);
      background: color-mix(in srgb, var(--og-text) 4%, transparent);
    }

    /* ── MAIN ── */
    .og-main { flex: 1; width: 100%; }

    /* ── FOOTER ── */
    .og-footer {
      border-top: 1px solid var(--og-line);
      padding: 3.5rem 2.5rem 2rem;
      margin-top: auto;
      background: var(--og-surface);
    }

    .og-footer-inner {
      display: grid;
      grid-template-columns: 1.6fr repeat(3, 1fr);
      gap: 2rem 3rem;
      max-width: var(--og-max);
      margin: 0 auto 2.5rem;
      align-items: start;
    }

    .og-footer-brand { display: grid; gap: 0.65rem; }
    .og-footer-wordmark {
      font-family: var(--og-heading);
      font-weight: 400;
      font-style: italic;
      font-size: 1.4rem;
      letter-spacing: 0.01em;
      color: var(--og-text);
    }
    .og-footer-tagline {
      color: var(--og-muted);
      font-size: 0.9rem;
      line-height: 1.5;
    }
    .og-footer-ctas {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.25rem;
    }

    .og-footer-col {
      display: grid;
      gap: 0.35rem;
      font-size: 0.875rem;
      color: var(--og-muted);
    }
    .og-footer-label {
      font-family: var(--og-heading);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--og-accent);
      margin-bottom: 0.2rem;
    }
    .og-footer-link {
      color: var(--og-muted);
      text-decoration: none;
      transition: color 130ms;
    }
    .og-footer-link:hover { color: var(--og-text); }

    .og-hours {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.18rem;
    }
    .og-hours li {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
    }

    .og-footer-bottom {
      display: flex;
      justify-content: space-between;
      max-width: var(--og-max);
      margin: 0 auto;
      padding-top: 1.5rem;
      border-top: 1px solid var(--og-line);
      font-size: 0.78rem;
      color: var(--og-muted);
      letter-spacing: 0.02em;
    }

    /* ── BURGER ── */
    .og-burger {
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      width: 36px;
      height: 36px;
      background: transparent;
      border: 1px solid var(--og-line);
      border-radius: 8px;
      cursor: pointer;
      padding: 0;
      flex-shrink: 0;
    }
    .og-burger span {
      display: block;
      width: 16px;
      height: 1.5px;
      background: var(--og-text);
      border-radius: 2px;
      transition: transform 240ms ease, opacity 200ms ease;
    }
    .og-burger[aria-expanded="true"] span:first-child {
      transform: translateY(3.25px) rotate(45deg);
    }
    .og-burger[aria-expanded="true"] span:last-child {
      transform: translateY(-3.25px) rotate(-45deg);
    }

    /* ── DRAWER ── */
    .og-drawer {
      position: fixed;
      top: 60px;
      left: 0;
      right: 0;
      z-index: 29;
      background: var(--og-bg);
      border-bottom: 1px solid var(--og-line);
      padding: 1.5rem;
      display: grid;
      gap: 1.5rem;
      transform: translateY(-110%);
      transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
      pointer-events: none;
    }
    .og-drawer.og-drawer-open {
      transform: translateY(0);
      pointer-events: auto;
    }

    .og-drawer-nav {
      display: grid;
      gap: 0.15rem;
    }
    .og-drawer-nav a {
      text-decoration: none;
      color: var(--og-text);
      font-size: 1.05rem;
      font-family: var(--og-heading);
      font-style: italic;
      font-weight: 300;
      padding: 0.65rem 0.5rem;
      border-bottom: 1px solid var(--og-line);
      display: block;
      transition: color 130ms;
    }
    .og-drawer-nav a:last-child { border-bottom: none; }
    .og-drawer-nav a.is-active,
    .og-drawer-nav a:hover { color: var(--og-accent); }

    .og-drawer-actions {
      display: flex;
      gap: 0.6rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1100px) {
      .og-footer-inner { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 820px) {
      .og-header { padding: 0 1.5rem; gap: 1rem; }
      .og-nav { display: none; }
      .og-burger { display: flex; }
      .og-footer { padding: 2.5rem 1.5rem 1.5rem; }
      .og-footer-inner { grid-template-columns: 1fr; gap: 1.5rem; }
    }
    @media (max-width: 600px) {
      .og-header { padding: 0 1.2rem; }
      .og-header-actions .og-btn-ghost:not(.og-burger-sibling) { display: none; }
    }
  </style>

  <script>
    const burger = document.getElementById('og-burger');
    const drawer = document.getElementById('og-drawer');
    if (burger && drawer) {
      burger.addEventListener('click', () => {
        const open = burger.getAttribute('aria-expanded') === 'true';
        burger.setAttribute('aria-expanded', String(!open));
        drawer.setAttribute('aria-hidden', String(open));
        drawer.classList.toggle('og-drawer-open', !open);
      });
      // Close on nav link click
      drawer.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => {
          burger.setAttribute('aria-expanded', 'false');
          drawer.setAttribute('aria-hidden', 'true');
          drawer.classList.remove('og-drawer-open');
        });
      });
    }
  </script>
</Layout>
