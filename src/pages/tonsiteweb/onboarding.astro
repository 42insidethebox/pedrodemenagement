---
import Layout from '~/layouts/Layout.astro';

export const prerender = false;

const SUPPORTED_LOCALES = ['fr', 'en', 'it', 'de'] as const;
type Locale = typeof SUPPORTED_LOCALES[number];

function resolveLocale(): Locale {
  const query = Astro.url.searchParams.get('lang');
  if (query && SUPPORTED_LOCALES.includes(query.toLowerCase() as Locale)) return query.toLowerCase() as Locale;
  const header = Astro.request.headers.get('accept-language') || '';
  const base = header.split(',')[0]?.split(';')[0]?.split('-')[0]?.toLowerCase();
  if (base && SUPPORTED_LOCALES.includes(base as Locale)) return base as Locale;
  return 'fr';
}

const locale = resolveLocale();
const sessionId = Astro.url.searchParams.get('session_id') || '';
const error = Astro.url.searchParams.get('error') || '';

