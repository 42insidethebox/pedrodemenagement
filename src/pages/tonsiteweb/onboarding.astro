const t = T[locale];
---

<Layout
  metadata={{ title: t.title }}
  brandKey="tonsiteweb"
>
  <main class="min-h-screen bg-gray-50 py-12 px-4">
    <div class="max-w-2xl mx-auto">

      <div class="text-center mb-10">
        <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">{t.heading}</h1>
        <p class="text-gray-500">{t.sub}</p>
      </div>

      {error && (
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-6 text-sm">
          {t.errorMsg}
        </div>
      )}

      <form
        method="POST"
        action="/api/tonsiteweb/onboarding"
        enctype="multipart/form-data"
        class="space-y-8"
      >
        <input type="hidden" name="session_id" value={sessionId} />
        <input type="hidden" name="locale" value={locale} />

        <!-- Section 1 -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">1</span>
            {t.s1}
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                {t.bizName} <span class="text-red-500">*</span>
              </label>
              <input type="text" name="business_name" required placeholder={t.bizNamePh}
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.tagline}</label>
              <input type="text" name="tagline" placeholder={t.taglinePh}
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.sector}</label>
              <select name="sector" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">{t.sectorPh}</option>
                {t.sectors.map((s) => <option>{s}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                {t.desc} <span class="text-red-500">*</span>
              </label>
              <textarea name="description" required rows="3" placeholder={t.descPh}
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
            </div>
          </div>
        </div>

        <!-- Section 2 -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">2</span>
            {t.s2}
          </h2>
          <p class="text-xs text-gray-400 mb-4">{t.s2sub}</p>
          {[1, 2, 3, 4].map((i) => (
            <div class={`grid grid-cols-1 sm:grid-cols-3 gap-3 ${i < 4 ? 'mb-4 pb-4 border-b border-gray-100' : ''}`}>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">
                  {t.svcLabel} {i} {i === 1 ? <span class="text-red-500">*</span> : <span class="text-gray-400">{t.optional}</span>}
                </label>
                <input type="text" name={`service_${i}_name`} required={i === 1} placeholder={t.svcName}
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">{t.svcDesc}</label>
                <input type="text" name={`service_${i}_desc`} placeholder={t.svcDescPh}
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">{t.svcPrice}</label>
                <input type="text" name={`service_${i}_price`} placeholder={t.svcPricePh}
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              </div>
            </div>
          ))}
        </div>

        <!-- Section 3 -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">3</span>
            {t.s3}
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.address}</label>
              <input type="text" name="address" placeholder={t.addressPh}
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{t.phone}</label>
                <input type="tel" name="phone" placeholder="+41 79 000 00 00"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{t.email}</label>
                <input type="email" name="site_email" placeholder={t.emailPh}
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.hours}</label>
              <textarea name="hours" rows="2" placeholder={t.hoursPh}
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
            </div>
          </div>
        </div>

        <!-- Section 4 -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">4</span>
            {t.s4}
          </h2>
          <div class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{t.colorMain}</label>
                <div class="flex items-center gap-2">
                  <input type="color" name="color_primary" value="#1d4ed8" class="h-10 w-14 rounded border border-gray-300 cursor-pointer p-0.5" />
                  <input type="text" name="color_primary_hex" placeholder="#1d4ed8" maxlength="7"
                    class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                  {t.colorSec} <span class="text-gray-400 text-xs">{t.optional}</span>
                </label>
                <div class="flex items-center gap-2">
                  <input type="color" name="color_secondary" value="#f59e0b" class="h-10 w-14 rounded border border-gray-300 cursor-pointer p-0.5" />
                  <input type="text" name="color_secondary_hex" placeholder="#f59e0b" maxlength="7"
                    class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono" />
                </div>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">{t.styleLabel}</label>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                {t.styles.map(({ value, label, emoji }) => (
                  <label class="flex items-center gap-2 border border-gray-200 rounded-xl p-3 cursor-pointer hover:border-blue-400 has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 transition-colors">
                    <input type="radio" name="style" value={value} class="accent-blue-600" />
                    <span class="text-sm">{emoji} {label}</span>
                  </label>
                ))}
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                {t.logo} <span class="text-gray-400 text-xs">({t.logoPh})</span>
              </label>
              <input type="file" name="logo" accept="image/*"
                class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                {t.photos} <span class="text-gray-400 text-xs">({t.photosPh})</span>
              </label>
              <input type="file" name="photos" accept="image/*" multiple
                class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
            </div>
          </div>
        </div>

        <!-- Section 5 -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">5</span>
            {t.s5}
          </h2>
          <div class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Instagram</label>
                <input type="url" name="instagram" placeholder={t.igPh}
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Facebook</label>
                <input type="url" name="facebook" placeholder={t.fbPh}
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.domain}</label>
              <input type="text" name="domain_desired" placeholder={t.domainPh}
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="domain_owned" value="yes" class="accent-blue-600 w-4 h-4" />
              <span class="text-sm text-gray-700">{t.domainOwned}</span>
            </label>
          </div>
        </div>

        <!-- Section 6 -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">6</span>
            {t.s6}
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.refs}</label>
              <textarea name="references" rows="2" placeholder={t.refsPh}
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.notes}</label>
              <textarea name="notes" rows="3" placeholder={t.notesPh}
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
            </div>
          </div>
        </div>

        <button type="submit"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold text-lg py-4 rounded-2xl transition-colors">
          {t.submit}
        </button>
        <p class="text-center text-xs text-gray-400 pb-8">{t.privacy}</p>
      </form>
    </div>
  </main>
</Layout>
