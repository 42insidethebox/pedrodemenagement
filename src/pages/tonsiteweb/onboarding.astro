---
import Layout from '~/layouts/Layout.astro';

export const prerender = false;

const sessionId = Astro.url.searchParams.get('session_id') || '';
const error = Astro.url.searchParams.get('error') || '';
---

<Layout
  metadata={{ title: 'Configurer votre site — TonSiteWeb.ch' }}
  brandKey="tonsiteweb"
>
  <main class="min-h-screen bg-gray-50 py-12 px-4">
    <div class="max-w-2xl mx-auto">

      <div class="text-center mb-10">
        <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Configurez votre site</h1>
        <p class="text-gray-500">Remplissez ce formulaire une seule fois — nous faisons le reste.</p>
      </div>

      {error && (
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-6 text-sm">
          Une erreur est survenue. Veuillez réessayer ou nous écrire sur WhatsApp.
        </div>
      )}

      <form
        method="POST"
        action="/api/tonsiteweb/onboarding"
        enctype="multipart/form-data"
        class="space-y-8"
      >
        <input type="hidden" name="session_id" value={sessionId} />

        <!-- Section 1: Votre entreprise -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">1</span>
            Votre entreprise
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Nom de l'entreprise <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                name="business_name"
                required
                placeholder="Ex : Salon Bella, Plomberie Dupont…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Slogan / accroche</label>
              <input
                type="text"
                name="tagline"
                placeholder="Ex : L'artisan de confiance depuis 1990"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Secteur d'activité</label>
              <select
                name="sector"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
                <option value="">-- Choisissez --</option>
                <option>Commerce / Boutique</option>
                <option>Artisan / Construction</option>
                <option>Beauté / Bien-être</option>
                <option>Restauration / Traiteur</option>
                <option>Santé / Thérapeute</option>
                <option>Immobilier / Conciergerie</option>
                <option>Transport / Déménagement</option>
                <option>Coiffure</option>
                <option>Sport / Fitness</option>
                <option>Autre</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Décrivez votre activité en 2-3 phrases <span class="text-red-500">*</span>
              </label>
              <textarea
                name="description"
                required
                rows="3"
                placeholder="Qui êtes-vous, ce que vous faites, pour qui…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
              ></textarea>
            </div>
          </div>
        </div>

        <!-- Section 2: Vos services -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">2</span>
            Vos services
          </h2>
          <p class="text-xs text-gray-400 mb-4">Listez vos 1 à 4 services principaux affichés sur le site.</p>
          {[1, 2, 3, 4].map((i) => (
            <div class={`grid grid-cols-1 sm:grid-cols-3 gap-3 ${i < 4 ? 'mb-4 pb-4 border-b border-gray-100' : ''}`}>
              <div class="sm:col-span-1">
                <label class="block text-xs font-medium text-gray-600 mb-1">
                  Service {i} {i === 1 ? <span class="text-red-500">*</span> : <span class="text-gray-400">(optionnel)</span>}
                </label>
                <input
                  type="text"
                  name={`service_${i}_name`}
                  required={i === 1}
                  placeholder="Nom"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div class="sm:col-span-1">
                <label class="block text-xs font-medium text-gray-600 mb-1">Description courte</label>
                <input
                  type="text"
                  name={`service_${i}_desc`}
                  placeholder="En une phrase"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div class="sm:col-span-1">
                <label class="block text-xs font-medium text-gray-600 mb-1">Prix indicatif</label>
                <input
                  type="text"
                  name={`service_${i}_price`}
                  placeholder="Ex : dès 80 CHF"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          ))}
        </div>

        <!-- Section 3: Contact & Localisation -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">3</span>
            Contact & Localisation
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Adresse complète</label>
              <input
                type="text"
                name="address"
                placeholder="Rue, numéro, ville, NPA"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Téléphone affiché sur le site</label>
                <input
                  type="tel"
                  name="phone"
                  placeholder="+41 79 000 00 00"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email affiché sur le site</label>
                <input
                  type="email"
                  name="site_email"
                  placeholder="contact@monentreprise.ch"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Horaires d'ouverture</label>
              <textarea
                name="hours"
                rows="2"
                placeholder="Ex : Lun–Ven 9h–18h, Sam 10h–16h, Dim fermé"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
              ></textarea>
            </div>
          </div>
        </div>

        <!-- Section 4: Identité visuelle -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">4</span>
            Identité visuelle
          </h2>
          <div class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Couleur principale</label>
                <div class="flex items-center gap-2">
                  <input type="color" name="color_primary" value="#1d4ed8" class="h-10 w-14 rounded border border-gray-300 cursor-pointer p-0.5" />
                  <input type="text" name="color_primary_hex" placeholder="#1d4ed8" maxlength="7"
                    class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Couleur secondaire <span class="text-gray-400 text-xs">(optionnel)</span></label>
                <div class="flex items-center gap-2">
                  <input type="color" name="color_secondary" value="#f59e0b" class="h-10 w-14 rounded border border-gray-300 cursor-pointer p-0.5" />
                  <input type="text" name="color_secondary_hex" placeholder="#f59e0b" maxlength="7"
                    class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono" />
                </div>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Style préféré</label>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                {[
                  { value: 'moderne', label: 'Moderne / Minimaliste', emoji: '✦' },
                  { value: 'chaleureux', label: 'Chaleureux / Artisanal', emoji: '🪵' },
                  { value: 'corporate', label: 'Professionnel / Corporate', emoji: '💼' },
                ].map(({ value, label, emoji }) => (
                  <label class="flex items-center gap-2 border border-gray-200 rounded-xl p-3 cursor-pointer hover:border-blue-400 has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 transition-colors">
                    <input type="radio" name="style" value={value} class="accent-blue-600" />
                    <span class="text-sm">{emoji} {label}</span>
                  </label>
                ))}
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Logo <span class="text-gray-400 text-xs">(optionnel — PNG, JPG, SVG)</span>
              </label>
              <input
                type="file"
                name="logo"
                accept="image/*"
                class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
              />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Photos (jusqu'à 3) <span class="text-gray-400 text-xs">(optionnel — votre équipe, local, travaux…)</span>
              </label>
              <input
                type="file"
                name="photos"
                accept="image/*"
                multiple
                class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
              />
            </div>
          </div>
        </div>

        <!-- Section 5: Réseaux sociaux & domaine -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">5</span>
            Réseaux sociaux & domaine
          </h2>
          <div class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Instagram</label>
                <input
                  type="url"
                  name="instagram"
                  placeholder="https://instagram.com/moncompte"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Facebook</label>
                <input
                  type="url"
                  name="facebook"
                  placeholder="https://facebook.com/mapage"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Domaine souhaité</label>
              <input
                type="text"
                name="domain_desired"
                placeholder="Ex : moncoiffeur.ch, salondubeau.ch…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="domain_owned" value="yes" class="accent-blue-600 w-4 h-4" />
              <span class="text-sm text-gray-700">J'ai déjà acheté ce domaine</span>
            </label>
          </div>
        </div>

        <!-- Section 6: Infos complémentaires -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-5 flex items-center gap-2">
            <span class="w-7 h-7 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-bold">6</span>
            Informations complémentaires
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Sites que vous aimez (références)</label>
              <textarea
                name="references"
                rows="2"
                placeholder="Collez des URLs ou décrivez le style que vous avez vu et aimé…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
              ></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Questions ou demandes spéciales</label>
              <textarea
                name="notes"
                rows="3"
                placeholder="Tout ce qui vous semble important pour votre site…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
              ></textarea>
            </div>
          </div>
        </div>

        <button
          type="submit"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold text-lg py-4 rounded-2xl transition-colors"
        >
          Envoyer — lancer la création de mon site →
        </button>
        <p class="text-center text-xs text-gray-400 pb-8">Vos informations sont sécurisées et utilisées uniquement pour créer votre site.</p>
      </form>
    </div>
  </main>
</Layout>
