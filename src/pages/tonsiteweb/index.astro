---
export const prerender = false;
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'TonSiteWeb.ch — Consulting technique, projets web et outils numériques sur mesure',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    id="process"
    class="tsw-home-hero"
    tagline="Consulting technique · Systems & operations · Sites standardisés"
    actions={[
      {
        variant: 'primary',
        text: 'Parler de votre besoin',
        href: '/contact#form',
        icon: 'tabler:arrow-right',
      },
      { text: 'Voir les tarifs', href: '/pricing' },
    ]}
  >
    <Fragment slot="title">Clarté technique, delivery propre et sites web quand le standard suffit.</Fragment>

    <Fragment slot="subtitle">
      Nous aidons les PME et indépendants à choisir le bon niveau d’intervention: cadrer vite, construire sur mesure, ou
      lancer un site simple dès 999 CHF.
    </Fragment>

    <Fragment slot="bg">
      <div class="tsw-home-hero-bg"></div>
      <div class="tsw-home-hero-glow tsw-home-hero-glow--warm" aria-hidden="true"></div>
      <div class="tsw-home-hero-glow tsw-home-hero-glow--cool" aria-hidden="true"></div>
      <div class="tsw-home-hero-plate" aria-hidden="true"></div>
      <div class="tsw-home-hero-axis" aria-hidden="true"></div>
      <div class="tsw-home-hero-orbit" aria-hidden="true"></div>
    </Fragment>

    <Fragment slot="image">
      <div class="tsw-home-hero-shell">
        <div class="tsw-home-hero-visual">
          <div class="tsw-home-hero-bar">
            <span class="tsw-home-hero-chip">TonSiteWeb.ch</span>
            <span class="tsw-home-hero-meta">Consulting technique • Systems & operations • Sites standardisés</span>
          </div>

          <article class="tsw-home-hero-intro">
            <p class="tsw-home-hero-kicker">Choisir le bon point d’entrée</p>
            <h3>Trois portes claires selon le besoin réel.</h3>
            <p>
              Consulting pour clarifier ou débloquer, systems & operations pour construire plus sérieusement, site
              standardisé quand une présence web simple suffit vraiment.
            </p>
          </article>

          <div class="tsw-home-hero-entry-grid">
            <a class="tsw-home-hero-entry tsw-home-hero-entry--consulting" href="/contact#form">
              <div class="tsw-home-hero-entry-head">
                <span class="tsw-home-hero-entry-label">Consulting technique</span>
                <strong>60 CHF / 15 min</strong>
              </div>
              <p>Arbitrer, débloquer, valider une direction.</p>
              <span class="tsw-home-hero-entry-cta">Réserver un consulting</span>
            </a>

            <a class="tsw-home-hero-entry tsw-home-hero-entry--systems" href="/contact#form">
              <div class="tsw-home-hero-entry-head">
                <span class="tsw-home-hero-entry-label">Systems & operations</span>
                <strong>Sur devis</strong>
              </div>
              <p>Codebase privée, backend, infra, automatisation, continuité.</p>
              <span class="tsw-home-hero-entry-cta">Discuter du scope</span>
            </a>

            <a class="tsw-home-hero-entry tsw-home-hero-entry--website" href="/pricing?tab=website#pricing-options">
              <div class="tsw-home-hero-entry-head">
                <span class="tsw-home-hero-entry-label">Site standardisé</span>
                <strong>Dès 999 CHF</strong>
              </div>
              <p>Site vitrine simple, rapide et propre quand cela suffit.</p>
              <span class="tsw-home-hero-entry-cta">Voir les packs site</span>
            </a>
          </div>
        </div>
      </div>
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Ce que nous faisons"
    title="Trois points d’entrée, selon le besoin réel"
    subtitle="Clarifier vite, construire proprement, ou lancer un site standard quand c’est suffisant."
    items={[
      {
        title: 'Consulting technique',
        description:
          '60 CHF / 15 min ou 140 CHF / h pour cadrer un sujet, arbitrer une décision, débloquer une implémentation ou éviter un mauvais chantier.',
        icon: 'tabler:sparkles',
      },
      {
        title: 'Systems & operations',
        description:
          'Codebase privée, backend, intégrations, automatisations, infrastructure et continuité technique quand le standard ne suffit plus.',
        icon: 'tabler:server',
      },
      {
        title: 'Site standardisé',
        description:
          'Une offre simple dès 999 CHF pour les cas où une présence en ligne propre et rapide est vraiment tout ce qu’il faut.',
        icon: 'tabler:layout',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Méthode"
    title="On commence par clarifier, puis on livre au bon niveau"
    items={[
      {
        title: 'Diagnostic rapide',
        description:
          'On distingue vite si le sujet relève d’un échange de cadrage, d’un projet sur mesure, ou simplement d’un site standard à lancer.',
      },
      {
        title: 'Périmètre net',
        description:
          'Vous savez ce qui est standard, ce qui demande une build privée, et ce qui peut être tranché en consulting court.',
      },
      {
        title: 'Exécution suivie',
        description:
          'Une fois le bon format choisi, nous exécutons proprement et restons disponibles pour la suite si le besoin évolue.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Pas de survente, pas de détour inutile
      </h3>
      Le bon service n’est pas toujours le plus gros projet. Parfois il faut juste un site. Parfois il faut d’abord trancher
      une décision technique.
    </Fragment>

    <Fragment slot="image">
      <div
        class="tsw-home-figure tsw-home-figure--method relative aspect-[4/3] overflow-hidden rounded-xl bg-gradient-to-br from-blue-600 via-slate-900 to-slate-800 p-10 text-left text-white shadow-xl"
      >
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Parcours clair</p>
        <h4 class="mt-4 text-3xl font-semibold">Diagnostic → Exécution → Suivi</h4>
        <p class="mt-6 max-w-xs text-base text-blue-100/90">
          On choisit d’abord le bon niveau d’intervention, puis on avance sans vous noyer dans la technique.
        </p>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Une méthode simple pour cadrer puis livrer"
    tagline="Parcours"
    items={[
      {
        title: 'Premier échange',
        description:
          'Vous décrivez le besoin, le blocage ou le projet, et nous identifions rapidement la bonne porte d’entrée.',
        icon: 'tabler:edit',
      },
      {
        title: 'Cadrage adapté',
        description:
          'Consulting court, projet sur mesure ou site standardisé: le format est clarifié avant d’engager du temps inutile.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Exécution supervisée',
        description:
          'Nous produisons, intégrons ou débloquons le sujet avec un périmètre clair et un point de contact unique.',
        icon: 'tabler:robot',
      },
      {
        title: 'Suivi ou extension',
        description:
          'Une fois la première étape livrée, nous pouvons rester en support, ouvrir un second chantier ou simplement clôturer proprement.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="image">
      <div
        class="tsw-home-figure tsw-home-figure--timeline relative aspect-[3/4] overflow-hidden rounded-xl bg-gradient-to-br from-slate-900 via-slate-800 to-blue-700 p-10 text-white shadow-xl"
      >
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Timeline</p>
        <p class="mt-6 max-w-xs text-base text-blue-100/90">
          Un site standard se lance vite. Un consulting court peut débloquer un sujet en une session. Un projet sur
          mesure suit ensuite un cadrage séparé, sans confusion entre les niveaux.
        </p>
      </div>
    </Fragment>
  </Steps>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Cadrage & arbitrage',
        description:
          'Audit rapide, décisions techniques, priorisation et regard externe quand il faut trancher proprement.',
      },
      {
        title: 'Intégration & automatisation',
        description:
          'Connexion d’outils, formulaires, rendez-vous, flux métier ou scripts ciblés quand le besoin sort du simple site.',
      },
      {
        title: 'Site standardisé',
        description:
          'Une présence en ligne simple, crédible et rapide à déployer quand le sujet n’a pas besoin d’une build lourde.',
      },
      {
        title: 'Support & continuité',
        description:
          'Maintenance, tickets, suivi ou second chantier si vous avez besoin de continuité après la première livraison.',
      },
    ]}
  >
    <Fragment slot="content">
      Tous les sujets n’ont pas besoin du même niveau d’effort. L’important est de choisir la formule utile, pas de
      pousser tout le monde vers la même offre.
    </Fragment>

    <Fragment slot="image">
      <div
        class="tsw-home-figure tsw-home-figure--decision relative aspect-[4/3] overflow-hidden rounded-xl bg-gradient-to-br from-slate-900 via-slate-800 to-blue-700 p-10 text-white shadow-xl"
      >
        <h4 class="text-3xl font-semibold">Le standard quand il suffit. Le sur mesure quand il faut.</h4>
        <ul class="mt-6 space-y-3 text-left text-blue-100/90">
          <li>✓ Consulting court pour arbitrer vite</li>
          <li>✓ Projet plus large quand il faut construire</li>
          <li>✓ Site standard dès 999 CHF quand le besoin est simple</li>
        </ul>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features2 Widget ************** -->

  <Features2
    id="included"
    title="Formats d’intervention"
    subtitle="Selon le niveau de complexité et ce qu’il est vraiment utile de construire"
    tagline="Concrètement"
    items={[
      {
        title: 'Consulting ciblé',
        description: 'Une session courte pour cadrer, arbitrer, challenger une solution ou débloquer un chantier.',
        icon: 'tabler:world',
      },
      {
        title: 'Projet sur mesure',
        description: 'Build privée, backend léger, intégration métier ou développement plus poussé quand nécessaire.',
        icon: 'tabler:git-branch',
      },
      {
        title: 'Site standardisé',
        description:
          'Une option rapide et propre pour les lancements simples, sans transformer un besoin basique en gros projet.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Support continu',
        description:
          'Mises à jour, tickets, maintenance et suivi après livraison si vous voulez une continuité claire.',
        icon: 'tabler:ruler-measure',
      },
      {
        title: 'Automatisation utile',
        description:
          'Scripts, formulaires, rendez-vous, notifications ou connexions ciblées quand cela fait vraiment gagner du temps.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Coordination technique',
        description:
          'Un interlocuteur pour garder le sujet lisible entre besoin métier, exécution et prochaines décisions.',
        icon: 'tabler:route',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Repères de départ"
    stats={[
      { title: 'Consulting express', amount: '60 CHF / 15 min' },
      { title: 'Consulting', amount: '140 CHF / h' },
      { title: 'Sur mesure', amount: 'scope sur devis' },
      { title: 'Site standard', amount: '999 CHF' },
    ]}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    id="faq"
    title="Questions fréquentes"
    subtitle="Transparence totale sur notre façon de travailler."
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Quand faut-il choisir le consulting plutôt qu’un pack site ?',
        description:
          'Quand le vrai besoin est de trancher une décision, débloquer un sujet technique, challenger une implémentation ou cadrer un chantier avant d’écrire plus de code.',
      },
      {
        title: 'Prenez-vous aussi des projets plus techniques ?',
        description:
          'Oui. Intégrations, automatisations, scripts, Linux, backend léger, code privé, ou développement plus large si le sujet dépasse l’offre standardisée.',
      },
      {
        title: 'Le site dès 999 CHF existe toujours ?',
        description:
          'Oui. Il reste pertinent quand vous avez surtout besoin d’une présence en ligne propre et rapide. Nous le traitons simplement comme une offre standard, pas comme l’unique identité du site.',
      },
      {
        title: 'Comment cadrez-vous un projet sur mesure ?',
        description:
          'Nous clarifions d’abord le besoin, les contraintes, le périmètre utile et le niveau d’effort. Ensuite seulement nous proposons un chiffrage et une séquence de livraison.',
      },
      {
        title: 'Pouvez-vous rester ensuite en support ?',
        description:
          'Oui. Nous pouvons rester disponibles en maintenance, tickets, visio planifiée ou accompagnement plus continu selon le sujet.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Parler de votre besoin',
        href: '/contact#form',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Voir les tarifs',
        href: '/pricing',
      },
    ]}
  >
    <Fragment slot="title">Commencez par le bon niveau d’intervention</Fragment>

    <Fragment slot="subtitle">
      Consulting technique, projet sur mesure ou site standard dès 999 CHF: nous vous aidons à choisir l’option utile au
      lieu de pousser tout le monde vers la même offre.
    </Fragment>
  </CallToAction>

  <style>
    .tsw-home-hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 10% 8%, rgba(249, 115, 22, 0.18), transparent 24%),
        radial-gradient(circle at 88% 10%, rgba(59, 130, 246, 0.14), transparent 28%),
        radial-gradient(circle at 74% 76%, rgba(239, 68, 68, 0.1), transparent 18%),
        radial-gradient(circle at 18% 78%, rgba(14, 165, 233, 0.08), transparent 22%),
        linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0));
    }

    .tsw-home-hero-glow,
    .tsw-home-hero-plate,
    .tsw-home-hero-axis,
    .tsw-home-hero-orbit {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    .tsw-home-hero-glow {
      filter: blur(24px);
      opacity: 0.9;
    }

    .tsw-home-hero-glow--warm {
      inset: 2.2rem auto auto 4%;
      width: min(18rem, 26vw);
      height: min(18rem, 26vw);
      border-radius: 999px;
      background:
        radial-gradient(circle, rgba(251, 146, 60, 0.3) 0%, rgba(249, 115, 22, 0.18) 38%, transparent 72%),
        radial-gradient(circle at 65% 65%, rgba(239, 68, 68, 0.16), transparent 62%);
    }

    .tsw-home-hero-glow--cool {
      inset: auto 4% 1.6rem auto;
      width: min(19rem, 28vw);
      height: min(19rem, 28vw);
      border-radius: 999px;
      background:
        radial-gradient(circle, rgba(14, 165, 233, 0.18) 0%, rgba(37, 99, 235, 0.14) 38%, transparent 74%),
        radial-gradient(circle at 35% 35%, rgba(125, 211, 252, 0.1), transparent 62%);
    }

    .tsw-home-hero-plate {
      inset: 2.5rem max(1rem, 8vw) auto;
      height: 15rem;
      border: 1px solid rgba(100, 116, 139, 0.12);
      border-radius: 1.7rem;
      background:
        linear-gradient(90deg, rgba(71, 85, 105, 0.04) 1px, transparent 1px),
        linear-gradient(rgba(71, 85, 105, 0.04) 1px, transparent 1px),
        linear-gradient(135deg, rgba(249, 115, 22, 0.06), transparent 32%, rgba(37, 99, 235, 0.04) 78%, transparent),
        linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.08));
      background-size:
        22px 22px,
        22px 22px,
        100% 100%,
        100% 100%;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.74),
        0 18px 54px -42px rgba(51, 65, 85, 0.22);
      mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.95), rgba(0, 0, 0, 0.2));
    }

    .tsw-home-hero-plate::before,
    .tsw-home-hero-plate::after {
      content: '';
      position: absolute;
      pointer-events: none;
    }

    .tsw-home-hero-plate::before {
      left: 1rem;
      right: 1rem;
      top: 1rem;
      bottom: 1rem;
      border: 1px dashed rgba(100, 116, 139, 0.15);
      border-radius: 1rem;
    }

    .tsw-home-hero-plate::after {
      left: 50%;
      top: 0.9rem;
      bottom: 0.9rem;
      width: 1px;
      background: linear-gradient(180deg, rgba(14, 165, 233, 0.1), rgba(71, 85, 105, 0.03));
      transform: translateX(-0.5px);
      opacity: 0.8;
    }

    .tsw-home-hero-axis::before,
    .tsw-home-hero-axis::after {
      content: '';
      position: absolute;
      pointer-events: none;
    }

    .tsw-home-hero-axis::before {
      left: 10%;
      right: 10%;
      top: 8.5rem;
      height: 1px;
      background:
        linear-gradient(90deg, transparent, rgba(100, 116, 139, 0.24) 12%, rgba(100, 116, 139, 0.24) 88%, transparent),
        linear-gradient(
          90deg,
          transparent 0%,
          transparent 15%,
          rgba(100, 116, 139, 0.18) 15%,
          rgba(100, 116, 139, 0.18) 15.4%,
          transparent 15.4%,
          transparent 49.3%,
          rgba(14, 165, 233, 0.18) 49.3%,
          rgba(14, 165, 233, 0.18) 50.7%,
          transparent 50.7%,
          transparent 84.6%,
          rgba(100, 116, 139, 0.18) 84.6%,
          rgba(100, 116, 139, 0.18) 85%,
          transparent 85%
        );
      opacity: 0.62;
    }

    .tsw-home-hero-axis::after {
      top: 4.6rem;
      bottom: 4.2rem;
      left: 50%;
      width: 1px;
      background:
        linear-gradient(180deg, transparent, rgba(100, 116, 139, 0.18) 18%, rgba(100, 116, 139, 0.18) 82%, transparent),
        linear-gradient(
          180deg,
          transparent 0%,
          transparent 18%,
          rgba(100, 116, 139, 0.15) 18%,
          rgba(100, 116, 139, 0.15) 18.5%,
          transparent 18.5%,
          transparent 49.3%,
          rgba(14, 165, 233, 0.16) 49.3%,
          rgba(14, 165, 233, 0.16) 50.7%,
          transparent 50.7%,
          transparent 81.5%,
          rgba(100, 116, 139, 0.15) 81.5%,
          rgba(100, 116, 139, 0.15) 82%,
          transparent 82%
        );
      transform: translateX(-0.5px);
      opacity: 0.5;
    }

    .tsw-home-hero-orbit::before,
    .tsw-home-hero-orbit::after {
      content: '';
      position: absolute;
      border-radius: 999px;
      pointer-events: none;
    }

    .tsw-home-hero-orbit::before {
      right: max(1.5rem, 7vw);
      top: 2.9rem;
      width: 14rem;
      height: 14rem;
      border: 1px solid rgba(100, 116, 139, 0.12);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.14);
      opacity: 0.72;
    }

    .tsw-home-hero-orbit::after {
      left: max(1.5rem, 8vw);
      top: 3.7rem;
      width: 8.5rem;
      height: 8.5rem;
      border: 1px dashed rgba(100, 116, 139, 0.15);
      opacity: 0.68;
    }

    .tsw-home-hero-shell {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(100, 116, 139, 0.14);
      border-radius: 1.9rem;
      padding: 0.8rem;
      background:
        linear-gradient(90deg, rgba(71, 85, 105, 0.035) 1px, transparent 1px),
        linear-gradient(rgba(71, 85, 105, 0.035) 1px, transparent 1px),
        linear-gradient(140deg, rgba(249, 115, 22, 0.05), transparent 30%, rgba(37, 99, 235, 0.04) 74%, transparent),
        linear-gradient(180deg, rgba(241, 245, 249, 0.34), rgba(255, 255, 255, 0));
      background-size:
        24px 24px,
        24px 24px,
        100% 100%,
        100% 100%;
      box-shadow: 0 30px 72px -56px rgba(51, 65, 85, 0.24);
    }

    .tsw-home-hero-shell::before,
    .tsw-home-hero-shell::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .tsw-home-hero-shell::before {
      background:
        radial-gradient(circle at 0% 0%, rgba(249, 115, 22, 0.12), transparent 24%),
        radial-gradient(circle at 100% 12%, rgba(59, 130, 246, 0.08), transparent 22%),
        linear-gradient(130deg, transparent 0%, rgba(255, 255, 255, 0.12) 48%, transparent 100%);
      opacity: 0.82;
    }

    .tsw-home-hero-shell::after {
      inset: auto -8% -20% auto;
      width: 15rem;
      height: 15rem;
      border-radius: 999px;
      background:
        radial-gradient(circle, rgba(37, 99, 235, 0.08), transparent 68%),
        radial-gradient(circle at 36% 36%, rgba(249, 115, 22, 0.08), transparent 58%);
      filter: blur(12px);
    }

    :global(.dark) .tsw-home-hero-bg {
      background:
        radial-gradient(circle at 15% 0%, rgba(100, 116, 139, 0.16), transparent 28%),
        radial-gradient(circle at 100% 10%, rgba(14, 165, 233, 0.1), transparent 24%),
        linear-gradient(180deg, rgba(2, 6, 23, 0.9), rgba(15, 23, 42, 0));
    }

    :global(.dark) .tsw-home-hero-plate {
      border-color: rgba(34, 211, 238, 0.08);
      background:
        linear-gradient(90deg, rgba(34, 211, 238, 0.035) 1px, transparent 1px),
        linear-gradient(rgba(34, 211, 238, 0.035) 1px, transparent 1px),
        linear-gradient(180deg, rgba(15, 23, 42, 0.34), rgba(2, 6, 23, 0.08));
      background-size:
        22px 22px,
        22px 22px,
        100% 100%;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.03),
        0 18px 54px -42px rgba(2, 6, 23, 0.72);
    }

    :global(.dark) .tsw-home-hero-plate::before {
      border-color: rgba(34, 211, 238, 0.08);
    }

    :global(.dark) .tsw-home-hero-plate::after {
      background: linear-gradient(180deg, rgba(34, 211, 238, 0.14), rgba(34, 211, 238, 0.02));
    }

    :global(.dark) .tsw-home-hero-axis::before {
      background:
