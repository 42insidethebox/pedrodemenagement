---
export const prerender = false;
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'TonSiteWeb.ch — Consulting technique, projets web et outils numériques sur mesure',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    id="process"
    actions={[
      {
        variant: 'primary',
        text: 'Parler de votre besoin',
        href: '/contact#form',
        icon: 'tabler:arrow-right',
      },
      { text: 'Voir les tarifs', href: '/pricing' },
    ]}
    image={{ src: '~/assets/images/light_minimalist.png', alt: 'Interface TonSiteWeb.ch' }}
  >
    <Fragment slot="title">Consulting technique, projets web et outils numériques sur mesure</Fragment>

    <Fragment slot="subtitle">
      TonSiteWeb.ch aide les PME et indépendants à cadrer un besoin technique, débloquer un sujet précis ou livrer un
      projet plus proprement. Et quand un site standard suffit, l’offre de lancement dès 999 CHF reste disponible.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note
    title="Le bon niveau d’intervention"
    description="Le site standard reste une option simple. Mais la valeur ne s’arrête pas là: nous intervenons aussi en consulting technique, intégration, automatisation et développement sur des sujets plus larges."
  />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Ce que nous faisons"
    title="Consulting d’abord, projet sur mesure ensuite, site standard si cela suffit"
    subtitle="Nous commençons par le besoin réel: arbitrer, construire, ou aller au plus simple quand un site standardisé suffit."
    items={[
      {
        title: 'Consulting technique',
        description:
          '60 CHF / 15 min ou 140 CHF / h pour cadrer un sujet, arbitrer une décision, débloquer une implémentation ou éviter un mauvais chantier.',
        icon: 'tabler:sparkles',
      },
      {
        title: 'Projets sur mesure',
        description:
          'Intégrations, automatisations, codebase privée, backend léger, outillage interne ou développement plus avancé quand le standard ne suffit plus.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Sites web standardisés',
        description:
          'Une offre simple dès 999 CHF pour les cas où une présence en ligne propre et rapide est vraiment tout ce qu’il faut.',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'Périmètre clair',
        description:
          'Chaque besoin est rangé dans la bonne catégorie: consulting court, projet cadré, ou lancement standardisé sans surconstruire.',
        icon: 'tabler:server',
      },
      {
        title: 'Continuité de support',
        description:
          'Un interlocuteur répond sous un jour ouvré et peut suivre le sujet après le cadrage, le lancement ou la mise en production.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Contact & rendez-vous',
        description:
          'Formulaire, WhatsApp, Calendly ou prise de rendez-vous simple selon qu’il s’agisse d’un site, d’un cadrage ou d’un projet plus large.',
        icon: 'tabler:headset',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Méthode"
    title="On commence par clarifier, puis on livre au bon niveau"
    items={[
      {
        title: 'Diagnostic rapide',
        description:
          'On distingue vite si le sujet relève d’un échange de cadrage, d’un projet sur mesure, ou simplement d’un site standard à lancer.',
      },
      {
        title: 'Périmètre net',
        description:
          'Vous savez ce qui est standard, ce qui demande une build privée, et ce qui peut être tranché en consulting court.',
      },
      {
        title: 'Exécution suivie',
        description:
          'Une fois le bon format choisi, nous exécutons proprement et restons disponibles pour la suite si le besoin évolue.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Pas de survente, pas de détour inutile
      </h3>
      Le bon service n’est pas toujours le plus gros projet. Parfois il faut juste un site. Parfois il faut d’abord trancher
      une décision technique.
    </Fragment>

    <Fragment slot="image">
      <div
        class="relative aspect-[4/3] overflow-hidden rounded-xl bg-gradient-to-br from-blue-600 via-slate-900 to-slate-800 p-10 text-left text-white shadow-xl"
      >
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Parcours clair</p>
        <h4 class="mt-4 text-3xl font-semibold">Diagnostic → Exécution → Suivi</h4>
        <p class="mt-6 max-w-xs text-base text-blue-100/90">
          On choisit d’abord le bon niveau d’intervention, puis on avance sans vous noyer dans la technique.
        </p>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Une méthode simple pour cadrer puis livrer"
    tagline="Parcours"
    items={[
      {
        title: 'Premier échange',
        description:
          'Vous décrivez le besoin, le blocage ou le projet, et nous identifions rapidement la bonne porte d’entrée.',
        icon: 'tabler:edit',
      },
      {
        title: 'Cadrage adapté',
        description:
          'Consulting court, projet sur mesure ou site standardisé: le format est clarifié avant d’engager du temps inutile.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Exécution supervisée',
        description:
          'Nous produisons, intégrons ou débloquons le sujet avec un périmètre clair et un point de contact unique.',
        icon: 'tabler:robot',
      },
      {
        title: 'Suivi ou extension',
        description:
          'Une fois la première étape livrée, nous pouvons rester en support, ouvrir un second chantier ou simplement clôturer proprement.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="image">
      <div
        class="relative aspect-[3/4] overflow-hidden rounded-xl bg-gradient-to-br from-slate-900 via-slate-800 to-blue-700 p-10 text-white shadow-xl"
      >
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Timeline</p>
        <p class="mt-6 max-w-xs text-base text-blue-100/90">
          Un site standard se lance vite. Un consulting court peut débloquer un sujet en une session. Un projet sur
          mesure suit ensuite un cadrage séparé, sans confusion entre les niveaux.
        </p>
      </div>
    </Fragment>
  </Steps>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Cadrage & arbitrage',
        description:
          'Audit rapide, décisions techniques, priorisation et regard externe quand il faut trancher proprement.',
      },
      {
        title: 'Intégration & automatisation',
        description:
          'Connexion d’outils, formulaires, rendez-vous, flux métier ou scripts ciblés quand le besoin sort du simple site.',
      },
      {
        title: 'Site standardisé',
        description:
          'Une présence en ligne simple, crédible et rapide à déployer quand le sujet n’a pas besoin d’une build lourde.',
      },
      {
        title: 'Support & continuité',
        description:
          'Maintenance, tickets, suivi ou second chantier si vous avez besoin de continuité après la première livraison.',
      },
    ]}
  >
    <Fragment slot="content">
      Tous les sujets n’ont pas besoin du même niveau d’effort. L’important est de choisir la formule utile, pas de
      pousser tout le monde vers la même offre.
    </Fragment>

    <Fragment slot="image">
      <div
        class="relative aspect-[4/3] overflow-hidden rounded-xl bg-gradient-to-br from-slate-900 via-slate-800 to-blue-700 p-10 text-white shadow-xl"
      >
        <h4 class="text-3xl font-semibold">Le standard quand il suffit. Le sur mesure quand il faut.</h4>
        <ul class="mt-6 space-y-3 text-left text-blue-100/90">
          <li>✓ Consulting court pour arbitrer vite</li>
          <li>✓ Projet plus large quand il faut construire</li>
          <li>✓ Site standard dès 999 CHF quand le besoin est simple</li>
        </ul>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features2 Widget ************** -->

  <Features2
    id="included"
    title="Formats d’intervention"
    subtitle="Selon le niveau de complexité et ce qu’il est vraiment utile de construire"
    tagline="Concrètement"
    items={[
      {
        title: 'Consulting ciblé',
        description: 'Une session courte pour cadrer, arbitrer, challenger une solution ou débloquer un chantier.',
        icon: 'tabler:world',
      },
      {
        title: 'Projet sur mesure',
        description: 'Build privée, backend léger, intégration métier ou développement plus poussé quand nécessaire.',
        icon: 'tabler:git-branch',
      },
      {
        title: 'Site standardisé',
        description:
          'Une option rapide et propre pour les lancements simples, sans transformer un besoin basique en gros projet.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Support continu',
        description:
          'Mises à jour, tickets, maintenance et suivi après livraison si vous voulez une continuité claire.',
        icon: 'tabler:ruler-measure',
      },
      {
        title: 'Automatisation utile',
        description:
          'Scripts, formulaires, rendez-vous, notifications ou connexions ciblées quand cela fait vraiment gagner du temps.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Coordination technique',
        description:
          'Un interlocuteur pour garder le sujet lisible entre besoin métier, exécution et prochaines décisions.',
        icon: 'tabler:route',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Repères de départ"
    stats={[
      { title: 'Consulting express', amount: '60 CHF / 15 min' },
      { title: 'Consulting', amount: '140 CHF / h' },
      { title: 'Sur mesure', amount: '2 000+ CHF' },
      { title: 'Site standard', amount: '999 CHF' },
    ]}
  />

  <!-- Use cases ******************** -->
  <div class="bg-white dark:bg-slate-900 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold uppercase tracking-widest text-blue-600 mb-2">Cas typiques</p>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Le bon point d’entrée dépend du besoin</h2>
        <p class="text-gray-500 max-w-xl mx-auto text-sm">
          Nous n’essayons pas de faire entrer chaque demande dans la même boîte. Le bon format dépend du niveau de
          complexité et de l’urgence réelle.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 border border-gray-100 dark:border-slate-700">
          <p class="text-blue-700 dark:text-blue-300 font-semibold text-sm mb-3">Consulting</p>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4">
            Vous avez un doute technique, un arbitrage à faire, un devis à challenger ou un chantier qui part dans tous
            les sens.
          </p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white">On commence court</p>
          <p class="text-xs text-gray-400">15 min ou 1 h pour décider avant de surconstruire</p>
        </div>
        <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 border border-gray-100 dark:border-slate-700">
          <p class="text-blue-700 dark:text-blue-300 font-semibold text-sm mb-3">Projet sur mesure</p>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4">
            Il faut connecter des outils, automatiser un flux, structurer un backend léger ou sortir d’un template
            standard.
          </p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white">On cadre avant de builder</p>
          <p class="text-xs text-gray-400">Périmètre, chiffrage et prochaine étape lisibles</p>
        </div>
        <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 border border-gray-100 dark:border-slate-700">
          <p class="text-blue-700 dark:text-blue-300 font-semibold text-sm mb-3">Site standardisé</p>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4">
            Vous avez surtout besoin d’une présence en ligne propre, crédible et rapide, sans budget ni complexité de
            build privée.
          </p>
          <p class="text-sm font-semibold text-gray-900 dark:text-white">On lance simplement</p>
          <p class="text-xs text-gray-400">Offre standard dès 999 CHF quand cela suffit</p>
        </div>
      </div>
      <div
        class="bg-blue-50 dark:bg-blue-900/20 rounded-2xl p-6 text-center border border-blue-100 dark:border-blue-800"
      >
        <p class="text-blue-700 dark:text-blue-300 font-semibold mb-1">Point important</p>
        <p class="text-gray-600 dark:text-gray-400 text-sm">
          Le pack site reste utile et rentable dans beaucoup de cas. La différence est que nous ne réduisons plus toute
          la relation à cela: consulting, exécution technique et support restent aussi des portes d’entrée normales.
        </p>
      </div>
    </div>
  </div>

  <!-- FAQs Widget ******************* -->

  <FAQs
    id="faq"
    title="Questions fréquentes"
    subtitle="Transparence totale sur notre façon de travailler."
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Quand faut-il choisir le consulting plutôt qu’un pack site ?',
        description:
          'Quand le vrai besoin est de trancher une décision, débloquer un sujet technique, challenger une implémentation ou cadrer un chantier avant d’écrire plus de code.',
      },
      {
        title: 'Prenez-vous aussi des projets plus techniques ?',
        description:
          'Oui. Intégrations, automatisations, scripts, Linux, backend léger, code privé, ou développement plus large si le sujet dépasse l’offre standardisée.',
      },
      {
        title: 'Le site dès 999 CHF existe toujours ?',
        description:
          'Oui. Il reste pertinent quand vous avez surtout besoin d’une présence en ligne propre et rapide. Nous le traitons simplement comme une offre standard, pas comme l’unique identité du site.',
      },
      {
        title: 'Comment cadrez-vous un projet sur mesure ?',
        description:
          'Nous clarifions d’abord le besoin, les contraintes, le périmètre utile et le niveau d’effort. Ensuite seulement nous proposons un chiffrage et une séquence de livraison.',
      },
      {
        title: 'Pouvez-vous rester ensuite en support ?',
        description:
          'Oui. Nous pouvons rester disponibles en maintenance, tickets, visio planifiée ou accompagnement plus continu selon le sujet.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Parler de votre besoin',
        href: '/contact#form',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Voir les tarifs',
        href: '/pricing',
      },
    ]}
  >
    <Fragment slot="title">Commencez par le bon niveau d’intervention</Fragment>

    <Fragment slot="subtitle">
      Consulting technique, projet sur mesure ou site standard dès 999 CHF: nous vous aidons à choisir l’option utile au
      lieu de pousser tout le monde vers la même offre.
    </Fragment>
  </CallToAction>
</Layout>
