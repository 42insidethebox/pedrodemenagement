---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import PricingOptions from '~/components/widgets/PricingOptions.astro';
import Note from '~/components/widgets/Note.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Tarifs',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Tarifs"
    title="Des offres transparentes, facturées en Suisse"
    subtitle="Deux voies standards pour les sites simples, puis une couche custom cadrée proprement quand le sujet dépasse le template."
  />

  <!-- Starter pack banner -->
  <div class="max-w-3xl mx-auto px-4 mb-2">
    <div class="rounded-2xl border-2 border-blue-200 bg-blue-50 dark:bg-blue-900/20 px-6 py-4 text-center">
      <p class="text-lg font-bold text-blue-900 dark:text-blue-100">Pack Essentiel — dès 999 CHF</p>
      <p class="mt-1 text-sm text-blue-700 dark:text-blue-200">Prix fixe pour un site vitrine professionnel. Livraison typique en 3–5 jours ouvrables selon vos contenus.</p>
      <a href="/onboarding?plan=essential999" class="mt-3 inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm px-6 py-2 rounded-xl transition-colors">Commander maintenant →</a>
    </div>
  </div>

  <!-- Pricing Widget ******************* -->

  <Prices
    title="Nos packs clés-en-main"
    subtitle="Choisissez l'offre qui correspond à votre besoin. Sans frais cachés."
    prices={[
      {
        title: 'Essentiel',
        subtitle: 'Site vitrine professionnel dès 999 CHF',
        price: 999,
        period: 'paiement unique',
        info: [
          'Pack 999 = site vitrine standard de 5 sections sur l’infrastructure mutualisée TonSiteWeb.',
          'Ajout de pages, brainstorming, changement de structure ou nouveaux modules sur devis.',
          'Toute demande hors périmètre est facturée séparément avant production.',
        ],
        items: [
          {
            description: 'Site vitrine 5 sections + page contact responsive',
          },
          {
            description: 'Intégration et mise en forme de vos contenus',
          },
          {
            description: 'Déploiement sur l’infrastructure mutualisée TonSiteWeb',
          },
        ],
        callToAction: { text: 'Choisir un style →', href: '/choose-template?plan=essential999' },
      },
      {
        title: 'Pack 1 500',
        subtitle: 'Site standard + WhatsApp + Calendly',
        price: 1500,
        period: 'paiement unique',
        info: [
          'Toujours dans la logique standard TonSiteWeb, sans entrer dans une build privée.',
          'WhatsApp, Calendly et passation légère inclus dans le périmètre validé.',
          'Pages en plus, redesign, brainstorming ou modules hors scope sur devis séparé.',
        ],
        items: [
          { description: 'Inclut la base 999 CHF' },
          { description: 'WhatsApp cliquable + prise de rendez-vous Calendly' },
          { description: 'Explication légère et handoff simple' },
        ],
        callToAction: { text: 'Choisir le pack 1 500 →', href: '/choose-template?plan=essential1500' },
      },
      {
        title: 'Systèmes sur mesure',
        subtitle: 'Codebase privée, back-end ou architecture plus lourde',
        price: 2000,
        period: 'dès — scope avant build',
        items: [
          { description: '2 000 CHF: codebase privée' },
          { description: '2 200 CHF: codebase privée + transmission' },
          { description: '4 500 CHF: back-end léger' },
          { description: '8 000+ CHF: headless shop ou système plus lourd' },
        ],
        callToAction: '<a class="btn btn-primary" href="#modal-custom">Voir la progression</a>',
      },
    ]}
  />

  <!-- Pricing selectors (modals) -->
  <div class="sr-only" aria-hidden="true"></div>
  <div class="mt-0 grid gap-0">
    <div class="hidden" id="modals"></div>
  </div>

  <div class="mt-6 grid gap-4 max-w-7xl mx-auto px-4">
    <div class="flex flex-wrap gap-4">
      <div id="insert-essential">
        <PricingOptions
          id="modal-essential"
          triggerText=""
          title="Packs standards"
          subtitle="Choisissez le bon niveau sans acheter du custom trop tôt"
          ctaText="Choisir"
          tiers={[
            {
              label: 'CHF 999',
              price: 'dès 999',
              features: ['Site statique', 'Formulaire simple (email)'],
              href: '/choose-template?plan=essential999',
              info: ['Hébergement & SSL inclus (3 mois)', 'Déploiement sur l’infrastructure TonSiteWeb mutualisée', 'Pages en plus, brainstorming ou hors scope sur devis séparé'],
            },
            {
              label: 'CHF 1 500',
              price: '1 500',
              features: ['Inclut la base 999', 'WhatsApp + Calendly', 'Explication légère / passation'],
              href: '/choose-template?plan=essential1500',
              primary: true,
              info: ['Toujours sur l’infrastructure TonSiteWeb mutualisée', 'WhatsApp et Calendly installés dans le périmètre validé', 'Pages en plus, brainstorming ou hors scope sur devis séparé'],
            },
          ]}
          footnote="Le périmètre validé est livré tel quel ; ajout de pages, cadrage/brainstorming, redesign et demandes hors scope sont facturés séparément."
        />
      </div>
      <div id="insert-custom">
        <PricingOptions
          id="modal-custom"
          triggerText=""
          title="Progression custom"
          subtitle="Quand le bon mouvement n’est plus un simple template"
          ctaText="Ouvrir"
          tiers={[
            {
              label: 'CHF 2 000',
              price: 'codebase privée',
              features: ['Codebase séparée', 'Sortie de l’infrastructure mutualisée'],
              href: '/custom-systems?track=private-2000#diagnostic',
            },
            {
              label: 'CHF 2 200',
              price: 'privé + transmission',
              features: ['Codebase séparée', 'Transmission et explication structurée'],
              primary: true,
              href: '/custom-systems?track=private-2200#diagnostic',
            },
            {
              label: 'CHF 4 500',
              price: 'back‑end léger',
              features: ['Logique métier légère', 'Collecte, sync ou portail simple'],
              href: '/custom-systems?track=backend-4500#diagnostic',
            },
            {
              label: 'CHF 8 000+',
              price: 'système plus lourd',
              features: ['Headless shop', 'Admin, portail ou architecture plus profonde'],
              href: '/custom-systems?track=shop-8000#diagnostic',
            },
          ]}
          footnote="Architecture, portail, admin ou plateforme interne sont scopes après le diagnostic payé 15 min / 80 CHF."
        />
      </div>
    </div>
  </div>

  

  <!-- Features3 Widget ************** -->

  <Features3
    title="Ce que peuvent inclure nos offres"
    subtitle="Selon le pack choisi et vos besoins."
    columns={2}
    items={[
      {
        title: 'Support humain',
        description: 'Accompagnement par email et téléphone, réponses sous un jour ouvré.',
        icon: 'tabler:headset',
      },
      
      {
        title: 'Processus simple',
        description: "Échanges par email et validations par étapes (pas d'espace client à gérer).",
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Facturation claire',
        description: 'TVA incluse, facture QR ou Twint, mensualisation disponible.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Performance optimisée',
        description: "Architecture Astro et optimisation d'images pour un chargement rapide.",
        icon: 'tabler:gauge',
      },
      {
        title: 'Sécurité renforcée',
        description: 'Sauvegardes initiales, pare-feu applicatif et mises à jour régulières.',
        icon: 'tabler:lock',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

    <Steps
      title="Comment se déroule votre projet"
      tagline="Parcours"
      isReversed={true}
      items={[
        {
          title: '1. Signature numérique',
          description: 'Validez le pack choisi et recevez votre accès onboarding.',
          icon: 'tabler:edit',
        },
        {
          title: '2. Questionnaire intelligent',
          description: 'Renseignez vos informations clés, importez vos visuels et sélectionnez vos modules.',
          icon: 'tabler:clipboard-list',
        },
        {
          title: '3. Production supervisée',
          description: 'Notre plateforme génère votre site, nos experts ajustent et contrôlent.',
          icon: 'tabler:robot',
        },
        {
          title: '4. Validation & mise en ligne',
          description: 'Vous validez la version finale, nous programmons la mise en ligne et chiffrons séparément toute extension hors périmètre.',
          icon: 'tabler:rocket',
        },
      ]}
    >
      <Fragment slot="image">
        <div class="relative aspect-[3/4] overflow-hidden rounded-xl bg-gradient-to-br from-blue-700 via-slate-900 to-slate-800 p-10 text-white shadow-xl">
          <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Process</p>
          <p class="mt-6 max-w-xs text-base text-blue-100/90">
            Brief, intégration de vos contenus et validations par email.
          </p>
        </div>
      </Fragment>
    </Steps>

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Questions sur nos tarifs"
    subtitle="Nous croyons en une transparence totale."
    items={[
      {
        title: 'Les prix incluent-ils la TVA ?',
        description: 'Oui, tous les montants sont affichés TTC. La facture mentionne la TVA suisse et le numéro IDE.',
      },
      {
        title: 'Quel est le délai moyen pour le pack Essentiel ?',
        description: 'Comptez environ cinq jours ouvrés après réception de vos contenus. Nous vous donnons un planning précis lors du brief.',
      },
      {
        title: 'Que se passe-t-il si j’ai besoin d’autres pages ou d’un cadrage supplémentaire ?',
        description: 'Nous chiffrons séparément les ajouts de pages, ateliers de cadrage ou brainstorming, changements de structure et demandes hors périmètre avant toute production.',
      },
      {
        title: 'La maintenance est-elle obligatoire ?',
        description: 'Non. Maintenance dès 79 CHF/mois, résiliable avec un préavis de 30 jours.',
      },
      {
        title: 'Quels moyens de paiement acceptez-vous ?',
        description: 'Cartes suisses, Twint, virement bancaire et facturation QR. Les abonnements peuvent être payés mensuellement ou annuellement.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Choisir un modèle — 999 CHF',
        href: '/onboarding?plan=essential999',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Contacter un expert',
        href: '/contact#form',
      },
    ]}
  >
    <Fragment slot="title">
      Votre site vitrine dès 999 CHF
    </Fragment>

    <Fragment slot="subtitle">
      Pack Essentiel TonSiteWeb.ch au tarif standard. Livraison typique en 3–5 jours ouvrables selon vos contenus.
    </Fragment>
  </CallToAction>
</Layout>
