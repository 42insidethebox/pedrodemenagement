---
import Layout from '~/layouts/Layout.astro';

export const prerender = false;

const SUPPORTED_LOCALES = ['fr', 'en', 'it', 'de'] as const;
type Locale = typeof SUPPORTED_LOCALES[number];

function resolveLocale(): Locale {
  const query = Astro.url.searchParams.get('lang');
  if (query && SUPPORTED_LOCALES.includes(query.toLowerCase() as Locale)) return query.toLowerCase() as Locale;
  const header = Astro.request.headers.get('accept-language') || '';
  const base = header.split(',')[0]?.split(';')[0]?.split('-')[0]?.toLowerCase();
  if (base && SUPPORTED_LOCALES.includes(base as Locale)) return base as Locale;
  return 'fr';
}

const locale = resolveLocale();

const T = {
  fr: {
    title: 'Informations reçues — TonSiteWeb.ch',
    heading: 'Merci, on a tout reçu !',
    sub: 'Votre site sera prêt sous',
    days: '5–7 jours ouvrables',
    desc: 'Nous vous envoyons un email de confirmation dès que la première version est en ligne.',
    wa: 'Une question ? Écrivez-nous sur WhatsApp',
    home: "Revenir à l'accueil",
    waMsg: "Bonjour, j'ai envoyé les informations pour mon site sur TonSiteWeb.ch.",
  },
  en: {
    title: 'Information received — TonSiteWeb.ch',
    heading: 'Thanks, we got everything!',
    sub: 'Your site will be ready within',
    days: '5–7 business days',
    desc: 'We will send you a confirmation email as soon as the first version is live.',
    wa: 'Any questions? Message us on WhatsApp',
    home: 'Back to homepage',
    waMsg: 'Hello, I submitted my website information on TonSiteWeb.ch.',
  },
  de: {
    title: 'Informationen erhalten — TonSiteWeb.ch',
    heading: 'Danke, wir haben alles erhalten!',
    sub: 'Ihre Website ist fertig in',
    days: '5–7 Werktagen',
    desc: 'Wir schicken Ihnen eine Bestätigungs-E-Mail, sobald die erste Version live ist.',
    wa: 'Fragen? Schreiben Sie uns auf WhatsApp',
    home: 'Zur Startseite',
    waMsg: 'Hallo, ich habe meine Website-Informationen auf TonSiteWeb.ch eingereicht.',
  },
  it: {
    title: 'Informazioni ricevute — TonSiteWeb.ch',
    heading: 'Grazie, abbiamo ricevuto tutto!',
    sub: 'Il vostro sito sarà pronto in',
    days: '5–7 giorni lavorativi',
    desc: "Vi invieremo un'email di conferma non appena la prima versione sarà online.",
    wa: 'Domande? Scriveteci su WhatsApp',
    home: "Torna all'home",
    waMsg: 'Ciao, ho inviato le informazioni per il mio sito su TonSiteWeb.ch.',
  },
} as const;

const t = T[locale];
const waUrl = `https://wa.me/41767982793?text=${encodeURIComponent(t.waMsg)}`;
---

<Layout
  metadata={{ title: t.title }}
  brandKey="tonsiteweb"
>
  <main class="min-h-screen bg-white flex flex-col items-center justify-center px-4 py-16 text-center">
    <div class="max-w-lg w-full">
      <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 mb-4">{t.heading}</h1>
      <p class="text-lg text-gray-600 mb-2">
        {t.sub} <strong>{t.days}</strong>.
      </p>
      <p class="text-gray-500 text-sm mb-10">{t.desc}</p>

      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-green-500 hover:bg-green-600 text-white font-semibold text-base px-7 py-4 rounded-xl transition-colors mb-6"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {t.wa}
      </a>

      <div class="mt-4">
        <a href="/tonsiteweb" class="text-sm text-gray-400 hover:text-gray-600 underline">{t.home}</a>
      </div>
    </div>
  </main>
</Layout>
