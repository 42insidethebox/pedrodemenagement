---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

import { headerDataIt, footerDataIt } from '~/navigation';

const metadata = {
  title: 'Contatto',
};
---

<Layout metadata={metadata} header={headerDataIt} footer={footerDataIt}>
  <HeroText tagline="Contatto" title="Parliamo della via TonSiteWeb giusta" subtitle="Separiamo siti standard, build private e sistemi più pesanti senza perdere tempo." />

  <ContactUs
    id="form"
    title="Richiedi demo o preventivo"
    subtitle="Compila il modulo e ti orientiamo verso il livello giusto: CHF 999, CHF 1’500 o diagnosi custom a pagamento."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Nome e cognome',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email professionale',
      },
      {
        type: 'text',
        name: 'company',
        label: 'Azienda',
      },
      {
        type: 'select',
        name: 'service',
        label: 'Pacchetto desiderato',
        options: [
          { label: 'Sito standard — CHF 999', value: 'essential999' },
          { label: 'Sito standard + WhatsApp + Calendly — CHF 1’500', value: 'essential1500' },
          { label: 'Codebase privato / backend leggero — CHF 2’000 a 8’000+', value: 'custom' },
          { label: 'Diagnosi a pagamento — 15 min / CHF 80', value: 'diagnostic80' },
        ],
      },
    ]}
    textarea={{
      label: 'Il tuo progetto',
      placeholder: 'Descrivi attività, obiettivi e tempi.',
    }}
    disclaimer={{
      label:
        'Inviando il modulo accetti che TonSiteWeb.ch tratti i tuoi dati per rispondere alla richiesta, secondo la nostra privacy policy.',
    }}
    description="Siamo disponibili dal lunedì al venerdì, 9:00–17:00. Parliamo francese, inglese e tedesco."
  />

  <Features2
    title="Contatto diretto"
    subtitle="Scegli il canale più comodo."
    items={[
      {
        title: 'Telefono',
        description: '+41 76 798 27 93',
        icon: 'tabler:phone',
      },
      {
        title: 'Email',
    description: 'support@tonsiteweb.ch',
        icon: 'tabler:mail',
      },
      {
        title: 'Indirizzo',
        description: 'Avenue de la Gare 29, 1003 Losanna',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Disponibilità',
        description: 'Dal lunedì al venerdì, 9:00 – 17:00',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'Supporto clienti',
    description: 'support@tonsiteweb.ch — risposta entro un giorno lavorativo',
        icon: 'tabler:help',
      },
    ]}
  />
</Layout>
