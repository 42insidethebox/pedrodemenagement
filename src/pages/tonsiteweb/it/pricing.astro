---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import PricingOptions from '~/components/widgets/PricingOptions.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { headerDataIt, footerDataIt } from '~/navigation';

const metadata = {
  title: 'Prezzi',
};
---

<Layout metadata={metadata} header={headerDataIt} footer={footerDataIt}>
  <HeroText
    tagline="Prezzi"
    title="Pacchetti trasparenti, fatturati in Svizzera"
    subtitle="Due vie standard per i siti di lancio semplici, poi uno strato custom pulito quando il lavoro supera il template."
  />

  <!-- Starter pack banner -->
  <div class="max-w-3xl mx-auto px-4 mb-2">
    <div class="rounded-2xl border-2 border-blue-200 bg-blue-50 dark:bg-blue-900/20 px-6 py-4 text-center">
      <p class="text-lg font-bold text-blue-900 dark:text-blue-100">Pacchetto Essenziale — da 999 CHF</p>
      <p class="mt-1 text-sm text-blue-700 dark:text-blue-200">Prezzo fisso per un sito vetrina professionale. Consegna tipica in 3–5 giorni lavorativi in base ai contenuti.</p>
      <a href="/onboarding?plan=essential999" class="mt-3 inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm px-6 py-2 rounded-xl transition-colors">Ordina ora →</a>
    </div>
  </div>

  <Prices
    title="I nostri pacchetti chiavi in mano"
    subtitle="Scegli la soluzione più adatta. Nessun costo nascosto."
    prices={[
      {
        title: 'Essenziale',
        subtitle: 'Sito vetrina professionale da 999 CHF',
        price: 999,
        period: 'pagamento unico',
        info: [
          "CHF 999 copre un sito vetrina standard di 5 sezioni sulla piattaforma condivisa di TonSiteWeb.",
          'Pagine aggiuntive, workshop/brainstorming, cambi strutturali o nuovi moduli sono preventivati a parte.',
          'Ogni richiesta fuori perimetro viene fatturata separatamente prima della produzione.',
        ],
        items: [
          {
            description: 'Sito vetrina con 5 sezioni + pagina contatti responsive',
          },
          {
            description: 'Contenuti forniti dal cliente; noi li integriamo e li impaginiamo',
          },
          {
            description: 'Deploy sulla piattaforma condivisa TonSiteWeb',
          },
        ],
        callToAction: { text: 'Scegli uno stile →', href: '/it/choose-template?plan=essential999' },
      },
      {
        title: 'Pacchetto CHF 1’500',
        subtitle: 'Sito standard + WhatsApp + Calendly',
        price: 1500,
        period: 'pagamento unico',
        info: [
          'Resta nella logica standard TonSiteWeb, senza entrare in una build privata.',
          'WhatsApp, Calendly e passaggio leggero inclusi nel perimetro validato.',
          'Pagine extra, workshop, redesign o moduli fuori scope preventivati a parte.',
        ],
        items: [
          { description: 'Include la base da CHF 999' },
          { description: 'WhatsApp cliccabile + Calendly' },
          { description: 'Spiegazione leggera e handoff' },
        ],
        callToAction: { text: 'Scegli il pacchetto da CHF 1’500 →', href: '/it/choose-template?plan=essential1500' },
      },
      {
        title: 'Custom systems',
        subtitle: 'Codebase privato, backend o architettura più pesante',
        price: 2000,
        period: 'da — scope prima della build',
        items: [
          { description: 'CHF 2’000: codebase privato' },
          { description: 'CHF 2’200: codebase privato + passaggio' },
          { description: 'CHF 4’500: backend leggero' },
          { description: 'CHF 8’000+: headless shop o sistema più pesante' },
        ],
        callToAction: '<a class="btn btn-primary" href="#modal-custom-it">Vedi progressione</a>',
      },
    ]}
  />
  <div class="mt-6 grid gap-4 max-w-7xl mx-auto px-4">
    <div class="flex flex-wrap gap-4">
      <PricingOptions
        id="modal-essential-it"
        triggerText=""
        title="Pacchetti standard"
        subtitle="Scegli il livello giusto senza comprare custom troppo presto"
        ctaText="Scegli"
        tiers={[
          { label: 'CHF 999', price: 'da 999', features: ['Sito statico', 'Form semplice (email)'], href: '/it/choose-template?plan=essential999', info: ['Hosting & SSL inclusi (3 mesi)', 'Deploy sulla piattaforma condivisa TonSiteWeb', 'Pagine extra, workshop o fuori scope preventivati a parte'] },
          { label: 'CHF 1’500', price: '1’500', features: ['Include la base da CHF 999', 'WhatsApp + Calendly', 'Spiegazione leggera / handoff'], href: '/it/choose-template?plan=essential1500', primary: true, info: ['Sempre sulla piattaforma condivisa TonSiteWeb', 'WhatsApp e Calendly cablati nel perimetro validato', 'Pagine extra, workshop o fuori scope preventivati a parte'] },
        ]}
        footnote="Viene consegnato il perimetro validato; pagine extra, workshop/brainstorming, redesign e richieste fuori scope sono fatturati separatamente."
      />
      <PricingOptions
        id="modal-custom-it"
        triggerText=""
        title="Progressione custom"
        subtitle="Quando la mossa giusta non è più un semplice template"
        ctaText="Apri"
        tiers={[
          { label: 'CHF 2’000', price: 'codebase privato', features: ['Codebase separato', 'Esce dall’infrastruttura condivisa'], href: '/it/custom-systems?track=private-2000#diagnostic' },
          { label: 'CHF 2’200', price: 'privato + passaggio', features: ['Codebase separato', 'Passaggio strutturato'], href: '/it/custom-systems?track=private-2200#diagnostic', primary: true },
          { label: 'CHF 4’500', price: 'backend leggero', features: ['Logica business leggera', 'Intake, sync o portale semplice'], href: '/it/custom-systems?track=backend-4500#diagnostic' },
          { label: 'CHF 8’000+', price: 'sistema più pesante', features: ['Headless shop', 'Admin, portale o architettura più profonda'], href: '/it/custom-systems?track=shop-8000#diagnostic' },
        ]}
        footnote="Architettura, portale, admin o piattaforma interna vengono scoped dopo la diagnosi a pagamento 15 min / CHF 80."
      />
    </div>
  </div>

  <Features3
    title="Vantaggi inclusi"
    subtitle="Ogni offerta comprende queste garanzie."
    columns={2}
    items={[
      {
        title: 'Supporto umano',
        description: 'Assistenza via email e telefono, risposta entro un giorno lavorativo.',
        icon: 'tabler:headset',
      },
      {
        title: 'Hosting sovrano',
        description: 'Server in Svizzera, conformi GDPR/LPD, con SSL incluso.',
        icon: 'tabler:server',
      },
      {
        title: 'Dashboard cliente',
        description: 'Monitora avanzamento, condividi contenuti e approva le fasi online.',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Fatturazione chiara',
        description: 'IVA inclusa, fattura QR o Twint, possibilità di rate mensili.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Performance ottimizzata',
        description: 'Architettura Astro e immagini ottimizzate per caricamenti rapidi.',
        icon: 'tabler:gauge',
      },
      {
        title: 'Sicurezza potenziata',
        description: 'Backup iniziali, firewall applicativo e aggiornamenti regolari.',
        icon: 'tabler:lock',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <Steps
    title="Come si svolge il progetto"
    tagline="Percorso"
    isReversed={true}
    items={[
      {
        title: '1. Firma digitale',
        description: 'Conferma il pacchetto e ricevi l’accesso onboarding.',
        icon: 'tabler:edit',
      },
      {
        title: '2. Questionario smart',
        description: 'Inserisci informazioni chiave, carica visual e scegli i moduli.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: '3. Produzione supervisionata',
        description: 'La piattaforma genera il sito, gli esperti rifiniscono e verificano.',
        icon: 'tabler:robot',
      },
      {
        title: '4. Validazione & messa online',
        description: 'Approvi la versione finale, poi pianifichiamo la messa online e preventiviamo a parte ogni estensione fuori perimetro.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="image">
      <div class="relative aspect-[3/4] overflow-hidden rounded-xl bg-gradient-to-br from-blue-700 via-slate-900 to-slate-800 p-10 text-white shadow-xl">
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Processo</p>
        <p class="mt-6 max-w-xs text-base text-blue-100/90">
          Dalla firma al lancio, ogni fase è tracciata e documentata nel tuo spazio cliente.
        </p>
      </div>
    </Fragment>
  </Steps>

  <FAQs
    title="Domande sui prezzi"
    subtitle="Crediamo nella massima trasparenza."
    items={[
      {
        title: 'L’IVA è inclusa?',
        description: 'Sì, tutti gli importi sono IVA inclusa. La fattura indica l’IVA svizzera e il numero IDE.',
      },
      {
        title: 'Qual è la tempistica media per l’Essenziale?',
        description: 'Circa cinque giorni lavorativi dopo aver ricevuto i contenuti. Condividiamo il planning durante il brief.',
      },
      {
        title: 'Cosa succede se mi servono pagine extra o più brainstorming?',
        description: 'Pagine aggiuntive, workshop o brainstorming, cambi strutturali e richieste fuori perimetro vengono preventivati separatamente prima dell’avvio della produzione.',
      },
      {
        title: 'Il piano di cura è obbligatorio?',
        description: 'No. Puoi gestire il sito in autonomia oppure affidarci il piano da CHF 79/mese, disdicibile con 30 giorni di preavviso.',
      },
      {
        title: 'Quali metodi di pagamento accettate?',
        description: 'Carte svizzere, Twint, bonifico bancario e fattura QR. Gli abbonamenti possono essere mensili o annuali.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Ricevi una proposta',
        href: '/it/contact#form',
        icon: 'tabler:mail-forward',
      },
      {
        text: 'Confronta i pacchetti',
        href: '/it/services',
      },
    ]}
  >
    <Fragment slot="title">
      Hai bisogno di un preventivo su misura?
    </Fragment>

    <Fragment slot="subtitle">
      Adattiamo ogni offerta alle specificità della tua attività nell’Arco lemanico.
    </Fragment>
  </CallToAction>
</Layout>
