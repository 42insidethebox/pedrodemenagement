---
import Layout from '~/layouts/PageLayout.astro';

const SUPPORTED_LOCALES = ['fr', 'en', 'it', 'de'] as const;

function resolveLocale() {
  const query = Astro.url.searchParams.get('lang');
  if (query && SUPPORTED_LOCALES.includes(query.toLowerCase() as any)) return query.toLowerCase() as typeof SUPPORTED_LOCALES[number];
  const header = Astro.request.headers.get('accept-language') || '';
  const [raw] = header.split(',');
  if (raw) {
    const base = raw.split(';')[0]?.split('-')[0]?.toLowerCase();
    if (base && SUPPORTED_LOCALES.includes(base as any)) return base as typeof SUPPORTED_LOCALES[number];
  }
  return 'fr';
}

const locale = resolveLocale();

const TEXT = {
  fr: {
    metadataTitle: 'Merci — TonSiteWeb.ch',
    headingWithSession: 'Paiement confirmé !',
    headingGeneric: 'Merci',
    descAwaiting: 'Nous confirmons votre paiement…',
    descGeneric: 'Nous revenons vers vous sous un jour ouvré.',
    descConfirmed: 'Votre paiement est confirmé.',
    emailLabel: 'Email',
    orderLabel: 'Commande n°',
    amountLabel: 'Montant',
    statusLabel: 'Statut',
    templateLabel: 'Modèle',
    planLabel: 'Plan',
    loading: 'Chargement des détails du paiement…',
    error: 'Impossible de charger les détails. Merci de contacter le support.',
    home: "Revenir à l'accueil",
    currencyLocale: 'fr-CH',
    buildingTitle: 'Votre site est en cours de création',
    buildingDesc: 'Notre équipe commence dès maintenant. Livraison estimée demain avant 20h.',
    whatsappLabel: 'Questions ? Écrivez-nous sur WhatsApp',
    whatsappBtn: 'Écrire sur WhatsApp',
    customTitle: 'Besoin d\'un site plus élaboré ?',
    customDesc: 'E-commerce, réservation, branding complet… On peut faire quelque chose de sur-mesure.',
    customBtn: 'Demander un devis personnalisé',
  },
  en: {
    metadataTitle: 'Thank you — TonSiteWeb.ch',
    headingWithSession: 'Payment confirmed!',
    headingGeneric: 'Thank you',
    descAwaiting: 'We are confirming your payment…',
    descGeneric: 'We will get back to you within one business day.',
    descConfirmed: 'Your payment is confirmed.',
    emailLabel: 'Email',
    orderLabel: 'Order #',
    amountLabel: 'Amount',
    statusLabel: 'Status',
    templateLabel: 'Template',
    planLabel: 'Plan',
    loading: 'Loading payment details…',
    error: 'Unable to load details. Please contact support.',
    home: 'Back to homepage',
    currencyLocale: 'en-CH',
    buildingTitle: 'Your site is being built',
    buildingDesc: 'Our team starts now. Estimated delivery: tomorrow before 8pm.',
    whatsappLabel: 'Questions? Message us on WhatsApp',
    whatsappBtn: 'Message on WhatsApp',
    customTitle: 'Need something bigger?',
    customDesc: 'E-commerce, booking system, full branding… We can build something custom.',
    customBtn: 'Request a custom quote',
  },
  it: {
    metadataTitle: 'Grazie — TonSiteWeb.ch',
    headingWithSession: 'Pagamento confermato!',
    headingGeneric: 'Grazie',
    descAwaiting: 'Stiamo confermando il pagamento…',
    descGeneric: 'Ti ricontatteremo entro un giorno lavorativo.',
    descConfirmed: 'Il pagamento è confermato.',
    emailLabel: 'Email',
    orderLabel: 'Ordine n°',
    amountLabel: 'Importo',
    statusLabel: 'Stato',
    templateLabel: 'Template',
    planLabel: 'Piano',
    loading: 'Caricamento dei dettagli del pagamento…',
    error: 'Impossibile caricare i dettagli. Contatta il supporto.',
    home: 'Torna alla home',
    currencyLocale: 'it-CH',
    buildingTitle: 'Il tuo sito è in fase di creazione',
    buildingDesc: 'Il nostro team inizia subito. Consegna stimata domani entro le 20.',
    whatsappLabel: 'Domande? Scrivici su WhatsApp',
    whatsappBtn: 'Scrivi su WhatsApp',
    customTitle: 'Hai bisogno di qualcosa di più elaborato?',
    customDesc: 'E-commerce, prenotazioni, branding completo… Possiamo creare qualcosa su misura.',
    customBtn: 'Richiedi un preventivo personalizzato',
  },
  de: {
    metadataTitle: 'Danke — TonSiteWeb.ch',
    headingWithSession: 'Zahlung bestätigt!',
    headingGeneric: 'Danke',
    descAwaiting: 'Wir bestätigen gerade Ihre Zahlung…',
    descGeneric: 'Wir melden uns innerhalb eines Werktages.',
    descConfirmed: 'Ihre Zahlung ist bestätigt.',
    emailLabel: 'E-Mail',
    orderLabel: 'Bestellung Nr.',
    amountLabel: 'Betrag',
    statusLabel: 'Status',
    templateLabel: 'Vorlage',
    planLabel: 'Plan',
    loading: 'Zahlungsdetails werden geladen…',
    error: 'Details konnten nicht geladen werden. Bitte kontaktieren Sie den Support.',
    home: 'Zur Startseite',
    currencyLocale: 'de-CH',
    buildingTitle: 'Ihre Website wird erstellt',
    buildingDesc: 'Unser Team beginnt sofort. Geschätzte Lieferung morgen bis 20 Uhr.',
    whatsappLabel: 'Fragen? Schreiben Sie uns auf WhatsApp',
    whatsappBtn: 'Auf WhatsApp schreiben',
    customTitle: 'Brauchen Sie etwas Umfangreicheres?',
    customDesc: 'E-Commerce, Buchungssystem, komplettes Branding… Wir können etwas Massgeschneidertes erstellen.',
    customBtn: 'Individuelles Angebot anfragen',
  },
} as const;

const copy = TEXT[locale];
const metadata = { title: copy.metadataTitle };
const sessionId = Astro.url.searchParams.get('session_id') || '';
const hasSession = Boolean(sessionId);

// WhatsApp: REPLACE 41770000000 with your real WhatsApp number (no + or spaces)
const WA_NUMBER = '41770000000';
const waMessageBase = encodeURIComponent(`Bonjour, j'ai commandé un site sur TonSiteWeb.ch`);
const waMessageWithSession = encodeURIComponent(`Bonjour, j'ai commandé un site sur TonSiteWeb.ch (ref: ${sessionId})`);
const waUrl = `https://wa.me/${WA_NUMBER}?text=${hasSession ? waMessageWithSession : waMessageBase}`;
const waCustomUrl = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent("Bonjour, j'ai payé pour un site à 500 CHF et j'aimerais discuter d'un projet plus élaboré.")}`;
---

<Layout metadata={metadata}>
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-2xl">

      <!-- CONFIRMATION HEADER -->
      <div class="text-center mb-10">
        <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold">{hasSession ? copy.headingWithSession : copy.headingGeneric}</h1>
        <p class="mt-3 text-muted" id="desc">{hasSession ? copy.descAwaiting : copy.descGeneric}</p>
      </div>

      <!-- ORDER DETAILS CARD -->
      {hasSession ? (
        <div id="session" class="mb-8 text-left mx-auto rounded border border-gray-200 dark:border-gray-700 p-4 text-sm bg-white/50 dark:bg-slate-900/50">
          <div id="loader">{copy.loading}</div>
          <div id="content" class="hidden">
            <p><strong>{copy.emailLabel}:</strong> <span id="email">—</span></p>
            <p><strong>{copy.orderLabel}</strong> <span id="orderNumber">—</span></p>
            <p><strong>{copy.amountLabel}:</strong> <span id="amount">—</span></p>
            <p><strong>{copy.planLabel}:</strong> <span id="plan">—</span></p>
            <p><strong>{copy.templateLabel}:</strong> <span id="template">—</span></p>
            <p><strong>{copy.statusLabel}:</strong> <span id="status">—</span></p>
          </div>
          <div id="error" class="hidden text-red-600">{copy.error}</div>
        </div>
      ) : null}

      <!-- WHAT HAPPENS NEXT -->
      <div class="bg-blue-50 dark:bg-blue-950/30 border border-blue-200 dark:border-blue-800 rounded-2xl p-6 mb-6 text-center">
        <p class="text-2xl mb-2">🏗️</p>
        <h2 class="font-bold text-lg text-blue-900 dark:text-blue-100 mb-2">{copy.buildingTitle}</h2>
        <p class="text-blue-700 dark:text-blue-300 text-sm">{copy.buildingDesc}</p>
      </div>

      <!-- WHATSAPP CONTACT -->
      <div class="border border-gray-200 dark:border-gray-700 rounded-2xl p-6 mb-6 text-center">
        <p class="text-sm text-gray-500 mb-4">{copy.whatsappLabel}</p>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-green-500 hover:bg-green-600 text-white font-semibold text-base px-7 py-4 rounded-xl transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {copy.whatsappBtn}
        </a>
      </div>

      <!-- CARE PLAN UPSELL (real Stripe button) -->
      <div class="border-2 border-blue-200 dark:border-blue-700 bg-blue-50 dark:bg-blue-950/30 rounded-2xl p-6 mb-6 text-center">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-2">Offre spéciale — clients TonSiteWeb</p>
        <p class="font-bold text-xl text-gray-900 dark:text-white mb-1">Protégez votre site pour 79 CHF/mois</p>
        <p class="text-gray-500 text-sm mb-4">Hébergement continu · Mises à jour de sécurité · Support prioritaire</p>
        <a
          href="/api/checkout?plan=care79&tenant=tonsiteweb"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold text-base px-8 py-3 rounded-xl transition-colors"
        >
          Ajouter la maintenance →
        </a>
        <p class="text-xs text-gray-400 mt-2">Résiliable à tout moment · Sans engagement</p>
      </div>

      <!-- CUSTOM WORK UPSELL -->
      <div class="bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-gray-700 rounded-2xl p-6 mb-8 text-center">
        <p class="font-bold text-gray-900 dark:text-white mb-2">{copy.customTitle}</p>
        <p class="text-gray-500 text-sm mb-4">{copy.customDesc}</p>
        <a
          href={waCustomUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-slate-700 text-gray-700 dark:text-gray-300 font-medium text-sm px-6 py-3 rounded-xl transition-colors"
        >
          {copy.customBtn} →
        </a>
      </div>

      <div class="text-center">
        <a href="/" class="text-sm text-gray-400 hover:text-gray-600 underline">{copy.home}</a>
      </div>

    </div>
  </section>

  {hasSession ? (
    <script is:inline define:vars={{ copy }}>
      const params = new URLSearchParams(location.search);
      const id = params.get('session_id');
      if (id) {
        fetch(`/api/payment/session?session_id=${encodeURIComponent(id)}`)
          .then(r => (r.ok ? r.json() : Promise.reject(new Error('HTTP ' + r.status))))
          .then(data => {
            const amountMinor = typeof data.amount_total_order === 'number' ? data.amount_total_order : data.amount_total;
            const currency = (data.currency || 'CHF').toUpperCase();
            const formatter = new Intl.NumberFormat(copy.currencyLocale, { style: 'currency', currency });
            document.getElementById('email').textContent = data.customer_email || data.metadata?.email || '—';
            document.getElementById('orderNumber').textContent = data.order_number || '—';
            document.getElementById('amount').textContent = typeof amountMinor === 'number' ? formatter.format((amountMinor || 0) / 100) : '—';
            document.getElementById('status').textContent = data.payment_status || '—';
            document.getElementById('template').textContent = data.template || data.metadata?.template || '—';
            document.getElementById('plan').textContent = data.plan || data.metadata?.plan || '—';
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('content').classList.remove('hidden');
            document.getElementById('desc').textContent = copy.descConfirmed;
            // FB Pixel Purchase event — critical for ad optimization
            if (typeof fbq !== 'undefined' && data.payment_status === 'paid') {
              fbq('track', 'Purchase', {
                value: typeof amountMinor === 'number' ? (amountMinor / 100).toFixed(2) : '500.00',
                currency: currency,
                content_ids: [data.plan || 'essential500'],
                content_type: 'product',
              });
            }
          })
          .catch(() => {
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('error').classList.remove('hidden');
          });
      }
    </script>
  ) : null}
</Layout>
