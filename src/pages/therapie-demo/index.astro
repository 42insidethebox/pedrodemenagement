---
export const prerender = false;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Cabinet Lumière — Physiothérapie & Bien-être, Lausanne</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f8f7f4;
      --surface: #ffffff;
      --teal: #0d9488;
      --teal-light: #e6f4f3;
      --emerald: #065f46;
      --text: #1c2b2a;
      --muted: #6b7a78;
      --border: #e2e8e6;
    }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; line-height: 1.6; }
    a { color: var(--teal); text-decoration: none; }
    /* Nav */
    nav { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 40px; display: flex; justify-content: space-between; align-items: center; height: 68px; position: sticky; top: 0; z-index: 10; }
    .nav-brand { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--text); }
    .nav-brand span { color: var(--teal); }
    .nav-links { display: flex; gap: 28px; font-size: 13px; }
    .nav-links a { color: var(--muted); transition: color 0.2s; }
    .nav-links a:hover { color: var(--text); }
    .nav-cta { background: var(--teal); color: #fff; font-weight: 600; font-size: 13px; padding: 10px 22px; border-radius: 6px; }
    /* Hero */
    .hero { display: grid; grid-template-columns: 1fr 1fr; min-height: 80vh; }
    .hero-left { background: linear-gradient(160deg, #0d9488 0%, #065f46 100%); padding: 80px 60px; display: flex; flex-direction: column; justify-content: center; }
    .hero-tag { font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.65); margin-bottom: 20px; }
    .hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(36px, 4vw, 56px); line-height: 1.1; color: #fff; margin-bottom: 20px; }
    .hero h1 em { font-style: italic; color: rgba(255,255,255,0.75); }
    .hero-left p { color: rgba(255,255,255,0.75); font-size: 16px; margin-bottom: 36px; max-width: 380px; }
    .btn-primary { background: #fff; color: var(--teal); font-weight: 700; font-size: 15px; padding: 14px 28px; border-radius: 8px; display: inline-block; }
    .hero-right { background: var(--bg); padding: 60px 40px; display: flex; flex-direction: column; justify-content: center; gap: 20px; }
    .hero-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 22px 24px; display: flex; align-items: flex-start; gap: 16px; }
    .hero-card-icon { font-size: 24px; flex-shrink: 0; }
    .hero-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
    .hero-card p { font-size: 13px; color: var(--muted); }
    /* Specialties */
    .section { padding: 80px 40px; max-width: 1080px; margin: 0 auto; }
    .section-tag { font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--teal); margin-bottom: 10px; }
    .section h2 { font-family: 'DM Serif Display', serif; font-size: clamp(26px, 3.5vw, 40px); margin-bottom: 12px; }
    .section-sub { color: var(--muted); margin-bottom: 44px; max-width: 540px; }
    .spec-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
    .spec-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 28px; transition: box-shadow 0.2s; }
    .spec-card:hover { box-shadow: 0 6px 24px rgba(13,148,136,0.1); }
    .spec-icon { font-size: 28px; margin-bottom: 14px; }
    .spec-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
    .spec-card p { font-size: 14px; color: var(--muted); }
    /* Team */
    .team-bg { background: var(--teal-light); }
    .team { padding: 80px 40px; max-width: 1080px; margin: 0 auto; }
    .team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 28px; margin-top: 44px; }
    .team-card { background: var(--surface); border-radius: 12px; padding: 28px; text-align: center; border: 1px solid var(--border); }
    .team-avatar { width: 72px; height: 72px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--emerald)); margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; font-size: 28px; }
    .team-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
    .team-card .team-role { font-size: 13px; color: var(--teal); font-weight: 500; margin-bottom: 8px; }
    .team-card p { font-size: 13px; color: var(--muted); }
    /* Testimonials */
    .testimonials { padding: 80px 40px; max-width: 1080px; margin: 0 auto; }
    .testimonials-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 44px; }
    .testimonial { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 24px; }
    .testimonial-stars { color: #10b981; font-size: 15px; margin-bottom: 10px; }
    .testimonial-text { font-size: 14px; color: var(--muted); font-style: italic; line-height: 1.7; }
    .testimonial-author { margin-top: 14px; font-size: 13px; font-weight: 600; color: var(--text); }
    /* RDV CTA */
    .cta-rdv { background: linear-gradient(135deg, var(--teal), var(--emerald)); padding: 80px 40px; text-align: center; }
    .cta-rdv h2 { font-family: 'DM Serif Display', serif; font-size: clamp(26px, 3.5vw, 42px); color: #fff; margin-bottom: 14px; }
    .cta-rdv p { color: rgba(255,255,255,0.75); font-size: 16px; margin-bottom: 32px; }
    /* Footer */
    footer { background: var(--emerald); padding: 48px 40px; }
    .footer-inner { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 32px; }
    .footer-brand { font-family: 'DM Serif Display', serif; font-size: 20px; color: #fff; margin-bottom: 6px; }
    .footer-title { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 12px; }
    .footer-list { list-style: none; display: grid; gap: 7px; font-size: 14px; color: rgba(255,255,255,0.65); }
    .demo-badge { position: fixed; bottom: 20px; right: 20px; background: var(--teal); color: #fff; font-size: 12px; font-weight: 700; padding: 10px 16px; border-radius: 6px; box-shadow: 0 4px 20px rgba(0,0,0,0.2); z-index: 100; }
    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; }
      .hero-left { padding: 48px 24px; }
      .hero-right { display: none; }
      nav { padding: 0 20px; }
      .nav-links { display: none; }
      .section, .team, .testimonials { padding: 48px 20px; }
      .cta-rdv { padding: 48px 20px; }
      footer { padding: 32px 20px; }
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-brand">Cabinet <span>Lumière</span></div>
  <div class="nav-links">
    <a href="#">Spécialités</a>
    <a href="#">L'équipe</a>
    <a href="#">Témoignages</a>
    <a href="#">Prendre RDV</a>
  </div>
