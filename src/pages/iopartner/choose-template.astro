      }[locale] ?? '',
    url: 'https://maisoncortes.ch',
    img: toAssetSrc(maisonPreview as string | { src: string }),
    alt: 'Maison Cortes - selection d objet premium',
    color: 'from-stone-600 to-stone-900',
    isBase: false,
    variations: [],
  },
  {
    id: 'onglesgel',
    name: 'Ongles Gel',
    deliveredTier: '999 CHF',
    sector:
