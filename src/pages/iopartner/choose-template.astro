    mergedTitle: 'Stay on the standard path',
    mergedLead:
      'Two clean paths: CHF 999 or CHF 1,500 if the work stays standard. Otherwise move into the custom route.',
    starterTitle: 'Standard path',
    starterItems: [
      'CHF 999: 5-section showcase site on shared infrastructure.',
      'CHF 1,500: standard deployment + integrated booking + short handoff.',
    ],
    starterCtaPrimary: 'Choose CHF 999',
    starterCtaSecondary: 'Choose CHF 1,500',
    customTitle: 'Template and tenant not enough?',
    customLead: 'Separate codebase, handoff, light backend, headless shop, or a heavier architecture layer.',
    customItems: [
      'CHF 2,000: private codebase.',
      'CHF 2,200: private codebase + handoff.',
      'CHF 4,500: light backend.',
      'CHF 8,000+: headless shop or heavier system.',
      'Entry point: paid 15 min / CHF 60 diagnostic.',
    ],
    customCta: 'See the custom progression →',
  },
  de: {
    title: 'Stil wählen — IOPartner.ch',
    heading: 'Welcher Stil für Ihre Website?',
    sub: 'Wählen Sie aus unseren echten Projekten — wir passen alles an Ihre Branche an.',
    planLabel: 'Paket',
    select: 'Diesen Stil wählen',
