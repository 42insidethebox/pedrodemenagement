      'CHF 999: sito vetrina di 5 sezioni su infrastruttura condivisa.',
      'CHF 1’500: deployment standard + prenotazione integrata + passaggio breve.',
    ],
    starterCtaPrimary: 'Scegli CHF 999',
    starterCtaSecondary: 'Scegli CHF 1’500',
    customTitle: 'Template e tenant non bastano più?',
    customLead: 'Codebase separato, passaggio, backend leggero, headless shop o architettura più pesante.',
    customItems: [
      'CHF 2’000: codebase privato.',
      'CHF 2’200: codebase privato + passaggio.',
      'CHF 4’500: backend leggero.',
      'CHF 8’000+: headless shop o sistema più pesante.',
      'Ingresso: diagnosi a pagamento 15 min / CHF 60.',
    ],
    customCta: 'Vedi la progressione custom →',
  },
} as const;

const t = T[locale as keyof typeof T] ?? T.fr;

const templates = [
  {
    id: 'lausanne-demenagement',
    name: 'Pedro Déménagement',
    sector:
      {
        fr: 'Services & déménagement',
        en: 'Services & moving',
        de: 'Dienstleistungen & Umzug',
        it: 'Servizi & trasloco',
      }[locale] ?? 'Services',
    desc:
      {
        fr: 'Design professionnel sobre, sections services, témoignages, CTA fort. Modèle de référence — les autres styles sont des variations de celui-ci.',
        en: 'Professional clean design, services sections, testimonials, strong CTA. The base template — all other styles are variations of this one.',
        de: 'Professionelles sauberes Design, Service-Sektionen, Referenzen, starker CTA. Basis-Vorlage — alle anderen Stile sind Variationen davon.',
        it: 'Design professionale sobrio, sezioni servizi, testimonianze, CTA forte. Modello di riferimento — gli altri stili sono variazioni di questo.',
      }[locale] ?? '',
    url: 'https://pedrodemenagement.ch',
    img: toAssetSrc(pedroLogo as string | { src: string }),
    alt: 'Pedro Demenagement - logo et identite de marque',
    imageClass: 'object-contain p-8 bg-gradient-to-br from-slate-50 to-blue-100',
    color: 'from-blue-600 to-blue-900',
    isBase: true,
    variations: [
      'lausannedemenagement.ch',
      'demenagementurgent.ch',
      'debarraslausanne.ch',
      'transportmeubles.ch',
      'videmaison.ch',
    ],
  },
  {
    id: 'tolo-coiffure',
    name: 'Tolo Coiffure',
    sector:
      { fr: 'Beauté & coiffure', en: 'Beauty & hair salon', de: 'Beauty & Friseur', it: 'Bellezza & parrucchiere' }[
        locale
      ] ?? 'Beauty',
    desc:
      {
        fr: 'Style moderne et chaleureux, galerie photos, prise de rendez-vous, palette claire.',
        en: 'Warm modern style, photo gallery, booking integration, light palette.',
        de: 'Warmes modernes Design, Fotogalerie, Terminbuchung, helle Palette.',
        it: 'Stile moderno e caldo, galleria foto, prenotazione appuntamenti, palette chiara.',
      }[locale] ?? '',
    url: 'https://tolocoiffure.ch',
    img: toAssetSrc(toloPreview as string | { src: string }),
    alt: 'Tolo Coiffure - balayage signature Lausanne',
    color: 'from-rose-400 to-pink-700',
    isBase: false,
    variations: [],
  },
  {
    id: 'maison-cortes',
    name: 'Maison Cortès',
    sector:
      { fr: 'Hôtellerie & luxe', en: 'Hospitality & luxury', de: 'Hotellerie & Luxus', it: 'Ospitalità & lusso' }[
        locale
      ] ?? 'Hospitality',
    desc:
      {
        fr: 'Élégant, typographie soignée, tons neutres, ambiance haut de gamme. Idéal pour boutique-hôtels, restaurants, artisans premium.',
        en: 'Elegant, refined typography, neutral tones, premium feel. Ideal for boutique hotels, restaurants, premium artisans.',
        de: 'Elegant, verfeinerte Typografie, neutrale Töne, Premium-Atmosphäre. Ideal für Boutique-Hotels, Restaurants, Premium-Handwerk.',
        it: 'Elegante, tipografia raffinata, toni neutri, atmosfera premium. Ideale per boutique hotel, ristoranti, artigiani premium.',
      }[locale] ?? '',
    url: 'https://maisoncortes.ch',
    img: toAssetSrc(maisonPreview as string | { src: string }),
    alt: 'Maison Cortes - selection d objet premium',
    color: 'from-stone-600 to-stone-900',
    isBase: false,
    variations: [],
  },
  {
    id: 'onglesgel',
    name: 'Ongles Gel',
    sector:
      { fr: 'Beauté & ongles', en: 'Beauty & nails', de: 'Beauty & Nägel', it: 'Bellezza & unghie' }[locale] ??
      'Beauty',
    desc:
      {
        fr: 'Style féminin doux, palette pastel, mise en avant des prestations, portfolio visuel.',
        en: 'Soft feminine style, pastel palette, service highlights, visual portfolio.',
        de: 'Sanfter femininer Stil, Pastellpalette, Leistungspräsentation, visuelles Portfolio.',
        it: 'Stile femminile delicato, palette pastello, evidenziazione servizi, portfolio visivo.',
      }[locale] ?? '',
    url: 'https://onglesgel.ch',
    img: toAssetSrc(onglesPreview as string | { src: string }),
    alt: 'Ongles Gel - nail art et pose gel Lausanne',
    color: 'from-fuchsia-300 to-purple-600',
    isBase: false,
    variations: [],
  },
];
---

<Layout metadata={{ title: t.title }} brandKey="iopartner">
  <!-- Promo banner -->
  <div class="bg-slate-950 text-white text-center px-4 py-3">
    <span
      class="inline-block bg-blue-600/30 text-xs font-bold uppercase tracking-widest px-2.5 py-0.5 rounded-full mr-2"
      >{t.promoBadge}</span
    >
    <span class="font-semibold text-sm">{t.promoTitle}</span>
    <span class="hidden sm:inline text-white/80 text-sm mx-2">—</span>
    <span class="block sm:inline text-white/90 text-xs sm:text-sm mt-0.5 sm:mt-0">{t.promoDesc}</span>
  </div>

  <main class="min-h-screen bg-gray-50 py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">{t.heading}</h1>
        <p class="text-gray-500 max-w-xl mx-auto">{t.sub}</p>
        {
          plan && (
            <p class="mt-2 text-xs text-blue-600 font-medium uppercase tracking-wide">
              {t.planLabel}: {plan}
            </p>
          )
        }
      </div>

      <!-- Surprise / let us choose — TOP -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6 text-slate-950 text-center mb-10 shadow-sm">
        <h2 class="font-bold text-xl mb-1">{t.surprise}</h2>
        <p class="text-slate-500 text-sm mb-5 max-w-md mx-auto">{t.surpriseDesc}</p>
        <a
          href={`/api/payment/redirect?plan=${encodeURIComponent(plan)}&template=surprise`}
          class="inline-block bg-slate-950 text-white font-semibold text-sm px-6 py-3 rounded-xl hover:bg-slate-800 transition-colors"
        >
          {t.surpriseBtn}
        </a>
      </div>

      <!-- Real template cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {
          templates.map((tpl) => (
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden flex flex-col hover:border-blue-400 hover:shadow-md transition-all">
              <div class="relative aspect-video overflow-hidden bg-gray-100">
                <img
                  src={tpl.img}
                  alt={tpl.alt || tpl.name}
                  class={`w-full h-full ${tpl.imageClass || 'object-cover object-top'}`}
                  loading="lazy"
                  onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
                />
                <div
                  class={`absolute inset-0 bg-gradient-to-br ${tpl.color} hidden items-center justify-center text-white/60 text-sm font-medium`}
                >
                  {tpl.name}
                </div>
                <a
                  href={tpl.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="absolute inset-0 flex items-center justify-center bg-black/0 hover:bg-black/40 transition-colors group"
                >
                  <span class="opacity-0 group-hover:opacity-100 bg-white text-gray-900 text-sm font-semibold px-4 py-2 rounded-full transition-opacity shadow-lg">
                    {t.preview}
                  </span>
                </a>
                {tpl.isBase && (
                  <div class="absolute top-3 left-3">
                    <span class="bg-blue-600 text-white text-xs font-bold px-2.5 py-1 rounded-full shadow">
                      {t.baseTemplate}
                    </span>
                  </div>
                )}
              </div>
              <div class="p-5 flex-1 flex flex-col">
                <div class="mb-3">
                  <div class="flex items-start justify-between gap-2 mb-1">
                    <h3 class="font-bold text-gray-900">{tpl.name}</h3>
                    <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full whitespace-nowrap shrink-0">
                      {tpl.sector}
                    </span>
                  </div>
                  <p class="text-gray-500 text-sm leading-relaxed">{tpl.desc}</p>
                </div>

                {tpl.isBase && tpl.variations.length > 0 && (
                  <div class="mb-4 bg-blue-50 rounded-xl px-3 py-2.5">
                    <p class="text-xs font-semibold text-blue-700 mb-1.5">
                      {t.liveExamples} — {tpl.variations.length} {t.variation}s
                    </p>
                    <div class="flex flex-wrap gap-1.5">
                      {tpl.variations.map((domain) => (
                        <a
                          href={`https://${domain}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-xs text-blue-600 hover:underline"
                        >
                          {domain}
                        </a>
                      ))}
                    </div>
                  </div>
                )}

                <div class="mt-auto flex gap-2">
                  <a
                    href={tpl.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 text-center border border-gray-200 hover:border-gray-300 text-gray-600 text-sm font-medium px-4 py-2.5 rounded-xl transition-colors"
                  >
                    {t.preview}
                  </a>
                  <a
                    href={`/api/payment/redirect?plan=${encodeURIComponent(plan)}&template=${encodeURIComponent(tpl.id)}`}
                    class="flex-1 text-center bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors"
                  >
                    {t.select} →
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Bottom path split -->
      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        <article class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-1">{t.starterTitle}</p>
          <h2 class="text-2xl font-bold text-gray-900">{t.mergedTitle}</h2>
          <p class="mt-3 text-sm text-gray-500">{t.mergedLead}</p>
          <ul class="mt-5 space-y-2 text-sm text-slate-700">
            {t.starterItems.map((item) => <li>• {item}</li>)}
          </ul>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={`${localePrefix}/choose-template?plan=essential999`}
              class="inline-block bg-slate-950 hover:bg-slate-800 text-white font-semibold px-5 py-3 rounded-xl transition-colors"
            >
              {t.starterCtaPrimary}
            </a>
            <a
              href={`${localePrefix}/choose-template?plan=essential1500`}
              class="inline-block border border-slate-200 hover:border-slate-300 text-slate-700 font-semibold px-5 py-3 rounded-xl transition-colors"
            >
              {t.starterCtaSecondary}
            </a>
          </div>
        </article>

        <article class="bg-slate-950 border border-slate-900 rounded-2xl p-6 shadow-sm text-white">
          <p class="text-sm font-semibold text-blue-200 uppercase tracking-wide mb-1">{t.customTitle}</p>
          <h2 class="text-2xl font-bold">{t.customTitle}</h2>
          <p class="mt-3 text-sm text-white/75">{t.customLead}</p>
          <ul class="mt-5 space-y-2 text-sm text-white/80">
            {t.customItems.map((item) => <li>• {item}</li>)}
          </ul>
          <a
            href={`${localePrefix}/custom-systems`}
            class="mt-6 inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-3 rounded-xl transition-colors"
          >
            {t.customCta}
          </a>
        </article>
      </div>
    </div>
  </main>
</Layout>
