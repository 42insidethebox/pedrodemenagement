---
import Layout from '~/layouts/Layout.astro';
import { detectRequestLocale } from '~/lib/locale';
import { normalizePlanId, TONSITEWEB_DEFAULT_PLAN } from '~/lib/pricing.js';
import pedroLogo from '~/assets/lausannedemenagement/logo.png';
import toloPreview from '~/assets/tolocoiffure_images/template_preview.jpg';
import maisonPreview from '~/assets/maisoncortes_images/lausanne-ring-02.png';
import onglesPreview from '~/assets/onglesgel_images/01.png';

export const prerender = false;

const locale = detectRequestLocale(Astro.request, Astro.url);
const plan = normalizePlanId(Astro.url.searchParams.get('plan') || TONSITEWEB_DEFAULT_PLAN);
const toAssetSrc = (asset: string | { src: string }) => (typeof asset === 'string' ? asset : asset.src);
const localePrefix = ['en', 'de', 'it'].includes(locale) ? `/${locale}` : '';

const T = {
  fr: {
    title: 'Choisir une base de déploiement — IOPartner.ch',
    heading: 'Choisir une base de déploiement',
    sub: 'Sélectionnez une direction visuelle. Nous adaptons la base au contenu, au secteur et au niveau de complexité.',
    planLabel: 'Plan',
    select: 'Choisir ce style',
    preview: 'Voir le site →',
    surprise: 'Recommandation IOPartner',
    surpriseDesc: 'Laissez-nous choisir la base la plus rationnelle selon votre secteur et vos contenus.',
    surpriseBtn: 'Continuer avec recommandation →',
    baseTemplate: 'Modèle de base',
    variation: 'variation',
    liveExamples: 'Exemples réels',
    promoBadge: 'Pack Essentiel',
    promoTitle: 'IOPartner dès 999 CHF',
