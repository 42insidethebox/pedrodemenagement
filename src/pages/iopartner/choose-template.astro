    variation: 'Variation',
    liveExamples: 'Live-Beispiele',
    promoBadge: 'Essentiel-Paket',
    promoTitle: 'IOPartner ab 999 CHF',
    promoDesc: 'Fixpreis für eine professionelle Showcase-Website. Lieferung in 3–5 Arbeitstagen je nach Inhalt.',
    promoBtn: 'Jetzt bestellen →',
    mergedTitle: 'Im Standard bleiben',
    mergedLead:
      'Zwei saubere Wege: CHF 999 oder CHF 1’500, wenn das Thema standardisiert bleibt. Sonst wechseln Sie in die Custom-Route.',
    starterTitle: 'Standardweg',
    starterItems: [
      'CHF 999: 5-teilige Showcase-Seite auf gemeinsamer Infrastruktur.',
      'CHF 1’500: Standard-Deployment + integrierte Terminroute + kurze Übergabe.',
    ],
    starterCtaPrimary: 'CHF 999 wählen',
    starterCtaSecondary: 'CHF 1’500 wählen',
    customTitle: 'Reichen Vorlage und Tenant nicht aus?',
    customLead: 'Getrennte Codebase, Übergabe, leichtes Backend, Headless Shop oder schwerere Architektur.',
    customItems: [
      'CHF 2’000: private Codebase.',
      'CHF 2’200: private Codebase + Übergabe.',
      'CHF 4’500: leichtes Backend.',
      'CHF 8’000+: Headless Shop oder schwereres System.',
      'Einstieg: bezahlte 15 Min. / CHF 60 Diagnose.',
    ],
    customCta: 'Custom-Prozess ansehen →',
  },
  it: {
    title: 'Scegli uno stile — IOPartner.ch',
    heading: 'Quale stile per il vostro sito?',
    sub: 'Scegliete tra i nostri progetti reali — adattiamo tutto al vostro settore.',
    planLabel: 'Piano',
    select: 'Scegli questo stile',
    preview: 'Vedi il sito →',
    surprise: 'Raccomandazione IOPartner',
    surpriseDesc: 'Vi fidate di noi, scegliamo lo stile più adatto al vostro settore e ai vostri contenuti.',
