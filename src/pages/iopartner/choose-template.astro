      '2 000 CHF: codebase privée.',
      '2 200 CHF: codebase privée + transmission.',
      '4 500 CHF: back-end léger.',
      '8 000+ CHF: headless shop ou système plus lourd.',
      'Entrée: diagnostic payé 15 min / 60 CHF.',
    ],
    customCta: 'Voir la progression custom →',
  },
  en: {
    title: 'Choose a style — IOPartner.ch',
    heading: 'Which style for your site?',
