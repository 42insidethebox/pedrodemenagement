    variation: 'variazione',
    liveExamples: 'Esempi reali',
    promoBadge: 'Pacchetto Essenziale',
    promoTitle: 'IOPartner da 999 CHF',
    promoDesc:
      'Prezzo fisso per un sito vetrina professionale. Consegna in 3–5 giorni lavorativi in base ai contenuti.',
    promoBtn: 'Ordina ora →',
    mergedTitle: 'Restare sul percorso standard',
    mergedLead: 'Due vie pulite: CHF 999 o CHF 1’500 se il lavoro resta standard. Altrimenti passa alla via custom.',
    starterTitle: 'Via standard',
