      { label: '02', title: 'Arbitrage', detail: 'Standard, custom ou pause.', icon: 'scope' },
      { label: '03', title: 'Direction', detail: 'Ce qu’il faut faire ensuite.', icon: 'consulting' },
      { label: '04', title: 'Suite', detail: 'Build, systems ou rien.', icon: 'check' },
