  de: {
    metadata: {
      title: 'Technisches Scoping — IOPartner',
      description:
        'Technisches Scoping für KMU: eine Entscheidung klären, ein Projekt entblocken oder den falschen Build vorab vermeiden.',
    },
    kicker: 'Technisches Scoping',
    heroTitle: 'Erst entscheiden, dann bauen.',
    heroLead:
      'Eine kurze bezahlte Session, um eine Entscheidung zu klären, ein Thema zu entblocken oder aus einem einfachen Bedarf kein falsches Projekt zu machen.',
