    useKicker: 'When to use it',
    useTitle: 'When the problem is not the build yet.',
    situations: [
      { text: 'You are hesitating between a simple site, a private build, or a heavier system.', icon: 'standard' },
      { text: 'A project is blocked by a technical decision.', icon: 'diagnostic' },
