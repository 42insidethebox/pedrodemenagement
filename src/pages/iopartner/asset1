  padding:60px 0 40px;
  display:flex;flex-direction:column;align-items:center;
  font-family:'Inter',sans-serif;
}
.intune-eyebrow{
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.18em;text-transform:uppercase;
  color:#1a56ff;margin-bottom:8px;text-align:center;font-weight:500;
}
.intune-title{
  font-size:clamp(20px,3vw,30px);font-weight:600;
  letter-spacing:-.025em;color:#0b1526;text-align:center;
  margin-bottom:8px;line-height:1.2;
}
.intune-sub{
  font-size:13px;color:#5a6a82;text-align:center;
  max-width:500px;line-height:1.7;margin-bottom:28px;
}
.intune-frame{
  width:100%;
  border:1px solid rgba(11,21,38,.08);
  border-radius:3px;
  overflow:hidden;
  box-shadow:0 1px 3px rgba(11,21,38,.04),0 8px 40px rgba(11,21,38,.08);
}
.intune-topbar{
  background:#0b1526;height:32px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 14px;
}
.intune-topbar-left{display:flex;gap:6px;align-items:center}
.intune-topbar-dot{
  width:10px;height:10px;border-radius:50%;display:inline-block;
}
.intune-topbar-title{
  font-family:'JetBrains Mono',monospace;font-size:8px;
  letter-spacing:.12em;text-transform:uppercase;
  color:rgba(255,255,255,.4);
}
.intune-topbar-rev{
  font-family:'JetBrains Mono',monospace;font-size:8px;
  letter-spacing:.1em;color:rgba(255,255,255,.2);
}
#intune-svg{width:100%;height:auto;display:block;background:#f8f9fb}

/* Legend */
.intune-legend{
  display:flex;flex-wrap:wrap;gap:20px;justify-content:center;
  margin-top:16px;
}
.legend-item{
  display:flex;align-items:center;gap:7px;
  font-family:'JetBrains Mono',monospace;font-size:9.5px;
  color:rgba(11,21,38,.45);letter-spacing:.04em;
}
.legend-dot{
  width:8px;height:8px;border-radius:50%;flex-shrink:0;
}
