<!-- ══════════════════════════════════════
     PARTICLES (signal flow animation)
══════════════════════════════════════ -->
<script>
(function() {
  const ns = 'http://www.w3.org/2000/svg';
  const partG = document.getElementById('particles');
  if (!partG) return;

  // Key paths to animate signal flow along
  // Each path: from point → to point with control points
  const FLOWS = [
    // Device → Intune (enrollment)
    { pts:[441,380, 441,340, 350,290, 310,270], col:'rgba(26,86,255,.8)', speed:.007 },
    { pts:[455,380, 455,330, 415,295, 415,285], col:'rgba(26,86,255,.7)', speed:.009 },
    // Intune ↔ Entra (group targeting)
    { pts:[670,178, 710,178, 760,178, 812,178], col:'rgba(255,255,255,.7)', speed:.008 },
    // Entra → Auth → SaaS
    { pts:[1032,220, 1048,220, 1052,355, 1048,380], col:'rgba(0,120,212,.8)', speed:.006 },
    // MTD signal
    { pts:[320,432, 350,440, 370,450, 376,460], col:'rgba(220,38,38,.8)', speed:.011 },
    // Compliance results
    { pts:[792,232, 800,232, 806,232, 812,232], col:'rgba(255,255,255,.6)', speed:.012 },
    // Telecom → device
    { pts:[292,432, 330,432, 355,432, 376,450], col:'rgba(22,163,74,.8)', speed:.007 },
  ];

  class Pulse {
    constructor(flow) {
      this.flow = flow;
      this.t = Math.random();
      this.speed = flow.speed + (Math.random() - .5) * .002;
      this.el = document.createElementNS(ns, 'circle');
      this.el.setAttribute('r', '2.5');
      this.el.setAttribute('fill', flow.col);
      this.el.style.filter = 'url(#i-glow-sm)';
      partG.appendChild(this.el);
      this.dead = false;
    }
    tick() {
      this.t += this.speed;
      if (this.t > 1) { this.t = 0; }
      const t = this.t, mt = 1 - t;
      const [x0,y0,x1,y1,x2,y2,x3,y3] = this.flow.pts;
      const x = mt**3*x0 + 3*mt**2*t*x1 + 3*mt*t**2*x2 + t**3*x3;
      const y = mt**3*y0 + 3*mt**2*t*y1 + 3*mt*t**2*y2 + t**3*y3;
      this.el.setAttribute('cx', x.toFixed(1));
      this.el.setAttribute('cy', y.toFixed(1));
    }
  }

  const pulses = FLOWS.map(f => new Pulse(f));
  // Add a second pulse on each flow with offset
  FLOWS.forEach(f => pulses.push(new Pulse(f)));

  function loop() {
    pulses.forEach(p => p.tick());
    requestAnimationFrame(loop);
  }
  loop();
})();
</script>