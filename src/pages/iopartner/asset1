---
// IntuneArchitecture.astro
// Microsoft Intune + Azure AD / Entra ID architecture diagram
// Rebuilt in IOPartner Swiss blueprint style
// Source: Microsoft official Intune architecture diagram
---

<section class="intune-section">

  <!-- Header -->
  <div class="intune-header">
    <p class="intune-eyebrow">Reference Architecture</p>
    <h2 class="intune-title">Microsoft Intune &amp; Entra ID</h2>
    <p class="intune-sub">
      Device management, conditional access, and app protection —
      how the identity and compliance layer actually connects.
    </p>
  </div>

  <!-- SVG Frame -->
  <div class="intune-frame">
    <div class="intune-topbar">
      <span class="intune-topbar-left">
        <span class="intune-topbar-dot" style="background:#ef4444"></span>
        <span class="intune-topbar-dot" style="background:#f59e0b"></span>
        <span class="intune-topbar-dot" style="background:#22c55e"></span>
      </span>
      <span class="intune-topbar-title">
        MICROSOFT INTUNE · ENTRA ID · CONDITIONAL ACCESS · MDM ARCHITECTURE
      </span>
      <span class="intune-topbar-rev">REV.1 · 2026</span>
    </div>

    <svg
      id="intune-svg"
      viewBox="0 0 1080 720"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Microsoft Intune and Entra ID architecture diagram"
    >
      <defs>
        <!-- Dot grid -->
        <pattern id="i-dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="10" cy="10" r=".6" fill="rgba(26,86,255,.08)"/>
        </pattern>

        <!-- Fine rule grid -->
        <pattern id="i-grid" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M60 0L0 0 0 60" fill="none"
                stroke="rgba(26,86,255,.04)" stroke-width=".5"/>
        </pattern>

        <!-- Filters -->
        <filter id="i-card-shadow" x="-6%" y="-8%" width="112%" height="122%">
          <feDropShadow dx="0" dy="2" stdDeviation="5"
                        flood-color="rgba(11,21,38,.1)"/>
        </filter>
        <filter id="i-glow-blue" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="5" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="i-glow-sm" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur stdDeviation="2.5" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="i-cloud-shadow" x="-8%" y="-8%" width="116%" height="124%">
          <feDropShadow dx="0" dy="3" stdDeviation="8"
                        flood-color="rgba(0,120,212,.18)"/>
        </filter>
        <filter id="i-highlight-shadow" x="-8%" y="-8%" width="116%" height="124%">
          <feDropShadow dx="0" dy="3" stdDeviation="8"
                        flood-color="rgba(255,165,0,.35)"/>
        </filter>

        <!-- Gradients -->
        <linearGradient id="i-azure-grad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#1565c0"/>
          <stop offset="100%" stop-color="#0d47a1"/>
        </linearGradient>
        <linearGradient id="i-intune-grad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#1976d2"/>
          <stop offset="100%" stop-color="#1565c0"/>
        </linearGradient>
        <linearGradient id="i-entra-grad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#0078d4"/>
          <stop offset="100%" stop-color="#005a9e"/>
        </linearGradient>
        <radialGradient id="i-cloud-inner" cx="50%" cy="40%" r="55%">
          <stop offset="0%" stop-color="rgba(25,118,210,.15)"/>
          <stop offset="100%" stop-color="rgba(13,71,161,.0)"/>
        </radialGradient>

        <!-- Arrow markers -->
        <marker id="m-blue" markerWidth="7" markerHeight="7"
                refX="6" refY="3.5" orient="auto">
          <polygon points="0 1,6 3.5,0 6" fill="#1a56ff"/></marker>
        <marker id="m-white" markerWidth="7" markerHeight="7"
                refX="6" refY="3.5" orient="auto">
          <polygon points="0 1,6 3.5,0 6" fill="rgba(255,255,255,.8)"/></marker>
        <marker id="m-dim" markerWidth="6" markerHeight="6"
                refX="5" refY="3" orient="auto">
          <polygon points="0 .8,5 3,0 5.2" fill="rgba(11,21,38,.2)"/></marker>
        <marker id="m-amber" markerWidth="7" markerHeight="7"
                refX="6" refY="3.5" orient="auto">
          <polygon points="0 1,6 3.5,0 6" fill="#f59e0b"/></marker>
        <marker id="m-both-l" markerWidth="7" markerHeight="7"
                refX="1" refY="3.5" orient="auto">
          <polygon points="7 1,1 3.5,7 6" fill="rgba(255,255,255,.7)"/></marker>
      </defs>

      <!-- ── BACKGROUND ── -->
      <rect width="1080" height="720" fill="#f8f9fb"/>
      <rect width="1080" height="720" fill="url(#i-dots)"/>
      <rect width="1080" height="720" fill="url(#i-grid)"/>

      <!-- ═══════════════════════════════════════
           AZURE CLOUD — large background shape
      ═══════════════════════════════════════ -->
      <!-- Cloud blob path: hand-crafted organic shape -->
      <g id="azure-cloud">
        <!-- Outer cloud silhouette (dark blue fill) -->
        <path id="cloud-path"
          d="M180,60
             Q220,20 280,30 Q310,8 360,20 Q400,4 450,18
             Q510,0 560,20 Q610,5 660,22 Q700,8 740,28
             Q790,10 830,35 Q870,18 910,40 Q940,22 970,48
             Q1010,32 1020,65
             Q1040,90 1030,130 Q1050,160 1040,195
             Q1060,230 1040,265 Q1050,295 1030,320
             Q1020,355 990,370 Q970,390 940,388
             L200,388
             Q165,385 145,360 Q120,335 130,305
             Q110,280 120,250 Q100,220 115,190
             Q95,160 110,130 Q100,95 130,72 Q155,55 180,60 Z"
          fill="url(#i-azure-grad)"
          filter="url(#i-cloud-shadow)"
          opacity=".97"
        />
        <!-- Inner cloud highlight -->
        <path
          d="M200,75 Q250,40 320,52 Q370,28 430,45 Q490,22 550,40
             Q610,20 670,42 Q720,22 770,45 Q820,28 870,55
             Q920,35 960,62 Q990,78 1000,115 Q1020,150 1005,185
             Q1020,215 1005,245 Q1015,275 995,302
             Q978,330 950,340
             L220,340
             Q190,335 172,310 Q152,282 165,252
             Q148,222 162,192 Q145,162 162,132 Q152,100 178,80 Z"
          fill="rgba(255,255,255,.04)"
        />
        <!-- Azure label -->
        <text x="540" y="68" font-family="'Inter',sans-serif" font-size="13"
              font-weight="300" fill="rgba(255,255,255,.55)" text-anchor="middle"
              letter-spacing=".1em">Microsoft Azure</text>
        <line x1="360" y1="74" x2="720" y2="74"
              stroke="rgba(255,255,255,.12)" stroke-width=".7"/>
      </g>

      <!-- ═══════════════════════════════════════
           INTUNE SUB-CLOUD
      ═══════════════════════════════════════ -->
      <g id="intune-cloud">
        <path
          d="M155,105
             Q185,78 230,88 Q265,68 315,82
             Q360,62 415,80 Q460,62 510,80
             Q555,60 600,80 Q640,62 680,82
             Q715,68 745,90 Q775,74 800,102
             Q825,118 820,150 Q835,178 820,205
             Q828,235 810,258 Q795,278 770,285
             L185,285
             Q158,280 140,258 Q120,232 128,205
             Q112,178 125,152 Q118,122 155,105 Z"
          fill="url(#i-intune-grad)"
          opacity=".92"
        />
        <!-- Intune label -->
        <text x="490" y="122" font-family="'Inter',sans-serif" font-size="12"
              font-weight="500" fill="rgba(255,255,255,.9)" text-anchor="middle"
              letter-spacing=".06em">Microsoft Intune</text>

        <!-- ── Three capability columns inside Intune ── -->
        <!-- Configure Devices -->
        <g id="col-configure">
          <rect x="170" y="136" width="150" height="120" rx="6"
                fill="rgba(255,255,255,.07)" stroke="rgba(255,255,255,.12)"
                stroke-width=".8"/>
          <!-- Icon: gear outline -->
          <g transform="translate(245,157)">
            <circle r="10" fill="none" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/>
            <circle r="4" fill="rgba(255,255,255,.6)"/>
            <!-- Gear teeth (simplified) -->
            <line x1="0" y1="-10" x2="0" y2="-14" stroke="rgba(255,255,255,.6)" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="0" y1="10" x2="0" y2="14" stroke="rgba(255,255,255,.6)" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="-10" y1="0" x2="-14" y2="0" stroke="rgba(255,255,255,.6)" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="10" y1="0" x2="14" y2="0" stroke="rgba(255,255,255,.6)" stroke-width="2.5" stroke-linecap="round"/>
          </g>
          <text x="245" y="178" font-family="'Inter',sans-serif" font-size="9"
                font-weight="500" fill="rgba(255,255,255,.85)" text-anchor="middle"
                letter-spacing=".04em">Configure devices</text>
          <!-- Sub items -->
          <rect x="182" y="186" width="60" height="28" rx="3"
                fill="rgba(255,255,255,.1)" stroke="rgba(255,255,255,.15)" stroke-width=".6"/>
          <text x="212" y="198" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.7)" text-anchor="middle">Profiles</text>
          <text x="212" y="208" font-family="'JetBrains Mono',monospace" font-size="6"
                fill="rgba(255,255,255,.45)" text-anchor="middle">device config</text>

          <rect x="252" y="186" width="60" height="28" rx="3"
                fill="rgba(255,255,255,.1)" stroke="rgba(255,255,255,.15)" stroke-width=".6"/>
          <text x="282" y="198" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.7)" text-anchor="middle">Config</text>
          <text x="282" y="208" font-family="'JetBrains Mono',monospace" font-size="6"
                fill="rgba(255,255,255,.45)" text-anchor="middle">policies</text>

          <!-- Small device icons row -->
          <text x="245" y="242" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.35)" text-anchor="middle"
                letter-spacing=".06em">Win · Mac · iOS · And</text>
        </g>

        <!-- Protect Data -->
        <g id="col-protect">
          <rect x="335" y="136" width="160" height="120" rx="6"
                fill="rgba(255,255,255,.07)" stroke="rgba(255,255,255,.12)"
                stroke-width=".8"/>
          <!-- Lock icon -->
          <g transform="translate(415,156)">
            <rect x="-8" y="-2" width="16" height="12" rx="2"
                  fill="none" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/>
            <path d="M-5,-2 Q-5,-10 0,-10 Q5,-10 5,-2"
                  fill="none" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/>
            <circle cx="0" cy="4" r="2" fill="rgba(255,255,255,.6)"/>
          </g>
          <text x="415" y="178" font-family="'Inter',sans-serif" font-size="9"
                font-weight="500" fill="rgba(255,255,255,.85)" text-anchor="middle"
                letter-spacing=".04em">Protect data</text>

          <rect x="344" y="186" width="66" height="28" rx="3"
                fill="rgba(255,255,255,.1)" stroke="rgba(255,255,255,.15)" stroke-width=".6"/>
          <text x="377" y="198" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.7)" text-anchor="middle">App protect</text>
          <text x="377" y="208" font-family="'JetBrains Mono',monospace" font-size="6"
                fill="rgba(255,255,255,.45)" text-anchor="middle">policies</text>

          <rect x="420" y="186" width="66" height="28" rx="3"
                fill="rgba(255,255,255,.1)" stroke="rgba(255,255,255,.15)" stroke-width=".6"/>
          <text x="453" y="198" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.7)" text-anchor="middle">Device</text>
          <text x="453" y="208" font-family="'JetBrains Mono',monospace" font-size="6"
                fill="rgba(255,255,255,.45)" text-anchor="middle">compliance</text>

          <text x="415" y="242" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.35)" text-anchor="middle"
                letter-spacing=".06em">MAM · MDM · BYOD</text>
        </g>

        <!-- Manage Apps -->
        <g id="col-apps">
          <rect x="510" y="136" width="145" height="120" rx="6"
                fill="rgba(255,255,255,.07)" stroke="rgba(255,255,255,.12)"
                stroke-width=".8"/>
          <!-- Grid icon -->
          <g transform="translate(582,156)">
            <rect x="-10" y="-10" width="8" height="8" rx="1.5"
                  fill="rgba(255,255,255,.65)"/>
            <rect x="2"   y="-10" width="8" height="8" rx="1.5"
                  fill="rgba(255,255,255,.65)"/>
            <rect x="-10" y="2"   width="8" height="8" rx="1.5"
                  fill="rgba(255,255,255,.65)"/>
            <rect x="2"   y="2"   width="8" height="8" rx="1.5"
                  fill="rgba(255,255,255,.65)"/>
          </g>
          <text x="582" y="178" font-family="'Inter',sans-serif" font-size="9"
                font-weight="500" fill="rgba(255,255,255,.85)" text-anchor="middle"
                letter-spacing=".04em">Manage apps</text>

          <rect x="519" y="186" width="58" height="28" rx="3"
                fill="rgba(255,255,255,.1)" stroke="rgba(255,255,255,.15)" stroke-width=".6"/>
          <text x="548" y="198" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.7)" text-anchor="middle">Apps</text>
          <text x="548" y="208" font-family="'JetBrains Mono',monospace" font-size="6"
                fill="rgba(255,255,255,.45)" text-anchor="middle">deploy</text>

          <rect x="587" y="186" width="60" height="28" rx="3"
                fill="rgba(255,255,255,.1)" stroke="rgba(255,255,255,.15)" stroke-width=".6"/>
          <text x="617" y="198" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.7)" text-anchor="middle">App config</text>
          <text x="617" y="208" font-family="'JetBrains Mono',monospace" font-size="6"
                fill="rgba(255,255,255,.45)" text-anchor="middle">policies</text>

          <text x="582" y="242" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="rgba(255,255,255,.35)" text-anchor="middle"
                letter-spacing=".06em">Store · LOB · Web</text>
        </g>

        <!-- Compliance bridge box (between Intune and Entra) -->
        <g id="compliance-bridge">
          <rect x="680" y="160" width="112" height="36" rx="3"
                fill="rgba(255,255,255,.12)" stroke="rgba(255,255,255,.2)"
                stroke-width=".8"/>
          <text x="736" y="174" font-family="'JetBrains Mono',monospace" font-size="7.5"
                font-weight="500" fill="rgba(255,255,255,.8)" text-anchor="middle"
                letter-spacing=".08em">Group targeting</text>
          <text x="736" y="186" font-family="'JetBrains Mono',monospace" font-size="6.5"
                fill="rgba(255,255,255,.45)" text-anchor="middle">Entra → Intune</text>
        </g>

        <g id="device-compliance-bridge">
          <rect x="680" y="213" width="112" height="44" rx="3"
                fill="rgba(255,255,255,.1)" stroke="rgba(255,255,255,.18)"
                stroke-width=".8"/>
          <text x="736" y="228" font-family="'JetBrains Mono',monospace" font-size="7.5"
                font-weight="500" fill="rgba(255,255,255,.8)" text-anchor="middle"
                letter-spacing=".08em">Device compliance</text>
          <text x="736" y="240" font-family="'JetBrains Mono',monospace" font-size="6.5"
                fill="rgba(255,255,255,.45)" text-anchor="middle">results → Entra CA</text>
          <text x="736" y="251" font-family="'JetBrains Mono',monospace" font-size="6"
                fill="rgba(255,255,255,.3)" text-anchor="middle">read compliance info</text>
        </g>
      </g>

      <!-- ═══════════════════════════════════════
           ENTRA ID / AZURE AD — highlighted box
           (the orange-highlighted component)
      ═══════════════════════════════════════ -->
      <g id="entra-box">
        <!-- Outer highlight (the "selected" orange frame from original) -->
        <rect x="812" y="90" width="240" height="200" rx="4"
              fill="rgba(245,158,11,.08)"
              stroke="#f59e0b" stroke-width="1.5"
              filter="url(#i-highlight-shadow)"
              stroke-dasharray="none"/>

        <!-- Inner box -->
        <rect x="822" y="98" width="220" height="184" rx="3"
              fill="rgba(0,120,212,.12)" stroke="rgba(0,120,212,.3)"
              stroke-width="1" filter="url(#i-card-shadow)"/>

        <!-- Entra ID diamond icon -->
        <g transform="translate(932,130)">
          <polygon points="0,-18 18,0 0,18 -18,0"
                   fill="none" stroke="#0078d4" stroke-width="1.5"
                   filter="url(#i-glow-sm)"/>
          <polygon points="0,-10 10,0 0,10 -10,0"
                   fill="#0078d4" opacity=".7"
                   filter="url(#i-glow-sm)"/>
          <polygon points="0,-5 5,0 0,5 -5,0"
                   fill="#fff" opacity=".8"/>
        </g>

        <text x="932" y="158" font-family="'Inter',sans-serif" font-size="11"
              font-weight="600" fill="#0b1526" text-anchor="middle"
              letter-spacing=".02em">Entra ID</text>
        <text x="932" y="171" font-family="'JetBrains Mono',monospace" font-size="7.5"
              fill="#4a6080" text-anchor="middle" letter-spacing=".06em">
          Azure Active Directory
        </text>

        <!-- Divider -->
        <line x1="835" y1="180" x2="1028" y2="180"
              stroke="rgba(11,21,38,.08)" stroke-width=".8"/>

        <!-- Conditional Access sub-box -->
        <rect x="832" y="186" width="100" height="52" rx="3"
              fill="rgba(0,120,212,.08)" stroke="rgba(0,120,212,.2)"
              stroke-width=".8"/>
        <!-- CA icon: shield -->
        <g transform="translate(860,204)">
          <path d="M0,-9 L9,-4 L9,4 Q9,10 0,13 Q-9,10 -9,4 L-9,-4 Z"
                fill="none" stroke="#0078d4" stroke-width="1.3"/>
          <text y="4" font-size="8" fill="#0078d4" text-anchor="middle">✓</text>
        </g>
        <text x="895" y="204" font-family="'JetBrains Mono',monospace" font-size="7.5"
              font-weight="500" fill="#0b1526" text-anchor="middle">Conditional</text>
        <text x="895" y="215" font-family="'JetBrains Mono',monospace" font-size="7.5"
              font-weight="500" fill="#0b1526" text-anchor="middle">Access</text>
        <text x="882" y="230" font-family="'JetBrains Mono',monospace" font-size="6.5"
              fill="#4a6080" text-anchor="middle">MFA · location · risk</text>

        <!-- Auth & Authorization sub-box -->
        <rect x="942" y="186" width="100" height="52" rx="3"
              fill="rgba(0,120,212,.08)" stroke="rgba(0,120,212,.2)"
              stroke-width=".8"/>
        <!-- Key icon -->
        <g transform="translate(970,204)">
          <circle cx="0" cy="0" r="6" fill="none" stroke="#0078d4" stroke-width="1.3"/>
          <line x1="6" y1="0" x2="14" y2="0" stroke="#0078d4" stroke-width="1.3"/>
          <line x1="11" y1="0" x2="11" y2="4" stroke="#0078d4" stroke-width="1.3"/>
          <line x1="14" y1="0" x2="14" y2="4" stroke="#0078d4" stroke-width="1.3"/>
        </g>
        <text x="1005" y="204" font-family="'JetBrains Mono',monospace" font-size="7.5"
              font-weight="500" fill="#0b1526" text-anchor="middle">Auth &amp;</text>
        <text x="1005" y="215" font-family="'JetBrains Mono',monospace" font-size="7.5"
              font-weight="500" fill="#0b1526" text-anchor="middle">Authorization</text>
        <text x="994" y="230" font-family="'JetBrains Mono',monospace" font-size="6.5"
              fill="#4a6080" text-anchor="middle">SSO · tokens · RBAC</text>

        <!-- Highlight label -->
        <text x="932" y="284" font-family="'JetBrains Mono',monospace" font-size="7.5"
              fill="rgba(245,158,11,.8)" text-anchor="middle" letter-spacing=".1em">
          ← IDENTITY BACKBONE
        </text>
      </g>

      <!-- ═══════════════════════════════════════
           LEFT SIDE — Web Console / Graph API
      ═══════════════════════════════════════ -->
      <g id="left-panel">
        <!-- Graph API cloud shape -->
        <g id="graph-api">
          <ellipse cx="70" cy="195" rx="52" ry="38"
                   fill="rgba(173,216,230,.25)" stroke="rgba(100,160,220,.4)"
                   stroke-width="1" stroke-dasharray="5 3"/>
          <!-- Cloud bumps -->
          <ellipse cx="52" cy="183" rx="20" ry="15"
                   fill="rgba(173,216,230,.3)" stroke="rgba(100,160,220,.35)"
                   stroke-width=".8" stroke-dasharray="4 3"/>
          <ellipse cx="88" cy="180" rx="22" ry="16"
                   fill="rgba(173,216,230,.3)" stroke="rgba(100,160,220,.35)"
                   stroke-width=".8" stroke-dasharray="4 3"/>
          <text x="70" y="198" font-family="'Inter',sans-serif" font-size="9"
                font-weight="500" fill="#2d4a6b" text-anchor="middle">Graph API</text>
          <text x="70" y="210" font-family="'JetBrains Mono',monospace" font-size="7"
                fill="#6b8aaa" text-anchor="middle">config · report</text>
        </g>

        <!-- Web Console box -->
        <g id="web-console">
          <rect x="18" y="296" width="104" height="72" rx="3"
                fill="rgba(255,255,255,.9)" stroke="rgba(11,21,38,.12)"
                stroke-width="1" filter="url(#i-card-shadow)"/>
          <!-- Screen lines mockup -->
          <rect x="28" y="306" width="84" height="48" rx="2"
                fill="#f0f2f8" stroke="rgba(11,21,38,.08)" stroke-width=".6"/>
          <line x1="32" y1="316" x2="100" y2="316"
                stroke="rgba(26,86,255,.3)" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="32" y1="324" x2="88"  y2="324"
                stroke="rgba(11,21,38,.15)" stroke-width="1" stroke-linecap="round"/>
          <line x1="32" y1="332" x2="94"  y2="332"
                stroke="rgba(11,21,38,.1)" stroke-width="1" stroke-linecap="round"/>
