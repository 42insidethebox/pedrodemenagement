      slot: 'Slot',
      teams: 'Teams',
    },
    loading: 'Caricamento dettagli…',
    error: 'Impossibile caricare i dettagli. Contatta il supporto.',
    orderTitle: 'Il tuo sito entra ora in produzione',
    orderLead: 'Abbiamo brief e ordine. Le richieste fuori perimetro restano preventivate separatamente prima dell’esecuzione.',
    orderBullets: [
      'Integrazione e impaginazione dei contenuti validati.',
      'Consegna tipica in 3–5 giorni lavorativi in base ai contenuti.',
      'Supporto umano via email o WhatsApp entro un giorno lavorativo.',
    ],
    bookingTitle: 'La tua diagnosi custom è prenotata',
    bookingLead: 'Lo slot è bloccato. Riceverai anche i dettagli via email, incluso il link Teams condiviso.',
    bookingBullets: [
      'Sessione breve e pagata, non una call vaga.',
      'La diagnosi qualifica il livello giusto: 2’000, 2’200, 4’500, 8’000+ o architettura più profonda.',
      'Se la mossa giusta resta 999 o 1’500, te lo diremo chiaramente.',
    ],
    customTitle: 'Serve andare oltre?',
    customDesc: 'Se la diagnosi apre una vera superficie di implementazione, il passo successivo viene scoped bene dopo questa prima lettura.',
    customBtn: 'Vedi custom systems',
    whatsappLabel: 'Domande? Scrivici su WhatsApp',
    whatsappBtn: 'Scrivi su WhatsApp',
    currencyLocale: 'it-CH',
  },
} as const;

const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
const waMessageBase = encodeURIComponent("Bonjour, j'ai une question concernant IOPartner.");
const waUrl = `https://wa.me/41767982793?text=${waMessageBase}`;
---

<Layout metadata={{ title: copy.title }} brandKey="iopartner">
  <section class="py-16 px-4 bg-slate-50">
    <div class="container mx-auto max-w-3xl">
      <div class="text-center mb-10">
        <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-slate-950">{copy.heading}</h1>
        <p class="mt-3 text-slate-500" id="desc">{hasSession ? copy.descLoading : copy.descGeneric}</p>
      </div>

      {hasSession ? (
        <div id="session" class="mb-8 rounded-2xl border border-slate-200 bg-white p-5 text-sm shadow-sm">
          <div id="loader">{copy.loading}</div>
          <div id="content" class="hidden space-y-2">
            <p><strong>{copy.summary.email}:</strong> <span id="email">—</span></p>
            <p><strong>{copy.summary.amount}:</strong> <span id="amount">—</span></p>
            <p><strong>{copy.summary.status}:</strong> <span id="status">—</span></p>
            <p data-order-row><strong>{copy.summary.template}:</strong> <span id="template">—</span></p>
            <p data-order-row><strong>{copy.summary.plan}:</strong> <span id="plan">—</span></p>
            <p data-booking-row class="hidden"><strong>{copy.summary.service}:</strong> <span id="service">—</span></p>
            <p data-booking-row class="hidden"><strong>{copy.summary.slot}:</strong> <span id="slot">—</span></p>
            <p data-booking-row class="hidden"><strong>{copy.summary.teams}:</strong> <a id="teams" href="#" target="_blank" rel="noreferrer" class="text-blue-600 hover:underline">—</a></p>
          </div>
          <div id="error" class="hidden text-red-600">{copy.error}</div>
        </div>
      ) : null}

      <div id="order-panel" class="rounded-3xl border border-blue-100 bg-blue-50 p-6 md:p-8 shadow-sm">
        <h2 class="text-2xl font-bold text-blue-950">{copy.orderTitle}</h2>
        <p class="mt-3 text-blue-900/80">{copy.orderLead}</p>
        <ul class="mt-5 space-y-2 text-sm text-blue-900/75">
          {copy.orderBullets.map((item) => <li>• {item}</li>)}
        </ul>
      </div>

      <div id="booking-panel" class="hidden rounded-3xl border border-emerald-100 bg-emerald-50 p-6 md:p-8 shadow-sm">
        <h2 class="text-2xl font-bold text-emerald-950">{copy.bookingTitle}</h2>
        <p class="mt-3 text-emerald-900/80">{copy.bookingLead}</p>
        <ul class="mt-5 space-y-2 text-sm text-emerald-900/75">
          {copy.bookingBullets.map((item) => <li>• {item}</li>)}
        </ul>
      </div>

      <div class="mt-8 rounded-3xl border border-slate-200 bg-white p-6 text-center shadow-sm">
        <p class="text-sm text-slate-500 mb-4">{copy.whatsappLabel}</p>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-green-500 hover:bg-green-600 text-white font-semibold text-base px-7 py-4 rounded-xl transition-colors"
        >
          {copy.whatsappBtn}
        </a>
      </div>

      <div class="mt-8 rounded-3xl border border-slate-200 bg-white p-6 text-center shadow-sm">
        <p class="font-bold text-slate-950 mb-2">{copy.customTitle}</p>
        <p class="text-slate-500 text-sm mb-4">{copy.customDesc}</p>
        <a
          href={`${localePrefix}/custom-systems`}
          class="inline-block border border-slate-200 hover:border-slate-300 hover:bg-slate-50 text-slate-700 font-medium text-sm px-6 py-3 rounded-xl transition-colors"
        >
          {copy.customBtn} →
        </a>
      </div>

      <div class="text-center mt-8">
        <a href={localePrefix || '/'} class="text-sm text-slate-400 hover:text-slate-600 underline">{copy.home}</a>
      </div>
    </div>
  </section>

  {hasSession ? (
    <script is:inline define:vars={{ copy }}>
      const params = new URLSearchParams(location.search);
      const id = params.get('session_id');
      if (id) {
        fetch(`/api/payment/session?session_id=${encodeURIComponent(id)}`)
          .then((r) => (r.ok ? r.json() : Promise.reject(new Error('HTTP ' + r.status))))
          .then((data) => {
            const amountMinor =
              typeof data.amount_total_order === 'number'
                ? data.amount_total_order
                : typeof data.amount_total === 'number'
                  ? data.amount_total
                  : null;
            const currency = (data.currency || 'CHF').toUpperCase();
            const formatter = new Intl.NumberFormat(copy.currencyLocale, { style: 'currency', currency });

            document.getElementById('email').textContent = data.customer_email || data.metadata?.email || '—';
            document.getElementById('amount').textContent = typeof amountMinor === 'number' ? formatter.format((amountMinor || 0) / 100) : '—';
            document.getElementById('status').textContent = data.payment_status || '—';
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('content').classList.remove('hidden');

            if (data.mode === 'booking' && data.booking) {
              document.getElementById('desc').textContent = copy.descBooking;
              document.getElementById('order-panel').classList.add('hidden');
              document.getElementById('booking-panel').classList.remove('hidden');
              document.querySelectorAll('[data-order-row]').forEach((el) => el.classList.add('hidden'));
              document.querySelectorAll('[data-booking-row]').forEach((el) => el.classList.remove('hidden'));
              document.getElementById('service').textContent = data.booking.service || '—';
              document.getElementById('slot').textContent = `${data.booking.start_time || '—'} → ${data.booking.end_time || '—'}`;
              const teams = document.getElementById('teams');
              if (teams && data.booking.teams_url) {
                teams.href = data.booking.teams_url;
                teams.textContent = data.booking.teams_url;
              }
            } else {
              document.getElementById('desc').textContent = copy.descOrder;
              document.getElementById('template').textContent = data.template || data.metadata?.template || '—';
              document.getElementById('plan').textContent = data.plan || data.metadata?.plan || '—';
            }
          })
          .catch(() => {
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('error').classList.remove('hidden');
          });
      }
    </script>
  ) : null}
</Layout>
