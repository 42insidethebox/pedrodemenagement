    bookingLead: 'The slot is locked. You will also receive the details by email, including the shared Teams link.',
    bookingBullets: [
      'Short paid session, not a vague exploratory call.',
      'The diagnostic qualifies the right layer: 2,000, 2,200, 4,500, 8,000+, or a deeper architecture subject.',
      'If the right move is still 999 or 1,500, we will tell you clearly.',
    ],
    customTitle: 'Need to go further?',
    customDesc: 'If the diagnostic opens a real implementation surface, the next step gets scoped properly after this first pass.',
    customBtn: 'See custom systems',
    whatsappLabel: 'Questions? Message us on WhatsApp',
    whatsappBtn: 'Message on WhatsApp',
    currencyLocale: 'en-CH',
  },
  de: {
    title: 'Danke — IOPartner.ch',
    heading: hasSession ? 'Zahlung bestätigt' : 'Danke',
    descLoading: 'Wir bestätigen Ihre Zahlung…',
    descGeneric: 'Wir melden uns innerhalb eines Arbeitstages.',
    descOrder: 'Ihre Zahlung ist bestätigt. Die Produktion startet jetzt.',
    descBooking: 'Ihre Zahlung ist bestätigt. Ihre Diagnose ist gebucht.',
    home: 'Zur Startseite',
    summary: {
      email: 'E-Mail',
      amount: 'Betrag',
      status: 'Status',
      template: 'Vorlage',
      plan: 'Plan',
