    descOrder: 'Il pagamento è confermato. La produzione parte ora.',
    descBooking: 'Il pagamento è confermato. La tua diagnosi è prenotata.',
    home: 'Torna alla home',
    summary: {
      email: 'Email',
      amount: 'Importo',
      status: 'Stato',
      template: 'Template',
      plan: 'Piano',
      order: 'Ordine',
