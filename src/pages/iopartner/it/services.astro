---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

import { iopartnerHeaderDataIt, iopartnerFooterDataIt } from '~/navigation';

const metadata = {
  title: 'Servizi IOPartner',
  description:
    'Websites, automazione AI, infrastruttura open-source e supporto gestito per aziende moderne.',
  openGraph: {
    type: 'website',
  },
  twitter: {
    cardType: 'summary',
  },
};
---

<Layout metadata={metadata} header={iopartnerHeaderDataIt} footer={iopartnerFooterDataIt}>
  <Hero
    id="services"
    tagline="Servizi"
    title="Websites, automazione, infrastruttura, supporto"
    subtitle="IOPartner organizza il lavoro in quattro blocchi chiari così le aziende moderne ottengono il giusto livello tecnico senza complessità superflua."
    actions={[{ variant: 'primary', text: 'Scopri i prezzi', href: '/it/pricing' }]}
  >
    <Fragment slot="image">
      <div class="relative aspect-[5/3] overflow-hidden rounded-2xl bg-gradient-to-br from-blue-700 via-slate-900 to-slate-800 p-10 text-left text-white shadow-2xl">
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">IOPartner capabilities</p>
        <h4 class="mt-4 text-4xl font-semibold">Website delivery · AI workflows · Open ops</h4>
        <p class="mt-6 max-w-xl text-lg text-blue-100/90">
          Stesso layout, posizionamento più ampio: questo tenant presenta ora IOPartner come partner di operazioni tecniche, non solo come creatore di siti.
        </p>
      </div>
    </Fragment>
  </Hero>

  <Features2
    id="websites"
    title="Websites"
    subtitle="Lo strato visibile del business, consegnato in modo pulito e collegato al resto."
    columns={3}
    items={[
      {
        title: 'Launch',
        description: 'Siti marketing, siti vetrina, redesign leggeri e presenze di lancio con perimetro chiaro.',
        icon: 'tabler:layout',
      },
      {
        title: 'Evoluzioni',
        description: 'Nuove pagine, miglioramenti di conversione, form e integrazioni front-end mirate.',
        icon: 'tabler:browser-plus',
      },
      {
        title: 'Migrazioni',
        description: 'Passaggio a una stack più veloce, pulizia contenuti e consolidamento tecnico progressivo.',
        icon: 'tabler:arrows-shuffle',
      },
    ]}
  />

  <Content
    id="ai-automation"
    isReversed
    title="AI & Automation"
    subtitle="Workflow utili, con validazione umana dove serve."
    items={[
      {
        title: 'Qualifica & instradamento',
        description: 'Le richieste in ingresso vengono ordinate, arricchite e inviate allo strumento o alla persona giusta.',
        icon: 'tabler:route',
      },
      {
        title: 'Assistenti mirati',
        description: 'Copilot interni, basi di conoscenza, bozze strutturate e supporto assistito.',
        icon: 'tabler:message-chatbot',
      },
      {
        title: 'Connessioni API o no-code',
        description: 'Integrazioni tra form, calendari, CRM, email, dashboard e sistemi esistenti.',
        icon: 'tabler:api',
      },
      {
        title: 'Guardrail operativi',
        description: 'Log, limiti, approvazioni e controlli prima di mettere online automazioni sensibili.',
        icon: 'tabler:shield-lock',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Automazioni che reggono in produzione</h3>
      Evitiamo demo spettacolari senza vita operativa. Ogni workflow deve restare leggibile, testabile e mantenibile.
    </Fragment>

    <Fragment slot="image">
      <div class="relative aspect-[4/3] overflow-hidden rounded-xl bg-gradient-to-br from-blue-600 via-slate-900 to-slate-800 p-10 text-left text-white shadow-xl">
        <h4 class="text-3xl font-semibold">Dall’intake all’azione</h4>
        <p class="mt-6 max-w-sm text-blue-100/90">
          Form, triage, risposta assistita, assegnazione, follow-up: il flusso resta utile perché i punti di controllo sono espliciti.
        </p>
      </div>
    </Fragment>
  </Content>

  <Content
    id="open-infrastructure"
    isAfterContent
    title="Open Infrastructure"
    subtitle="Mattoni aperti quando rendono la stack più durevole."
    items={[
      {
        title: 'Deploy',
        description: 'Git, hosting, DNS, domini, certificati e routine di rilascio adatte al giusto livello di complessità.',
        icon: 'tabler:cloud-upload',
      },
      {
        title: 'Osservabilità',
        description: 'Monitoring, alert e visibilità sui punti che non devono fallire in silenzio.',
        icon: 'tabler:activity-heartbeat',
      },
      {
        title: 'Portabilità',
        description: 'Strumenti open-source o standard collaudati che riducono lock-in inutili nel tempo.',
        icon: 'tabler:brand-open-source',
      },
      {
        title: 'Documentazione',
        description: 'Accessi essenziali, dipendenze e procedure tracciati per garantire continuità.',
        icon: 'tabler:file-description',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Un’infrastruttura che si può davvero operare</h3>
      Nessuna complessità gratuita. Cerchiamo il giusto livello di robustezza oggi, con una traiettoria chiara se il business cresce.
    </Fragment>

    <Fragment slot="image">
      <div class="relative aspect-[4/3] overflow-hidden rounded-xl bg-gradient-to-br from-slate-900 via-slate-800 to-blue-700 p-10 text-left text-white shadow-xl">
        <h4 class="text-3xl font-semibold">Open by default, pragmatic by necessity</h4>
        <p class="mt-6 max-w-sm text-blue-100/90">
          L’architettura resta leggibile così deploy, incidenti e handoff rimangono gestibili nel tempo.
        </p>
      </div>
    </Fragment>
  </Content>

  <Features2
    id="managed-support"
    title="Managed Support"
    subtitle="Il seguito operativo quotidiano che evita di riaprire il dossier da zero a ogni problema."
    columns={3}
    items={[
      {
        title: 'Supporto reattivo',
        description: 'Risposta entro un giorno lavorativo, follow-up dei temi attivi e priorità in base all’impatto reale.',
        icon: 'tabler:headset',
      },
      {
        title: 'Manutenzione',
        description: 'Aggiornamenti, backup, fix e controlli tecnici ricorrenti.',
        icon: 'tabler:tools',
      },
      {
        title: 'Monitoraggio',
        description: 'Controlli di disponibilità, rilevazione segnali deboli e alert sui servizi sensibili.',
        icon: 'tabler:antenna',
      },
      {
        title: 'Coordinamento',
        description: 'Un partner che mantiene il contesto quando prodotto, operations e terze parti devono allinearsi.',
        icon: 'tabler:git-merge',
      },
      {
        title: 'Iterazioni brevi',
        description: 'Piccoli miglioramenti e correzioni continue senza riaprire ogni volta un progetto completo.',
        icon: 'tabler:arrows-left-right',
      },
      {
        title: 'Controllo scope',
        description: 'Se un tema diventa un sistema più grande, lo re-scopeiamo in modo pulito invece di allungarlo in silenzio.',
        icon: 'tabler:stack-2',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Parla con IOPartner',
        href: '/it/contact#form',
        icon: 'tabler:device-desktop-analytics',
      },
    ]}
  >
    <Fragment slot="title">Scegli il giusto livello di intervento</Fragment>

    <Fragment slot="subtitle">
      Ti aiutiamo a distinguere ciò che appartiene a un website, a un progetto di automazione, a un’infrastruttura più strutturata o a un supporto gestito continuo.
    </Fragment>
  </CallToAction>
</Layout>
