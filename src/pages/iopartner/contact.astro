<script is:inline define:vars={{ heroMapLabels, miniMapLabels }}>
'use strict';

const ns = 'http://www.w3.org/2000/svg';
const svg = (tag, attrs = {}, parent) => {
  const el = document.createElementNS(ns, tag);
  Object.entries(attrs).forEach(([k, v]) => el.setAttribute(k, v));
  if (parent) parent.appendChild(el);
  return el;
};
const $ = sel => document.querySelector(sel);
const $$ = sel => Array.from(document.querySelectorAll(sel));

function openPath(id) {
  $$('.path-card').forEach(card => card.classList.remove('active'));
  const card = $('#card-' + id);
  if (card) card.classList.add('active');
  $$('.form-panel').forEach(panel => panel.classList.remove('open'));
  const panel = $('#panel-' + id);
  if (panel) panel.classList.add('open');
}

function tog(el) {
  el.classList.toggle('on');
}

function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  $$('.faq-item').forEach(i => {
    i.classList.remove('open');
    const s = i.querySelector('.faq-q span');
    if (s) s.textContent = '+';
  });
  if (!isOpen) {
    item.classList.add('open');
    btn.querySelector('span').textContent = '−';
  }
}

function revealOnScroll() {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('in');
    });
  }, { threshold: .12 });
  $$('.reveal').forEach(el => obs.observe(el));
}

function drawTopologyBg() {
  const root = $('#topology-bg');
  if (!root) return;
  const nodes = [
    [140,120,4], [320,210,3], [520,120,4], [780,170,3], [1040,100,4], [1260,220,3],
    [190,440,3], [420,540,4], [690,420,3], [960,520,4], [1240,470,3],
    [260,820,4], [580,910,3], [860,790,4], [1140,890,3]
  ];
  const lines = [[0,1],[1,2],[2,3],[3,4],[4,5],[1,6],[6,7],[7,8],[8,9],[9,10],[7,11],[11,12],[12,13],[13,14],[8,13],[3,8],[5,10]];
  const defs = svg('defs', {}, root);
  const grad = svg('linearGradient', { id:'bgLine', x1:'0%', y1:'0%', x2:'100%', y2:'0%' }, defs);
  svg('stop', { offset:'0%', 'stop-color':'rgba(26,86,255,0)' }, grad);
  svg('stop', { offset:'50%', 'stop-color':'rgba(26,86,255,.34)' }, grad);
  svg('stop', { offset:'100%', 'stop-color':'rgba(26,86,255,0)' }, grad);
  const g = svg('g', { opacity: '.46' }, root);
  lines.forEach(([a,b], idx) => {
    const A = nodes[a], B = nodes[b];
    const path = svg('path', {
      d: `M${A[0]},${A[1]} C${(A[0]+B[0])/2},${A[1]} ${(A[0]+B[0])/2},${B[1]} ${B[0]},${B[1]}`,
      fill:'none', stroke:'url(#bgLine)', 'stroke-width': idx % 3 === 0 ? '1.2' : '.8', opacity: '.55'
    }, g);
    path.style.strokeDasharray = '7 10';
    path.style.animation = `dashMove ${18 + idx}s linear infinite`;
  });
  nodes.forEach(([x,y,r], idx) => {
    svg('circle', { cx:x, cy:y, r:r+9, fill:'rgba(26,86,255,.04)' }, g);
    svg('circle', { cx:x, cy:y, r, fill:'rgba(26,86,255,.34)' }, g);
  });
  const style = document.createElement('style');
  style.textContent = `@keyframes dashMove { to { stroke-dashoffset: -220; } }`;
  document.head.appendChild(style);
}

function drawHeroMap() {
  const root = $('#hero-map');
  if (!root) return;
  const defs = svg('defs', {}, root);
  const glow = svg('filter', { id:'softGlow', x:'-30%', y:'-30%', width:'160%', height:'160%' }, defs);
  svg('feGaussianBlur', { stdDeviation:'4', result:'blur' }, glow);
  const merge = svg('feMerge', {}, glow);
  svg('feMergeNode', { in:'blur' }, merge);
  svg('feMergeNode', { in:'SourceGraphic' }, merge);

  const items = [
    { id: heroMapLabels[0], x:92, y:112, r:38 },
    { id: heroMapLabels[1], x:266, y:76, r:34 },
    { id: heroMapLabels[2], x:410, y:156, r:42 },
    { id: heroMapLabels[3], x:148, y:278, r:36 },
    { id: heroMapLabels[4], x:318, y:254, r:46 },
    { id: heroMapLabels[5], x:238, y:390, r:34 },
    { id: heroMapLabels[6], x:410, y:362, r:40 }
  ];
  const links = [[0,1],[1,2],[0,3],[3,4],[2,4],[4,5],[4,6],[5,6],[1,4]];
  const linkG = svg('g', {}, root);
  const nodeG = svg('g', {}, root);
  links.forEach(([a,b], i) => {
    const A = items[a], B = items[b];
    const p = svg('path', {
      d:`M${A.x},${A.y} C${(A.x+B.x)/2},${A.y} ${(A.x+B.x)/2},${B.y} ${B.x},${B.y}`,
      fill:'none', stroke:'rgba(26,86,255,.24)', 'stroke-width':'1.5'
    }, linkG);
    p.style.strokeDasharray = '5 8';
    p.style.animation = `dashMove ${14+i}s linear infinite`;
  });
  items.forEach((n, i) => {
    const group = svg('g', { transform:`translate(${n.x} ${n.y})` }, nodeG);
    svg('circle', { r:n.r+10, fill:'rgba(26,86,255,.055)' }, group);
    svg('circle', { r:n.r, fill:'rgba(255,255,255,.84)', stroke:'rgba(26,86,255,.28)', 'stroke-width':'1.4', filter:'url(#softGlow)' }, group);
    svg('circle', { r:5, fill:'#1a56ff' }, group);
    const text = svg('text', { y:n.r+26, 'text-anchor':'middle', 'font-family':'JetBrains Mono, monospace', 'font-size':'10', 'letter-spacing':'.08em', fill:'rgba(7,17,31,.48)' }, group);
    text.textContent = n.id;
    const ring = svg('circle', { r:n.r + 4, fill:'none', stroke:'rgba(26,86,255,.16)', 'stroke-width':'1' }, group);
    ring.style.transformOrigin = 'center';
    ring.style.animation = `pulseNode ${3.8 + i * .4}s ease-in-out infinite`;
  });
  const style = document.createElement('style');
  style.textContent = `@keyframes pulseNode { 0%,100%{ opacity:.35; transform:scale(1); } 50%{ opacity:.9; transform:scale(1.04); } }`;
  document.head.appendChild(style);
}

function drawMiniMap(id, variant) {
  const root = $('#' + id);
  if (!root) return;
  const nodesByVariant = {
    orientation: [[46,78,miniMapLabels.orientation[0]],[138,48,miniMapLabels.orientation[1]],[138,112,miniMapLabels.orientation[2]],[250,78,miniMapLabels.orientation[3]]],
    scoping: [[38,78,miniMapLabels.scoping[0]],[112,38,miniMapLabels.scoping[1]],[112,118,miniMapLabels.scoping[2]],[198,48,miniMapLabels.scoping[3]],[198,112,miniMapLabels.scoping[4]],[280,78,miniMapLabels.scoping[5]]],
    context: [[52,50,miniMapLabels.context[0]],[52,112,miniMapLabels.context[1]],[150,80,miniMapLabels.context[2]],[252,48,miniMapLabels.context[3]],[252,112,miniMapLabels.context[4]]]
  };
  const data = nodesByVariant[variant] || nodesByVariant.orientation;
  const links = variant === 'orientation' ? [[0,1],[0,2],[1,3],[2,3]] : variant === 'scoping' ? [[0,1],[0,2],[1,3],[2,4],[3,5],[4,5]] : [[0,2],[1,2],[2,3],[2,4]];
  links.forEach(([a,b]) => {
    const A = data[a], B = data[b];
    svg('path', { d:`M${A[0]},${A[1]} C${(A[0]+B[0])/2},${A[1]} ${(A[0]+B[0])/2},${B[1]} ${B[0]},${B[1]}`, fill:'none', stroke:'rgba(26,86,255,.28)', 'stroke-width':'1.4', 'stroke-dasharray':'4 6' }, root);
  });
  data.forEach(([x,y,label]) => {
    const g = svg('g', { transform:`translate(${x} ${y})` }, root);
    svg('circle', { r:'18', fill:'rgba(26,86,255,.08)', stroke:'rgba(26,86,255,.28)' }, g);
    svg('circle', { r:'4', fill:'#1a56ff' }, g);
    const t = svg('text', { y:'36', 'text-anchor':'middle', 'font-family':'JetBrains Mono, monospace', 'font-size':'8.5', fill:'rgba(7,17,31,.42)' }, g);
    t.textContent = label;
  });
}

document.addEventListener('DOMContentLoaded', () => {
  revealOnScroll();
  drawTopologyBg();
  drawHeroMap();
  drawMiniMap('mini-orientation', 'orientation');
  drawMiniMap('mini-scoping', 'scoping');
  drawMiniMap('mini-context', 'context');

  $$('[data-open-path]').forEach(el => {
    el.addEventListener('click', event => {
      const id = el.getAttribute('data-open-path');
      if (!id) return;
      openPath(id);
      const isAnchor = el.tagName === 'A';
      const href = isAnchor ? el.getAttribute('href') || '' : '';
      if (isAnchor && href.startsWith('#')) {
        event.preventDefault();
        const target = document.querySelector(href);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  $$('[data-toggle-tag]').forEach(el => {
    el.addEventListener('click', () => tog(el));
  });

  $$('[data-faq-button]').forEach(btn => {
    btn.addEventListener('click', () => toggleFaq(btn));
  });

  $$('.path-card').forEach(card => {
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const id = card.getAttribute('data-open-path') || card.id.replace('card-', '');
        openPath(id);
      }
    });
  });
});
</script>
</Layout>
