const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
const formInputs = copy.form.inputs as any;
const channelItems = copy.channels.items as any;
---

<Layout metadata={copy.metadata}>
  <HeroText tagline={copy.hero.tagline} title={copy.hero.title} subtitle={copy.hero.subtitle} />

  <ContactUs
    id="form"
    title={copy.form.title}
    subtitle={copy.form.subtitle}
    action="/api/contact"
    tenant="iopartner"
    source="iopartner-contact-context"
    button={copy.form.button}
    inputs={formInputs}
    textarea={copy.form.textarea}
    disclaimer={{ label: copy.form.disclaimer }}
    description={copy.form.description}
  />

  <Features2 title={copy.channels.title} subtitle={copy.channels.subtitle} items={channelItems} />
</Layout>
