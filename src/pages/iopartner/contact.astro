  <script is:inline define:vars={{ validation: copy.validation }}>
    (() => {
      const bind = () => {
        const form = document.querySelector('[data-qualification-form]');
        const scrollButton = document.querySelector('[data-scroll-qualification]');

        if (scrollButton && scrollButton.dataset.bound !== '1') {
          scrollButton.dataset.bound = '1';
          scrollButton.addEventListener('click', () => {
            form?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            const firstField = form?.querySelector('input, select, textarea');
            window.setTimeout(() => firstField?.focus({ preventScroll: true }), 320);
          });
        }

        if (!form || form.dataset.validationBound === '1') return;
        form.dataset.validationBound = '1';

        if (form.dataset.presetBound !== '1') {
          form.dataset.presetBound = '1';
          const type = new URLSearchParams(window.location.search).get('type');
          const presets = {
            scoping: 'consulting',
            systems: 'custom_software',
            'web-presence': 'standard_website',
            'editable-site': 'website_plus',
          };
          const needType = form.querySelector('select[name="need_type"]');
          if (type && presets[type] && needType) {
            needType.value = presets[type];
          }
        }

        const fields = Array.from(form.querySelectorAll('input[required], select[required], textarea[required]'));
        const applyMessage = (field) => {
          field.setCustomValidity('');
          if (field.validity.valueMissing) {
            field.setCustomValidity(validation.required);
          } else if (field.validity.typeMismatch && field.type === 'email') {
            field.setCustomValidity(validation.email);
          }
        };

        fields.forEach((field) => {
          field.addEventListener('invalid', () => applyMessage(field));
          field.addEventListener('input', () => field.setCustomValidity(''));
          field.addEventListener('change', () => field.setCustomValidity(''));
        });

        form.addEventListener('submit', (event) => {
          fields.forEach((field) => applyMessage(field));
          if (!form.checkValidity()) {
            event.preventDefault();
            form.reportValidity();
          }
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bind, { once: true });
      } else {
        bind();
      }
      document.addEventListener('astro:page-load', bind);
    })();
  </script>
