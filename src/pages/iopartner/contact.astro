---
import Layout from '~/layouts/PageLayout.astro';
import { detectRequestLocale } from '~/lib/locale';

const locale = detectRequestLocale(Astro.request, Astro.url);
const t = (fr: string, en: string, de: string, it: string) =>
  (locale === 'en' ? en : locale === 'de' ? de : locale === 'it' ? it : fr);

const emailSubject = t('Contexte IOPartner', 'IOPartner context', 'IOPartner Kontext', 'Contesto IOPartner');
const heroMapLabels = [
  t('Site', 'Website', 'Website', 'Sito'),
  t('Accès', 'Access', 'Zugänge', 'Accessi'),
  t('Infra', 'Infra', 'Infra', 'Infra'),
  t('Docs', 'Docs', 'Docs', 'Docs'),
  t('Workflows', 'Workflows', 'Workflows', 'Workflow'),
  t('Backups', 'Backups', 'Backups', 'Backup'),
  t('Décision', 'Decision', 'Entscheidung', 'Decisione'),
];
const miniMapLabels = {
  orientation: [
    t('Question', 'Question', 'Frage', 'Domanda'),
    t('Options', 'Options', 'Optionen', 'Opzioni'),
    t('Risque', 'Risk', 'Risiko', 'Rischio'),
    t('Décision', 'Decision', 'Entscheidung', 'Decisione'),
  ],
  scoping: [
    t('Actuel', 'Now', 'Jetzt', 'Attuale'),
    t('Outils', 'Tools', 'Tools', 'Strumenti'),
    t('Équipe', 'People', 'Team', 'Persone'),
    t('Risques', 'Risks', 'Risiken', 'Rischi'),
    t('Scope', 'Scope', 'Scope', 'Scope'),
    t('Plan', 'Plan', 'Plan', 'Piano'),
  ],
  context: [
    t('Web', 'Web', 'Web', 'Web'),
    t('Ops', 'Ops', 'Ops', 'Ops'),
    t('Route', 'Route', 'Route', 'Route'),
    t('15 min', '15 min', '15 Min', '15 min'),
    t('1 h', '1 h', '1 h', '1 h'),
  ],
};
---

<Layout
  metadata={{
    title: t('Contact — IOPartner', 'Contact — IOPartner', 'Kontakt — IOPartner', 'Contatto — IOPartner'),
    description: t(
      'Choisissez le bon point d entrée pour le cadrage technique, la clarté opérationnelle ou un projet web/système cadré.',
      'Choose the right entry point for technical scoping, operational clarity, or a structured web/system project.',
      'Wählen Sie den richtigen Einstieg für technisches Scoping, operative Klarheit oder ein sauber gerahmtes Web-/Systemprojekt.',
      'Scegliete il giusto punto di ingresso per l inquadramento tecnico, la chiarezza operativa o un progetto web/sistema ben definito.'
    ),
  }}
>
<style>
/* ═══════════════════════════════════════════════
   IOPARTNER CONTACT — LIGHT MODE REDESIGN
   Calm Swiss operational trust + subtle topology
═══════════════════════════════════════════════ */

:root {
  --paper: #f7f9fc;
  --paper-2: #ffffff;
  --paper-3: #eef3fb;
  --ink: #07111f;
  --ink-2: rgba(7,17,31,.72);
  --ink-3: rgba(7,17,31,.52);
  --ink-4: rgba(7,17,31,.34);
  --blue: #1a56ff;
  --blue-2: #0d3fd1;
  --blue-soft: rgba(26,86,255,.08);
  --blue-soft-2: rgba(26,86,255,.13);
  --blue-line: rgba(26,86,255,.22);
  --green: #16a34a;
  --amber: #c87900;
  --border: rgba(7,17,31,.09);
  --border-strong: rgba(7,17,31,.16);
  --shadow: 0 24px 70px rgba(16,30,54,.10);
  --shadow-soft: 0 14px 40px rgba(16,30,54,.08);
  --radius: 24px;
  --radius-sm: 14px;
  --sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
  --max: 1180px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
:global(html) { scroll-behavior: smooth; background: var(--paper) !important; color: var(--ink); }
:global(body),
:global(body.brand-iopartner) {
  font-family: var(--sans);
  background:
    radial-gradient(circle at 10% 0%, rgba(26,86,255,.10), transparent 34%),
    linear-gradient(180deg, #ffffff 0%, var(--paper) 42%, #f3f7fd 100%) !important;
  background-color: var(--paper) !important;
  color: var(--ink) !important;
  font-size: 15px;
  line-height: 1.65;
  overflow-x: hidden;
}
a { color: inherit; text-decoration: none; }
button, input, textarea, select { font: inherit; }
::selection { background: var(--blue); color: white; }

/* ═══════════════════════════════════════════════
   BACKGROUND SYSTEM
═══════════════════════════════════════════════ */
.bg-system {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: -1;
  opacity: .82;
}
.bg-system::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(26,86,255,.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(26,86,255,.045) 1px, transparent 1px);
  background-size: 36px 36px;
  mask-image: linear-gradient(180deg, black 0%, transparent 72%);
}
.bg-system::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 85% 12%, rgba(26,86,255,.10), transparent 26%),
    radial-gradient(circle at 15% 76%, rgba(26,86,255,.06), transparent 32%);
}
#topology-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* ═══════════════════════════════════════════════
   UTILITIES
═══════════════════════════════════════════════ */
.wrap { max-width: var(--max); margin: 0 auto; padding: 0 28px; }
.kicker {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--blue);
  font-weight: 600;
}
.kicker::before {
  content: '';
  width: 26px;
  height: 1px;
  background: var(--blue);
}
.h2 {
  margin-top: 16px;
  font-size: clamp(32px, 4vw, 54px);
  line-height: 1.02;
  letter-spacing: -.045em;
  font-weight: 800;
}
.lead {
  color: var(--ink-2);
  font-size: 17px;
  line-height: 1.75;
  max-width: 690px;
}
.mono {
  font-family: var(--mono);
  letter-spacing: .04em;
}
.pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.72);
  border-radius: 999px;
  padding: 8px 13px;
  font-size: 12px;
  color: var(--ink-3);
  backdrop-filter: blur(10px);
}
.pill-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: var(--green);
  box-shadow: 0 0 0 4px rgba(22,163,74,.10);
}
.reveal {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity .7s ease, transform .7s cubic-bezier(.2,1,.2,1);
}
.reveal.in { opacity: 1; transform: none; }

/* ═══════════════════════════════════════════════
   NAV
═══════════════════════════════════════════════ */
.nav-shell {
  position: sticky;
  top: 0;
  z-index: 80;
  border-bottom: 1px solid rgba(7,17,31,.07);
  background: rgba(255,255,255,.78);
  backdrop-filter: blur(18px);
}
.nav {
  height: 68px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}
.logo {
  display: inline-flex;
  align-items: center;
  gap: 11px;
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: .04em;
  font-weight: 600;
}
.logo-mark {
  width: 30px;
  height: 30px;
  display: block;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 26px;
}
.nav-links a {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .13em;
  text-transform: uppercase;
  color: var(--ink-4);
  transition: color .18s ease;
}
.nav-links a:hover { color: var(--blue); }
.nav-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--ink);
  color: white;
  padding: 10px 17px;
  border-radius: 999px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  transition: transform .18s ease, background .18s ease;
}
.nav-cta:hover { transform: translateY(-1px); background: var(--blue); }
.mobile-menu { display: none; }

/* ═══════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════ */
.hero {
  position: relative;
  padding: 88px 0 62px;
}
.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(420px, .95fr);
  gap: 58px;
  align-items: center;
}
.hero-copy { position: relative; z-index: 2; }
.hero-status {
  margin-bottom: 26px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.hero h1 {
  font-size: clamp(46px, 6.7vw, 84px);
  line-height: .94;
  letter-spacing: -.065em;
  font-weight: 860;
  max-width: 780px;
}
.hero h1 span { color: var(--blue); }
.hero .lead {
  margin-top: 28px;
  max-width: 620px;
}
.hero-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 34px;
}
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  border: 1px solid transparent;
  border-radius: 999px;
  padding: 14px 22px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  font-weight: 600;
  transition: transform .18s ease, box-shadow .18s ease, background .18s ease, border-color .18s ease;
  cursor: pointer;
}
.btn:hover { transform: translateY(-2px); }
.btn-primary {
  background: var(--blue);
  color: white;
  box-shadow: 0 16px 38px rgba(26,86,255,.20);
}
.btn-primary:hover { background: var(--blue-2); box-shadow: 0 18px 44px rgba(26,86,255,.25); }
.btn-secondary {
  background: rgba(255,255,255,.76);
  border-color: var(--border);
  color: var(--ink);
}
.btn-secondary:hover { border-color: var(--blue-line); background: white; }
.hero-note {
  margin-top: 18px;
  color: var(--ink-3);
  font-size: 13px;
  max-width: 520px;
}

/* ═══════════════════════════════════════════════
   HERO VISUAL — calm operating map
═══════════════════════════════════════════════ */
.visual-card {
  position: relative;
  min-height: 760px;
  border-radius: 34px;
  background:
    linear-gradient(180deg, rgba(255,255,255,.92), rgba(247,249,252,.84)),
    radial-gradient(circle at 70% 8%, rgba(26,86,255,.13), transparent 38%);
  border: 1px solid rgba(7,17,31,.08);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.visual-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(26,86,255,.16) 1px, transparent 1px);
  background-size: 22px 22px;
  opacity: .45;
  mask-image: radial-gradient(circle at 50% 46%, black 0%, transparent 72%);
}
.visual-topbar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  border-bottom: 1px solid var(--border);
  background: rgba(255,255,255,.62);
  backdrop-filter: blur(10px);
  z-index: 2;
}
.visual-topbar span {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--ink-4);
}
.status-lights { display: flex; gap: 7px; }
.status-lights i {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--blue-line);
}
.visual-map {
  position: absolute;
  inset: 72px 24px 228px;
  width: calc(100% - 48px);
  height: calc(100% - 300px);
}
.visual-panel {
  position: absolute;
  left: 24px;
  right: 24px;
  bottom: 24px;
  background: rgba(255,255,255,.78);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 18px;
  backdrop-filter: blur(14px);
  z-index: 3;
  box-shadow: var(--shadow-soft);
}
.visual-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 14px;
}
.visual-panel-title {
  font-size: 16px;
  font-weight: 750;
  letter-spacing: -.02em;
}
.visual-panel-meta {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .09em;
  text-transform: uppercase;
  color: var(--blue);
}
.visual-rows {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}
.visual-row {
  min-height: 82px;
  border: 1px solid var(--border);
  border-radius: 16px;
  background: rgba(247,249,252,.82);
  padding: 13px;
}
.visual-row b {
  display: block;
  font-size: 13px;
  letter-spacing: -.01em;
}
.visual-row span {
  display: block;
  margin-top: 7px;
  font-size: 12px;
  line-height: 1.45;
  color: var(--ink-3);
}

/* ═══════════════════════════════════════════════
   TRUST STRIP
═══════════════════════════════════════════════ */
.trust-strip {
  padding: 24px 0 70px;
}
.trust-box {
  border: 1px solid var(--border);
  background: rgba(255,255,255,.72);
  border-radius: 28px;
  padding: 18px;
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(14px);
}
.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.trust-item {
  padding: 18px 18px;
  border-right: 1px solid var(--border);
}
.trust-item:last-child { border-right: none; }
.trust-item .num {
  display: block;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .14em;
  color: var(--blue);
  margin-bottom: 7px;
}
.trust-item b {
  display: block;
  font-size: 15px;
  letter-spacing: -.015em;
}
.trust-item p {
  color: var(--ink-3);
  font-size: 13px;
  margin-top: 6px;
}

/* ═══════════════════════════════════════════════
   SECTIONS
═══════════════════════════════════════════════ */
.section { padding: 72px 0; }
.section-head {
  display: grid;
  grid-template-columns: .78fr 1fr;
  gap: 46px;
  align-items: end;
  margin-bottom: 34px;
}
.section-head .lead { margin-bottom: 4px; }

/* ═══════════════════════════════════════════════
   TYPICAL SITUATIONS
═══════════════════════════════════════════════ */
.situation-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}
.situation-card {
  position: relative;
  background: rgba(255,255,255,.74);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 24px;
  min-height: 210px;
  box-shadow: 0 10px 28px rgba(16,30,54,.045);
  overflow: hidden;
  transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
}
.situation-card:hover {
  transform: translateY(-3px);
  border-color: var(--blue-line);
  box-shadow: var(--shadow-soft);
}
.situation-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 24px;
  right: 24px;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--blue), transparent);
  opacity: .46;
}
.situation-card .icon {
  width: 40px;
  height: 40px;
  display: grid;
  place-items: center;
  border-radius: 13px;
  background: var(--blue-soft);
  color: var(--blue);
  margin-bottom: 18px;
}
.situation-card h3 {
  font-size: 18px;
  letter-spacing: -.025em;
  line-height: 1.2;
  margin-bottom: 10px;
}
.situation-card p {
  color: var(--ink-2);
  font-size: 14px;
  line-height: 1.65;
}

/* ═══════════════════════════════════════════════
   ROUTING / CONTACT CARDS
═══════════════════════════════════════════════ */
.routing-area {
  padding: 86px 0;
  position: relative;
}
.routing-shell {
  background: rgba(255,255,255,.78);
  border: 1px solid var(--border);
  border-radius: 34px;
  box-shadow: var(--shadow);
  overflow: hidden;
}
.routing-intro {
  padding: 34px;
  display: grid;
  grid-template-columns: .86fr 1fr;
  gap: 34px;
  border-bottom: 1px solid var(--border);
  background:
    radial-gradient(circle at 95% 0%, rgba(26,86,255,.10), transparent 34%),
    rgba(255,255,255,.64);
}
.routing-intro h2 {
  font-size: clamp(30px, 3.4vw, 48px);
  line-height: 1.04;
  letter-spacing: -.045em;
  font-weight: 820;
}
.routing-intro p {
  color: var(--ink-2);
  font-size: 16px;
  max-width: 620px;
}
.path-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
}
.path-card {
  position: relative;
  min-height: 360px;
  background: rgba(255,255,255,.95);
  padding: 30px;
  cursor: pointer;
  transition: background .18s ease, box-shadow .18s ease;
  overflow: hidden;
}
.path-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--blue-soft), transparent 48%);
  opacity: 0;
  transition: opacity .22s ease;
}
.path-card:hover::after,
.path-card.active::after { opacity: 1; }
.path-card.active {
  background: #f8fbff;
  box-shadow: inset 0 0 0 2px var(--blue);
  z-index: 2;
}
.path-content { position: relative; z-index: 2; }
.path-label {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .13em;
  text-transform: uppercase;
  color: var(--blue);
  font-weight: 600;
}
.path-title {
  margin-top: 20px;
  font-size: 24px;
  line-height: 1.08;
  letter-spacing: -.035em;
  font-weight: 800;
}
.path-price {
  margin-top: 20px;
  font-size: 42px;
  line-height: 1;
  letter-spacing: -.05em;
  font-weight: 850;
  color: var(--ink);
}
.path-price span {
  display: block;
  margin-top: 8px;
  color: var(--ink-3);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .06em;
  font-weight: 500;
}
.path-copy {
  margin-top: 20px;
  color: var(--ink-2);
  font-size: 14px;
  max-width: 330px;
}
.path-best {
  margin-top: 24px;
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}
.path-best span {
  display: inline-flex;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.68);
  color: var(--ink-3);
  border-radius: 999px;
  padding: 6px 9px;
  font-size: 11px;
}
.path-icon {
  position: absolute;
  right: 24px;
  bottom: 20px;
  width: 96px;
  height: 96px;
  opacity: .14;
  color: var(--blue);
}

/* ═══════════════════════════════════════════════
   FORM PANEL
═══════════════════════════════════════════════ */
.form-panel {
  display: none;
  border-top: 1px solid var(--border);
  background:
    linear-gradient(180deg, rgba(255,255,255,.96), rgba(248,251,255,.94));
}
.form-panel.open { display: block; }
.form-inner {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 360px;
  gap: 42px;
  padding: 38px 34px 34px;
}
.form-head {
  margin-bottom: 28px;
}
.selected-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 11px;
  border-radius: 999px;
  background: var(--blue-soft);
  border: 1px solid var(--blue-line);
  color: var(--blue);
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .11em;
  text-transform: uppercase;
  font-weight: 600;
}
.selected-badge::before {
  content: '';
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--blue);
}
.form-title {
  margin-top: 18px;
  font-size: 30px;
  letter-spacing: -.035em;
  line-height: 1.1;
  font-weight: 820;
}
.form-subtitle {
  margin-top: 10px;
  color: var(--ink-2);
  max-width: 620px;
}
.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.field { margin-bottom: 16px; }
.field label {
  display: block;
  margin-bottom: 7px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--ink-4);
  font-weight: 600;
}
.field input,
.field textarea,
.field select {
  width: 100%;
  border: 1px solid var(--border-strong);
  border-radius: 14px;
  background: white;
  padding: 13px 14px;
  outline: none;
  color: var(--ink);
  transition: border-color .18s ease, box-shadow .18s ease, background .18s ease;
}
.field textarea { min-height: 116px; resize: vertical; }
.field input:focus,
.field textarea:focus,
.field select:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 4px rgba(26,86,255,.10);
}
.field input::placeholder,
.field textarea::placeholder { color: rgba(7,17,31,.30); }
.hint {
  margin-top: 6px;
  color: var(--ink-4);
  font-size: 12px;
}
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
