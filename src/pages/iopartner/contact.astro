const formStartedAt = Date.now();
---

<Layout metadata={copy.metadata}>
  <div class="io-discovery">
    <section class="io-band io-hero">
      <div class="io-shell io-hero-grid">
        <div class="io-hero-copy">
          <p class="io-kicker">{copy.kicker}</p>
          <h1>{copy.title}</h1>
          <p>{copy.lead}</p>
          <div class="io-actions">
            <button class="io-btn io-btn-primary" type="button" data-scroll-qualification>{copy.primary}</button>
            <a class="io-btn io-btn-secondary" href={`${localePrefix}/pricing`}>{copy.secondary}</a>
          </div>
        </div>
        <aside class="io-hero-panel" aria-label={copy.nextTitle}>
          <span>IOP · CH</span>
          <strong>{copy.panelTitle}</strong>
          <p>{copy.privacy}</p>
        </aside>
      </div>
    </section>

    {
      submitted && (
        <section class="io-shell io-success" role="status">
          <strong>{copy.success.title}</strong>
          <p>{copy.success.body}</p>
        </section>
      )
    }

    <section class="io-band io-principles-band" aria-label={copy.nextTitle}>
      <div class="io-shell">
        <div class="io-principles">
          {
            copy.principles.map(([title, body], index) => (
              <article>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <h2>{title}</h2>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="io-band io-form-band">
      <div class="io-shell io-form-wrap">
        <form class="io-form" method="POST" action="/api/contact" data-qualification-form>
          <input type="hidden" name="tenant" value="iopartner" />
          <input type="hidden" name="source" value="iopartner-discovery" />
          <input type="hidden" name="locale" value={locale} />
          <input type="hidden" name="message" value="Demande de qualification IOPartner" />
          <input type="hidden" name="form_started_at" value={formStartedAt} />
          <label class="io-honeypot" aria-hidden="true">
            Website
            <input name="website_url" type="text" tabindex="-1" autocomplete="off" />
          </label>

          <div class="io-form-head">
            <p class="io-kicker">{copy.formTitle}</p>
            <h2>{copy.formTitle}</h2>
            <p>{copy.formLead}</p>
          </div>

          <div class="io-fields two">
            <label>
              <span>{copy.fields.name}</span>
              <input name="name" type="text" required autocomplete="name" />
            </label>
            <label>
              <span>{copy.fields.email}</span>
              <input name="email" type="email" required autocomplete="email" />
            </label>
            <label>
              <span>{copy.fields.company}</span>
              <input name="company" type="text" placeholder={copy.placeholders.company} autocomplete="organization" />
            </label>
            <label>
              <span>{copy.fields.role}</span>
              <input name="role" type="text" placeholder={copy.placeholders.role} />
            </label>
          </div>

          <div class="io-fields">
            <label>
              <span>{copy.fields.needType}</span>
              <select name="need_type" required>
                {copy.options.needTypes.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
            <label>
              <span>{copy.fields.objective}</span>
              <textarea name="objective" rows="3" required placeholder={copy.placeholders.objective}></textarea>
            </label>
            <label>
              <span>{copy.fields.problem}</span>
              <textarea name="problem" rows="4" required placeholder={copy.placeholders.problem}></textarea>
            </label>
          </div>

          <div class="io-fields two">
            <label>
              <span>{copy.fields.whyNow}</span>
              <textarea name="why_now" rows="3" placeholder={copy.placeholders.whyNow}></textarea>
            </label>
            <label>
              <span>{copy.fields.tried}</span>
              <textarea name="already_tried" rows="3" placeholder={copy.placeholders.tried}></textarea>
            </label>
            <label>
              <span>{copy.fields.budget}</span>
              <select name="budget" required>
                {copy.options.budgets.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
            <label>
              <span>{copy.fields.timeline}</span>
              <select name="timeline" required>
                {copy.options.timelines.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
            <label>
              <span>{copy.fields.decisionMaker}</span>
              <select name="decision_maker" required>
                {copy.options.decisions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
