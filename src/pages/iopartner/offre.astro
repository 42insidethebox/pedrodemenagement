    scopeNeed: 'Cadrer le besoin',
    beforeKicker: 'Avant de démarrer',
    beforeTitle: 'Envoyez le contexte si vous hésitez.',
    beforeBody:
      'Si le standard suffit, nous vous le dirons. Si le sujet mérite un cadrage technique, nous proposerons le bon point d’entrée.',
    form: {
      error: 'Merci de vérifier les informations et de réessayer.',
      name: 'Prénom et nom',
      phone: 'Téléphone',
      email: 'Email',
      sector: 'Activité / secteur',
      sectorPh: 'Ex. fiduciaire, artisan, thérapeute...',
      submit: 'Envoyer le contexte',
