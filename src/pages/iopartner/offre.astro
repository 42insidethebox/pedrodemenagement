      sector: 'Tätigkeit / Branche',
      sectorPh: 'Z. B. Treuhand, Handwerk, Therapeut...',
      submit: 'Kontext senden',
    },
  },
  it: {
    metadata: {
      title: 'Presenza web strutturata — IOPartner',
      description:
        'Presenza web IOPartner: sito vetrina professionale da CHF 999, con perimetro chiaro e soglia verso soluzione editabile o deployment dedicato.',
    },
    kicker: 'Presenza web strutturata',
    heroTitle: 'Un sito vetrina professionale, senza trasformare un bisogno semplice in un grande progetto.',
    heroBody:
      'Questo formato standard funziona quando l’obiettivo è chiaro: presentare l’attività, rassicurare, generare contatti e mettere online rapidamente una base mantenibile, senza complessità editoriale pesante.',
    start: 'Qualificare il bisogno',
    contextFirst: 'Vedere i prezzi',
    strip: [
      ['CHF 999', 'Pagamento unico'],
      ['3-5 giorni', 'Tempo tipico dopo i contenuti'],
      ['Fatturato in Svizzera', 'Trasparente, senza costi nascosti'],
    ],
    includedKicker: 'Incluso',
    includedTitle: 'Una baseline pulita per partire.',
    includes: [
      'Sito vetrina in 5 sezioni',
      'Design responsive',
      'Contenuti forniti dal cliente integrati',
      'Modulo semplice o contatto base',
      'Deploy su infrastruttura condivisa IOPartner',
    ],
    infraNote:
      'Infrastruttura leggera condivisa con separazione logica. Contenuti e media possono essere restituiti. Migrazione o deployment dedicato vengono scoped separatamente.',
    notEnoughKicker: 'Quando lo standard non basta',
    notEnoughTitle: 'A quel punto si passa a editabile, scoping o dedicato.',
    notEnoughBody:
      'Avete bisogno di modificare spesso i contenuti, gestire novità, avere una base privata, integrazioni, automazione o infrastruttura dedicata? Questi temi vengono definiti a parte per evitare custom finto.',
    scopeNeed: 'Definire il bisogno',
    beforeKicker: 'Prima di iniziare',
    beforeTitle: 'Invia il contesto se hai dubbi.',
    beforeBody:
      'Se basta il percorso standard, lo diremo. Se il tema merita un inquadramento tecnico, proporremo il punto d’ingresso giusto.',
    form: {
      error: 'Verifica i dati e riprova.',
      name: 'Nome e cognome',
      phone: 'Telefono',
      email: 'Email',
      sector: 'Attività / settore',
      sectorPh: 'Es. fiduciaria, artigiano, terapista...',
      submit: 'Invia il contesto',
    },
  },
} as const;

const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
---

<Layout metadata={copy.metadata}>
  <main class="io-offer">
    <section class="io-shell io-hero">
      <div>
        <p class="io-kicker">{copy.kicker}</p>
        <h1>{copy.heroTitle}</h1>
        <p>{copy.heroBody}</p>
        <div class="io-actions">
          <a class="io-btn io-btn-primary" href="#form">{copy.start}</a>
          <a class="io-btn io-btn-secondary" href={`${localePrefix}/pricing`}>{copy.contextFirst}</a>
        </div>
      </div>
      <IoBlueprintVisual variant="standard" />
    </section>

    <section class="io-shell io-strip">
      {
        copy.strip.map(([strong, text]) => (
          <div>
            <strong>{strong}</strong>
            <span>{text}</span>
          </div>
        ))
      }
    </section>

    <section class="io-shell io-scope">
      <article>
        <p class="io-kicker">{copy.includedKicker}</p>
        <h2>{copy.includedTitle}</h2>
        <ul>
          {copy.includes.map((item) => <li>{item}</li>)}
        </ul>
        <p>{copy.infraNote}</p>
      </article>
      <article class="io-dark-panel">
        <p class="io-kicker">{copy.notEnoughKicker}</p>
        <h2>{copy.notEnoughTitle}</h2>
        <p>{copy.notEnoughBody}</p>
        <a class="io-btn io-btn-light" href={contextUrl}>{copy.scopeNeed}</a>
      </article>
    </section>

    <section class="io-shell io-form-section" id="form">
      <div>
        <p class="io-kicker">{copy.beforeKicker}</p>
        <h2>{copy.beforeTitle}</h2>
        <p>{copy.beforeBody}</p>
      </div>

      <form method="POST" action="/api/contact" class="io-form">
        {error && <p class="io-error">{copy.form.error}</p>}
        <input type="hidden" name="tenant" value="iopartner" />
        <input type="hidden" name="source" value="standard-deployment-offer" />
        <input type="hidden" name="locale" value={locale} />
        <input type="hidden" name="message" value="Demande de qualification pour une présence web cadrée" />
        <input type="hidden" name="need_type" value="standard_website" />
        <input type="hidden" name="budget" value="1000_1500" />
        <input type="hidden" name="form_started_at" value={formStartedAt} />
        <input type="hidden" name="utm_source" value={Astro.url.searchParams.get('utm_source') || ''} />
        <input type="hidden" name="utm_campaign" value={Astro.url.searchParams.get('utm_campaign') || ''} />
        <label class="io-honeypot" aria-hidden="true">
          Website
          <input name="website_url" type="text" tabindex="-1" autocomplete="off" />
        </label>
        <label>
          {copy.form.name}
          <input name="name" type="text" required />
        </label>
        <label>
          {copy.form.phone}
          <input name="telephone" type="tel" required />
        </label>
        <label>
          {copy.form.email}
          <input name="email" type="email" />
        </label>
        <label>
          {copy.form.sector}
          <input name="company" type="text" placeholder={copy.form.sectorPh} />
        </label>
        <button type="submit" class="io-btn io-btn-primary">{copy.form.submit}</button>
      </form>
    </section>
  </main>

  <style>
    .io-offer {
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-line: rgba(148, 163, 184, 0.22);
      --io-blue: #0b63f6;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px), #f8fbff;
      background-size:
        34px 34px,
        34px 34px,
        100% 100%;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 84rem);
      margin-inline: auto;
    }

    .io-hero,
    .io-scope,
    .io-form-section {
      display: grid;
      grid-template-columns: minmax(0, 0.88fr) minmax(26rem, 1fr);
      gap: 3rem;
      align-items: center;
    }

    .io-hero {
      padding: 5rem 0;
    }

    h1,
    h2 {
      margin: 0;
      font-weight: 850;
      line-height: 1.05;
    }

    h1 {
      max-width: 48rem;
      font-size: 4rem;
    }

    h2 {
      font-size: 2.7rem;
    }

    p {
      color: var(--io-muted);
      font-size: 1.1rem;
      line-height: 1.72;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 2rem;
    }

    .io-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3rem;
      border: 0;
      border-radius: 999px;
      padding: 0.78rem 1.35rem;
      font-weight: 780;
      text-decoration: none;
      cursor: pointer;
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      color: var(--io-ink);
      background: rgba(255, 255, 255, 0.72);
    }

    .io-btn-light {
      border: 1px solid rgba(226, 232, 240, 0.34);
      color: #f8fafc;
      background: rgba(255, 255, 255, 0.04);
    }

    .io-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      margin-bottom: 4.5rem;
      overflow: hidden;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.78);
    }

    .io-strip div {
      display: grid;
      gap: 0.35rem;
      padding: 1.4rem;
    }

    .io-strip div + div {
      border-left: 1px solid var(--io-line);
    }

    .io-strip strong {
      font-size: 1.2rem;
    }

    .io-strip span {
      color: var(--io-muted);
    }

    .io-scope {
      align-items: stretch;
      padding-bottom: 5rem;
    }

    .io-scope article,
    .io-form {
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 2rem;
      background: rgba(255, 255, 255, 0.82);
    }

    .io-scope ul {
      display: grid;
      gap: 0.85rem;
      margin: 1.5rem 0 0;
      padding: 0;
      list-style: none;
    }

    .io-scope li {
      color: #334155;
      font-weight: 720;
    }

    .io-dark-panel {
      background: #061120 !important;
      color: #fff;
    }

    .io-dark-panel h2 {
      color: #fff;
    }

    .io-dark-panel p {
      color: #cbd5e1;
    }

    .io-form-section {
      align-items: start;
      padding-bottom: 6rem;
    }

    .io-form {
      display: grid;
      gap: 1rem;
    }

    .io-form label {
      display: grid;
      gap: 0.45rem;
      color: #334155;
      font-weight: 720;
    }

    .io-honeypot {
      position: absolute;
      left: -10000px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .io-form input {
      width: 100%;
      border: 1px solid rgba(148, 163, 184, 0.34);
      border-radius: 0.75rem;
      padding: 0.9rem 1rem;
      color: var(--io-ink);
      background: #fff;
    }

    .io-error {
      margin: 0;
      border: 1px solid rgba(239, 68, 68, 0.25);
      border-radius: 0.75rem;
      padding: 0.85rem;
      color: #991b1b;
      background: #fef2f2;
      font-size: 0.92rem;
    }

    @media (max-width: 1000px) {
      .io-hero,
      .io-scope,
      .io-form-section {
        grid-template-columns: 1fr;
      }

      .io-strip {
        grid-template-columns: 1fr;
      }

      .io-strip div + div {
        border-left: 0;
        border-top: 1px solid var(--io-line);
      }
    }

    @media (max-width: 640px) {
      .io-shell {
        width: min(100% - 1rem, 84rem);
      }

      h1 {
        font-size: 2.55rem;
      }

      h2 {
        font-size: 2rem;
      }

      .io-scope article,
      .io-form {
        padding: 1.2rem;
      }
    }
  </style>
</Layout>
