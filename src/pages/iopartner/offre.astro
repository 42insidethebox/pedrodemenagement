---
import IoBlueprintVisual from '~/components/iopartner/IoBlueprintVisual.astro';
import Layout from '~/layouts/PageLayout.astro';

export const prerender = false;

const error = Astro.url.searchParams.get('error');
const checkoutUrl = '/api/checkout?plan=essential999&template=classic-clean&tenant=iopartner';
---

<Layout
  metadata={{
    title: 'Déploiement standard — IOPartner',
    description:
      'Déploiement standard IOPartner: site vitrine professionnel dès 999 CHF, cadré, facturé en Suisse et livré proprement.',
  }}
>
  <main class="io-offer">
    <section class="io-shell io-hero">
      <div>
        <p class="io-kicker">Déploiement standard</p>
        <h1>Un site vitrine professionnel, sans transformer un besoin simple en gros chantier.</h1>
        <p>
          Le format standard convient quand l’objectif est clair: présenter l’activité, rassurer, générer des contacts
          et mettre en ligne rapidement une base maintenable.
        </p>
        <div class="io-actions">
          <a class="io-btn io-btn-primary" href={checkoutUrl}>Démarrer le projet — 999 CHF</a>
          <a class="io-btn io-btn-secondary" href="#form">Envoyer le contexte d’abord</a>
        </div>
      </div>
      <IoBlueprintVisual variant="standard" />
    </section>

    <section class="io-shell io-strip">
      <div>
        <strong>999 CHF</strong>
        <span>Paiement unique</span>
      </div>
      <div>
        <strong>3-5 jours</strong>
        <span>Délai typique après contenus</span>
      </div>
      <div>
        <strong>Facturé en Suisse</strong>
        <span>Transparent, sans frais cachés</span>
      </div>
    </section>

    <section class="io-shell io-scope">
      <article>
        <p class="io-kicker">Inclus</p>
        <h2>Une baseline propre pour démarrer.</h2>
        <ul>
          <li>Site vitrine 5 sections</li>
          <li>Design responsive</li>
          <li>Contenu fourni intégré</li>
          <li>Formulaire ou contact simple</li>
          <li>Déploiement sur infrastructure mutualisée IOPartner</li>
        </ul>
      </article>
      <article class="io-dark-panel">
        <p class="io-kicker">Quand le standard ne suffit pas</p>
        <h2>On bascule en consulting ou systems & operations.</h2>
        <p>
          Codebase privée, backend, intégrations, automatisation ou infrastructure dédiée ne sont pas inclus dans le
          standard. Ces sujets sont cadrés séparément pour éviter le faux sur mesure.
        </p>
        <a class="io-btn io-btn-light" href="/contact#form">Cadrer le besoin</a>
      </article>
    </section>

    <section class="io-shell io-form-section" id="form">
      <div>
        <p class="io-kicker">Avant de démarrer</p>
        <h2>Envoyez le contexte si vous hésitez.</h2>
        <p>
          Si le standard suffit, nous vous le dirons. Si le sujet mérite un cadrage technique, nous proposerons le bon
          point d’entrée.
        </p>
      </div>

      <form method="POST" action="/api/iopartner/lead-offre" class="io-form">
        {error && <p class="io-error">Merci de vérifier les informations et de réessayer.</p>}
        <input type="hidden" name="utm_source" value={Astro.url.searchParams.get('utm_source') || ''} />
        <input type="hidden" name="utm_campaign" value={Astro.url.searchParams.get('utm_campaign') || ''} />
        <label>
          Prénom et nom
          <input name="prenom" type="text" required />
        </label>
        <label>
          Téléphone
          <input name="telephone" type="tel" required />
        </label>
        <label>
          Email
          <input name="email" type="email" />
        </label>
        <label>
          Activité / secteur
          <input name="secteur" type="text" placeholder="Ex. fiduciaire, artisan, thérapeute..." />
        </label>
        <button type="submit" class="io-btn io-btn-primary">Envoyer le contexte</button>
      </form>
    </section>
  </main>

  <style>
    .io-offer {
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-line: rgba(148, 163, 184, 0.22);
      --io-blue: #0b63f6;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px), #f8fbff;
      background-size:
        34px 34px,
        34px 34px,
        100% 100%;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 84rem);
      margin-inline: auto;
    }

    .io-hero,
    .io-scope,
    .io-form-section {
      display: grid;
      grid-template-columns: minmax(0, 0.88fr) minmax(26rem, 1fr);
      gap: 3rem;
      align-items: center;
    }

    .io-hero {
      padding: 5rem 0;
    }

    h1,
    h2 {
      margin: 0;
      font-weight: 850;
      line-height: 1.05;
    }

    h1 {
      max-width: 48rem;
      font-size: 4rem;
    }

    h2 {
      font-size: 2.7rem;
    }

    p {
      color: var(--io-muted);
      font-size: 1.1rem;
      line-height: 1.72;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 2rem;
    }

    .io-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3rem;
      border: 0;
      border-radius: 999px;
      padding: 0.78rem 1.35rem;
      font-weight: 780;
      text-decoration: none;
      cursor: pointer;
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      color: var(--io-ink);
      background: rgba(255, 255, 255, 0.72);
    }

    .io-btn-light {
      border: 1px solid rgba(226, 232, 240, 0.34);
      color: #f8fafc;
      background: rgba(255, 255, 255, 0.04);
    }

    .io-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      margin-bottom: 4.5rem;
      overflow: hidden;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.78);
    }

    .io-strip div {
      display: grid;
      gap: 0.35rem;
      padding: 1.4rem;
    }

    .io-strip div + div {
      border-left: 1px solid var(--io-line);
    }

    .io-strip strong {
      font-size: 1.2rem;
    }

    .io-strip span {
      color: var(--io-muted);
    }

    .io-scope {
      align-items: stretch;
      padding-bottom: 5rem;
    }

    .io-scope article,
    .io-form {
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 2rem;
      background: rgba(255, 255, 255, 0.82);
    }

    .io-scope ul {
      display: grid;
      gap: 0.85rem;
      margin: 1.5rem 0 0;
      padding: 0;
      list-style: none;
    }

    .io-scope li {
      color: #334155;
      font-weight: 720;
    }

    .io-dark-panel {
      background: #061120 !important;
      color: #fff;
    }

    .io-dark-panel h2 {
      color: #fff;
    }

    .io-dark-panel p {
      color: #cbd5e1;
    }

    .io-form-section {
      align-items: start;
      padding-bottom: 6rem;
    }

    .io-form {
      display: grid;
      gap: 1rem;
    }

    .io-form label {
      display: grid;
      gap: 0.45rem;
      color: #334155;
      font-weight: 720;
    }

    .io-form input {
      width: 100%;
      border: 1px solid rgba(148, 163, 184, 0.34);
      border-radius: 0.75rem;
      padding: 0.9rem 1rem;
      color: var(--io-ink);
      background: #fff;
    }

    .io-error {
      margin: 0;
      border: 1px solid rgba(239, 68, 68, 0.25);
      border-radius: 0.75rem;
      padding: 0.85rem;
      color: #991b1b;
      background: #fef2f2;
      font-size: 0.92rem;
    }

    @media (max-width: 1000px) {
      .io-hero,
      .io-scope,
      .io-form-section {
        grid-template-columns: 1fr;
      }

      .io-strip {
        grid-template-columns: 1fr;
      }

      .io-strip div + div {
        border-left: 0;
        border-top: 1px solid var(--io-line);
      }
    }

    @media (max-width: 640px) {
      .io-shell {
        width: min(100% - 1rem, 84rem);
      }

      h1 {
        font-size: 2.55rem;
      }

      h2 {
        font-size: 2rem;
      }

      .io-scope article,
      .io-form {
        padding: 1.2rem;
      }
    }
  </style>
</Layout>
