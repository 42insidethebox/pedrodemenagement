---
import IoBlueprintVisual from '~/components/iopartner/IoBlueprintVisual.astro';
import { detectRequestLocale } from '~/lib/locale';
import Layout from '~/layouts/PageLayout.astro';

export const prerender = false;

const error = Astro.url.searchParams.get('error');
const locale = detectRequestLocale(Astro.request, Astro.url);
const localePrefix = ['en', 'de', 'it'].includes(locale) ? `/${locale}` : '';
const contextUrl = `${localePrefix}/contact`;
const formStartedAt = Date.now();

const COPY = {
  fr: {
    metadata: {
      title: 'Présence web cadrée — IOPartner',
      description:
        'Présence web cadrée IOPartner: site vitrine professionnel dès 999 CHF, avec périmètre défini et seuil clair vers administrable ou déploiement dédié.',
    },
    kicker: 'Présence web cadrée',
    heroTitle: 'Un site vitrine professionnel, sans transformer un besoin simple en gros chantier.',
    heroBody:
      'Le format standard convient quand l’objectif est clair: présenter l’activité, rassurer, générer des contacts et mettre en ligne rapidement une base maintenable, sans complexité éditoriale lourde.',
    start: 'Qualifier le besoin',
    contextFirst: 'Voir les tarifs',
    strip: [
      ['999 CHF', 'Paiement unique'],
      ['3-5 jours', 'Délai typique après contenus'],
      ['Facturé en Suisse', 'Transparent, sans frais cachés'],
    ],
    includedKicker: 'Inclus',
