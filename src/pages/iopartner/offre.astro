  },
  en: {
    metadata: {
      title: 'Scoped web presence — IOPartner',
      description:
        'IOPartner scoped web presence: professional showcase site from CHF 999, with clear boundaries and a threshold toward editable or dedicated deployment.',
    },
    kicker: 'Scoped web presence',
    heroTitle: 'A professional showcase site, without turning a simple need into a large project.',
    heroBody:
      'This standard format fits when the objective is clear: present the business, reassure prospects, generate contacts, and launch a maintainable base quickly, without heavy editorial complexity.',
    start: 'Qualify the need',
    contextFirst: 'See pricing',
    strip: [
      ['CHF 999', 'One-time payment'],
      ['3-5 days', 'Typical lead time after content'],
      ['Billed in Switzerland', 'Transparent, with no hidden fees'],
    ],
    includedKicker: 'Included',
    includedTitle: 'A clean baseline to get started.',
    includes: [
      '5-section showcase site',
      'Responsive design',
      'Client-provided content integrated',
      'Simple form or contact setup',
      'Deployment on IOPartner shared infrastructure',
    ],
    infraNote:
      'Light shared infrastructure with logical separation. Content and media can be handed back. Migration or dedicated deployment is scoped separately.',
    notEnoughKicker: 'When the standard is not enough',
    notEnoughTitle: 'Then the path becomes editable, scoped, or dedicated.',
    notEnoughBody:
      'Need to edit content frequently, publish updates, have a private base, integrations, automation, or dedicated infrastructure? Those topics are scoped separately to avoid fake custom work.',
    scopeNeed: 'Scope the need',
    beforeKicker: 'Before starting',
    beforeTitle: 'Send the context if you are unsure.',
    beforeBody:
      'If the standard path is enough, we will say so. If the topic deserves technical scoping, we will propose the right entry point.',
    form: {
      error: 'Please check the information and try again.',
      name: 'Full name',
      phone: 'Phone',
      email: 'Email',
      sector: 'Business / sector',
      sectorPh: 'Example: accounting firm, trades, therapist...',
      submit: 'Send the context',
    },
  },
  de: {
    metadata: {
      title: 'Klar abgegrenzte Web-Präsenz — IOPartner',
      description:
        'IOPartner Web-Präsenz: professionelle Showcase-Website ab CHF 999, mit klarem Umfang und einer Schwelle zu editierbarer oder dedizierter Bereitstellung.',
    },
    kicker: 'Klar abgegrenzte Web-Präsenz',
    heroTitle: 'Eine professionelle Showcase-Website, ohne aus einem einfachen Bedarf ein Grossprojekt zu machen.',
    heroBody:
      'Dieses Standardformat passt, wenn das Ziel klar ist: das Unternehmen präsentieren, Vertrauen schaffen, Kontakte generieren und schnell eine wartbare Basis online bringen, ohne schwere redaktionelle Komplexität.',
    start: 'Bedarf qualifizieren',
    contextFirst: 'Preise ansehen',
    strip: [
      ['CHF 999', 'Einmalige Zahlung'],
      ['3-5 Tage', 'Typischer Zeitraum nach Inhalt'],
      ['In der Schweiz fakturiert', 'Transparent, ohne versteckte Kosten'],
    ],
    includedKicker: 'Inklusive',
    includedTitle: 'Eine saubere Basis für den Start.',
    includes: [
      'Showcase-Website mit 5 Sektionen',
      'Responsives Design',
      'Gelieferte Inhalte integriert',
      'Einfaches Formular oder Kontaktweg',
      'Deployment auf gemeinsamer IOPartner-Infrastruktur',
    ],
    infraNote:
      'Leichte gemeinsame Infrastruktur mit logischer Trennung. Inhalte und Medien können zurückgegeben werden. Migration oder dediziertes Deployment wird separat gescopt.',
    notEnoughKicker: 'Wenn der Standard nicht reicht',
    notEnoughTitle: 'Dann geht es in Richtung editierbar, Scoping oder dediziert.',
    notEnoughBody:
      'Müssen Inhalte häufig geändert werden, News gepflegt werden, eine private Basis, Integrationen, Automatisierung oder dedizierte Infrastruktur entstehen? Diese Themen werden separat gescopt, um falsches Custom zu vermeiden.',
    scopeNeed: 'Bedarf scopen',
    beforeKicker: 'Vor dem Start',
    beforeTitle: 'Senden Sie den Kontext, wenn Sie unsicher sind.',
    beforeBody:
      'Wenn der Standardweg reicht, sagen wir das. Wenn das Thema technisches Scoping verdient, schlagen wir den richtigen Einstieg vor.',
    form: {
      error: 'Bitte prüfen Sie die Angaben und versuchen Sie es erneut.',
      name: 'Vor- und Nachname',
      phone: 'Telefon',
