---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { iopartnerHeaderDataEn, iopartnerFooterDataEn } from '~/navigation';

const metadata = {
  title: 'IOPartner.ch — Fast websites and online presence for the Léman Arc',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata} header={iopartnerHeaderDataEn} footer={iopartnerFooterDataEn}>
  <Hero
    id="process"
    actions={[
      {
        variant: 'primary',
        text: 'Get started — CHF 999',
        href: '/choose-template?plan=essential999',
        icon: 'tabler:arrow-right',
      },
      { text: 'Talk to an expert', href: '/en/contact#form' },
    ]}
    image={{ src: '~/assets/images/light_minimalist.png', alt: 'IOPartner.ch interface' }}
  >
    <Fragment slot="title">Fast, clean websites designed to grow with your business</Fragment>

    <Fragment slot="subtitle">
      IOPartner.ch launches your online presence clearly from CHF 999, then stays with you if the business later needs
      automation, workflows, or more advanced development.
    </Fragment>
  </Hero>

  <Note
    title="Simple start"
    description="A professional website launched quickly, easy to maintain, with extra support available if the business grows."
  />

  <Features
    id="features"
    tagline="Why work with us"
    title="Useful online presence from day one"
    subtitle="Clarity, speed, and guidance to help your business look credible, generate contacts, and stay simple."
    items={[
      {
        title: 'Fast launch',
        description:
          'Brief, integration, and launch within a few business days depending on your content and readiness.',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'Professional image',
        description: 'A clean, reassuring website that helps visitors trust your business from the first visit.',
        icon: 'tabler:sparkles',
      },
      {
        title: 'Contact & bookings',
        description: 'Forms, WhatsApp, Calendly, or simple booking flows depending on the selected package.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Mobile performance',
        description: 'Fast architecture and reliable hosting so the site loads well on mobile and desktop.',
        icon: 'tabler:server',
      },
      {
        title: 'Human support',
        description:
          'A real person replies within one business day and keeps the project straightforward from brief to launch.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Room to grow',
        description:
          'If the business needs more later, we can add automation, consulting, or more advanced development.',
        icon: 'tabler:headset',
      },
    ]}
  />

  <Content
    isReversed
    tagline="Process"
    title="A clean launch without unnecessary complexity"
    items={[
      {
        title: 'Guided brief',
        description:
          'We collect your services, contact details, hours, visuals, and priorities so the project moves quickly.',
      },
      {
        title: 'Content integration',
        description:
          'We shape your content, calls to action, and contact points inside a simple and consistent structure.',
      },
      {
        title: 'Guided go-live',
        description:
          'You approve the final version, we publish it, and we stay available if the business needs more later.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Your online presence without the usual friction
      </h3>
      You move quickly, with a simple framework and clear approvals.
    </Fragment>

    <Fragment slot="image">
      <div
        class="relative aspect-[4/3] overflow-hidden rounded-xl bg-gradient-to-br from-blue-600 via-slate-900 to-slate-800 p-10 text-left text-white shadow-xl"
      >
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Simple process</p>
        <h4 class="mt-4 text-3xl font-semibold">Brief → Integration → Launch</h4>
        <p class="mt-6 max-w-xs text-base text-blue-100/90">
          Everything is structured to move quickly without drowning you in technical detail.
        </p>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Steps
    title="A simple method to launch quickly"
    tagline="Client journey"
    items={[
      {
        title: 'Digital signature',
        description: 'Choose your package, sign online, and start the brief in a few minutes.',
        icon: 'tabler:edit',
      },
      {
        title: 'Guided onboarding',
        description: 'We collect your content, key information, and contact or booking needs.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Supervised production',
        description: 'We integrate, review, and prepare the site for a clean and consistent launch.',
        icon: 'tabler:robot',
      },
      {
        title: 'Approval & launch',
        description:
          'You approve the final version, then we publish it and stay available if the business later needs more.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="image">
      <div
        class="relative aspect-[3/4] overflow-hidden rounded-xl bg-gradient-to-br from-slate-900 via-slate-800 to-blue-700 p-10 text-white shadow-xl"
      >
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Timeline</p>
        <p class="mt-6 max-w-xs text-base text-blue-100/90">
          Typical timeline: three to five business days after content is received. If you later need automation or
          deeper development, that gets scoped separately.
        </p>
      </div>
    </Fragment>
  </Steps>

  <Content
    isAfterContent
    items={[
      {
        title: 'Local credibility',
        description: 'A clear presence that reassures visitors, shows your services, and makes contact easier.',
      },
      {
        title: 'Contact & bookings',
        description: 'WhatsApp, Calendly, or simple forms to turn visits into real enquiries.',
      },
      {
        title: 'Maintenance & support',
        description: 'Updates, backups, and guidance when you want a more calm and reliable post-launch setup.',
      },
      {
        title: 'Room to grow',
        description:
          'If the business becomes more structured, we can later help with automation, consulting, or more advanced development.',
      },
    ]}
  >
    <Fragment slot="content">
      The website is often the first easy yes. What matters is that it is simple to launch today and able to support the
      business tomorrow.
    </Fragment>

    <Fragment slot="image">
      <div
        class="relative aspect-[4/3] overflow-hidden rounded-xl bg-gradient-to-br from-slate-900 via-slate-800 to-blue-700 p-10 text-white shadow-xl"
      >
        <h4 class="text-3xl font-semibold">Simple first, scalable later</h4>
        <ul class="mt-6 space-y-3 text-left text-blue-100/90">
          <li>✓ Clear launch from CHF 999</li>
          <li>✓ Contact, booking, and professional presence</li>
          <li>✓ Extra guidance available if the need grows</li>
        </ul>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Features2
    id="included"
    title="What your project can include"
    subtitle="Depending on your business, package, and priorities"
    tagline="In practice"
    items={[
      {
        title: 'Professional website',
        description: 'A clear and reassuring online presence to present your services and your business properly.',
        icon: 'tabler:world',
      },
      {
        title: 'Contact flow',
        description: 'Simple forms, visible contact details, and calls to action built to make enquiries easier.',
        icon: 'tabler:git-branch',
      },
      {
        title: 'Online booking',
        description: 'WhatsApp, Calendly, or integrated booking depending on the formula you choose.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Maintenance',
        description: 'Updates, backups, and follow-up when you want a more hands-off online presence.',
        icon: 'tabler:ruler-measure',
      },
      {
        title: 'Guidance',
        description: 'A human framework to answer questions, adjust the plan, and keep the project simple.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Future growth',
        description: 'If the business needs more later, we can move toward automation or more custom development.',
        icon: 'tabler:route',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Stats
    title="Simple benchmarks to decide"
    stats={[
      { title: 'Typical timeline', amount: '3–5 days' },
      { title: 'Starting package', amount: 'CHF 999' },
      { title: 'Care plan', amount: 'from CHF 79/mo' },
      { title: 'Future growth', amount: 'on request' },
    ]}
  />

  <FAQs
    id="faq"
    title="Frequently asked questions"
    subtitle="Transparency on how we work."
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What is the delivery timeline?',
        description:
          'After receiving your content, we usually deliver the first version within five business days. If you later need automation or deeper development, we define a separate schedule for that work.',
      },
      {
        title: 'Is copywriting included?',
        description: 'Yes, we write or adapt your French copy. English or German versions are quoted separately.',
      },
      {
        title: 'What does the care plan include?',
        description:
          'Care from CHF 79/month includes security updates, regular backups and uptime monitoring. Options can be added as needed.',
      },
      {
        title: 'Do you provide integrations?',
        description:
          'Yes. Simple integrations such as forms, bookings, or contact tools are included depending on the package. For API connections, more advanced automation, or deeper technical work, we define a separate scope.',
      },
      {
        title: 'How does support work after launch?',
        description: 'Support is handled by email or scheduled video, with responses within one business day.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get started — CHF 999',
        href: '/choose-template?plan=essential999',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Explore pricing',
        href: '/en/pricing',
      },
    ]}
  >
    <Fragment slot="title">Launch your online presence from CHF 999</Fragment>

    <Fragment slot="subtitle">
      We help you launch a clear website quickly, then stay available if the business later needs more.
    </Fragment>
  </CallToAction>
</Layout>
