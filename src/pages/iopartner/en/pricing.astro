---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import PricingOptions from '~/components/widgets/PricingOptions.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { iopartnerHeaderDataEn, iopartnerFooterDataEn } from '~/navigation';

const metadata = {
  title: 'IOPartner Pricing',
  description:
    'IOPartner pricing for website launches, custom systems, AI automation, and managed support.',
  openGraph: {
    type: 'website',
  },
  twitter: {
    cardType: 'summary',
  },
};
---

<Layout metadata={metadata} header={iopartnerHeaderDataEn} footer={iopartnerFooterDataEn}>
  <HeroText
    tagline="Pricing"
    title="Transparent packages, billed in Switzerland"
    subtitle="Two standard routes for simple launch sites, then a clean custom layer when the work exceeds the template."
  />

  <!-- Starter pack banner -->
  <div class="max-w-3xl mx-auto px-4 mb-2">
    <div class="rounded-2xl border-2 border-blue-200 bg-blue-50 dark:bg-blue-900/20 px-6 py-4 text-center">
      <p class="text-lg font-bold text-blue-900 dark:text-blue-100">Essential pack — from CHF 999</p>
      <p class="mt-1 text-sm text-blue-700 dark:text-blue-200">Fixed price for a professional showcase site. Typical delivery in 3–5 business days depending on your content.</p>
      <a href="/onboarding?plan=essential999" class="mt-3 inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm px-6 py-2 rounded-xl transition-colors">Order now →</a>
    </div>
  </div>

  <Prices
    title="Our turnkey packs"
    subtitle="Choose the offer that fits your needs. No hidden fees."
    prices={[
      {
        title: 'Essential',
        subtitle: 'Professional showcase site from CHF 999',
        price: 999,
        period: 'one-time payment',
        info: [
          "CHF 999 covers a standard 5-section showcase site on IOPartner's shared platform.",
          'Extra pages, brainstorming, structural changes, or new modules are quoted separately.',
          'Any out-of-scope request is billed separately before production.',
        ],
        items: [
          {
            description: 'Showcase site with 5 sections + responsive contact page',
          },
          {
            description: 'Client-provided content; we integrate and format it',
          },
          {
            description: 'Deployment on IOPartner shared infrastructure',
          },
        ],
        callToAction: { text: 'Choose a style →', href: '/en/choose-template?plan=essential999' },
      },
      {
        title: 'CHF 1,500 pack',
        subtitle: 'Standard site + WhatsApp + Calendly',
        price: 1500,
        period: 'one-time payment',
        info: [
          'Still within the standard IOPartner layer, without entering a private build.',
          'WhatsApp, Calendly, and a light handoff are included in the validated scope.',
          'Extra pages, redesign, workshops, or out-of-scope modules are quoted separately.',
        ],
        items: [
          { description: 'Includes the CHF 999 base layer' },
          { description: 'Clickable WhatsApp + Calendly booking' },
          { description: 'Light explanation and handoff' },
        ],
        callToAction: { text: 'Choose the CHF 1,500 pack →', href: '/en/choose-template?plan=essential1500' },
      },
      {
        title: 'Custom systems',
        subtitle: 'Private codebase, backend, or heavier architecture',
        price: 2000,
        period: 'from — scoped before build',
        items: [
          { description: 'CHF 2,000: private codebase' },
          { description: 'CHF 2,200: private codebase + handoff' },
          { description: 'CHF 4,500: light backend' },
          { description: 'CHF 8,000+: headless shop or heavier system' },
        ],
        callToAction: { text: 'See progression', href: '#modal-custom-en' },
      },
    ]}
  />
  <div class="mt-6 grid gap-4 max-w-7xl mx-auto px-4">
    <div class="flex flex-wrap gap-4">
      <PricingOptions
        id="modal-essential-en"
        triggerText=""
        title="Standard packs"
        subtitle="Choose the right level without buying custom too early"
        ctaText="Choose"
        tiers={[
          { label: 'CHF 999', price: 'from 999', features: ['Static site', 'Simple form (email)'], href: '/en/choose-template?plan=essential999', info: ['Hosting & SSL included (3 months)', 'Deployed on IOPartner shared infrastructure', 'Extra pages, workshops, or out-of-scope changes quoted separately'] },
          { label: 'CHF 1,500', price: '1,500', features: ['Includes the CHF 999 base', 'WhatsApp + Calendly', 'Light explanation / handoff'], href: '/en/choose-template?plan=essential1500', primary: true, info: ['Still on IOPartner shared infrastructure', 'WhatsApp and Calendly wired inside the validated scope', 'Extra pages, workshops, or out-of-scope changes quoted separately'] },
        ]}
        footnote="The validated scope is what gets delivered; extra pages, workshops/brainstorming, redesigns, and out-of-scope changes are billed separately."
      />
      <PricingOptions
        id="modal-custom-en"
        triggerText=""
        title="Custom progression"
        subtitle="When the right move is no longer a simple template"
        ctaText="Open"
        tiers={[
          { label: 'CHF 2,000', price: 'private codebase', features: ['Separate codebase', 'Leaves shared infrastructure'], href: '/en/custom-systems?track=private-2000#diagnostic' },
          { label: 'CHF 2,200', price: 'private + handoff', features: ['Separate codebase', 'Structured handoff'], href: '/en/custom-systems?track=private-2200#diagnostic', primary: true },
          { label: 'CHF 4,500', price: 'light backend', features: ['Light business logic', 'Intake, sync, or simple portal'], href: '/en/custom-systems?track=backend-4500#diagnostic' },
          { label: 'CHF 8,000+', price: 'heavier system', features: ['Headless shop', 'Admin, portal, or deeper architecture'], href: '/en/custom-systems?track=shop-8000#diagnostic' },
        ]}
        footnote="Architecture, portal, admin, or internal platform work gets scoped after the paid 15 min / CHF 80 diagnostic."
      />
    </div>
  </div>

  

  <Features3
    title="What our offers can include"
    subtitle="Depending on plan and needs."
    columns={2}
    items={[
      {
        title: 'Human support',
        description: 'Email and phone assistance, responses within one business day.',
        icon: 'tabler:headset',
      },
      {
        title: 'Swiss hosting included',
        description: 'Servers in Switzerland with SSL included for the launch period, according to the selected pack.',
        icon: 'tabler:server',
      },
      {
        title: 'Simple process',
        description: 'Email-based exchanges and step approvals (no client portal).',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Clear billing',
        description: 'VAT included, QR invoice or Twint, monthly payments available.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Optimised performance',
        description: 'Astro architecture and image optimisation for fast loading.',
        icon: 'tabler:gauge',
      },
      {
        title: 'Enhanced security',
        description: 'Initial backups, application firewall and regular updates.',
        icon: 'tabler:lock',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <Steps
    title="How your project unfolds"
    tagline="Journey"
    isReversed={true}
    items={[
      {
        title: '1. Digital signature',
        description: 'Confirm your pack and receive onboarding access.',
        icon: 'tabler:edit',
      },
      {
        title: '2. Smart questionnaire',
        description: 'Share key information, upload visuals and pick your modules.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: '3. Supervised production',
        description: 'Our platform generates your site while experts fine-tune and review.',
        icon: 'tabler:robot',
      },
      {
        title: '4. Approval & go-live',
        description: 'Approve the final version, then we schedule go-live and quote any out-of-scope extension separately.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="image">
      <div class="relative aspect-[3/4] overflow-hidden rounded-xl bg-gradient-to-br from-blue-700 via-slate-900 to-slate-800 p-10 text-white shadow-xl">
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Process</p>
        <p class="mt-6 max-w-xs text-base text-blue-100/90">
          Simple journey: brief, content integration and approvals by email.
        </p>
      </div>
    </Fragment>
  </Steps>

  <FAQs
    title="Pricing questions"
    subtitle="We believe in total transparency."
    items={[
      {
        title: 'Is VAT included?',
        description: 'Yes, all amounts include VAT. The invoice shows Swiss VAT and IDE number.',
      },
      {
        title: 'What is the average timeline for the Essential pack?',
        description: 'Around five business days after we receive your content. We share a detailed schedule during the brief.',
      },
      {
        title: 'What if I need extra pages or brainstorming?',
        description: 'Extra pages, workshops or brainstorming, structural changes, and out-of-scope requests are quoted separately before production starts.',
      },
      {
        title: 'Is the care plan mandatory?',
        description: 'No. Care from CHF 79/month with a 30-day notice to cancel.',
      },
      {
        title: 'Which payment methods do you accept?',
        description: 'Swiss cards, Twint, bank transfer and QR billing. Subscriptions can be paid monthly or annually.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get a proposal',
        href: '/en/contact#form',
        icon: 'tabler:mail-forward',
      },
      {
        text: 'Compare packs',
        href: '/en/services',
      },
    ]}
  >
    <Fragment slot="title">
      Need a tailored quote?
    </Fragment>

    <Fragment slot="subtitle">
      We adapt each offer to the specifics of your business in the Léman Arc.
    </Fragment>
  </CallToAction>
</Layout>
