---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

import { iopartnerHeaderDataEn, iopartnerFooterDataEn } from '~/navigation';

const metadata = {
  title: 'Contact IOPartner',
  description:
    'Talk to IOPartner about websites, AI automation, open-source infrastructure, or managed support.',
  openGraph: {
    type: 'website',
  },
  twitter: {
    cardType: 'summary',
  },
};
---

<Layout metadata={metadata} header={iopartnerHeaderDataEn} footer={iopartnerFooterDataEn}>
  <HeroText tagline="Contact" title="Let’s discuss the right IOPartner path" subtitle="We separate standard launches, private builds, and heavier systems work without wasting time." />

  <ContactUs
    id="form"
    title="Request a demo or quote"
    subtitle="Fill out the form and we’ll route you toward the right layer: CHF 999, CHF 1,500, or the custom diagnostic path."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Full name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Business email',
      },
      {
        type: 'text',
        name: 'company',
        label: 'Company',
      },
      {
        type: 'select',
        name: 'service',
        label: 'Desired pack',
        options: [
          { label: 'Standard site — CHF 999', value: 'essential999' },
          { label: 'Standard site + WhatsApp + Calendly — CHF 1,500', value: 'essential1500' },
          { label: 'Private codebase / light backend — CHF 2,000 to 8,000+', value: 'custom' },
          { label: 'Paid diagnostic — 15 min / CHF 80', value: 'diagnostic80' },
        ],
      },
    ]}
    textarea={{
      label: 'Your project',
      placeholder: 'Describe your business, objectives and deadlines.',
    }}
    disclaimer={{
      label:
        'By submitting this form you agree that IOPartner.ch processes your data to answer your request, in line with our privacy policy.',
    }}
    description="Our offices are open Monday to Friday, 9am–5pm. We speak French, English and German."
  />

  <Features2
    title="Direct contact"
    subtitle="Choose the channel that suits you best."
    items={[
      {
        title: 'Phone',
        description: '+41 76 798 27 93',
        icon: 'tabler:phone',
      },
      {
        title: 'Email',
        description: 'support@iopartner.ch',
        icon: 'tabler:mail',
      },
      {
        title: 'Address',
        description: 'Avenue de la Gare 29, 1003 Lausanne',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Availability',
        description: 'Monday to Friday, 9:00 – 17:00',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'Client support',
        description: 'support@iopartner.ch — reply within one business day',
        icon: 'tabler:help',
      },
    ]}
  />
</Layout>
