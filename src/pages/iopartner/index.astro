      { href: `${localePrefix}/cadrage-technique`, icon: 'consulting', title: 'Inquadramento tecnico', body: 'Arbitrare, definire, sbloccare. Decisioni rapide, impatto diretto.', price: 'CHF 60 / 15 min' },
      { href: `${localePrefix}/systems-operations`, icon: 'systems', title: 'Sistemi & operazioni', body: 'Infrastruttura, automazione, supervisione e integrazioni.', price: 'Su preventivo' },
