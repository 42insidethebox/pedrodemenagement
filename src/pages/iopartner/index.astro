const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
const metadata = copy.metadata;
const processSteps = copy.steps;
const faqs = copy.faqs;
---

<Layout metadata={metadata}>
  <main class="io-home">
    <section class="io-hero" id="process">
      <div class="io-shell io-hero-grid">
        <div class="io-hero-copy">
          <p class="io-kicker">{copy.heroKicker}</p>
          <h1>{copy.heroTitle}</h1>
          <p class="io-lead">{copy.heroLead}</p>
          <div class="io-actions">
            <a class="io-btn io-btn-primary" href={`${localePrefix}/contact#form`}>{copy.talk}</a>
            <a class="io-btn io-btn-secondary" href={`${localePrefix}/pricing`}>{copy.pricing}</a>
          </div>
        </div>
        <Io04DecisionEntryMap />
      </div>
    </section>

    <section class="io-shell io-entry-band" id="entry-points">
      <div class="io-entry-head">
        <div>
          <p class="io-kicker">{copy.entryKicker}</p>
          <h2>{copy.entryTitle}</h2>
        </div>
        <a href={`${localePrefix}/pricing`} class="io-link">{copy.compare}</a>
      </div>

      <div class="io-entry-grid">
        {copy.entries.map((entry) => (
          <a class="io-entry-item" href={entry.href}>
            <span class="io-entry-icon"><IoNodeIcon name={entry.icon} /></span>
            <h3>{entry.title}</h3>
            <p>{entry.body}</p>
            <strong>{entry.price}</strong>
          </a>
        ))}
      </div>
    </section>

    <section class="io-shell io-philosophy">
      <p>{copy.philosophyLead}</p>
      <div>
        {copy.philosophy.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="io-shell io-process-section">
      <div class="io-section-head">
        <p class="io-kicker">{copy.methodKicker}</p>
        <h2>{copy.methodTitle}</h2>
        <p>{copy.methodBody}</p>
      </div>
      <IoProcessMap steps={processSteps} />
    </section>

    <section class="io-systems-section" id="systems-operations">
      <div class="io-shell io-systems-grid">
        <div class="io-systems-copy">
          <p class="io-kicker">{copy.systemsKicker}</p>
          <h2>{copy.systemsTitle}</h2>
          <p>{copy.systemsBody}</p>
          <div class="io-stack-line">Docker · VPS · DNS · SSL · monitoring · workflows · API · dashboards</div>
          <a class="io-btn io-btn-light" href={`${localePrefix}/systems-operations`}>{copy.systemsCta}</a>
        </div>
        <Io02SvgLinesPathsCurves />
      </div>
    </section>

    <section class="io-shell io-proof-grid">
      <article>
        <p class="io-kicker">{copy.proof1Kicker}</p>
        <h2>{copy.proof1Title}</h2>
        <p>{copy.proof1Body}</p>
        <IoBlueprintVisual variant="decision" />
      </article>
      <article id="standard-deployment">
        <p class="io-kicker">{copy.proof2Kicker}</p>
        <h2>{copy.proof2Title}</h2>
        <p>{copy.proof2Body}</p>
        <IoBlueprintVisual variant="standard" />
      </article>
    </section>

    <section class="io-shell io-pricing-strip">
      {copy.strip.map(([strong, text]) => (
        <div>
          <strong>{strong}</strong>
          <span>{text}</span>
        </div>
      ))}
    </section>

    <section class="io-shell io-faq" id="faq">
      <div class="io-section-head">
        <p class="io-kicker">{copy.faqKicker}</p>
        <h2>{copy.faqTitle}</h2>
      </div>
      <div class="io-faq-list">
        {
          faqs.map((faq) => (
            <details>
              <summary>{faq.title}</summary>
              <p>{faq.body}</p>
            </details>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-final-cta">
      <h2>{copy.finalTitle}</h2>
      <p>{copy.finalBody}</p>
      <div class="io-actions">
        <a class="io-btn io-btn-primary" href={`${localePrefix}/contact#form`}>{copy.finalPrimary}</a>
        <a class="io-btn io-btn-secondary" href={`${localePrefix}/pricing`}>{copy.finalSecondary}</a>
      </div>
    </section>
  </main>

  <style>
    .io-home {
      --io-dark: #07111f;
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-line: rgba(148, 163, 184, 0.22);
      --io-blue: #0b63f6;
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(180deg, #f8fbff 0%, #ffffff 38%, #f8fbff 100%);
      background-size:
        34px 34px,
        34px 34px,
        100% 100%;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 82rem);
      margin-inline: auto;
    }

    .io-hero {
      padding: 4.8rem 0 3.6rem;
    }

    .io-hero-grid,
    .io-systems-grid,
    .io-proof-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.86fr) minmax(26rem, 1.14fr);
