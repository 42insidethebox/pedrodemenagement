---
export const prerender = false;

import IoBlueprintVisual from '~/components/iopartner/IoBlueprintVisual.astro';
import IoProcessMap from '~/components/iopartner/IoProcessMap.astro';
import Io01PremiumGridBlueprintArcs from '~/components/iopartner/visuals/Io01PremiumGridBlueprintArcs.astro';
import Io02SvgLinesPathsCurves from '~/components/iopartner/visuals/Io02SvgLinesPathsCurves.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'IOPartner.ch — Consulting technique, systems & operations pour PME',
  description:
    'Consulting technique, systèmes opérationnels et déploiement standard pour PME suisses. Le standard quand il suffit, le sur mesure quand il faut.',
  ignoreTitleTemplate: true,
};

const processSteps = [
  { label: '01', title: 'Diagnostic', detail: 'Comprendre le besoin réel.' },
  { label: '02', title: 'Périmètre', detail: 'Séparer standard et sur mesure.' },
  { label: '03', title: 'Build', detail: 'Livrer sans chantier inutile.' },
  { label: '04', title: 'Continuité', detail: 'Garder le système propre.' },
];

const faqs = [
  {
    title: 'Quand choisir le consulting technique ?',
    body: 'Quand il faut trancher une décision, débloquer une implémentation, relire une architecture ou éviter de lancer le mauvais chantier.',
  },
  {
    title: 'Quand passer en systems & operations ?',
    body: 'Quand le sujet implique infrastructure, backend, intégrations, automatisation, monitoring ou continuité technique au-delà d’un simple site.',
  },
  {
    title: 'Le déploiement standard dès 999 CHF existe toujours ?',
    body: 'Oui. Il reste pertinent quand une présence web cadrée suffit. Il n’est pas vendu comme du sur mesure déguisé.',
  },
  {
    title: 'Pouvez-vous rester après la mise en ligne ?',
    body: 'Oui. Le suivi peut couvrir corrections, incidents, DNS, monitoring, petites évolutions ou second chantier selon le contexte.',
  },
];
---

<Layout metadata={metadata}>
  <main class="io-home">
    <section class="io-hero" id="process">
      <div class="io-shell io-hero-grid">
        <div class="io-hero-copy">
          <p class="io-kicker">Consulting technique · Systems & operations · Déploiement standard</p>
          <h1>Clarté technique, delivery propre et sites web quand le standard suffit.</h1>
          <p class="io-lead">
            Nous aidons les PME et indépendants à choisir le bon niveau d’intervention: cadrer vite, construire sur
            mesure, ou lancer une présence web propre dès 999 CHF.
          </p>
          <div class="io-actions">
            <a class="io-btn io-btn-primary" href="/contact#form">Parler de votre besoin</a>
            <a class="io-btn io-btn-secondary" href="/pricing">Voir les tarifs</a>
          </div>
        </div>
        <Io01PremiumGridBlueprintArcs />
      </div>
    </section>

    <section class="io-shell io-entry-band" id="entry-points">
      <div class="io-entry-head">
        <div>
          <p class="io-kicker">Décider le bon niveau d’intervention</p>
          <h2>Trois portes d’entrée claires selon le besoin réel.</h2>
        </div>
        <a href="/pricing" class="io-link">Comparer les formats</a>
      </div>

      <div class="io-entry-grid">
        <a class="io-entry-item" href="/contact#form">
          <span class="io-entry-icon io-entry-icon-decision"></span>
          <h3>Consulting technique</h3>
          <p>Arbitrer, cadrer, débloquer. Décisions rapides, impact direct.</p>
          <strong>60 CHF / 15 min</strong>
        </a>
        <a class="io-entry-item" href="/pricing?tab=systems#systems-operations">
          <span class="io-entry-icon io-entry-icon-systems"></span>
          <h3>Systems & operations</h3>
          <p>Infrastructure, automatisation, supervision et intégrations.</p>
          <strong>Sur devis</strong>
        </a>
        <a class="io-entry-item" href="/pricing?tab=website#standard-deployment">
          <span class="io-entry-icon io-entry-icon-standard"></span>
          <h3>Déploiement standard</h3>
          <p>Site vitrine professionnel livré vite, au juste prix dès 999 CHF.</p>
          <strong>Dès 999 CHF</strong>
        </a>
      </div>
    </section>

    <section class="io-shell io-philosophy">
      <p>Le mauvais projet coûte plus cher que le bon arbitrage.</p>
      <div>
        <span>Parfois un site standard suffit.</span>
        <span>Parfois il faut une infrastructure dédiée.</span>
        <span>Le rôle du consulting est de distinguer les deux rapidement.</span>
      </div>
    </section>

    <section class="io-shell io-process-section">
      <div class="io-section-head">
        <p class="io-kicker">Méthode</p>
        <h2>Un cadrage court avant l’exécution.</h2>
        <p>
          L’objectif n’est pas de grossir le projet. L’objectif est de choisir la forme utile, puis d’exécuter
          proprement.
        </p>
      </div>
      <IoProcessMap steps={processSteps} />
    </section>

    <section class="io-systems-section" id="systems-operations">
      <div class="io-shell io-systems-grid">
        <div class="io-systems-copy">
          <p class="io-kicker">Systems & operations</p>
          <h2>Quand le site devient système.</h2>
          <p>
            Infrastructure, automatisation, backend léger, supervision et continuité technique pour les sujets qui
            dépassent réellement le template.
          </p>
          <div class="io-stack-line">Docker · VPS · DNS · SSL · monitoring · workflows · API · dashboards</div>
          <a class="io-btn io-btn-light" href="/pricing?tab=systems#systems-operations">Voir systems & operations</a>
        </div>
        <Io02SvgLinesPathsCurves />
      </div>
    </section>

    <section class="io-shell io-proof-grid">
      <article>
        <p class="io-kicker">Consulting</p>
        <h2>Ce qui repart avec vous.</h2>
        <p>Une carte de décision, un périmètre plus net, ou une direction technique défendable.</p>
        <IoBlueprintVisual variant="decision" />
      </article>
      <article id="standard-deployment">
        <p class="io-kicker">Déploiement standard</p>
        <h2>Quand une build privée n’est pas nécessaire.</h2>
        <p>Un format de lancement cadré pour une présence web propre, rapide et maintenable.</p>
        <IoBlueprintVisual variant="standard" />
      </article>
    </section>

    <section class="io-shell io-pricing-strip">
      <div>
        <strong>60 CHF / 15 min</strong>
        <span>Consulting ciblé</span>
      </div>
      <div>
        <strong>140 CHF / h</strong>
        <span>Support technique avancé</span>
      </div>
      <div>
        <strong>999 CHF</strong>
        <span>Déploiement standard</span>
      </div>
      <div>
        <strong>Sur devis</strong>
        <span>Systems & operations</span>
      </div>
    </section>

    <section class="io-shell io-faq" id="faq">
      <div class="io-section-head">
        <p class="io-kicker">FAQ</p>
        <h2>Questions fréquentes</h2>
      </div>
      <div class="io-faq-list">
        {
          faqs.map((faq) => (
            <details>
              <summary>{faq.title}</summary>
              <p>{faq.body}</p>
            </details>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-final-cta">
      <h2>Commencer par le bon niveau d’intervention.</h2>
      <p>
        Envoyez le contexte. Nous vous indiquons si le bon mouvement est consulting, systems, ou déploiement standard.
      </p>
      <div class="io-actions">
        <a class="io-btn io-btn-primary" href="/contact#form">Envoyer le contexte</a>
        <a class="io-btn io-btn-secondary" href="/pricing">Voir les tarifs</a>
      </div>
    </section>
  </main>

  <style>
    .io-home {
      --io-dark: #07111f;
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-line: rgba(148, 163, 184, 0.22);
      --io-blue: #0b63f6;
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(180deg, #f8fbff 0%, #ffffff 38%, #f8fbff 100%);
      background-size:
        34px 34px,
        34px 34px,
        100% 100%;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 82rem);
      margin-inline: auto;
    }

    .io-hero {
      padding: 4.8rem 0 3.6rem;
    }

    .io-hero-grid,
    .io-systems-grid,
    .io-proof-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.86fr) minmax(26rem, 1.14fr);
      gap: 3.6rem;
      align-items: center;
    }

    .io-hero-copy h1,
    .io-entry-head h2,
    .io-section-head h2,
    .io-systems-copy h2,
    .io-proof-grid h2,
    .io-final-cta h2 {
      margin: 0;
      font-weight: 850;
      line-height: 1.04;
    }

    .io-hero-copy h1 {
      max-width: 42rem;
      font-size: 4.05rem;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-lead,
    .io-section-head p,
    .io-systems-copy p,
    .io-proof-grid p,
    .io-final-cta p {
      color: var(--io-muted);
      font-size: 1.12rem;
      line-height: 1.72;
    }

    .io-lead {
      max-width: 37rem;
      margin: 1.35rem 0 0;
      font-size: 1.15rem;
    }

    .io-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 2rem;
    }

    .io-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3.15rem;
      border-radius: 999px;
      padding: 0.82rem 1.4rem;
      font-weight: 780;
      text-decoration: none;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease;
    }

    .io-btn:hover,
    .io-btn:focus-visible {
      transform: translateY(-1px);
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
      box-shadow: 0 16px 38px -24px rgba(11, 99, 246, 0.7);
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      color: var(--io-ink);
      background: rgba(255, 255, 255, 0.72);
    }

    .io-btn-light {
      width: fit-content;
      border: 1px solid rgba(226, 232, 240, 0.36);
      color: #f8fafc;
      background: rgba(255, 255, 255, 0.05);
    }

    .io-entry-band {
      margin-top: 2rem;
      padding: 2.05rem;
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 1.35rem;
      background:
        linear-gradient(90deg, rgba(125, 211, 252, 0.06) 1px, transparent 1px),
        linear-gradient(rgba(125, 211, 252, 0.06) 1px, transparent 1px), linear-gradient(135deg, #061120, #0b1728);
      background-size:
        30px 30px,
        30px 30px,
        100% 100%;
      color: #fff;
    }

    .io-entry-head {
      display: flex;
      justify-content: space-between;
      gap: 2rem;
      align-items: start;
      margin-bottom: 2.25rem;
    }

    .io-entry-head h2 {
      max-width: 33rem;
      color: #fff;
      font-size: 2.18rem;
    }

    .io-entry-band .io-kicker {
      color: #93c5fd;
    }

    .io-link {
      color: #bfdbfe;
      text-decoration: none;
      font-weight: 720;
    }

    .io-entry-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid rgba(226, 232, 240, 0.16);
      border-radius: 1rem;
      overflow: hidden;
    }

    .io-entry-item {
      display: grid;
      gap: 0.8rem;
      min-height: 12.7rem;
      padding: 1.65rem;
      color: #f8fafc;
      text-decoration: none;
      background: rgba(255, 255, 255, 0.025);
    }

    .io-entry-item + .io-entry-item {
      border-left: 1px solid rgba(226, 232, 240, 0.14);
    }

    .io-entry-item h3 {
      margin: 0;
      font-size: 1.28rem;
    }

    .io-entry-item p {
      margin: 0;
      color: rgba(226, 232, 240, 0.82);
      line-height: 1.6;
    }

    .io-entry-item strong {
      align-self: end;
      color: #93c5fd;
    }

    .io-entry-icon {
      width: 3.2rem;
      height: 3.2rem;
      border: 1px solid rgba(147, 197, 253, 0.5);
      border-radius: 0.75rem;
      background:
        linear-gradient(90deg, rgba(96, 165, 250, 0.55) 2px, transparent 2px),
        linear-gradient(rgba(96, 165, 250, 0.55) 2px, transparent 2px);
      background-size: 16px 16px;
    }

    .io-philosophy {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.9fr);
      gap: 3rem;
      align-items: end;
      padding: 5.8rem 0;
    }

    .io-philosophy > p {
      margin: 0;
      max-width: 43rem;
      font-size: 3.45rem;
      font-weight: 850;
      line-height: 1.04;
    }

    .io-philosophy div {
      display: grid;
      gap: 1rem;
      color: var(--io-muted);
      font-size: 1.1rem;
      line-height: 1.6;
    }

    .io-process-section,
    .io-faq {
      padding: 1.4rem 0 5.4rem;
    }

    .io-section-head {
      max-width: 40rem;
      margin-bottom: 2.2rem;
    }

    .io-section-head h2,
    .io-systems-copy h2,
    .io-proof-grid h2,
    .io-final-cta h2 {
      font-size: 2.65rem;
    }

    .io-systems-section {
      padding: 5.4rem 0;
      background: #061120;
      color: #f8fafc;
    }

    .io-systems-grid {
      grid-template-columns: minmax(0, 0.78fr) minmax(24rem, 1fr);
    }

    .io-systems-copy h2 {
      color: #f8fafc;
    }

    .io-systems-copy p {
      color: #cbd5e1;
      max-width: 35rem;
    }

    .io-stack-line {
      margin: 1.5rem 0 2rem;
      color: #93c5fd;
      font-weight: 760;
      line-height: 1.6;
    }

    .io-proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.8rem;
      padding: 5.4rem 0;
    }

    .io-proof-grid article {
      display: grid;
      gap: 1rem;
      align-content: start;
      border: 1px solid var(--io-line);
      border-radius: 1.15rem;
      padding: 1.35rem;
      background: rgba(255, 255, 255, 0.74);
    }

    .io-proof-grid h2 {
      font-size: 1.82rem;
    }

    .io-proof-grid p {
      margin: 0;
      min-height: 4rem;
    }

    .io-proof-grid :global(.io-blueprint) {
      min-height: 15.5rem;
    }

    .io-pricing-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      margin-bottom: 5.4rem;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.8);
      overflow: hidden;
    }

    .io-pricing-strip div {
      display: grid;
      gap: 0.35rem;
      padding: 1.2rem;
    }

    .io-pricing-strip div + div {
      border-left: 1px solid var(--io-line);
    }

    .io-pricing-strip strong {
      font-size: 1.25rem;
      color: var(--io-ink);
    }

    .io-pricing-strip span {
      color: var(--io-muted);
      font-size: 0.92rem;
    }

    .io-faq-list {
      display: grid;
      gap: 0.8rem;
      max-width: 58rem;
    }

    .io-faq details {
      border: 1px solid var(--io-line);
      border-radius: 0.8rem;
      background: rgba(255, 255, 255, 0.78);
      padding: 1.1rem 1.25rem;
    }

    .io-faq summary {
      cursor: pointer;
      color: var(--io-ink);
      font-weight: 780;
    }

    .io-faq details p {
      margin: 0.85rem 0 0;
      color: var(--io-muted);
      line-height: 1.65;
    }

    .io-final-cta {
      margin-bottom: 5.4rem;
      padding: 2.5rem;
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 1.25rem;
      background: #fff;
      text-align: center;
    }

    .io-final-cta p {
      max-width: 42rem;
      margin: 1rem auto 0;
    }

    .io-final-cta .io-actions {
      justify-content: center;
    }

    @media (max-width: 1024px) {
      .io-hero-grid,
      .io-systems-grid,
      .io-proof-grid,
      .io-philosophy {
        grid-template-columns: 1fr;
      }

      .io-hero-copy h1 {
        font-size: 3.35rem;
      }

      .io-philosophy > p {
        font-size: 3rem;
      }

      .io-entry-grid,
      .io-pricing-strip {
        grid-template-columns: 1fr;
      }

      .io-entry-item + .io-entry-item,
      .io-pricing-strip div + div {
        border-left: 0;
        border-top: 1px solid rgba(226, 232, 240, 0.14);
      }
    }

    @media (max-width: 640px) {
      .io-shell {
        width: min(100% - 1rem, 82rem);
      }

      .io-hero {
        padding-top: 3.2rem;
      }

      .io-hero-copy h1 {
        font-size: 2.35rem;
      }

      .io-section-head h2,
      .io-systems-copy h2,
      .io-final-cta h2 {
        font-size: 1.95rem;
      }

      .io-entry-band,
      .io-final-cta {
        padding: 1.2rem;
      }

      .io-entry-head {
        display: grid;
      }

      .io-entry-head h2,
      .io-philosophy > p {
        font-size: 2.2rem;
      }

      .io-proof-grid article {
        padding: 1rem;
      }
    }
  </style>
</Layout>
