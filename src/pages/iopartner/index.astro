---
export const prerender = false;

import IoBlueprintVisual from '~/components/iopartner/IoBlueprintVisual.astro';
import IoNodeIcon from '~/components/iopartner/IoNodeIcon.astro';
import IoProcessMap from '~/components/iopartner/IoProcessMap.astro';
import Io04DecisionEntryMap from '~/components/iopartner/visuals/Io04DecisionEntryMap.astro';
import Io02SvgLinesPathsCurves from '~/components/iopartner/visuals/Io02SvgLinesPathsCurves.astro';
import type { IoIconName } from '~/components/iopartner/ioNodeIconTypes';
import { detectRequestLocale } from '~/lib/locale';
import Layout from '~/layouts/PageLayout.astro';

const locale = detectRequestLocale(Astro.request, Astro.url);
const localePrefix = ['en', 'de', 'it'].includes(locale) ? `/${locale}` : '';

const COPY = {
