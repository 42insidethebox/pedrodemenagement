    talk: 'Bedarf besprechen',
    pricing: 'Preise ansehen',
    entryKicker: 'Das richtige Interventionsniveau wählen',
    entryTitle: 'Drei klare Einstiegspunkte je nach echtem Bedarf.',
    compare: 'Formate vergleichen',
    entries: [
      { href: `${localePrefix}/cadrage-technique`, icon: 'consulting', title: 'Technisches Scoping', body: 'Abwägen, scopen, entblocken. Schnelle Entscheidungen mit direkter Wirkung.', price: 'CHF 60 / 15 Min.' },
      { href: `${localePrefix}/systems-operations`, icon: 'systems', title: 'Systeme & Betrieb', body: 'Infrastruktur, Automatisierung, Überwachung und Integrationen.', price: 'Auf Anfrage' },
      { href: `${localePrefix}/presence-web-cadree`, icon: 'standard', title: 'Klar abgegrenzte Web-Präsenz', body: 'Professionelle Showcase-Website, schnell geliefert, mit klarer Schwelle zu editierbaren oder dedizierten Wegen.', price: 'Ab CHF 999' },
