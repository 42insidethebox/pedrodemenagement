      ignoreTitleTemplate: true,
    },
    heroKicker: 'Inquadramento tecnico · Sistemi & operazioni · Presenza web strutturata',
    heroTitle: 'Chiarezza tecnica, delivery pulito e siti web quando lo standard basta.',
    heroLead:
      'Aiutiamo PMI e indipendenti a scegliere il giusto livello di intervento: definire rapidamente, costruire custom quando serve, oppure lanciare una presenza web pulita da CHF 999.',
    talk: 'Parlare del bisogno',
    pricing: 'Vedere i prezzi',
    entryKicker: 'Scegliere il giusto livello di intervento',
    entryTitle: 'Tre punti di ingresso chiari in base al bisogno reale.',
