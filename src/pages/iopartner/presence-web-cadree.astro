      { label: '04', title: 'Go-live', detail: 'Validierung und Übergabe.', icon: 'deploy' },
    ] satisfies Array<{ label: string; title: string; detail: string; icon: IoIconName }>,
    finalCta: {
      title: 'Eine Web-Präsenz starten, ohne zu überbauen.',
      body: 'Beginnen Sie mit einer klaren Ebene. Wenn der Bedarf die klare Web-Präsenz übersteigt, wechseln wir zu editierbar oder technischem Scoping.',
