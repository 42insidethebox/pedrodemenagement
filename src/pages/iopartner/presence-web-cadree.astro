---
import IoBlueprintVisual from '~/components/iopartner/IoBlueprintVisual.astro';
import IoNodeIcon from '~/components/iopartner/IoNodeIcon.astro';
import IoProcessMap from '~/components/iopartner/IoProcessMap.astro';
import type { IoIconName } from '~/components/iopartner/ioNodeIconTypes';
import { detectRequestLocale } from '~/lib/locale';
import Layout from '~/layouts/PageLayout.astro';
import pedroLogo from '~/assets/lausannedemenagement/logo.png';
import maisonPreview from '~/assets/maisoncortes_images/lausanne-ring-02.png';
import onglesPreview from '~/assets/onglesgel_images/01.png';
import toloPreview from '~/assets/tolocoiffure_images/template_preview.jpg';

const locale = detectRequestLocale(Astro.request, Astro.url);

const toAssetSrc = (asset: string | { src: string }) => (typeof asset === 'string' ? asset : asset.src);

const COPY = {
  fr: {
    metadata: {
      title: 'Présence web cadrée — IOPartner',
      description:
        'Présence web cadrée pour PME: site vitrine dès 999 CHF, avec seuil clair vers site administrable ou build privé quand le besoin évolue.',
    },
    hero: {
      kicker: 'Présence web cadrée',
      title: 'Un site propre quand une présence web claire suffit.',
