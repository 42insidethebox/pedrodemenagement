const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
const steps = copy.steps as any;

const modelAssets = [
  {
    id: 'pedro',
    img: toAssetSrc(pedroLogo as string | { src: string }),
    href: '/choose-template?plan=essential999&template=lausanne-demenagement',
    imageClass: 'object-contain p-8 bg-gradient-to-br from-slate-50 to-blue-100',
  },
  {
    id: 'tolo-coiffure',
    img: toAssetSrc(toloPreview as string | { src: string }),
    href: '/choose-template?plan=essential1500&template=tolo-coiffure',
    imageClass: 'object-cover object-top',
  },
  {
    id: 'maison-cortes',
    img: toAssetSrc(maisonPreview as string | { src: string }),
    href: '/choose-template?plan=essential1500&template=maison-cortes',
    imageClass: 'object-cover object-top',
  },
  {
    id: 'onglesgel',
    img: toAssetSrc(onglesPreview as string | { src: string }),
    href: '/choose-template?plan=essential999&template=onglesgel',
    imageClass: 'object-cover object-top',
  },
];

const models = modelAssets.map((asset, index) => {
  const [title, body, cta] = copy.models[index];
  return { ...asset, title, body, cta };
});
---

<Layout metadata={copy.metadata}>
  <main class="io-presence">
    <section class="io-hero">
      <div class="io-shell io-hero-grid">
        <div>
          <p class="io-kicker">{copy.hero.kicker}</p>
          <h1>{copy.hero.title}</h1>
          <p class="io-lead">{copy.hero.lead}</p>
          <div class="io-actions">
            <a class="io-btn io-btn-primary" href="#offres">{copy.hero.primary}</a>
            <a class="io-btn io-btn-secondary" href="#modeles">{copy.hero.secondary}</a>
          </div>
        </div>
        <IoBlueprintVisual variant="standard" />
      </div>
    </section>

    <section class="io-shell io-offers" id="offres">
      <div class="io-section-head">
        <p class="io-kicker">{copy.offersHead.kicker}</p>
        <h2>{copy.offersHead.title}</h2>
      </div>
      <div class="io-offer-grid">
        {
          copy.offers.map((offer: any) => (
            <article id={offer.id}>
              <strong class="io-price">{offer.price}</strong>
              <h3>{offer.title}</h3>
              <p>{offer.body}</p>
              <ul>
                {offer.items.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
              <a class="io-link" href={offer.href}>
                {offer.cta}
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-level-guide">
      <div class="io-section-head">
        <p class="io-kicker">{copy.levelGuideHead.kicker}</p>
        <h2>{copy.levelGuideHead.title}</h2>
      </div>
      <div class="io-level-guide-grid">
        {
          copy.levelGuide.map((level: any) => (
            <article>
              <strong>{level.price}</strong>
              <h3>{level.title}</h3>
              <p>{level.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-thresholds">
      <div class="io-section-head">
        <p class="io-kicker">{copy.thresholdsHead.kicker}</p>
        <h2>{copy.thresholdsHead.title}</h2>
        <p>{copy.thresholdsHead.body}</p>
      </div>
      <div class="io-threshold-grid">
        {
          copy.thresholds.map((threshold: any) => (
            <article>
              <h3>{threshold.title}</h3>
              <p>{threshold.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="io-models" id="modeles">
      <div class="io-shell">
        <div class="io-section-head">
          <p class="io-kicker">{copy.modelsHead.kicker}</p>
          <h2>{copy.modelsHead.title}</h2>
          <p>{copy.modelsHead.body}</p>
        </div>
        <div class="io-model-grid">
          {
            models.map((model) => (
              <article>
                <div class="io-model-preview">
                  <img src={model.img} alt="" loading="lazy" class={model.imageClass} />
                </div>
                <div>
                  <h3>{model.title}</h3>
                  <p>{model.body}</p>
                  <a href={model.href}>{model.cta}</a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="io-shell io-decision">
      <div class="io-section-head">
        <p class="io-kicker">{copy.decision.kicker}</p>
        <h2>{copy.decision.title}</h2>
        <p>{copy.decision.body}</p>
      </div>
      <div class="io-decision-grid">
        {
          copy.decision.routes.map((route: any) => (
            <a href={route.href}>
              <h3>{route.title}</h3>
              <p>{route.body}</p>
              <span>{route.cta}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-codebase">
      <div>
        <p class="io-kicker">{copy.codebase.kicker}</p>
        <h2>{copy.codebase.title}</h2>
      </div>
      <div class="io-codebase-grid">
        <article>
          <span><IoNodeIcon name="standard" /></span>
          <h3>{copy.codebase.publicTitle}</h3>
          <p>{copy.codebase.publicBody}</p>
        </article>
        <article>
          <span><IoNodeIcon name="build" /></span>
          <h3>{copy.codebase.privateTitle}</h3>
          <p>{copy.codebase.privateBody}</p>
        </article>
      </div>
    </section>

    <section class="io-shell io-process">
      <div class="io-section-head">
        <p class="io-kicker">{copy.processHead.kicker}</p>
        <h2>{copy.processHead.title}</h2>
      </div>
      <IoProcessMap steps={steps} />
    </section>

    <section class="io-shell io-final-cta">
      <h2>{copy.finalCta.title}</h2>
      <p>{copy.finalCta.body}</p>
      <div class="io-actions">
        <a class="io-btn io-btn-primary" href="/choose-template?plan=essential999">{copy.finalCta.primary}</a>
        <a class="io-btn io-btn-secondary" href="/cadrage-technique">{copy.finalCta.secondary}</a>
      </div>
    </section>
  </main>

  <style>
    .io-presence {
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-blue: #0b63f6;
      --io-line: rgba(148, 163, 184, 0.22);
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px), #f8fbff;
      background-size:
        34px 34px,
        34px 34px,
        auto;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 80rem);
      margin-inline: auto;
    }

    .io-hero {
      padding: 4.8rem 0 4rem;
    }

    .io-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(24rem, 1fr);
      gap: 3.5rem;
      align-items: center;
    }

    h1,
    h2,
    h3 {
      margin: 0;
      font-weight: 850;
      line-height: 1.04;
    }

    h1 {
      max-width: 42rem;
      font-size: 3.65rem;
    }

    h2 {
      font-size: 2.5rem;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-lead,
    .io-section-head p,
    .io-final-cta p {
      color: var(--io-muted);
      font-size: 1.12rem;
      line-height: 1.72;
    }

    .io-lead {
      max-width: 37rem;
      margin: 1.25rem 0 0;
    }

    .io-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 1.9rem;
    }

    .io-btn {
      display: inline-flex;
      min-height: 3rem;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 0.78rem 1.35rem;
      font-weight: 780;
      text-decoration: none;
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      background: rgba(255, 255, 255, 0.72);
      color: var(--io-ink);
    }

    .io-section-head {
      max-width: 44rem;
      margin-bottom: 2rem;
    }

    .io-offers,
    .io-level-guide,
    .io-thresholds,
    .io-decision,
    .io-codebase,
    .io-process {
      padding-bottom: 5rem;
    }

    .io-offer-grid,
    .io-model-grid,
    .io-codebase-grid {
      display: grid;
      gap: 1rem;
    }

    .io-offer-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .io-threshold-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .io-level-guide-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.85rem;
      counter-reset: level;
    }

    .io-level-guide-grid article {
      counter-increment: level;
      position: relative;
      overflow: hidden;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.2rem;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.035) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.035) 1px, transparent 1px), rgba(255, 255, 255, 0.86);
      background-size: 24px 24px;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .io-level-guide-grid article::before {
      content: counter(level, decimal-leading-zero);
      display: grid;
      width: 2.2rem;
      height: 2.2rem;
      place-items: center;
      border-radius: 0.55rem;
      margin-bottom: 1rem;
      background: rgba(37, 99, 235, 0.08);
      color: var(--io-blue);
      font-size: 0.72rem;
      font-weight: 900;
    }

    .io-level-guide-grid article:hover {
      transform: translateY(-3px);
      border-color: rgba(37, 99, 235, 0.3);
      box-shadow: 0 26px 64px -54px rgba(15, 23, 42, 0.42);
    }

    .io-level-guide-grid strong {
      display: block;
      color: var(--io-blue);
      font-size: 1.4rem;
      line-height: 1;
    }

    .io-level-guide-grid h3 {
      margin: 0.75rem 0 0.55rem;
      font-size: 1.05rem;
      line-height: 1.14;
    }

    .io-level-guide-grid p {
      margin: 0;
      color: var(--io-muted);
      font-size: 0.92rem;
      line-height: 1.58;
    }

    .io-threshold-grid article {
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.35rem;
      background: rgba(255, 255, 255, 0.8);
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease,
        box-shadow 180ms ease;
    }

    .io-threshold-grid article:hover {
      transform: translateY(-3px);
      border-color: rgba(37, 99, 235, 0.3);
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 26px 64px -54px rgba(15, 23, 42, 0.42);
    }

    .io-threshold-grid h3 {
      margin: 0 0 0.7rem;
      font-size: 1.3rem;
      line-height: 1.12;
    }

    .io-threshold-grid p {
      margin: 0;
      color: var(--io-muted);
      line-height: 1.62;
    }

    .io-offer-grid article,
    .io-codebase article {
      display: grid;
      gap: 0.9rem;
      align-content: start;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.35rem;
      background: rgba(255, 255, 255, 0.8);
      scroll-margin-top: 7rem;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease,
        box-shadow 180ms ease;
    }

    .io-offer-grid article:hover,
    .io-offer-grid article:target,
    .io-codebase article:hover {
      transform: translateY(-3px);
      border-color: rgba(37, 99, 235, 0.32);
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 26px 64px -54px rgba(15, 23, 42, 0.42);
    }

    .io-offer-grid article:active,
    .io-codebase article:active {
      transform: translateY(-1px) scale(0.997);
    }

    .io-price {
      color: var(--io-blue);
      font-size: 1.8rem;
      line-height: 1;
    }

    .io-offer-grid p,
    .io-codebase p,
    .io-model-grid p {
      margin: 0;
      color: var(--io-muted);
      line-height: 1.62;
    }

    .io-offer-grid ul {
      display: grid;
      gap: 0.55rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .io-offer-grid li {
      position: relative;
      padding-left: 1rem;
      color: #334155;
      font-size: 0.94rem;
      font-weight: 680;
      line-height: 1.5;
    }

    .io-offer-grid li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.7em;
      width: 0.38rem;
      height: 0.38rem;
      border-radius: 999px;
      background: var(--io-blue);
    }

    .io-link,
    .io-model-grid a {
      color: var(--io-blue);
      font-weight: 800;
      text-decoration: none;
    }

    .io-models {
      margin-bottom: 5rem;
      padding: 5rem 0;
      background: #fff;
    }

    .io-model-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .io-model-grid article {
      overflow: hidden;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      background: #fff;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .io-model-grid article:hover {
      transform: translateY(-3px);
      border-color: rgba(37, 99, 235, 0.3);
      box-shadow: 0 26px 64px -54px rgba(15, 23, 42, 0.42);
    }

    .io-model-grid article:active {
      transform: translateY(-1px) scale(0.997);
    }

    .io-model-preview {
      aspect-ratio: 16 / 10;
      overflow: hidden;
      border-bottom: 1px solid var(--io-line);
      background: #f1f5f9;
    }

    .io-model-preview img {
      width: 100%;
      height: 100%;
    }

    .io-model-grid article > div:last-child {
      display: grid;
      gap: 0.7rem;
      padding: 1rem;
    }

    .io-decision {
      padding-top: 0.25rem;
    }

    .io-decision-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .io-decision-grid a {
      display: grid;
      gap: 0.75rem;
      align-content: start;
      min-height: 14rem;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.2rem;
      background: rgba(255, 255, 255, 0.82);
      color: inherit;
      text-decoration: none;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease,
        box-shadow 180ms ease;
    }

    .io-decision-grid a:hover,
    .io-decision-grid a:focus-visible {
      transform: translateY(-3px);
      border-color: rgba(37, 99, 235, 0.32);
      background: rgba(255, 255, 255, 0.95);
      box-shadow: 0 26px 64px -54px rgba(15, 23, 42, 0.42);
      outline: none;
    }

    .io-decision-grid a:active {
      transform: translateY(-1px) scale(0.997);
    }

    .io-decision-grid h3 {
      font-size: 1.12rem;
    }

    .io-decision-grid p {
      margin: 0;
      color: var(--io-muted);
      line-height: 1.58;
    }

    .io-decision-grid span {
      margin-top: auto;
      color: var(--io-blue);
      font-weight: 820;
    }

    .io-codebase {
      display: grid;
      grid-template-columns: minmax(0, 0.75fr) minmax(24rem, 1fr);
      gap: 3rem;
      align-items: start;
    }

    .io-codebase-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .io-codebase span {
      display: grid;
      width: 2.7rem;
      height: 2.7rem;
      place-items: center;
      border: 1px solid rgba(37, 99, 235, 0.2);
      border-radius: 0.72rem;
      color: var(--io-blue);
      background: rgba(37, 99, 235, 0.05);
    }

    .io-final-cta {
      margin-bottom: 5rem;
      border: 1px solid var(--io-line);
      border-radius: 1.25rem;
      padding: 2.5rem;
      background: #fff;
      text-align: center;
    }

    .io-final-cta p {
      max-width: 44rem;
      margin: 1rem auto 0;
    }

    .io-final-cta .io-actions {
      justify-content: center;
    }

    @media (max-width: 1024px) {
      .io-hero-grid,
      .io-codebase {
