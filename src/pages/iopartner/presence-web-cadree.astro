      title: 'Lo standard resta utile. L’autonomia aumenta solo quando è davvero necessaria.',
    },
    offers: [
      {
        price: 'CHF 999',
        title: 'Pack Essential',
        body: 'Presenza web professionale, perimetro breve, architettura leggera e manutenzione semplice.',
        href: '/choose-template?plan=essential999',
        cta: 'Vedere progetti CHF 999',
      },
      {
