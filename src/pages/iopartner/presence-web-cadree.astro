      { label: '01', title: 'Level', detail: '999, 1,500 or private.', icon: 'scope' },
      { label: '02', title: 'Examples', detail: 'View comparable projects.', icon: 'standard' },
      { label: '03', title: 'Content', detail: 'Texts, images, pages.', icon: 'content' },
      { label: '04', title: 'Go-live', detail: 'Validation and handoff.', icon: 'deploy' },
    ] satisfies Array<{ label: string; title: string; detail: string; icon: IoIconName }>,
    finalCta: {
      title: 'Launch a web presence without overbuilding.',
      body: 'Start with a clear level. If the need exceeds scoped web presence, we move toward editable or technical scoping.',
      primary: 'View projects from CHF 999',
      secondary: 'Scope before launch',
    },
  },
  de: {
    metadata: {
      title: 'Klare Web-Präsenz — IOPartner',
      description:
        'Klare Web-Präsenz für KMU: Website ab CHF 999, mit klarer Schwelle zu editierbarer Website oder privatem Build.',
