      ['Ruhig premium', 'Typografie, Raum, redaktionelleres Angebot.', 'Diese Basis wählen'],
      ['Visuelles Portfolio', 'Galerie, Leistungen und einfacher Kontaktweg.', 'Diese Basis wählen'],
    ],
    codebase: {
      kicker: 'Öffentlich oder privat',
      title: 'Die wichtige Wahl ist nicht nur visuell.',
      publicTitle: 'Öffentliche Basis',
