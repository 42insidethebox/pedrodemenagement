---
import Layout from '~/layouts/Layout.astro';

export const prerender = false;
---

<Layout metadata={{ title: 'Merci — IOPartner' }} brandKey="iopartner">
  <main class="min-h-screen bg-slate-50 flex flex-col items-center justify-center px-4 py-16 text-center">
    <div class="max-w-xl rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <div class="w-14 h-14 rounded-full bg-blue-50 flex items-center justify-center mx-auto mb-6">
        <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-slate-950 mb-4">Contexte reçu.</h1>
      <p class="text-lg text-slate-600 mb-8">
        Nous revenons vers vous avec la voie la plus rationnelle: présence web cadrée, cadrage technique ou systèmes &
        opérations.
      </p>

      <div class="flex flex-wrap justify-center gap-3">
        <a href="/iopartner" class="rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white">
          Revenir à l’accueil
        </a>
        <a
          href="/iopartner/pricing"
          class="rounded-full border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-800"
        >
          Voir les tarifs
        </a>
      </div>
    </div>
  </main>
</Layout>
