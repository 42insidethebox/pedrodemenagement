---
import IoBlueprintVisual from '~/components/iopartner/IoBlueprintVisual.astro';
import IoProcessMap from '~/components/iopartner/IoProcessMap.astro';
import Io02SvgLinesPathsCurves from '~/components/iopartner/visuals/Io02SvgLinesPathsCurves.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Tarifs',
  description:
    'Tarifs IOPartner: consulting technique, systems & operations et déploiement standard dès 999 CHF, facturés en Suisse.',
};

const processSteps = [
  { label: '01', title: 'Cadrage', detail: 'Besoins & objectifs' },
  { label: '02', title: 'Déploiement', detail: 'Build & intégration' },
  { label: '03', title: 'Mise en ligne', detail: 'Tests & validation' },
  { label: '04', title: 'Suivi', detail: 'Support & évolutions' },
];

const matrix = [
  {
    id: 'consulting',
    kicker: 'Consulting technique',
    title: 'Décider vite',
    price: '60 CHF / 15 min',
    detail: 'Puis 140 CHF / h si le sujet demande plus de travail.',
    items: ['Arbitrage', 'Revue technique', 'Déblocage', 'Cadrage avant build'],
    href: '/contact#form',
    cta: 'Réserver un cadrage',
  },
  {
    id: 'systems-operations',
    kicker: 'Systems & operations',
    title: 'Construire proprement',
    price: 'Sur devis',
    detail: 'Architecture, backend, infrastructure, automatisation et continuité.',
    items: ['VPS / Docker / DNS', 'API & dashboards', 'Monitoring', 'Workflows métier'],
    href: '/contact#form',
    cta: 'Discuter du scope',
    dark: true,
  },
  {
    id: 'standard-deployment',
    kicker: 'Déploiement standard',
    title: 'Lancer sans surconstruire',
    price: '999 CHF',
    detail: 'Site vitrine professionnel, cadré, livré rapidement selon vos contenus.',
    items: ['5 sections', 'Design responsive', 'Contenu intégré', 'Livraison 3-5 jours'],
    href: '/onboarding?plan=essential999',
    cta: 'Démarrer le projet',
  },
];

const faqs = [
  {
    title: 'Les prix incluent-ils la TVA ?',
    body: 'Oui, les montants publics sont affichés TTC et facturés en Suisse.',
  },
  {
    title: 'Pourquoi commencer par 60 CHF / 15 min ?',
    body: 'C’est le format le plus léger pour acheter de la clarté avant de lancer un projet plus large.',
  },
  {
    title: 'Le déploiement standard peut-il évoluer ?',
    body: 'Oui. On peut ajouter des modules cadrés ou passer vers systems & operations si le besoin sort du standard.',
  },
  {
    title: 'Quand faut-il un devis ?',
    body: 'Dès que le sujet implique codebase privée, backend, infrastructure, automatisation avancée ou continuité technique.',
  },
];
---

<Layout metadata={metadata}>
  <main class="io-pricing">
    <section class="io-pricing-hero">
      <div class="io-shell io-pricing-hero-grid">
        <div>
          <p class="io-kicker">Tarifs</p>
          <h1>Des offres transparentes, facturées en Suisse.</h1>
          <p class="io-lead">
            Deux voies standards pour les sites simples, puis du consulting et une couche systems & operations pour les
            sujets qui dépassent réellement le template.
          </p>
        </div>
        <IoBlueprintVisual variant="pricing" />
      </div>
    </section>

    <section class="io-shell io-standard-strip" id="standard-deployment">
      <div class="io-standard-icon">
        <span></span>
        <strong>Déploiement standard</strong>
      </div>
      <div class="io-standard-copy">
        <p class="io-kicker">Standard deployment</p>
        <h2>Pack Essentiel — dès 999 CHF</h2>
        <p>
          Prix fixe pour un site vitrine professionnel. Livraison typique en 3-5 jours ouvrables selon vos contenus.
        </p>
        <div class="io-standard-facts">
          <span>3-5 jours</span>
          <span>Contenu fourni</span>
          <span>Prix fixe</span>
        </div>
      </div>
      <div class="io-standard-action">
        <a class="io-btn io-btn-dark" href="/onboarding?plan=essential999">Commander maintenant</a>
        <small>999 CHF — paiement unique</small>
      </div>
    </section>

    <section class="io-shell io-price-matrix" id="pricing-options">
      <div class="io-section-head">
        <p class="io-kicker">Trois niveaux</p>
        <h2>Le standard quand il suffit. Le sur mesure quand il faut.</h2>
      </div>

      <div class="io-matrix-grid">
        {
          matrix.map((offer) => (
            <article class:list={['io-matrix-card', offer.dark && 'io-matrix-card-dark']} id={offer.id}>
              <p class="io-kicker">{offer.kicker}</p>
              <h3>{offer.title}</h3>
              <strong class="io-price">{offer.price}</strong>
              <p>{offer.detail}</p>
              <ul>
                {offer.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <a class:list={['io-btn', offer.dark ? 'io-btn-light' : 'io-btn-primary']} href={offer.href}>
                {offer.cta}
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-extensions">
      <article>
        <p class="io-kicker">Extensions opérationnelles</p>
        <h2>Ajoutez seulement ce qui sert.</h2>
        <div class="io-extension-list">
          <div>
            <strong>Communication & rendez-vous intégrés</strong>
            <span>+250 CHF</span>
          </div>
          <div>
            <strong>Automatisations simples & formulaires</strong>
            <span>à cadrer</span>
          </div>
          <div>
            <strong>Passation courte</strong>
            <span>incluse selon scope</span>
          </div>
        </div>
      </article>
      <article class="io-advanced-panel">
        <p class="io-kicker">Palier avancé</p>
        <h2>Besoin d’un vrai système ?</h2>
        <p>
          Quand le sujet dépasse un site standard: architecture, backend, automatisation, infrastructure et continuité.
        </p>
        <ul>
          <li><strong>Consulting technique</strong><span>Arbitrage, cadrage, direction technique</span></li>
          <li><strong>Build systems</strong><span>Développement, API, outils internes</span></li>
          <li><strong>Infrastructure & operations</strong><span>Environnements, monitoring, sécurité</span></li>
          <li><strong>Continuité technique</strong><span>Support, incidents, évolutions</span></li>
        </ul>
        <a class="io-btn io-btn-light" href="/systems-operations">Voir systems & operations</a>
      </article>
    </section>

    <section class="io-systems-band">
      <div class="io-shell io-systems-grid">
        <div>
          <p class="io-kicker">Systems & operations</p>
          <h2>Une couche avancée, cadrée avant build.</h2>
          <p>
            Codebase privée, API, automatisations, Linux, Docker, DNS, SSL, monitoring et continuité ne se vendent pas
            comme un pack. Le scope vient après cadrage.
          </p>
          <div class="io-stack-line">Docker · VPS · DNS · SSL · monitoring · workflows · API · dashboards</div>
        </div>
        <Io02SvgLinesPathsCurves />
      </div>
    </section>

    <section class="io-shell io-process">
      <div class="io-section-head">
        <p class="io-kicker">Parcours</p>
        <h2>Une séquence courte, lisible.</h2>
      </div>
      <IoProcessMap steps={processSteps} />
    </section>

    <section class="io-shell io-faq">
      <div class="io-section-head">
        <p class="io-kicker">FAQ</p>
        <h2>Questions sur les tarifs</h2>
      </div>
      <div class="io-faq-list">
        {
          faqs.map((faq) => (
            <details>
              <summary>{faq.title}</summary>
              <p>{faq.body}</p>
            </details>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-final-cta">
      <h2>Choisir le bon niveau avant de payer trop de custom.</h2>
      <p>Envoyez le contexte. Nous vous orientons vers consulting, systems & operations, ou déploiement standard.</p>
      <div class="io-actions">
        <a class="io-btn io-btn-primary" href="/contact#form">Envoyer le contexte</a>
        <a class="io-btn io-btn-secondary" href="/choose-template?plan=essential999">Choisir une base</a>
      </div>
    </section>
  </main>

  <style>
    .io-pricing {
      --io-dark: #07111f;
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-line: rgba(148, 163, 184, 0.22);
      --io-blue: #0b63f6;
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px), #f8fbff;
      background-size:
        34px 34px,
        34px 34px,
        100% 100%;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 80rem);
      margin-inline: auto;
    }

    .io-pricing-hero {
      padding: 4.6rem 0 3.6rem;
    }

    .io-pricing-hero-grid,
    .io-systems-grid,
    .io-extensions {
      display: grid;
      grid-template-columns: minmax(0, 0.86fr) minmax(24rem, 1fr);
      gap: 3.6rem;
      align-items: center;
    }

    .io-pricing-hero h1,
    .io-section-head h2,
    .io-standard-copy h2,
    .io-extensions h2,
    .io-systems-band h2,
    .io-final-cta h2 {
      margin: 0;
      font-weight: 850;
      line-height: 1.04;
    }

    .io-pricing-hero h1 {
      max-width: 38rem;
      font-size: 3.45rem;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-lead,
    .io-section-head p,
    .io-standard-copy p,
    .io-extensions p,
    .io-systems-band p,
    .io-final-cta p {
      color: var(--io-muted);
      font-size: 1.12rem;
      line-height: 1.72;
    }

    .io-lead {
      max-width: 35rem;
      margin: 1.35rem 0 0;
      font-size: 1.12rem;
    }

    .io-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3rem;
      border-radius: 999px;
      padding: 0.78rem 1.35rem;
      font-weight: 780;
      text-decoration: none;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease;
    }

    .io-btn:hover,
    .io-btn:focus-visible {
      transform: translateY(-1px);
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      color: var(--io-ink);
      background: rgba(255, 255, 255, 0.72);
    }

    .io-btn-dark {
      background: #061120;
      color: #fff;
    }

    .io-btn-light {
      border: 1px solid rgba(226, 232, 240, 0.34);
      color: #f8fafc;
      background: rgba(255, 255, 255, 0.04);
    }

    .io-standard-strip {
      display: grid;
      grid-template-columns: 10.5rem minmax(0, 1fr) auto;
      gap: 2.3rem;
      align-items: center;
      margin-bottom: 4.8rem;
      padding: 1.65rem;
      border: 1px solid rgba(37, 99, 235, 0.18);
      border-radius: 1.15rem;
      background: rgba(255, 255, 255, 0.8);
      box-shadow: 0 28px 82px -72px rgba(15, 23, 42, 0.46);
    }

    .io-standard-icon {
      display: grid;
      gap: 1rem;
      justify-items: center;
      border-right: 1px solid var(--io-line);
      padding-right: 1.65rem;
      color: var(--io-blue);
      font-size: 0.9rem;
      font-weight: 820;
      text-align: center;
      text-transform: uppercase;
    }

    .io-standard-icon span {
      display: block;
      width: 4rem;
      height: 4rem;
      border: 1px solid rgba(37, 99, 235, 0.25);
      border-radius: 0.8rem;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.18) 2px, transparent 2px),
        linear-gradient(rgba(37, 99, 235, 0.18) 2px, transparent 2px), #061120;
      background-size: 18px 18px;
    }

    .io-standard-copy h2 {
      font-size: 1.78rem;
    }

    .io-standard-copy p {
      margin: 0.75rem 0 0;
    }

    .io-standard-facts {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 1.2rem;
      color: #334155;
      font-weight: 760;
    }

    .io-standard-action {
      display: grid;
      gap: 0.8rem;
      justify-items: center;
      min-width: 16rem;
    }

    .io-standard-action small {
      color: var(--io-muted);
    }

    .io-section-head {
      max-width: 39rem;
      margin-bottom: 2.25rem;
    }

    .io-section-head h2,
    .io-extensions h2,
    .io-systems-band h2,
    .io-final-cta h2 {
      font-size: 2.55rem;
    }

    .io-price-matrix,
    .io-process,
    .io-faq {
      padding-bottom: 5rem;
    }

    .io-matrix-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.4rem;
    }

    .io-matrix-card {
      display: grid;
      gap: 1rem;
      align-content: start;
      min-height: 27.2rem;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.35rem;
      background: rgba(255, 255, 255, 0.82);
    }

    .io-matrix-card-dark {
      border-color: rgba(125, 211, 252, 0.18);
      background: #061120;
      color: #f8fafc;
    }

    .io-matrix-card h3 {
      margin: 0;
      font-size: 1.42rem;
      line-height: 1.15;
    }

    .io-price {
      display: block;
      font-size: 1.95rem;
      line-height: 1.05;
    }

    .io-matrix-card p {
      margin: 0;
      color: var(--io-muted);
      line-height: 1.62;
    }

    .io-matrix-card-dark p {
      color: #cbd5e1;
    }

    .io-matrix-card ul,
    .io-advanced-panel ul {
      display: grid;
      gap: 0.75rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .io-matrix-card li {
      color: #334155;
      font-weight: 680;
    }

    .io-matrix-card-dark li {
      color: #dbeafe;
    }

    .io-matrix-card .io-btn {
      align-self: end;
      width: fit-content;
      margin-top: auto;
    }

    .io-extensions {
      align-items: stretch;
      padding-bottom: 5rem;
    }

    .io-extensions > article {
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.65rem;
      background: rgba(255, 255, 255, 0.78);
    }

    .io-extension-list {
      display: grid;
      gap: 0;
      margin-top: 1.6rem;
      border-top: 1px solid var(--io-line);
    }

    .io-extension-list div {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid var(--io-line);
    }

    .io-extension-list span {
      color: var(--io-ink);
      font-weight: 800;
      white-space: nowrap;
    }

    .io-advanced-panel {
      background: #061120 !important;
      color: #f8fafc;
    }

    .io-advanced-panel h2 {
      color: #fff;
      font-size: 1.95rem;
    }

    .io-advanced-panel p {
      color: #cbd5e1;
    }

    .io-advanced-panel li {
      display: grid;
      gap: 0.2rem;
      padding: 0.85rem 0;
      border-top: 1px solid rgba(226, 232, 240, 0.16);
    }

    .io-advanced-panel li span {
      color: #94a3b8;
      font-size: 0.92rem;
    }

    .io-systems-band {
      margin-bottom: 5rem;
      padding: 5.2rem 0;
      background: #061120;
      color: #f8fafc;
    }

    .io-systems-band h2 {
      color: #fff;
    }

    .io-systems-band p {
      max-width: 35rem;
      color: #cbd5e1;
    }

    .io-stack-line {
      margin-top: 1.5rem;
      color: #93c5fd;
      font-weight: 760;
      line-height: 1.6;
    }

    .io-faq-list {
      display: grid;
      gap: 0.8rem;
      max-width: 58rem;
    }

    .io-faq details {
      border: 1px solid var(--io-line);
      border-radius: 0.8rem;
      background: rgba(255, 255, 255, 0.78);
      padding: 1.1rem 1.25rem;
    }

    .io-faq summary {
      cursor: pointer;
      color: var(--io-ink);
      font-weight: 780;
    }

    .io-faq details p {
      margin: 0.85rem 0 0;
      color: var(--io-muted);
      line-height: 1.65;
    }

    .io-final-cta {
      margin-bottom: 5.4rem;
      padding: 2.5rem;
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 1.25rem;
      background: #fff;
      text-align: center;
    }

    .io-final-cta p {
      max-width: 42rem;
      margin: 1rem auto 0;
    }

    .io-actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.85rem;
      margin-top: 1.8rem;
    }

    @media (max-width: 1100px) {
      .io-pricing-hero-grid,
      .io-systems-grid,
      .io-extensions {
        grid-template-columns: 1fr;
      }

      .io-matrix-grid {
        grid-template-columns: 1fr;
      }

      .io-standard-strip {
        grid-template-columns: 1fr;
      }

      .io-standard-icon {
        justify-items: start;
        border-right: 0;
        border-bottom: 1px solid var(--io-line);
        padding-right: 0;
        padding-bottom: 1.5rem;
        text-align: left;
      }

      .io-standard-action {
        justify-items: start;
      }
    }

    @media (max-width: 640px) {
      .io-shell {
        width: min(100% - 1rem, 80rem);
      }

      .io-pricing-hero h1 {
        font-size: 2.35rem;
      }

      .io-section-head h2,
      .io-extensions h2,
      .io-systems-band h2,
      .io-final-cta h2 {
        font-size: 1.92rem;
      }

      .io-standard-strip,
      .io-matrix-card,
      .io-extensions > article,
      .io-final-cta {
        padding: 1.2rem;
      }

      .io-extension-list div {
        display: grid;
      }
    }
  </style>
</Layout>
