---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Tarifs',
};

const pricingTabs = [
  { key: 'website', label: 'Website building' },
  { key: 'consulting', label: 'Consulting' },
  { key: 'systems', label: 'Systems & operations' },
];

const requestedTabRaw = Astro.url.searchParams.get('tab');
const requestedTab =
  requestedTabRaw === 'custom' ||
  requestedTabRaw === 'operations' ||
  requestedTabRaw === 'support' ||
  requestedTabRaw === 'systems'
    ? 'systems'
    : requestedTabRaw;
const defaultPricingTab = pricingTabs.some((tab) => tab.key === requestedTab) ? requestedTab : 'consulting';

const websiteOffers = [
  {
    title: 'Essentiel',
    subtitle: 'Site vitrine professionnel dès 999 CHF',
    price: '999',
    period: 'paiement unique',
    info: [
      'Pack 999 = site vitrine standard de 5 sections sur l’infrastructure mutualisée IOPartner.',
      'Ajout de pages, brainstorming, changement de structure ou nouveaux modules sur devis.',
      'Toute demande hors périmètre est facturée séparément avant production.',
    ],
    items: [
      'Site vitrine 5 sections + page contact responsive',
      'Intégration et mise en forme de vos contenus',
      'Déploiement sur l’infrastructure mutualisée IOPartner',
    ],
    cta: { text: 'Choisir un style →', href: '/choose-template?plan=essential999' },
  },
  {
    title: 'Pack 1 500',
    subtitle: 'Site standard + WhatsApp + Calendly',
    price: '1500',
    period: 'paiement unique',
    info: [
      'Toujours dans la logique standard IOPartner, sans entrer dans une build privée.',
      'WhatsApp, Calendly et passation légère inclus dans le périmètre validé.',
      'Pages en plus, redesign, brainstorming ou modules hors scope sur devis séparé.',
    ],
    items: [
      'Inclut la base 999 CHF',
      'WhatsApp cliquable + prise de rendez-vous Calendly',
      'Explication légère et handoff simple',
    ],
    cta: { text: 'Choisir le pack 1 500 →', href: '/choose-template?plan=essential1500' },
  },
];

const consultingOffers = [
  {
    title: 'Sprint 15 minutes',
    subtitle: 'Payé d’avance',
    price: '60',
    period: '15 min payés d’avance',
    info: [
      'À utiliser pour une question technique ciblée ou un blocage précis.',
      'Réservation et paiement avant le créneau.',
      'Le bon format pour obtenir de la clarté avant un périmètre plus large.',
    ],
    items: [
      'Arbitrage rapide ou mini-appel d’architecture',
      'Déblocage technique, question d’intégration ou validation de direction',
      'Réponse rapide sans engager tout de suite un projet complet',
    ],
    cta: { text: 'Réserver le consulting 15 min →', href: '/contact#form' },
  },
  {
    title: 'Consulting technique',
    subtitle: 'Support engineering senior',
    price: '140',
    period: 'CHF / heure',
    info: [
      'Pour revue d’architecture, debugging, delivery planning ou accompagnement d’implémentation.',
      'Le travail horaire démarre une fois le sujet confirmé.',
      'Le bon format quand le besoin dépasse largement 15 minutes.',
    ],
    items: [
      'Code review, debugging, revue d’architecture',
      'Guidage delivery et direction d’implémentation',
      'Support horaire pour les sujets techniques ouverts',
    ],
    cta: { text: 'Demander du consulting horaire →', href: '/contact#form' },
  },
];

const operationsOffers = [
  {
    title: 'Continuité technique',
    subtitle:
      'Gardez un point de contact technique stable après la mise en ligne ou entre deux projets plus complexes.',
    price: 'à cadrer',
    period: 'selon niveau de continuité',
    info: [
      'L’accompagnement continu dépend du niveau de support attendu, des systèmes concernés et du degré d’autonomie souhaité.',
      'Certaines structures ont seulement besoin d’un suivi léger, d’autres d’un véritable relais technique externe.',
      'Le bon format quand vous voulez éviter que les sujets techniques retombent entre deux projets.',
    ],
    items: [
      'Continuité technique après livraison ou entre deux projets',
      'DNS, emails, sauvegardes, contenu, monitoring ou incidents opérationnels courants',
      'Un interlocuteur qui garde le contexte et évite les pertes de continuité',
    ],
    cta: { text: 'Parler de la continuité →', href: '/contact#form' },
  },
  {
    title: 'Infrastructure',
    subtitle: 'Déploiement, supervision et maintenance d’environnements techniques plus solides.',
    price: 'à cadrer',
    period: 'selon environnement',
    info: [
      'Pour VPS, Linux, Docker, reverse proxy, SSL, monitoring ou migrations.',
      'Le périmètre dépend de la stack, du niveau de criticité et du besoin de supervision.',
      'Peut suivre un projet systems & operations ou exister comme chantier séparé.',
    ],
    items: [
      'VPS, Linux, Docker, reverse proxy, SSL / DNS',
      'Backups, monitoring, migrations et déploiement',
      'Base technique plus propre pour outils internes ou systèmes web',
    ],
    cta: { text: 'Demander un scope infra →', href: '/contact#form' },
  },
  {
    title: 'Automatisation',
    subtitle: 'Réduction des tâches manuelles et orchestration de workflows simples ou avancés.',
    price: 'à cadrer',
    period: 'selon workflow',
    info: [
      'Pour relier des outils, supprimer des étapes manuelles ou fluidifier un processus interne.',
      'Peut inclure n8n, Zapier, CRM sync, onboarding, notifications ou pipelines documentaires.',
      'Le consulting payant reste la meilleure entrée si le workflow n’est pas encore clair.',
    ],
    items: [
      'n8n, Zapier, CRM sync, onboarding et notifications',
      'Flows documentaires, automatisations métier et workflows IA assistés',
      'Moins de tâches manuelles, plus de continuité opérationnelle',
    ],
    cta: { text: 'Demander un scope automation →', href: '/contact#form' },
  },
];
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    class="tsw-pricing-hero"
    tagline="Tarifs"
    title="Des offres transparentes, facturées en Suisse"
    subtitle="Deux voies standards pour les sites simples, puis du consulting et une couche systems & operations pour les sujets qui dépassent réellement le template."
  >
    <Fragment slot="bg">
      <div class="tsw-pricing-hero-bg"></div>
      <div class="tsw-pricing-hero-plate" aria-hidden="true"></div>
      <div class="tsw-pricing-hero-axis" aria-hidden="true"></div>
      <div class="tsw-pricing-hero-orbit" aria-hidden="true"></div>
    </Fragment>
  </HeroText>

  <div class="max-w-3xl mx-auto px-4 mb-2">
    <div
      class="tsw-pricing-banner rounded-2xl border-2 border-slate-200 bg-stone-50 dark:bg-slate-900/30 px-6 py-4 text-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
    >
      <p class="text-lg font-bold text-slate-900 dark:text-slate-100">Pack Essentiel — dès 999 CHF</p>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
        Prix fixe pour un site vitrine professionnel. Livraison typique en 3–5 jours ouvrables selon vos contenus.
      </p>
      <a
        href="/onboarding?plan=essential999"
        class="mt-3 inline-block bg-slate-900 hover:bg-slate-700 text-white font-bold text-sm px-6 py-2 rounded-xl transition-colors"
        >Commander maintenant →</a
      >
    </div>
  </div>

  <section class="relative not-prose scroll-mt-[72px]">
    <div class="relative mx-auto max-w-7xl px-4 md:px-6 py-12 md:py-16 lg:py-20 text-default">
      <div class="mb-8 md:mx-auto md:mb-12 text-center max-w-3xl">
        <h2 class="font-bold leading-tighter tracking-tighter font-heading text-heading text-3xl md:text-4xl">
          Nos packs clés-en-main
        </h2>
        <p class="mt-4 text-muted text-xl">Choisissez l'offre qui correspond à votre besoin. Sans frais cachés.</p>
      </div>

      <div
        id="pricing-options"
        class="tsw-pricing-tabs tsw-pricing-shell scroll-mt-32 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <input
          class="tsw-pricing-switch"
          type="radio"
          name="tsw-pricing-tabs-fr"
          id="tsw-pricing-tab-website"
          checked={defaultPricingTab === 'website'}
        />
        <input
          class="tsw-pricing-switch"
          type="radio"
          name="tsw-pricing-tabs-fr"
          id="tsw-pricing-tab-consulting"
          checked={defaultPricingTab === 'consulting'}
        />
        <input
          class="tsw-pricing-switch"
          type="radio"
          name="tsw-pricing-tabs-fr"
          id="tsw-pricing-tab-systems"
          checked={defaultPricingTab === 'systems'}
        />

        <div class="tsw-pricing-tablist" aria-label="Parcours tarifaires IOPartner">
          {
            pricingTabs.map((tab) => (
              <label class="tsw-pricing-tab" for={`tsw-pricing-tab-${tab.key}`}>
                {tab.label}
              </label>
            ))
          }
        </div>

        <div class="mt-8 tsw-pricing-panels">
          <section id="website-building" class="tsw-pricing-panel tsw-pricing-panel-website scroll-mt-32">
            <div class="tsw-pricing-grid">
              {
                websiteOffers.map((offer) => (
                  <article class="tsw-price-card tsw-price-card-tooltip">
                    <div class="px-2 py-0">
                      <div class="mb-2 flex items-center justify-center gap-2">
                        <h3 class="text-center text-xl font-semibold uppercase leading-6 tracking-wider">
                          {offer.title}
                        </h3>
                        <div class="relative inline-block group">
                          <button
                            type="button"
                            class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-gray-300 text-[11px] leading-none text-gray-600 focus:outline-none focus:ring-2 focus:ring-primary dark:text-gray-300"
                            aria-label="Info"
                          >
                            i
                          </button>
                          <div class="pointer-events-none absolute left-1/2 top-full z-30 mt-2 hidden w-72 -translate-x-1/2 rounded-md border border-gray-200 bg-white p-3 text-left text-sm shadow-xl group-hover:block group-focus-within:block dark:border-gray-700 dark:bg-slate-900">
                            <ul class="space-y-1">
                              {offer.info.map((line) => (
                                <li>• {line}</li>
                              ))}
                            </ul>
                          </div>
                        </div>
                      </div>
                      <p class="font-light sm:text-lg text-gray-600 dark:text-slate-400">{offer.subtitle}</p>
                      <div class="my-8">
                        <div class="flex items-center justify-center text-center mb-1">
                          <span class="text-2xl mr-2">CHF</span>
                          <span class="text-6xl font-extrabold">{offer.price}</span>
                        </div>
                        <span class="text-base leading-6 lowercase text-gray-600 dark:text-slate-400">
                          {offer.period}
                        </span>
                      </div>
                      <ul class="my-8 md:my-10 space-y-3 text-center">
                        {offer.items.map((item) => (
                          <li class="mb-1.5 flex items-center justify-center gap-3 leading-7 text-center">
                            <div class="rounded-full bg-primary flex items-center justify-center w-7 h-7">
                              <span class="text-white text-sm font-bold">✓</span>
                            </div>
                            <span class="text-base">{item}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                    <div class="flex justify-center">
                      <a class="btn btn-primary" href={offer.cta.href}>
                        {offer.cta.text}
                      </a>
                    </div>
                  </article>
                ))
              }

              <article class="tsw-price-card tsw-price-card-muted">
                <div class="px-2 py-0">
                  <h3 class="text-center text-xl font-semibold uppercase leading-6 tracking-wider">
                    Besoin de plus qu’un site standard ?
                  </h3>
                  <p class="mt-3 font-light sm:text-lg text-gray-600 dark:text-slate-400">
                    Gardez la structure, puis passez en consulting ou en systems & operations dès que le sujet devient
                    réellement technique.
                  </p>
                  <ul class="my-8 md:my-10 space-y-3 text-center">
                    <li class="mb-1.5 flex items-center justify-center gap-3 leading-7 text-center">
                      <div class="rounded-full bg-primary flex items-center justify-center w-7 h-7">
                        <span class="text-white text-sm font-bold">→</span>
                      </div>
                      <span class="text-base"
                        >Utilisez le consulting pour arbitrer vite ou débloquer un point précis</span
                      >
                    </li>
                    <li class="mb-1.5 flex items-center justify-center gap-3 leading-7 text-center">
                      <div class="rounded-full bg-primary flex items-center justify-center w-7 h-7">
                        <span class="text-white text-sm font-bold">→</span>
                      </div>
                      <span class="text-base"
                        >Utilisez systems & operations pour codebase privée, backend, infra ou intégrations</span
                      >
                    </li>
                  </ul>
                </div>
                <div class="flex justify-center gap-3 flex-wrap">
                  <label class="btn cursor-pointer" for="tsw-pricing-tab-consulting">Voir le consulting</label>
                  <label class="btn btn-primary cursor-pointer" for="tsw-pricing-tab-systems"
                    >Voir systems & operations</label
                  >
                </div>
              </article>
            </div>
          </section>

          <section id="consulting" class="tsw-pricing-panel tsw-pricing-panel-consulting scroll-mt-32">
            <div class="tsw-pricing-grid">
              {
                consultingOffers.map((offer) => (
                  <article class="tsw-price-card tsw-price-card-tooltip">
                    <div class="px-2 py-0">
                      <div class="mb-2 flex items-center justify-center gap-2">
                        <h3 class="text-center text-xl font-semibold uppercase leading-6 tracking-wider">
                          {offer.title}
                        </h3>
                        <div class="relative inline-block group">
                          <button
                            type="button"
                            class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-gray-300 text-[11px] leading-none text-gray-600 focus:outline-none focus:ring-2 focus:ring-primary dark:text-gray-300"
                            aria-label="Info"
                          >
                            i
                          </button>
                          <div class="pointer-events-none absolute left-1/2 top-full z-30 mt-2 hidden w-72 -translate-x-1/2 rounded-md border border-gray-200 bg-white p-3 text-left text-sm shadow-xl group-hover:block group-focus-within:block dark:border-gray-700 dark:bg-slate-900">
                            <ul class="space-y-1">
                              {offer.info.map((line) => (
                                <li>• {line}</li>
                              ))}
                            </ul>
                          </div>
                        </div>
                      </div>
                      <p class="font-light sm:text-lg text-gray-600 dark:text-slate-400">{offer.subtitle}</p>
                      <div class="my-8">
                        <div class="flex items-center justify-center text-center mb-1">
                          <span class="text-2xl mr-2">CHF</span>
                          <span class="text-6xl font-extrabold">{offer.price}</span>
                        </div>
                        <span class="text-base leading-6 text-gray-600 dark:text-slate-400">{offer.period}</span>
                      </div>
                      <ul class="my-8 md:my-10 space-y-3 text-center">
                        {offer.items.map((item) => (
                          <li class="mb-1.5 flex items-center justify-center gap-3 leading-7 text-center">
                            <div class="rounded-full bg-primary flex items-center justify-center w-7 h-7">
                              <span class="text-white text-sm font-bold">✓</span>
                            </div>
                            <span class="text-base">{item}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                    <div class="flex justify-center">
                      <a class="btn btn-primary" href={offer.cta.href}>
                        {offer.cta.text}
                      </a>
                    </div>
                  </article>
                ))
              }

              <article class="tsw-price-card tsw-price-card-muted">
                <div class="px-2 py-0">
                  <h3 class="text-center text-xl font-semibold uppercase leading-6 tracking-wider">
                    Cas d’usage typiques
                  </h3>
                  <p class="mt-3 font-light sm:text-lg text-gray-600 dark:text-slate-400">
                    Achetez d’abord de la clarté quand le sujet n’a pas encore besoin d’un scope de build complet.
                  </p>
                  <ul class="my-8 md:my-10 space-y-3 text-center">
                    <li class="mb-1.5 flex items-center justify-center gap-3 leading-7 text-center">
                      <div class="rounded-full bg-primary flex items-center justify-center w-7 h-7">
                        <span class="text-white text-sm font-bold">•</span>
                      </div>
                      <span class="text-base">Choisir entre template, codebase privée, backend ou vrai système</span>
                    </li>
                    <li class="mb-1.5 flex items-center justify-center gap-3 leading-7 text-center">
                      <div class="rounded-full bg-primary flex items-center justify-center w-7 h-7">
                        <span class="text-white text-sm font-bold">•</span>
                      </div>
                      <span class="text-base"
                        >Relire une architecture, un plan d’intégration ou une direction delivery</span
                      >
                    </li>
                    <li class="mb-1.5 flex items-center justify-center gap-3 leading-7 text-center">
                      <div class="rounded-full bg-primary flex items-center justify-center w-7 h-7">
                        <span class="text-white text-sm font-bold">•</span>
                      </div>
                      <span class="text-base">Débloquer un problème avant qu’un projet plus large ne démarre</span>
                    </li>
                  </ul>
                </div>
                <div class="flex justify-center">
                  <label class="btn cursor-pointer" for="tsw-pricing-tab-systems"
                    >Le consulting peut ouvrir vers systems & operations</label
                  >
                </div>
              </article>
            </div>
          </section>

          <section id="systems-operations" class="tsw-pricing-panel tsw-pricing-panel-systems scroll-mt-32">
            <div class="tsw-systems-layout">
              <article class="tsw-price-card tsw-blueprint-card tsw-blueprint-card-wide">
                <div class="tsw-blueprint-layout">
                  <div class="tsw-blueprint-copy">
                    <p class="tsw-blueprint-kicker">Engineering blueprint</p>
                    <h3 class="tsw-blueprint-title">
                      Infrastructure, automatisation, développement logiciel et continuité technique.
                    </h3>
                    <p class="tsw-blueprint-lead">
                      Une seule couche avancée pour les sujets qui dépassent un simple site vitrine: build systems,
                      environnements techniques, workflows et relais opérationnel.
                    </p>
                  </div>
                  <div class="tsw-blueprint-map" aria-hidden="true">
                    <div class="tsw-blueprint-node">
                      <strong>Build systems</strong>
                      <span>codebase privée · backend · API · outils internes</span>
                    </div>
                    <div class="tsw-blueprint-node">
                      <strong>Infra</strong>
                      <span>VPS · Docker · DNS · SSL · monitoring</span>
                    </div>
                    <div class="tsw-blueprint-node">
                      <strong>Automation</strong>
                      <span>n8n · CRM sync · notifications · flows documentaires</span>
                    </div>
                    <div class="tsw-blueprint-node">
                      <strong>Continuity</strong>
                      <span>incidents · support léger · coordination · suivi</span>
                    </div>
                  </div>
                </div>
              </article>

              <div class="tsw-systems-main-grid">
                <article class="tsw-price-card tsw-systems-build-panel">
                  <div class="tsw-systems-panel-head">
                    <p class="tsw-systems-panel-kicker">Scoped build</p>
                    <h3 class="tsw-systems-panel-title">Systèmes sur mesure</h3>
                    <p class="tsw-systems-panel-lead">
                      Codebase privée, backend, automatisation ou architecture plus lourde quand le sujet demande un
                      vrai système dédié et un périmètre cadré proprement.
                    </p>
                  </div>

                  <div class="tsw-systems-build-split">
                    <div class="tsw-systems-price-mark">
                      <span class="tsw-systems-price-prefix">à discuter</span>
                      <strong>Scope cadré avant build</strong>
                      <em
                        >Le niveau d’effort dépend du périmètre, des intégrations et du niveau de continuité attendu.</em
                      >
                    </div>
                    <div class="tsw-systems-capability-grid">
                      <div class="tsw-systems-scope-areas">
                        <div class="tsw-systems-scope-card">
                          <strong>Frontend & apps</strong>
                          <span>Angular, React, JavaScript, TypeScript, delivery full-stack</span>
                        </div>
                        <div class="tsw-systems-scope-card">
                          <strong>Infra & automation</strong>
                          <span>Bash scripting, Linux infra, automation, intégrations</span>
                        </div>
                        <div class="tsw-systems-scope-card">
                          <strong>Engineering rigoureux</strong>
                          <span>Python, C, C++, structures de données, algorithmes, sujets plus exigeants</span>
                        </div>
                      </div>

                      <ul class="tsw-systems-runway">
                        <li>
                          <strong>Build privée</strong>
                          <span
                            >Codebase dédiée, structure propriétaire ou handoff quand le standard ne suffit plus</span
                          >
                        </li>
                        <li>
                          <strong>Backend & logique métier</strong>
                          <span>API, dashboard, intégration ou logique applicative plus sérieuse</span>
                        </li>
                        <li>
                          <strong>Infrastructure & automatisation</strong>
                          <span>Environnements plus propres, orchestration, scripts et workflows métier</span>
                        </li>
                        <li>
                          <strong>Systèmes plus lourds</strong>
                          <span>Projets plus ambitieux cadrés selon risque, architecture et continuité</span>
                        </li>
                      </ul>
                    </div>
                  </div>

                  <div class="flex justify-center sm:justify-start">
                    <a class="btn btn-primary" href="/contact#form">Discuter du scope</a>
                  </div>
                </article>

                <article class="tsw-price-card tsw-systems-ramp-panel">
                  <div class="tsw-systems-panel-head">
                    <p class="tsw-systems-panel-kicker">Paid clarity first</p>
                    <h3 class="tsw-systems-panel-title">Commencer proprement</h3>
                    <p class="tsw-systems-panel-lead">
                      Utilisez d’abord le consulting payé quand la vraie taille du sujet, le risque technique ou la
                      direction delivery doivent encore être cadrés.
                    </p>
                  </div>

                  <div class="tsw-systems-ramp-steps">
                    <div class="tsw-systems-ramp-step">
                      <strong>60 CHF / 15 min</strong>
                      <span>entrée ciblée, payée d’avance, pour arbitrer vite ou débloquer un point précis</span>
                    </div>
                    <div class="tsw-systems-ramp-step">
                      <strong>140 CHF / heure</strong>
                      <span>quand il faut aller plus loin en support, cadrage ou delivery technique</span>
                    </div>
                  </div>

                  <div class="flex justify-center sm:justify-start">
                    <label class="btn cursor-pointer" for="tsw-pricing-tab-consulting">Voir le consulting d’abord</label
                    >
                  </div>
                </article>
              </div>

              <div class="tsw-systems-stack">
                {
                  operationsOffers.map((offer, index) => (
                    <article class={`tsw-price-card tsw-systems-stack-card tsw-systems-stack-card-${index + 1}`}>
                      <div class="tsw-systems-stack-meta">
                        <span class="tsw-systems-stack-badge">{offer.period}</span>
                        <span class="tsw-systems-stack-price">{offer.price}</span>
                      </div>

                      <h3 class="tsw-systems-stack-title">{offer.title}</h3>
                      <p class="tsw-systems-stack-lead">{offer.subtitle}</p>

                      <ul class="tsw-systems-stack-list">
                        {offer.items.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>

                      <div class="flex justify-center sm:justify-start">
