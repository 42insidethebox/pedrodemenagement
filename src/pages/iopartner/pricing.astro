        title: 'Presenza web strutturata',
        price: 'CHF 999 a 1’500',
        body: 'Per strutture che desiderano una presenza professionale senza manutenzione editoriale pesante.',
        items: ['Pagine essenziali', 'Contenuti integrati', 'Contatto semplice', 'Manutenzione leggera'],
        href: '/presence-web-cadree#offres',
      },
      {
        key: 'editorial',
        kicker: 'Livello 2',
        stage: 'Modificabile',
        title: 'Sito modificabile & evolutivo',
        price: 'Da CHF 2’200',
        body: 'Per strutture che vogliono modificare contenuti, pubblicare notizie o far vivere il sito più regolarmente.',
        items: ['Interfaccia admin', 'Sezioni modificabili', 'Blog o news', 'Ambiente dedicato secondo bisogno'],
        href: '/presence-web-cadree#offres',
      },
      {
        key: 'systems',
        kicker: 'Livello 3',
        stage: 'Operativo',
        title: 'Sistemi & operazioni',
        price: 'Dopo inquadramento',
        body: 'Per bisogni oltre il sito vetrina: workflow, dashboard, automazione, ruoli e strumenti interni.',
        items: ['Portali e dashboard', 'RBAC e ruoli', 'Automazione', 'Continuità tecnica'],
        href: '/systems-operations',
      },
    ],
    extensions: {
      kicker: 'Estensioni operative',
      title: 'Aggiungere solo ciò che serve.',
      items: [
        ['communication', 'Comunicazione & appuntamenti integrati', '+CHF 250'],
        ['automation', 'Automazioni semplici & moduli', 'da inquadrare'],
        ['handoff', 'Passaggio breve', 'incluso secondo scope'],
      ],
    },
    advanced: {
      kicker: 'Soglia di evoluzione',
      title: 'Quando il sito diventa modificabile, poi sistema.',
      body: 'WordPress, headless CMS o dashboard admin diventano utili quando l’autonomia editoriale aumenta. Quando il bisogno supera questo livello, si passa ad architettura, backend, automazione e continuità.',
      items: [
        ['consulting', 'Inquadramento tecnico', 'Arbitraggio, inquadramento, direzione tecnica'],
        ['build', 'Build systems', 'Sviluppo, API, strumenti interni'],
        ['systems', 'Infrastruttura & operazioni', 'Ambienti, monitoring, sicurezza'],
        ['continuity', 'Continuità tecnica', 'Supporto, incidenti, evoluzioni'],
      ],
      cta: 'Vedere sistemi & operazioni',
    },
    systemsBand: {
      kicker: 'Sistemi & operazioni',
      title: 'Uno strato avanzato, inquadrato prima del build.',
      body: 'Portali, API, automazioni, Linux, Docker, DNS, SSL, monitoring e continuità non si vendono come un pack. Lo scope arriva dopo l’inquadramento.',
      stack: 'Docker · VPS · DNS · SSL · monitoring · workflow · API · dashboard',
    },
    processHead: { kicker: 'Percorso', title: 'Una sequenza breve e leggibile.' },
    processSteps: [
      { label: '01', title: 'Inquadramento', detail: 'Bisogni & obiettivi', icon: 'scope' },
      { label: '02', title: 'Deployment', detail: 'Build & integrazione', icon: 'build' },
      { label: '03', title: 'Messa online', detail: 'Test & validazione', icon: 'deploy' },
      { label: '04', title: 'Seguito', detail: 'Supporto & evoluzioni', icon: 'continuity' },
    ],
    faqHead: { kicker: 'FAQ', title: 'Domande sui prezzi' },
    faqs: [
      {
        title: 'I prezzi includono l’IVA?',
        body: 'Sì, gli importi pubblici sono indicati IVA inclusa e fatturati in Svizzera.',
      },
      {
        title: 'Perché iniziare da CHF 60 / 15 min?',
        body: 'Perché serve un ingresso leggero. Se il tema merita più profondità dall’inizio, esiste anche il formato 1 ora a CHF 140.',
      },
      {
        title: 'La presenza web strutturata può evolvere?',
        body: 'Sì. Può restare su evoluzioni puntuali, passare a un sito modificabile o spostarsi verso sistemi & operazioni se il bisogno cambia davvero.',
      },
      {
        title: 'Quando serve un preventivo?',
        body: 'Quando il tema implica autonomia editoriale più ampia, codebase privato, backend, infrastruttura, automazione o continuità tecnica.',
      },
    ],
    finalCta: {
      title: 'Scegliere il livello giusto prima di investire troppo nel custom.',
      body: 'Invia il contesto. Ti orientiamo verso inquadramento, sistemi & operazioni o presenza web strutturata.',
      primary: 'Invia il contesto',
      secondary: 'Vedere progetti consegnati',
    },
  },
} as const;

const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
const processSteps = copy.processSteps as any;
---

<Layout metadata={copy.metadata}>
  <main class="io-pricing">
    <section class="io-pricing-hero">
      <div class="io-shell io-pricing-hero-grid">
        <div>
          <p class="io-kicker">{copy.hero.kicker}</p>
          <h1>{copy.hero.title}</h1>
          <p class="io-lead">{copy.hero.lead}</p>
        </div>
        <IoPricingLayersVisual />
      </div>
    </section>

    <section class="io-shell io-standard-strip" id="standard-deployment">
      <div class="io-standard-icon">
        <span><IoNodeIcon name="standard" /></span>
        <strong>{copy.standard.label}</strong>
      </div>
      <div class="io-standard-copy">
        <p class="io-kicker">{copy.standard.kicker}</p>
        <h2>{copy.standard.title}</h2>
        <p>{copy.standard.body}</p>
        <p class="io-standard-note">{copy.standard.note}</p>
        <div class="io-standard-facts">
          <span><IoNodeIcon name="clock" />{copy.standard.facts[0]}</span>
          <span><IoNodeIcon name="content" />{copy.standard.facts[1]}</span>
          <span><IoNodeIcon name="check" />{copy.standard.facts[2]}</span>
        </div>
      </div>
      <div class="io-standard-action">
        <a class="io-btn io-btn-dark" href="/presence-web-cadree#offres">{copy.standard.cta}</a>
        <small>{copy.standard.small}</small>
      </div>
    </section>

    <section class="io-shell io-price-matrix" id="pricing-options">
      <div class="io-section-head">
        <p class="io-kicker">{copy.matrixHead.kicker}</p>
        <h2>{copy.matrixHead.title}</h2>
      </div>

      <div class="io-matrix-grid">
        {
          copy.matrix.map((offer: any) => (
            <a class:list={['io-matrix-card', offer.dark && 'io-matrix-card-dark']} id={offer.id} href={offer.href}>
              <p class="io-kicker">{offer.kicker}</p>
              <h3>{offer.title}</h3>
              <strong class="io-price">{offer.price}</strong>
              <p>{offer.detail}</p>
              <ul>
                {offer.items.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
              <span class:list={['io-btn', offer.dark ? 'io-btn-light' : 'io-btn-primary']}>{offer.cta}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-autonomy-ladder">
      <div class="io-section-head">
        <p class="io-kicker">{copy.autonomyHead.kicker}</p>
        <h2>{copy.autonomyHead.title}</h2>
        <p>{copy.autonomyHead.body}</p>
      </div>

      <div class="io-autonomy-grid">
        {
          copy.autonomyLevels.map((level: any) => (
            <a class={`io-autonomy-card io-autonomy-card-${level.key}`} href={level.href}>
              <p class="io-kicker">{level.kicker}</p>
              <span class="io-autonomy-stage">{level.stage}</span>
              <h3>{level.title}</h3>
              <strong class="io-price">{level.price}</strong>
              <p>{level.body}</p>
              <ul>
                {level.items.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </a>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-extensions">
      <article>
        <p class="io-kicker">{copy.extensions.kicker}</p>
        <h2>{copy.extensions.title}</h2>
        <div class="io-extension-list">
          {
            copy.extensions.items.map(([icon, title, price]) => (
              <div>
                <strong>
                  <IoNodeIcon name={icon} />
                  {title}
                </strong>
                <span>{price}</span>
              </div>
            ))
          }
        </div>
      </article>
      <article class="io-advanced-panel">
        <p class="io-kicker">{copy.advanced.kicker}</p>
        <h2>{copy.advanced.title}</h2>
        <p>{copy.advanced.body}</p>
        <ul>
          {
            copy.advanced.items.map(([icon, title, detail]) => (
              <li>
                <IoNodeIcon name={icon} />
                <>
                  <strong>{title}</strong>
                  <span>{detail}</span>
                </>
              </li>
            ))
          }
        </ul>
        <a class="io-btn io-btn-light" href="/systems-operations">{copy.advanced.cta}</a>
      </article>
    </section>

    <section class="io-systems-band">
      <div class="io-shell io-systems-grid">
        <div>
          <p class="io-kicker">{copy.systemsBand.kicker}</p>
          <h2>{copy.systemsBand.title}</h2>
          <p>{copy.systemsBand.body}</p>
          <div class="io-stack-line">{copy.systemsBand.stack}</div>
        </div>
        <Io02SvgLinesPathsCurves />
      </div>
    </section>

    <section class="io-shell io-process">
      <div class="io-section-head">
        <p class="io-kicker">{copy.processHead.kicker}</p>
        <h2>{copy.processHead.title}</h2>
      </div>
      <IoProcessMap steps={processSteps} />
    </section>

    <section class="io-shell io-faq">
      <div class="io-section-head">
        <p class="io-kicker">{copy.faqHead.kicker}</p>
        <h2>{copy.faqHead.title}</h2>
      </div>
      <div class="io-faq-list">
        {
          copy.faqs.map((faq: any) => (
            <details>
              <summary>{faq.title}</summary>
              <p>{faq.body}</p>
            </details>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-final-cta">
      <h2>{copy.finalCta.title}</h2>
      <p>{copy.finalCta.body}</p>
      <div class="io-actions">
        <a class="io-btn io-btn-primary" href="/contact">{copy.finalCta.primary}</a>
        <a class="io-btn io-btn-secondary" href="/presence-web-cadree#modeles">{copy.finalCta.secondary}</a>
      </div>
    </section>
  </main>

  <style>
    .io-pricing {
      --io-dark: #07111f;
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-line: rgba(148, 163, 184, 0.22);
      --io-blue: #0b63f6;
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px), #f8fbff;
      background-size:
        34px 34px,
        34px 34px,
        100% 100%;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 80rem);
      margin-inline: auto;
    }

    .io-pricing-hero {
      padding: 4.6rem 0 3.6rem;
    }

    .io-pricing-hero-grid,
    .io-systems-grid,
    .io-extensions {
      display: grid;
      grid-template-columns: minmax(0, 0.86fr) minmax(24rem, 1fr);
      gap: 3.6rem;
      align-items: center;
    }

    .io-pricing-hero h1,
    .io-section-head h2,
    .io-standard-copy h2,
    .io-extensions h2,
    .io-systems-band h2,
    .io-final-cta h2 {
      margin: 0;
      font-weight: 850;
      line-height: 1.04;
    }

    .io-pricing-hero h1 {
      max-width: 38rem;
      font-size: 3.45rem;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-lead,
    .io-section-head p,
    .io-standard-copy p,
    .io-extensions p,
    .io-systems-band p,
    .io-final-cta p {
      color: var(--io-muted);
      font-size: 1.12rem;
      line-height: 1.72;
    }

    .io-lead {
      max-width: 35rem;
      margin: 1.35rem 0 0;
      font-size: 1.12rem;
    }

    .io-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3rem;
      border-radius: 999px;
      padding: 0.78rem 1.35rem;
      font-weight: 780;
      text-decoration: none;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease;
    }

    .io-btn:hover,
    .io-btn:focus-visible {
      transform: translateY(-1px);
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      color: var(--io-ink);
      background: rgba(255, 255, 255, 0.72);
    }

    .io-btn-dark {
      background: #061120;
      color: #fff;
    }

    .io-btn-light {
      border: 1px solid rgba(226, 232, 240, 0.34);
      color: #f8fafc;
      background: rgba(255, 255, 255, 0.04);
    }

    .io-standard-strip {
      display: grid;
      grid-template-columns: 10.5rem minmax(0, 1fr) auto;
      gap: 2.3rem;
      align-items: center;
      margin-bottom: 4.8rem;
      padding: 1.65rem;
      border: 1px solid rgba(37, 99, 235, 0.18);
      border-radius: 1.15rem;
      background: rgba(255, 255, 255, 0.8);
      box-shadow: 0 28px 82px -72px rgba(15, 23, 42, 0.46);
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease,
        box-shadow 180ms ease;
    }

    .io-standard-strip:hover {
      transform: translateY(-3px);
      border-color: rgba(37, 99, 235, 0.34);
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 28px 70px -50px rgba(15, 23, 42, 0.38);
    }

    .io-standard-strip:active {
      transform: translateY(-1px) scale(0.997);
    }

    .io-standard-icon {
      display: grid;
      gap: 1rem;
      justify-items: center;
      border-right: 1px solid var(--io-line);
      padding-right: 1.65rem;
      color: var(--io-blue);
      font-size: 0.9rem;
      font-weight: 820;
      text-align: center;
      text-transform: uppercase;
    }

    .io-standard-icon span {
      display: grid;
      width: 4rem;
      height: 4rem;
      place-items: center;
      border: 1px solid rgba(37, 99, 235, 0.25);
      border-radius: 0.8rem;
      background: #061120;
      color: #93c5fd;
    }

    .io-standard-icon span :global(.io-node-icon-svg) {
      width: 1.85rem;
      height: 1.85rem;
    }

    .io-standard-copy h2 {
      font-size: 1.78rem;
    }

    .io-standard-copy p {
      margin: 0.75rem 0 0;
    }

    .io-standard-note {
      max-width: 38rem;
      color: #334155 !important;
      font-size: 0.98rem !important;
      font-weight: 620;
      line-height: 1.6 !important;
    }

    .io-standard-facts {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 1.2rem;
      color: #334155;
      font-weight: 760;
    }

    .io-standard-facts span {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }

    .io-standard-facts :global(.io-node-icon-svg) {
      width: 1rem;
      height: 1rem;
      color: var(--io-blue);
    }

    .io-standard-action {
      display: grid;
      gap: 0.8rem;
      justify-items: center;
      min-width: 16rem;
    }

    .io-standard-action small {
      color: var(--io-muted);
    }

    .io-section-head {
      max-width: 39rem;
      margin-bottom: 2.25rem;
    }

    .io-section-head h2,
    .io-extensions h2,
    .io-systems-band h2,
    .io-final-cta h2 {
      font-size: 2.55rem;
    }

    .io-price-matrix,
    .io-autonomy-ladder,
    .io-process,
    .io-faq {
      padding-bottom: 5rem;
    }

    .io-autonomy-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.4rem;
    }

    .io-autonomy-card {
      --lift: 0rem;
      display: grid;
      gap: 1rem;
      align-content: start;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.35rem;
      background: rgba(255, 255, 255, 0.82);
      box-shadow: 0 18px 42px -40px rgba(15, 23, 42, 0.35);
      color: inherit;
      overflow: hidden;
      position: relative;
      text-decoration: none;
      transform: translateY(var(--lift));
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease,
        box-shadow 180ms ease;
    }

    .io-autonomy-card:hover,
    .io-autonomy-card:focus-visible {
      transform: translateY(calc(var(--lift) - 0.22rem));
      border-color: rgba(37, 99, 235, 0.36);
      box-shadow: 0 28px 70px -50px rgba(15, 23, 42, 0.42);
    }

    .io-autonomy-card:active {
      transform: translateY(var(--lift)) scale(0.997);
    }

    .io-autonomy-card:focus-visible,
    .io-matrix-card:focus-visible {
      outline: 2px solid rgba(37, 99, 235, 0.34);
      outline-offset: 3px;
    }

    .io-autonomy-card::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 0.28rem;
      border-radius: 1rem 0 0 1rem;
      background: rgba(37, 99, 235, 0.2);
    }

    .io-autonomy-card h3 {
      margin: 0;
      font-size: 1.42rem;
      line-height: 1.15;
    }

    .io-autonomy-card p {
      margin: 0;
      color: var(--io-muted);
      line-height: 1.62;
    }

    .io-autonomy-card ul {
      display: grid;
      gap: 0.75rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .io-autonomy-card li {
      color: #334155;
      font-weight: 680;
    }

    .io-autonomy-stage {
      display: inline-flex;
      width: fit-content;
      align-items: center;
      border-radius: 999px;
      padding: 0.34rem 0.62rem;
      font-size: 0.72rem;
      font-weight: 820;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .io-autonomy-card-presence {
      background: linear-gradient(180deg, rgba(219, 234, 254, 0.58), rgba(255, 255, 255, 0.9));
      border-color: rgba(96, 165, 250, 0.26);
    }

    .io-autonomy-card-presence::before {
      background: #60a5fa;
    }

    .io-autonomy-card-presence .io-autonomy-stage {
      color: #0b63f6;
      background: rgba(191, 219, 254, 0.7);
    }

    .io-autonomy-card-editorial {
      background: linear-gradient(180deg, rgba(224, 242, 254, 0.7), rgba(248, 250, 252, 0.94));
      border-color: rgba(14, 165, 233, 0.28);
      --lift: -0.45rem;
    }

    .io-autonomy-card-editorial::before {
      background: #0ea5e9;
    }

    .io-autonomy-card-editorial .io-autonomy-stage {
      color: #0369a1;
      background: rgba(186, 230, 253, 0.72);
    }

    .io-autonomy-card-systems {
      background: linear-gradient(180deg, rgba(6, 17, 32, 0.98), rgba(15, 23, 42, 0.98));
      border-color: rgba(125, 211, 252, 0.2);
      color: #f8fafc;
      --lift: -0.9rem;
    }

    .io-autonomy-card-systems::before {
      background: #d52b1e;
    }

    .io-autonomy-card-systems .io-autonomy-stage {
      color: #fee2e2;
      background: rgba(213, 43, 30, 0.16);
    }

    .io-autonomy-card-systems:hover,
    .io-autonomy-card-systems:focus-visible {
      border-color: rgba(213, 43, 30, 0.38);
      box-shadow: 0 30px 82px -50px rgba(7, 17, 31, 0.68);
    }

    .io-autonomy-card-systems:focus-visible {
      outline-color: rgba(213, 43, 30, 0.4);
    }

    .io-autonomy-card-systems .io-price,
    .io-autonomy-card-systems h3 {
      color: #fff;
    }

    .io-autonomy-card-systems p {
      color: #cbd5e1;
    }

    .io-autonomy-card-systems li {
      color: #dbeafe;
    }

    .io-matrix-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.4rem;
    }

    .io-matrix-card {
      display: grid;
      gap: 1rem;
      align-content: start;
      min-height: 27.2rem;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.35rem;
      background: rgba(255, 255, 255, 0.82);
      color: inherit;
      text-decoration: none;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease,
        box-shadow 180ms ease;
    }

    .io-matrix-card:hover,
    .io-matrix-card:focus-visible {
      transform: translateY(-3px);
      border-color: rgba(37, 99, 235, 0.34);
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 28px 70px -52px rgba(15, 23, 42, 0.42);
    }

    .io-matrix-card:active {
      transform: translateY(-1px) scale(0.997);
    }

    .io-matrix-card-dark {
      border-color: rgba(125, 211, 252, 0.18);
      background: #061120;
      color: #f8fafc;
    }

    .io-matrix-card-dark:hover,
    .io-matrix-card-dark:focus-visible {
      border-color: rgba(213, 43, 30, 0.38);
      background: linear-gradient(180deg, rgba(7, 17, 31, 0.98), rgba(15, 23, 42, 0.98));
      box-shadow: 0 30px 82px -50px rgba(7, 17, 31, 0.68);
      outline-color: rgba(213, 43, 30, 0.4);
    }

    .io-matrix-card-dark .io-kicker {
      color: #ffb4ad;
    }

    .io-matrix-card h3 {
      margin: 0;
      font-size: 1.42rem;
      line-height: 1.15;
    }

    .io-price {
      display: block;
      font-size: 1.95rem;
      line-height: 1.05;
    }

    .io-matrix-card p {
      margin: 0;
      color: var(--io-muted);
      line-height: 1.62;
    }

    .io-matrix-card-dark p {
      color: #cbd5e1;
    }

    .io-matrix-card ul,
    .io-advanced-panel ul {
      display: grid;
      gap: 0.75rem;
