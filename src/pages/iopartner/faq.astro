            bullets: [
              'dashboard',
              'portali',
              'workflow',
              'monitoring',
              'automazione',
              'RBAC',
              'onboarding',
              'documentazione',
              'API',
              'infrastruttura',
              'continuità tecnica',
            ],
          },
          {
            question: 'Lavorate su progetti Linux, Docker o VPS?',
