const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
---

<Layout metadata={copy.metadata}>
  <main class="io-faq-page">
    <section class="io-faq-hero">
      <div class="io-shell">
        <p class="io-kicker">{copy.kicker}</p>
        <h1>{copy.title}</h1>
        <p>{copy.lead}</p>
      </div>
    </section>

    <section class="io-shell io-faq-sections">
      {
        copy.sections.map((section: any) => (
          <section class="io-faq-section">
            <div class="io-faq-section-head">
              <h2>{section.title}</h2>
              {section.lead && <p>{section.lead}</p>}
            </div>
            <div class="io-faq-list">
              {section.items.map((item: any) => (
                <details>
                  <summary>{item.question}</summary>
                  <div class="io-faq-answer">
                    {item.paragraphs?.map((paragraph: string) => (
                      <p>{paragraph}</p>
                    ))}
                    {item.bullets && (
                      <ul>
                        {item.bullets.map((bullet: string) => (
                          <li>{bullet}</li>
                        ))}
                      </ul>
                    )}
                    {item.ordered && (
                      <ol>
                        {item.ordered.map((step: string) => (
                          <li>{step}</li>
                        ))}
                      </ol>
                    )}
                  </div>
                </details>
              ))}
            </div>
          </section>
        ))
      }
    </section>
  </main>

  <style>
    .io-faq-page {
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-blue: #0b63f6;
      --io-line: rgba(148, 163, 184, 0.22);
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px), #f8fbff;
      background-size:
        34px 34px,
        34px 34px,
        auto;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 72rem);
      margin-inline: auto;
    }

    .io-faq-hero {
      padding: 4.8rem 0 3rem;
    }

    .io-faq-hero h1,
    .io-faq-section h2 {
      margin: 0;
      font-weight: 850;
      line-height: 1.04;
    }

    .io-faq-hero h1 {
      font-size: clamp(2.4rem, 6vw, 4.8rem);
    }

    .io-faq-hero p {
      max-width: 50rem;
      margin: 1.25rem 0 0;
      color: var(--io-muted);
      font-size: 1.16rem;
      line-height: 1.72;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-faq-sections {
      display: grid;
      gap: 2.3rem;
      padding-bottom: 5.5rem;
    }

    .io-faq-section {
      display: grid;
      grid-template-columns: minmax(12rem, 0.38fr) minmax(0, 1fr);
      gap: 2rem;
      align-items: start;
      border-top: 1px solid var(--io-line);
      padding-top: 2.3rem;
    }

    .io-faq-section:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .io-faq-section h2 {
      font-size: 1.65rem;
    }

    .io-faq-section-head p {
      margin: 0.9rem 0 0;
      color: var(--io-muted);
      line-height: 1.65;
    }

    .io-faq-list {
      display: grid;
      gap: 0.8rem;
    }

    .io-faq-list details {
      border: 1px solid var(--io-line);
      border-radius: 0.9rem;
      background: rgba(255, 255, 255, 0.82);
      padding: 1.15rem 1.25rem;
    }

    .io-faq-list summary {
      cursor: pointer;
      color: var(--io-ink);
      font-weight: 820;
      line-height: 1.35;
    }

    .io-faq-answer {
      display: grid;
      gap: 0.75rem;
      margin-top: 1rem;
      color: var(--io-muted);
      line-height: 1.7;
    }

    .io-faq-answer p,
    .io-faq-answer ul,
    .io-faq-answer ol {
      margin: 0;
    }

    .io-faq-answer ul,
    .io-faq-answer ol {
      padding-left: 1.25rem;
    }

    @media (max-width: 780px) {
      .io-shell {
        width: min(100% - 1rem, 72rem);
      }

      .io-faq-section {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
    }
  </style>
</Layout>
