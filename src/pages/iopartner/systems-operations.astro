---
import IoNodeIcon from '~/components/iopartner/IoNodeIcon.astro';
import IoProcessMap from '~/components/iopartner/IoProcessMap.astro';
import Io02SvgLinesPathsCurves from '~/components/iopartner/visuals/Io02SvgLinesPathsCurves.astro';
import type { IoIconName } from '~/components/iopartner/ioNodeIconTypes';
import { detectRequestLocale } from '~/lib/locale';
import Layout from '~/layouts/PageLayout.astro';

const locale = detectRequestLocale(Astro.request, Astro.url);
const localePrefix = ['en', 'de', 'it'].includes(locale) ? `/${locale}` : '';

const COPY = {
  fr: {
    metadata: {
      title: 'Systèmes & opérations — IOPartner',
      description:
        'Systèmes & opérations pour PME: réduire le chaos opérationnel, clarifier les outils, les accès, les workflows, l’infrastructure et la continuité.',
    },
    kicker: 'Systèmes & opérations',
    heroTitle: 'Réduire le chaos opérationnel sans empiler des outils.',
    heroLead:
      'Pour les PME dont les outils, accès, workflows ou infrastructures fonctionnent encore, mais deviennent trop dépendants des habitudes, des raccourcis et des explications orales.',
    discuss: 'Discuter de votre setup',
    seeSituations: 'Voir les situations',
    pipeline: ['confusion', 'reconnaissance', 'confiance', 'consultation', 'relation opérationnelle'],
    recKicker: 'Reconnaissance immédiate',
    recTitle: 'Le problème est rarement “manque d’outils”.',
    recBody: 'Le plus souvent, le système s’est construit par couches successives sans carte commune.',
    symptoms: [
      'Les systèmes ont grandi sans structure claire.',
      'Trop d’outils se parlent mal ou pas du tout.',
      'Personne ne sait exactement où vivent les accès, les données ou les procédures.',
      'L’onboarding dépend encore d’explications orales.',
      'Une seule personne connaît les raccourcis critiques.',
      'La stack fonctionne, mais personne ne lui fait vraiment confiance.',
    ],
    beforeAfterKicker: 'Transformation opérationnelle',
    beforeAfterTitle: 'Avant / après doit être visible.',
    before: 'Avant',
    after: 'Après',
    beforeItems: ['mots de passe partagés', 'SaaS fragmentés', 'systèmes non documentés', 'processus manuels aléatoires'],
    afterItems: ['accès centralisés', 'workflows documentés', 'infrastructure visible', 'systèmes maintenables'],
    domainsKicker: 'Domaines concrets',
    domainsTitle: 'Le travail technique est traduit en stabilité opérationnelle.',
    domains: [
      { title: 'Structure opérationnelle', body: 'Permissions, onboarding, documentation, accès et standards de travail.', icon: 'scope' },
      { title: 'Infrastructure', body: 'Déploiements, monitoring, sauvegardes, continuité de service et clarté réseau.', icon: 'systems' },
      { title: 'Systèmes internes', body: 'Workflows, bases de connaissance, automatisations, intégrations et cartographie métier.', icon: 'automation' },
      { title: 'Simplification', body: 'Réduire la complexité inutile, consolider les outils et retirer les frictions.', icon: 'check' },
    ] as Array<{ title: string; body: string; icon: IoIconName }>,
    discernLead: 'Parfois une stack plus simple est la meilleure solution.',
    discernBody: 'Le but n’est pas d’ajouter une couche technique. Le but est de rendre le système compréhensible, fiable et exploitable par l’équipe.',
    entryKicker: 'Points d’entrée',
    entryTitle: 'Choisir le sujet opérationnel à clarifier.',
    scenarios: [
      { title: 'Clarifier l’existant', body: 'Cartographier outils, accès, données, responsabilités et zones de risque.', href: `${localePrefix}/contact?type=systems&scenario=audit#form` },
      { title: 'Stabiliser l’infrastructure', body: 'Rendre les déploiements, DNS, SSL, sauvegardes et monitoring plus lisibles.', href: `${localePrefix}/contact?type=systems&scenario=infra#form` },
      { title: 'Organiser un workflow', body: 'Relier formulaires, CRM, notifications, documents et tâches sans empiler du SaaS.', href: `${localePrefix}/contact?type=systems&scenario=workflow#form` },
      { title: 'Créer un outil interne', body: 'Dashboard, API légère, rôles, données structurées ou interface métier.', href: `${localePrefix}/contact?type=systems&scenario=tool#form` },
      { title: 'Installer une continuité', body: 'Runbooks, suivi, monitoring, incidents, petites évolutions et passation.', href: `${localePrefix}/contact?type=systems&scenario=continuity#form` },
    ],
    askScope: 'Demander un cadrage',
    workflowKicker: 'Workflow',
    workflowTitle: 'Une progression vers une relation opérationnelle, pas un tunnel de vente.',
    intakeKicker: 'Intake systems',
    intakeTitle: 'Décrire le sujet avant de parler solution.',
    intakeBody: 'Le but est de comprendre le setup réel, les points de friction et le niveau de continuité attendu.',
    steps: [
      { label: '01', title: 'Reconnaître', detail: 'Ce qui crée le chaos.', icon: 'diagnostic' },
      { label: '02', title: 'Cartographier', detail: 'Outils, accès, flux, risques.', icon: 'scope' },
      { label: '03', title: 'Simplifier', detail: 'Retirer ou structurer.', icon: 'build' },
      { label: '04', title: 'Continuer', detail: 'Suivi, runbook, évolutions.', icon: 'continuity' },
    ] as Array<{ label: string; title: string; detail: string; icon: IoIconName }>,
  },
  en: {
    metadata: {
      title: 'Systems & operations — IOPartner',
      description:
        'Systems & operations for SMEs: reduce operational chaos, clarify tools, access, workflows, infrastructure, and continuity.',
    },
    kicker: 'Systems & operations',
    heroTitle: 'Reduce operational chaos without piling on more tools.',
    heroLead:
      'For SMEs whose tools, access, workflows, or infrastructure still work, but have become too dependent on habits, shortcuts, and oral explanations.',
    discuss: 'Discuss your setup',
    seeSituations: 'See the situations',
    pipeline: ['confusion', 'recognition', 'confidence', 'consultation', 'operational relationship'],
    recKicker: 'Immediate recognition',
    recTitle: 'The problem is rarely “not enough tools”.',
    recBody: 'Most of the time, the system grew in layers without a shared map.',
    symptoms: [
      'The systems grew without a clear structure.',
      'Too many tools talk badly to each other, or not at all.',
      'Nobody knows exactly where the access, data, or procedures live.',
      'Onboarding still depends on oral explanations.',
      'One person still knows all the critical shortcuts.',
      'The stack works, but nobody really trusts it.',
    ],
    beforeAfterKicker: 'Operational transformation',
    beforeAfterTitle: 'The before / after should be visible.',
    before: 'Before',
    after: 'After',
    beforeItems: ['shared passwords', 'fragmented SaaS', 'undocumented systems', 'random manual processes'],
    afterItems: ['centralized access', 'documented workflows', 'visible infrastructure', 'maintainable systems'],
    domainsKicker: 'Concrete domains',
    domainsTitle: 'Technical work translated into operational stability.',
    domains: [
      { title: 'Operational structure', body: 'Permissions, onboarding, documentation, access, and work standards.', icon: 'scope' },
      { title: 'Infrastructure', body: 'Deployments, monitoring, backups, service continuity, and network clarity.', icon: 'systems' },
      { title: 'Internal systems', body: 'Workflows, knowledge bases, automation, integrations, and process mapping.', icon: 'automation' },
      { title: 'Simplification', body: 'Reduce unnecessary complexity, consolidate tools, and remove friction.', icon: 'check' },
    ] as Array<{ title: string; body: string; icon: IoIconName }>,
    discernLead: 'Sometimes a simpler stack is the best solution.',
    discernBody: 'The goal is not to add another technical layer. The goal is to make the system understandable, reliable, and usable by the team.',
    entryKicker: 'Entry points',
    entryTitle: 'Choose the operational topic to clarify.',
    scenarios: [
      { title: 'Clarify the current state', body: 'Map tools, access, data, responsibilities, and risk areas.', href: `${localePrefix}/contact?type=systems&scenario=audit#form` },
      { title: 'Stabilize infrastructure', body: 'Make deployments, DNS, SSL, backups, and monitoring easier to understand.', href: `${localePrefix}/contact?type=systems&scenario=infra#form` },
      { title: 'Organize a workflow', body: 'Connect forms, CRM, notifications, documents, and tasks without stacking more SaaS.', href: `${localePrefix}/contact?type=systems&scenario=workflow#form` },
      { title: 'Create an internal tool', body: 'Dashboard, light API, roles, structured data, or an internal interface.', href: `${localePrefix}/contact?type=systems&scenario=tool#form` },
      { title: 'Install continuity', body: 'Runbooks, monitoring, incidents, small evolutions, and handoff.', href: `${localePrefix}/contact?type=systems&scenario=continuity#form` },
    ],
    askScope: 'Request scoping',
    workflowKicker: 'Workflow',
    workflowTitle: 'A progression toward an operational relationship, not a sales funnel.',
    intakeKicker: 'Systems intake',
    intakeTitle: 'Describe the topic before talking about the solution.',
    intakeBody: 'The goal is to understand the real setup, the friction points, and the expected level of continuity.',
    steps: [
      { label: '01', title: 'Recognize', detail: 'What creates the chaos.', icon: 'diagnostic' },
      { label: '02', title: 'Map', detail: 'Tools, access, flows, risks.', icon: 'scope' },
      { label: '03', title: 'Simplify', detail: 'Remove or structure.', icon: 'build' },
      { label: '04', title: 'Continue', detail: 'Follow-up, runbook, evolutions.', icon: 'continuity' },
    ] as Array<{ label: string; title: string; detail: string; icon: IoIconName }>,
  },
} as const;

const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
const metadata = copy.metadata;
---

<Layout metadata={metadata}>
  <main class="io-systems-page">
    <section class="io-hero">
      <div class="io-shell io-hero-grid">
        <div>
          <p class="io-kicker">{copy.kicker}</p>
          <h1>{copy.heroTitle}</h1>
          <p class="io-lead">{copy.heroLead}</p>
          <div class="io-actions">
            <a class="io-btn io-btn-primary" href={`${localePrefix}/contact?type=systems#form`}>{copy.discuss}</a>
            <a class="io-btn io-btn-secondary" href="#situations">{copy.seeSituations}</a>
          </div>
        </div>
        <Io02SvgLinesPathsCurves />
      </div>
    </section>

    <section class="io-shell io-pipeline" aria-label="Progression de confiance">
      <span>{copy.pipeline[0]}</span>
      <strong>{copy.pipeline[1]}</strong>
      <strong>{copy.pipeline[2]}</strong>
      <strong>{copy.pipeline[3]}</strong>
      <span>{copy.pipeline[4]}</span>
    </section>

    <section class="io-shell io-recognition" id="situations">
      <div class="io-section-head">
        <p class="io-kicker">{copy.recKicker}</p>
        <h2>{copy.recTitle}</h2>
        <p>{copy.recBody}</p>
      </div>
      <div class="io-symptom-grid">
        {copy.symptoms.map((symptom) => <article>{symptom}</article>)}
      </div>
    </section>

    <section class="io-shell io-before-after">
      <div>
        <p class="io-kicker">{copy.beforeAfterKicker}</p>
        <h2>{copy.beforeAfterTitle}</h2>
      </div>
      <div class="io-ba-grid">
        <article>
          <h3>{copy.before}</h3>
          <ul>
            {copy.beforeItems.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article>
          <h3>{copy.after}</h3>
          <ul>
            {copy.afterItems.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="io-domains">
      <div class="io-shell">
        <div class="io-section-head">
          <p class="io-kicker">{copy.domainsKicker}</p>
          <h2>{copy.domainsTitle}</h2>
        </div>
        <div class="io-domain-grid">
          {
            copy.domains.map((domain) => (
              <article>
                <span>
                  <IoNodeIcon name={domain.icon} />
                </span>
                <h3>{domain.title}</h3>
                <p>{domain.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="io-shell io-discernment">
      <p>{copy.discernLead}</p>
      <span>{copy.discernBody}</span>
    </section>

    <section class="io-shell io-scenarios">
      <div class="io-section-head">
        <p class="io-kicker">{copy.entryKicker}</p>
        <h2>{copy.entryTitle}</h2>
      </div>
      <div class="io-scenario-grid">
        {
          copy.scenarios.map((scenario) => (
            <article>
              <h3>{scenario.title}</h3>
              <p>{scenario.body}</p>
              <a href={scenario.href}>{copy.askScope}</a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="io-shell io-process">
      <div class="io-section-head">
        <p class="io-kicker">{copy.workflowKicker}</p>
        <h2>{copy.workflowTitle}</h2>
      </div>
      <IoProcessMap steps={copy.steps} />
    </section>

    <section class="io-shell io-intake" id="intake">
      <div class="io-section-head">
        <p class="io-kicker">{copy.intakeKicker}</p>
        <h2>{copy.intakeTitle}</h2>
        <p>{copy.intakeBody}</p>
      </div>
      <form class="io-intake-form" method="post" action="/api/contact">
        <input type="hidden" name="tenant" value="iopartner" />
        <input type="hidden" name="source" value="iopartner-systems-intake" />
        <div class="io-intake-grid">
          <label>
            Nom
            <input name="name" type="text" required />
          </label>
          <label>
            Email professionnel
            <input name="email" type="email" required />
          </label>
          <label>
            Entreprise
            <input name="company" type="text" required />
          </label>
          <label>
            Sujet principal
            <select name="scenario" required>
              <option value="">Choisir</option>
              <option value="audit">Clarifier l’existant</option>
              <option value="infra">Stabiliser l’infrastructure</option>
              <option value="workflow">Organiser un workflow</option>
              <option value="tool">Créer un outil interne</option>
              <option value="continuity">Installer une continuité</option>
            </select>
          </label>
          <label>
            Urgence
            <select name="urgency">
              <option value="asap">ASAP</option>
              <option value="2-weeks">Sous 2 semaines</option>
              <option value="1-month">Sous 1 mois</option>
              <option value="flexible">Flexible</option>
            </select>
          </label>
          <label>
            Niveau probable
            <select name="budget_band">
              <option value="cadrage">Cadrage 60 CHF / 15 min ou 140 CHF / h</option>
              <option value="quote">Scope sur devis</option>
              <option value="unknown">À arbitrer</option>
            </select>
          </label>
        </div>
        <label class="io-intake-block">
          Stack ou outils actuels
          <input
            name="stack"
            type="text"
            placeholder="Ex. Google Workspace, Notion, VPS, Docker, HubSpot, formulaires..."
          />
        </label>
        <label class="io-intake-block">
          Ce qui bloque aujourd’hui
          <textarea
            name="message"
            rows="5"
            required
            placeholder="Décrivez le problème concret: accès, visibilité, runbooks, dette opérationnelle, automatisation, dépendance à une seule personne, incidents, passation..."
          ></textarea>
        </label>
        <div class="io-actions">
          <button class="io-btn io-btn-primary" type="submit">Envoyer le contexte systems</button>
          <a class="io-btn io-btn-secondary" href="/cadrage-technique">Commencer par 15 min</a>
        </div>
      </form>
    </section>

    <section class="io-shell io-final-cta">
      <h2>Commencer par regarder le système réel.</h2>
      <p>
        Décrivez votre setup actuel, ce qui bloque et ce que vous voulez rendre plus fiable. La première étape est un
        cadrage technique, pas une promesse de refonte.
      </p>
      <div class="io-actions">
        <a class="io-btn io-btn-primary" href="#intake">Décrire le setup</a>
        <a class="io-btn io-btn-secondary" href="/cadrage-technique">Commencer par 15 min</a>
      </div>
    </section>
  </main>

  <style>
    .io-systems-page {
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-blue: #0b63f6;
      --io-line: rgba(148, 163, 184, 0.22);
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(180deg, #f8fbff 0%, #fff 44%, #f8fbff 100%);
      background-size:
        34px 34px,
        34px 34px,
        auto;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 82rem);
      margin-inline: auto;
    }

    .io-hero {
      padding: 4.8rem 0 3.2rem;
    }

    .io-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.85fr) minmax(24rem, 1fr);
      gap: 3.5rem;
      align-items: center;
    }

    h1,
    h2,
    h3 {
      margin: 0;
      font-weight: 850;
      line-height: 1.04;
    }

    h1 {
      max-width: 42rem;
      font-size: 3.9rem;
    }

    h2 {
      font-size: 2.55rem;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-lead,
    .io-section-head p,
    .io-final-cta p {
      color: var(--io-muted);
      font-size: 1.12rem;
      line-height: 1.72;
    }

    .io-lead {
      max-width: 38rem;
      margin: 1.25rem 0 0;
    }

    .io-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 1.9rem;
    }

    .io-btn {
      display: inline-flex;
      min-height: 3rem;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 0.78rem 1.35rem;
      font-weight: 780;
      text-decoration: none;
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      background: rgba(255, 255, 255, 0.72);
      color: var(--io-ink);
    }

    .io-pipeline {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      margin-bottom: 5rem;
      overflow: hidden;
      border: 1px solid var(--io-line);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.82);
    }

    .io-pipeline span,
    .io-pipeline strong {
      padding: 0.85rem 1rem;
      text-align: center;
      font-size: 0.82rem;
      line-height: 1.2;
    }

    .io-pipeline strong {
      color: var(--io-blue);
    }

    .io-pipeline span {
      color: var(--io-muted);
      font-weight: 720;
    }

    .io-pipeline * + * {
      border-left: 1px solid var(--io-line);
    }

    .io-recognition,
    .io-scenarios,
    .io-process {
      padding-bottom: 5rem;
    }

    .io-section-head {
      max-width: 45rem;
      margin-bottom: 2rem;
    }

    .io-symptom-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .io-symptom-grid article {
      min-height: 9.4rem;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.25rem;
      background: rgba(255, 255, 255, 0.78);
      color: #334155;
      font-weight: 720;
      line-height: 1.55;
    }

    .io-before-after {
      display: grid;
      grid-template-columns: minmax(0, 0.75fr) minmax(24rem, 1fr);
      gap: 3rem;
      align-items: start;
      padding: 4.8rem 0;
      border-top: 1px solid var(--io-line);
    }

    .io-ba-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .io-ba-grid article {
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.35rem;
      background: #fff;
    }

    .io-ba-grid ul {
      display: grid;
      gap: 0.7rem;
      margin: 1rem 0 0;
      padding: 0;
      list-style: none;
      color: var(--io-muted);
    }

    .io-domains {
      padding: 5rem 0;
      background: #fff;
    }

    .io-domain-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .io-domain-grid article {
      display: grid;
      gap: 0.9rem;
      align-content: start;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.25rem;
      background: #fff;
    }

    .io-domain-grid span {
      display: grid;
      width: 2.7rem;
      height: 2.7rem;
      place-items: center;
      border: 1px solid rgba(37, 99, 235, 0.2);
      border-radius: 0.72rem;
      color: var(--io-blue);
      background: rgba(37, 99, 235, 0.05);
    }

    .io-domain-grid p,
    .io-scenario-grid p {
      margin: 0;
      color: var(--io-muted);
      line-height: 1.62;
    }

    .io-discernment {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.8fr);
      gap: 3rem;
      align-items: end;
      padding: 5rem 0;
    }

    .io-discernment p {
      margin: 0;
      font-size: 3rem;
      font-weight: 850;
      line-height: 1.05;
    }

    .io-discernment span {
      color: var(--io-muted);
      font-size: 1.08rem;
      line-height: 1.7;
    }

    .io-scenario-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
    }

    .io-scenario-grid article {
      display: grid;
      gap: 0.75rem;
      align-content: start;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.15rem;
      background: rgba(255, 255, 255, 0.78);
    }

    .io-scenario-grid a {
      margin-top: 0.35rem;
      color: var(--io-blue);
      font-size: 0.92rem;
      font-weight: 820;
      text-decoration: none;
    }

    .io-intake {
      padding-bottom: 5rem;
    }

    .io-intake-form {
      padding: 2rem;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .io-intake-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .io-intake-form label {
      display: grid;
      gap: 0.45rem;
      color: #334155;
      font-size: 0.95rem;
      font-weight: 700;
    }

    .io-intake-block {
      margin-top: 1rem;
    }

    .io-intake-form input,
    .io-intake-form select,
    .io-intake-form textarea,
    .io-intake-form button {
      font: inherit;
    }

    .io-intake-form input,
    .io-intake-form select,
    .io-intake-form textarea {
      width: 100%;
      border: 1px solid rgba(148, 163, 184, 0.45);
      border-radius: 0.95rem;
      background: #fff;
      padding: 0.92rem 1rem;
      color: var(--io-ink);
    }

    .io-final-cta {
      margin-bottom: 5rem;
      border: 1px solid var(--io-line);
      border-radius: 1.25rem;
      padding: 2.5rem;
      background: #fff;
      text-align: center;
    }

    .io-final-cta p {
      max-width: 46rem;
      margin: 1rem auto 0;
    }

