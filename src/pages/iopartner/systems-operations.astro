        dashboard: ["M4 5h16v14H4Z", "M8 15v-3M12 15V9M16 15v-5", "M7 18h10"],
        auth: ["M7 10V7a5 5 0 0 1 10 0v3", "M5 10h14v10H5Z", "M9 15h6"],
        users: ["M12 12a4 4 0 1 0-4-4a4 4 0 0 0 4 4Z", "M5 20a7 7 0 0 1 14 0"],
        migration: ["M5 7h11", "m13 4 3 3-3 3", "M19 17H8", "m11 20-3-3 3-3"],
        stack: ["M6 7l6-3 6 3-6 3Z", "M6 12l6 3 6-3", "M6 17l6 3 6-3"],
        training: ["M4 6h16v12H4Z", "M8 21h8", "M12 18v3", "M8 10h8M8 13h5"],
      };

      const scenarios = {
        infra: {
          title: "Infrastructure propre",
          range: "Dès 2’900–9’900 CHF",
          description:
            "Pour repartir sur une base serveur claire: domaine, SSL, VPS, Docker, déploiement, sauvegardes, monitoring et documentation.",
          cta: "Discuter de l’infrastructure",
          href: "/contact?type=systems&scenario=infra#form",
          factors: [
            "nombre de services à héberger",
            "niveau de sécurité attendu",
            "besoin staging / production",
            "backups et test de restauration",
            "monitoring et alertes inclus",
          ],
          nodes: [
            ["dns", "DNS", "Domaine", "dns", 14, 24],
            ["ssl", "SSL", "Certificat", "ssl", 14, 48],
            ["vps", "VPS", "Serveur", "server", 39, 34, true],
            ["docker", "Docker", "Containers", "docker", 59, 34],
            ["deploy", "Deploy", "Mise en ligne", "deploy", 79, 34],
            ["backup", "Backup", "Sauvegardes", "database", 59, 66],
            ["monitoring", "Monitoring", "Supervision", "monitoring", 79, 66],
            ["runbook", "Runbook", "Procédure", "doc", 39, 74],
          ],
          routes: [
            ["dns", "right", "vps", "left"],
            ["ssl", "right", "vps", "left"],
            ["vps", "right", "docker", "left"],
            ["docker", "right", "deploy", "left"],
            ["docker", "bottom", "backup", "top"],
            ["backup", "right", "monitoring", "left"],
            ["backup", "left", "runbook", "right"],
            ["monitoring", "left", "runbook", "right", true],
          ],
        },

        workflow: {
          title: "Workflow métier",
          range: "Dès 1’900–7’900 CHF",
          description:
            "Pour transformer une demande client en flux exploitable: formulaire, API, worker, CRM, notifications, emails et dashboard.",
          cta: "Cadrer une automatisation",
          href: "/contact?type=systems&scenario=workflow#form",
          factors: [
            "nombre d’étapes dans le workflow",
            "logique conditionnelle",
            "outils à connecter",
            "gestion des erreurs",
            "niveau de documentation attendu",
          ],
          nodes: [
            ["form", "Formulaire", "Demande", "form", 14, 40],
            ["api", "API", "Webhook", "api", 34, 40, true],
            ["worker", "Worker", "Traitement", "worker", 54, 40],
            ["crm", "CRM / Data", "Client", "database", 74, 40],
            ["email", "Email", "Réponse", "notification", 54, 68],
            ["notify", "Notification", "Interne", "alert", 74, 68],
            ["dashboard", "Dashboard", "Suivi", "dashboard", 34, 68],
          ],
          routes: [
            ["form", "right", "api", "left"],
            ["api", "right", "worker", "left"],
            ["worker", "right", "crm", "left"],
            ["worker", "bottom", "email", "top"],
            ["worker", "bottom", "dashboard", "top"],
            ["crm", "bottom", "notify", "top"],
            ["dashboard", "right", "notify", "left", true],
          ],
        },

        tool: {
          title: "Outil interne",
          range: "Dès 7’900–25’000 CHF+",
          description:
            "Pour construire un outil métier: dashboard, base de données, API, authentification, rôles, exports, backups et monitoring.",
          cta: "Cadrer un outil interne",
          href: "/contact?type=systems&scenario=internal-tool#form",
          factors: [
            "authentification et rôles",
            "volume et structure des données",
            "exports et rapports",
            "audit log ou permissions avancées",
            "maintenance et évolutions",
          ],
          nodes: [
            ["auth", "Auth", "Accès", "auth", 16, 38],
            ["dashboard", "Dashboard", "Interface", "dashboard", 38, 38, true],
            ["api", "API", "Logique", "api", 60, 38],
            ["database", "Database", "Données", "database", 82, 38],
            ["roles", "Roles", "Permissions", "users", 38, 68],
            ["exports", "Exports", "Rapports", "doc", 60, 68],
            ["backup", "Backup", "Sécurité", "database", 82, 68],
            ["monitoring", "Monitoring", "Santé", "monitoring", 16, 68],
          ],
          routes: [
            ["auth", "right", "dashboard", "left"],
            ["dashboard", "right", "api", "left"],
            ["api", "right", "database", "left"],
            ["dashboard", "bottom", "roles", "top"],
            ["api", "bottom", "exports", "top"],
            ["database", "bottom", "backup", "top"],
            ["monitoring", "right", "backup", "left", true],
          ],
        },

        migration: {
          title: "Migration open-source",
          range: "Dès 4’900–20’000 CHF+",
          description:
            "Pour remplacer ou consolider des outils SaaS par une stack plus maîtrisable: cadrage, données, utilisateurs, backups, formation et support.",
          cta: "Évaluer une migration",
          href: "/contact?type=systems&scenario=open-source-migration#form",
          factors: [
            "outil remplacé et dépendances",
            "volume de données à migrer",
            "nombre d’utilisateurs",
            "risque métier pendant la transition",
            "formation et support après migration",
          ],
          nodes: [
            ["saas", "SaaS actuel", "Existant", "migration", 14, 42],
            ["scope", "Cadrage", "Plan", "doc", 34, 42, true],
            ["stack", "Open-source", "Stack", "stack", 56, 42],
            ["data", "Données", "Migration", "database", 78, 42],
            ["users", "Users", "Accès", "users", 56, 68],
            ["backup", "Backup", "Sécurité", "database", 78, 68],
            ["training", "Training", "Équipe", "training", 34, 68],
            ["monitoring", "Monitoring", "Continuité", "monitoring", 14, 68],
          ],
          routes: [
            ["saas", "right", "scope", "left"],
            ["scope", "right", "stack", "left"],
            ["stack", "right", "data", "left"],
            ["stack", "bottom", "users", "top"],
            ["data", "bottom", "backup", "top"],
            ["scope", "bottom", "training", "top"],
            ["monitoring", "right", "training", "left", true],
          ],
        },

        continuity: {
          title: "Continuité technique",
          range: "Dès 490–2’900 CHF / mois",
          description:
            "Pour éviter que les systèmes importants cassent en silence: monitoring, alertes, backups, restore tests, incidents, runbooks et support.",
          cta: "Discuter continuité",
          href: "/contact?type=systems&scenario=continuity#form",
          factors: [
            "nombre de systèmes à suivre",
            "temps de réponse attendu",
            "fréquence des contrôles",
            "patching ou support inclus",
            "criticité du système",
          ],
          nodes: [
            ["app", "App / Site", "Système", "website", 16, 42],
            ["monitoring", "Monitoring", "Checks", "monitoring", 38, 42, true],
            ["alerts", "Alerts", "Signal", "alert", 60, 42],
            ["incident", "Incident", "Traitement", "alert", 82, 42],
            ["backup", "Backup", "Copies", "database", 38, 70],
            ["restore", "Restore test", "Preuve", "deploy", 60, 70],
            ["runbook", "Runbook", "Procédure", "doc", 82, 70],
            ["support", "Support", "Évolution", "users", 16, 70],
          ],
          routes: [
            ["app", "right", "monitoring", "left"],
            ["monitoring", "right", "alerts", "left"],
            ["alerts", "right", "incident", "left"],
            ["monitoring", "bottom", "backup", "top"],
            ["backup", "right", "restore", "left"],
            ["restore", "right", "runbook", "left"],
            ["support", "right", "backup", "left", true],
          ],
        },
      };

      const anchorMap = {
        left: [0, 0.5],
        right: [1, 0.5],
        top: [0.5, 0],
        bottom: [0.5, 1],
        center: [0.5, 0.5],
      };

      function iconSvg(type) {
        const paths = iconPaths[type] || iconPaths.doc;
        return paths.map((d) => `<path d="${d}" />`).join("");
      }

      function getResponsiveNodePosition(x, y, index) {
        const map = document.querySelector(".architecture-map");
        const width = map?.getBoundingClientRect().width || window.innerWidth;

        if (width < 560) {
          return {
            x: index % 2 === 0 ? 27 : 73,
            y: 11 + Math.floor(index / 2) * 21,
          };
        }

        return { x, y };
      }

      function renderScenario(id) {
        const scenario = scenarios[id];

        title.textContent = scenario.title;
        range.textContent = scenario.range;
        sideTitle.textContent = scenario.title;
        sideRange.textContent = scenario.range;
        description.textContent = scenario.description;
        cta.textContent = scenario.cta;
        cta.href = scenario.href;

        factors.innerHTML = scenario.factors.map((factor) => `<li>${factor}</li>`).join("");

        nodeStage.innerHTML = scenario.nodes
          .map(([nodeId, label, detail, icon, x, y, core], index) => {
            const position = getResponsiveNodePosition(x, y, index);

            return `
              <article
                class="system-node ${core ? "is-core" : ""}"
                data-node="${nodeId}"
                style="left:${position.x}%; top:${position.y}%"
              >
                <span class="node-icon">
                  <svg viewBox="0 0 24 24">${iconSvg(icon)}</svg>
                </span>
                <span>
                  <strong>${label}</strong>
                  <small>${detail}</small>
                </span>
              </article>
            `;
          })
          .join("");

        requestAnimationFrame(() => {
          renderRoutes(scenario);
          setTimeout(() => renderRoutes(scenario), 120);
        });
      }

      function getNodeElement(id) {
        return document.querySelector(`[data-node="${id}"]`);
      }

      function getAnchorPoint(element, anchor) {
        const map = document.querySelector(".architecture-map");
        const mapRect = map.getBoundingClientRect();
        const nodeRect = element.getBoundingClientRect();
        const [anchorX, anchorY] = anchorMap[anchor] ?? anchorMap.center;

        const x = nodeRect.left - mapRect.left + nodeRect.width * anchorX;
        const y = nodeRect.top - mapRect.top + nodeRect.height * anchorY;

        return {
          x: (x / mapRect.width) * 100,
          y: (y / mapRect.height) * 100,
        };
      }

      function directionFor(anchor) {
        if (anchor === "left") return { x: -1, y: 0 };
        if (anchor === "right") return { x: 1, y: 0 };
        if (anchor === "top") return { x: 0, y: -1 };
        if (anchor === "bottom") return { x: 0, y: 1 };
        return { x: 0, y: 0 };
      }

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
      }

      function curvedPath(from, to, fromAnchor, toAnchor) {
        const fromDirection = directionFor(fromAnchor);
        const toDirection = directionFor(toAnchor);
        const distance = Math.hypot(to.x - from.x, to.y - from.y);
        const tension = clamp(distance * 0.42, 7, 20);

        const c1 = {
          x: from.x + fromDirection.x * tension,
          y: from.y + fromDirection.y * tension,
        };

        const c2 = {
          x: to.x + toDirection.x * tension,
          y: to.y + toDirection.y * tension,
        };

        return `M ${from.x.toFixed(2)} ${from.y.toFixed(2)}
                C ${c1.x.toFixed(2)} ${c1.y.toFixed(2)},
                  ${c2.x.toFixed(2)} ${c2.y.toFixed(2)},
                  ${to.x.toFixed(2)} ${to.y.toFixed(2)}`;
      }

      function svgElement(tag, attributes) {
        const element = document.createElementNS("http://www.w3.org/2000/svg", tag);
        Object.entries(attributes).forEach(([key, value]) => element.setAttribute(key, value));
        return element;
      }

      function renderRoutes(scenario) {
        routeLayer.innerHTML = "";

        scenario.routes.forEach(([fromId, fromAnchor, toId, toAnchor, secondary]) => {
          const fromElement = getNodeElement(fromId);
          const toElement = getNodeElement(toId);

          if (!fromElement || !toElement) return;

          const from = getAnchorPoint(fromElement, fromAnchor);
          const to = getAnchorPoint(toElement, toAnchor);

          const path = svgElement("path", {
            class: `generated-route ${secondary ? "is-secondary" : ""}`,
            d: curvedPath(from, to, fromAnchor, toAnchor),
          });

          const fromDot = svgElement("circle", {
            class: "route-dot",
            cx: from.x.toFixed(2),
            cy: from.y.toFixed(2),
            r: "0.42",
          });

          const toDot = svgElement("circle", {
            class: "route-dot",
            cx: to.x.toFixed(2),
            cy: to.y.toFixed(2),
            r: "0.42",
          });

          routeLayer.append(path, fromDot, toDot);
        });
      }

      themeControls.forEach((button) => {
        button.addEventListener("click", () => {
          panel.dataset.theme = button.dataset.theme;

          themeControls.forEach((item) => item.classList.remove("is-active"));
          button.classList.add("is-active");
        });
      });

      scenarioButtons.forEach((button) => {
        button.addEventListener("click", () => {
          scenarioButtons.forEach((item) => item.classList.remove("is-active"));
          button.classList.add("is-active");

          renderScenario(button.dataset.scenario);
        });
      });

      window.addEventListener("resize", () => {
        const active = document.querySelector(".scenario-button.is-active");
        renderScenario(active?.dataset.scenario || "infra");
      });

      renderScenario("infra");
    </script>
  </body>
