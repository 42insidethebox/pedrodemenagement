---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import PricingOptions from '~/components/widgets/PricingOptions.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { iopartnerHeaderDataDe, iopartnerFooterDataDe } from '~/navigation';

const metadata = {
  title: 'IOPartner Preise',
  description:
    'IOPartner Preise für Websites, KI-Automatisierung, strukturiert aufgebaute Systeme und Managed Support.',
  openGraph: {
    type: 'website',
  },
  twitter: {
    cardType: 'summary',
  },
};
---

<Layout metadata={metadata} header={iopartnerHeaderDataDe} footer={iopartnerFooterDataDe}>
  <HeroText
    tagline="Preise"
    title="Transparente Pakete, in der Schweiz fakturiert"
    subtitle="Zwei Standardwege für einfache Launch-Sites, dann eine saubere Custom-Schicht, wenn das Thema die Vorlage übersteigt."
  />

  <!-- Starter pack banner -->
  <div class="max-w-3xl mx-auto px-4 mb-2">
    <div class="rounded-2xl border-2 border-blue-200 bg-blue-50 dark:bg-blue-900/20 px-6 py-4 text-center">
      <p class="text-lg font-bold text-blue-900 dark:text-blue-100">Essentiel-Paket — ab 999 CHF</p>
      <p class="mt-1 text-sm text-blue-700 dark:text-blue-200">Fixpreis für eine professionelle Showcase-Website. Typische Lieferung in 3–5 Arbeitstagen je nach Inhalt.</p>
      <a href="/onboarding?plan=essential999" class="mt-3 inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm px-6 py-2 rounded-xl transition-colors">Jetzt bestellen →</a>
    </div>
  </div>

  <Prices
    title="Unsere schlüsselfertigen Pakete"
    subtitle="Wählen Sie das Angebot, das zu Ihrem Bedarf passt. Ohne versteckte Kosten."
    prices={[
      {
        title: 'Essentiel',
        subtitle: 'Professionelle Showcase-Website ab 999 CHF',
        price: 999,
        period: 'einmalige Zahlung',
        info: [
          'CHF 999 deckt eine standardisierte Showcase-Seite mit 5 Sektionen auf der gemeinsamen IOPartner-Infrastruktur ab.',
          'Zusätzliche Seiten, Workshops/Brainstorming, Strukturänderungen oder neue Module werden separat offeriert.',
          'Jede Leistung ausserhalb des Umfangs wird vor der Produktion separat verrechnet.',
        ],
        items: [
          {
            description: 'Showcase-Seite mit 5 Sektionen + responsive Kontaktseite',
          },
          {
            description: 'Inhalte vom Kunden geliefert; wir integrieren und formatieren',
          },
          {
            description: 'Bereitstellung auf der gemeinsamen IOPartner-Infrastruktur',
          },
        ],
        callToAction: { text: 'Stil wählen →', href: '/de/choose-template?plan=essential999' },
      },
      {
        title: 'Paket CHF 1’500',
        subtitle: 'Standardseite + WhatsApp + Calendly',
        price: 1500,
        period: 'einmalige Zahlung',
        info: [
          'Weiterhin innerhalb der Standardlogik von IOPartner, ohne in einen privaten Build zu wechseln.',
          'WhatsApp, Calendly und eine leichte Übergabe sind im validierten Umfang enthalten.',
          'Zusätzliche Seiten, Workshops, Redesigns oder Extra-Module werden separat offeriert.',
        ],
        items: [
          { description: 'Enthält die Basis zu CHF 999' },
          { description: 'Klickbares WhatsApp + Calendly-Einbindung' },
          { description: 'Leichte Erklärung und Übergabe' },
        ],
        callToAction: { text: 'Paket CHF 1’500 wählen →', href: '/de/choose-template?plan=essential1500' },
      },
      {
        title: 'Custom systems',
        subtitle: 'Private Codebase, Backend oder schwerere Architektur',
        price: 2000,
        period: 'ab — vor Build gescopt',
        items: [
          { description: 'CHF 2’000: private Codebase' },
          { description: 'CHF 2’200: private Codebase + Übergabe' },
          { description: 'CHF 4’500: leichtes Backend' },
          { description: 'CHF 8’000+: Headless Shop oder schwereres System' },
        ],
        callToAction: { text: 'Progression ansehen', href: '#modal-custom-de' },
      },
    ]}
  />

  <div class="mt-6 grid gap-4 max-w-7xl mx-auto px-4">
    <div class="flex flex-wrap gap-4">
      <PricingOptions
        id="modal-essential-de"
        triggerText=""
        title="Standardpakete"
        subtitle="Das richtige Niveau wählen, ohne zu früh Custom zu kaufen"
        ctaText="Wählen"
        tiers={[
          { label: 'CHF 999', price: 'ab 999', features: ['Statische Seite', 'Einfaches Formular (E-Mail)'], href: '/de/choose-template?plan=essential999', info: ['Hosting & SSL inklusive (3 Monate)', 'Bereitstellung auf der gemeinsamen IOPartner-Infrastruktur', 'Zusätzliche Seiten, Workshops oder Extra-Scope separat offeriert'] },
          { label: 'CHF 1’500', price: '1’500', features: ['Enthält die CHF-999-Basis', 'WhatsApp + Calendly', 'Leichte Erklärung / Übergabe'], href: '/de/choose-template?plan=essential1500', primary: true, info: ['Weiterhin auf der gemeinsamen IOPartner-Infrastruktur', 'WhatsApp und Calendly im validierten Umfang verkabelt', 'Zusätzliche Seiten, Workshops oder Extra-Scope separat offeriert'] },
        ]}
        footnote="Geliefert wird der bestätigte Umfang; zusätzliche Seiten, Workshops/Brainstorming, Redesigns und Leistungen ausserhalb des Scopes werden separat verrechnet."
      />
      <PricingOptions
        id="modal-custom-de"
        triggerText=""
        title="Custom progression"
        subtitle="Wenn der richtige Zug kein einfacher Template-Launch mehr ist"
        ctaText="Öffnen"
        tiers={[
          { label: 'CHF 2’000', price: 'private Codebase', features: ['Getrennte Codebase', 'Verlässt die gemeinsame Infrastruktur'], href: '/de/custom-systems?track=private-2000#diagnostic' },
          { label: 'CHF 2’200', price: 'privat + Übergabe', features: ['Getrennte Codebase', 'Strukturierte Übergabe'], href: '/de/custom-systems?track=private-2200#diagnostic', primary: true },
          { label: 'CHF 4’500', price: 'leichtes Backend', features: ['Leichte Business-Logik', 'Intake, Sync oder simples Portal'], href: '/de/custom-systems?track=backend-4500#diagnostic' },
          { label: 'CHF 8’000+', price: 'schwereres System', features: ['Headless Shop', 'Admin, Portal oder tiefere Architektur'], href: '/de/custom-systems?track=shop-8000#diagnostic' },
        ]}
        footnote="Architektur-, Portal-, Admin- oder Plattformarbeit wird nach dem bezahlten 15-Min.-/CHF-80-Diagnostik sauber gescopt."
      />
    </div>
  </div>

  

  <Features3
    title="Was unsere Angebote beinhalten können"
    subtitle="Je nach Paket und Bedarf."
    columns={2}
    items={[
      {
        title: 'Menschlicher Support',
        description: 'Begleitung per E-Mail und Telefon, Antworten innerhalb eines Arbeitstages.',
        icon: 'tabler:headset',
      },
      {
        title: 'Schweizer Hosting (optional)',
        description: 'Server in der Schweiz mit SSL, auf höheren Stufen verfügbar.',
        icon: 'tabler:server',
      },
      {
        title: 'Einfacher Prozess',
        description: 'Austausch per E‑Mail und Freigaben pro Schritt (kein Kundenportal).',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Klare Fakturierung',
        description: 'MwSt. inklusive, QR-Rechnung oder Twint, monatliche Zahlung möglich.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Optimierte Performance',
        description: 'Astro-Architektur und Bildoptimierung für schnelle Ladezeiten.',
        icon: 'tabler:gauge',
      },
      {
        title: 'Erhöhte Sicherheit',
        description: 'Initiale Backups, Application-Firewall und regelmässige Updates.',
        icon: 'tabler:lock',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <Steps
    title="So läuft Ihr Projekt ab"
    tagline="Ablauf"
    isReversed={true}
    items={[
      {
        title: '1. Digitale Unterschrift',
        description: 'Paket bestätigen und Zugang zum Onboarding erhalten.',
        icon: 'tabler:edit',
      },
      {
        title: '2. Intelligenter Fragebogen',
        description: 'Schlüsselinformationen teilen, Visuals hochladen und Module wählen.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: '3. Überwachte Produktion',
        description: 'Plattform generiert Ihre Website, Expert·innen finalisieren und prüfen.',
        icon: 'tabler:robot',
      },
      {
        title: '4. Freigabe & Go-Live',
        description: 'Sie geben die finale Version frei, wir planen den Go-Live und offerieren jede Scope-Erweiterung separat.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="image">
      <div class="relative aspect-[3/4] overflow-hidden rounded-xl bg-gradient-to-br from-blue-700 via-slate-900 to-slate-800 p-10 text-white shadow-xl">
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200/80">Prozess</p>
          <p class="mt-6 max-w-xs text-base text-blue-100/90">
            Einfacher Ablauf: Briefing, Inhaltsintegration und Freigaben per E‑Mail.
          </p>
      </div>
    </Fragment>
  </Steps>

  <FAQs
    title="Fragen zu unseren Preisen"
    subtitle="Wir setzen auf vollständige Transparenz."
    items={[
      {
        title: 'Ist die MwSt. enthalten?',
        description: 'Ja, alle Beträge sind inkl. MwSt. Die Rechnung weist die Schweizer MwSt. und die IDE-Nummer aus.',
      },
      {
        title: 'Wie lange dauert das Paket Essentiel?',
        description: 'Rund fünf Arbeitstage nach Eingang Ihrer Inhalte. Den genauen Zeitplan erhalten Sie beim Briefing.',
      },
      {
        title: 'Was passiert bei zusätzlichen Seiten oder weiterem Brainstorming?',
        description: 'Zusätzliche Seiten, Workshops oder Brainstorming, Strukturänderungen und Leistungen ausserhalb des Umfangs werden vor Produktionsstart separat offeriert.',
      },
      {
        title: 'Ist der Serviceplan obligatorisch?',
        description: 'Nein. Pläne zu 79 / 149 / 249 CHF/Monat verfügbar. Kündigungsfrist 30 Tage.',
      },
      {
        title: 'Welche Zahlungsmittel akzeptiert ihr?',
        description: 'Schweizer Karten, Twint, Banküberweisung und QR-Rechnung. Abonnemente monatlich oder jährlich zahlbar.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Angebot erhalten',
        href: '/de/contact#form',
        icon: 'tabler:mail-forward',
      },
      {
        text: 'Pakete vergleichen',
        href: '/de/services',
      },
    ]}
  >
    <Fragment slot="title">Brauchen Sie ein massgeschneidertes Angebot?</Fragment>

    <Fragment slot="subtitle">
      Wir passen jedes Paket an die Besonderheiten Ihres Unternehmens im Genfersee-Raum an.
    </Fragment>
  </CallToAction>
</Layout>
