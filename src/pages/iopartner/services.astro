---
import IoBlueprintVisual from '~/components/iopartner/IoBlueprintVisual.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
  description:
    'Services IOPartner: consulting technique, systems & operations, déploiement standard et continuité technique pour PME.',
};

const capabilities = [
  {
    title: 'Consulting technique',
    body: 'Arbitrage, revue, déblocage et cadrage avant d’engager du temps de build.',
    meta: '60 CHF / 15 min · 140 CHF / h',
  },
  {
    title: 'Systems & operations',
    body: 'Infrastructure, backend léger, automatisation, supervision, intégrations et continuité.',
    meta: 'scope sur devis',
  },
  {
    title: 'Déploiement standard',
    body: 'Présence web cadrée quand une build privée serait inutilement lourde.',
    meta: 'dès 999 CHF',
  },
  {
    title: 'Continuité technique',
    body: 'Support, incidents, DNS, monitoring, corrections et évolutions après livraison.',
    meta: 'selon besoin',
  },
];

const outcomes = [
  'Décision technique plus nette',
  'Périmètre de build défendable',
  'Infrastructure plus propre',
  'Workflows moins manuels',
  'Présence web maintenable',
  'Point de contact stable',
];
---

<Layout metadata={metadata}>
  <main class="io-services">
    <section class="io-shell io-hero">
      <div>
        <p class="io-kicker">Services</p>
        <h1>Conseil, systèmes et déploiement au bon niveau.</h1>
        <p>
          IOPartner ne pousse pas chaque besoin vers du custom. On clarifie d’abord, puis on livre la forme utile:
          consulting, systems & operations, ou déploiement standard.
        </p>
        <div class="io-actions">
          <a class="io-btn io-btn-primary" href="/contact#form">Envoyer le contexte</a>
          <a class="io-btn io-btn-secondary" href="/pricing">Voir les tarifs</a>
        </div>
      </div>
      <IoBlueprintVisual variant="decision" />
    </section>

    <section class="io-shell io-capabilities">
      {
        capabilities.map((item) => (
          <article>
            <span>{item.meta}</span>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))
      }
    </section>

    <section class="io-systems-band">
      <div class="io-shell io-systems-grid">
        <div>
          <p class="io-kicker">Systems & operations</p>
          <h2>La couche avancée reste séparée du site standard.</h2>
          <p>
            Quand il faut toucher à l’architecture, au backend, aux workflows ou à la continuité technique, le sujet est
            cadré comme un système, pas comme une option de site.
          </p>
          <div class="io-stack-line">Docker · VPS · DNS · SSL · monitoring · workflows · API · dashboards</div>
        </div>
        <IoBlueprintVisual variant="systems" />
      </div>
    </section>

    <section class="io-shell io-outcomes">
      <div>
        <p class="io-kicker">Sorties concrètes</p>
        <h2>Moins de théorie. Plus d’artefacts utiles.</h2>
      </div>
      <ul>
        {outcomes.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="io-shell io-standard">
      <div>
        <p class="io-kicker">Déploiement standard</p>
        <h2>Quand le standard suffit, il doit rester propre.</h2>
        <p>
          Le format 999 CHF est gardé comme une baseline de lancement: rapide, cadrée, maintenable, sans prétendre être
          une infrastructure sur mesure.
        </p>
        <a class="io-btn io-btn-primary" href="/choose-template?plan=essential999">Choisir une base</a>
      </div>
      <IoBlueprintVisual variant="standard" />
    </section>
  </main>

  <style>
    .io-services {
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-line: rgba(148, 163, 184, 0.22);
      --io-blue: #0b63f6;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px), #f8fbff;
      background-size:
        34px 34px,
        34px 34px,
        100% 100%;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 84rem);
      margin-inline: auto;
    }

    .io-hero,
    .io-systems-grid,
    .io-standard {
      display: grid;
      grid-template-columns: minmax(0, 0.88fr) minmax(26rem, 1fr);
      gap: 3rem;
      align-items: center;
    }

    .io-hero,
    .io-standard {
      padding: 5rem 0;
    }

    h1,
    h2 {
      margin: 0;
      font-weight: 850;
      line-height: 1.05;
    }

    h1 {
      max-width: 43rem;
      font-size: 4rem;
    }

    h2 {
      font-size: 2.4rem;
    }

    p {
      color: var(--io-muted);
      font-size: 1.1rem;
      line-height: 1.7;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 2rem;
    }

    .io-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3rem;
      border-radius: 999px;
      padding: 0.78rem 1.35rem;
      font-weight: 780;
      text-decoration: none;
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      color: var(--io-ink);
      background: rgba(255, 255, 255, 0.72);
    }

    .io-capabilities {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      padding-bottom: 5rem;
    }

    .io-capabilities article {
      min-height: 17rem;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.5rem;
      background: rgba(255, 255, 255, 0.8);
    }

    .io-capabilities span {
      color: var(--io-blue);
      font-size: 0.82rem;
      font-weight: 820;
      text-transform: uppercase;
    }

    .io-capabilities h2 {
      margin-top: 1.1rem;
      font-size: 1.55rem;
    }

    .io-systems-band {
      padding: 5rem 0;
      background: #061120;
      color: #f8fafc;
    }

    .io-systems-band h2 {
      color: #fff;
      font-size: 3rem;
    }

    .io-systems-band p {
      color: #cbd5e1;
      max-width: 38rem;
    }

    .io-stack-line {
      margin-top: 1.5rem;
      color: #93c5fd;
      font-weight: 760;
      line-height: 1.6;
    }

    .io-outcomes {
      display: grid;
      grid-template-columns: minmax(0, 0.8fr) minmax(24rem, 1fr);
      gap: 3rem;
      padding: 5rem 0 2rem;
      align-items: start;
    }

    .io-outcomes h2 {
      font-size: 3rem;
    }

    .io-outcomes ul {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.8rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .io-outcomes li {
      border: 1px solid var(--io-line);
      border-radius: 0.8rem;
      padding: 1rem;
      background: rgba(255, 255, 255, 0.74);
      font-weight: 730;
    }

    .io-standard {
      padding-bottom: 6rem;
    }

    @media (max-width: 1100px) {
      .io-hero,
      .io-systems-grid,
      .io-standard,
      .io-outcomes {
        grid-template-columns: 1fr;
      }

      .io-capabilities {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .io-shell {
        width: min(100% - 1rem, 84rem);
      }

      h1 {
        font-size: 2.65rem;
      }

      .io-systems-band h2,
      .io-outcomes h2 {
        font-size: 2.15rem;
      }

      .io-capabilities,
      .io-outcomes ul {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
