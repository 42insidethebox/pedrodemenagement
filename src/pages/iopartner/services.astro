---
import IoBlueprintVisual from '~/components/iopartner/IoBlueprintVisual.astro';
import Io02SvgLinesPathsCurves from '~/components/iopartner/visuals/Io02SvgLinesPathsCurves.astro';
import { detectRequestLocale } from '~/lib/locale';
import Layout from '~/layouts/PageLayout.astro';

const locale = detectRequestLocale(Astro.request, Astro.url);
const localePrefix = ['en', 'de', 'it'].includes(locale) ? `/${locale}` : '';

const COPY = {
  fr: {
    metadata: {
      title: 'Services',
      description:
        'Services IOPartner: cadrage technique, systèmes & opérations, présence web cadrée et continuité technique pour PME.',
    },
    kicker: 'Services',
    heroTitle: 'Conseil, systèmes et déploiement au bon niveau.',
    heroBody:
      'IOPartner ne pousse pas chaque besoin vers du custom. On clarifie d’abord, puis on livre la forme utile: cadrage, systèmes & opérations, ou présence web cadrée.',
    primary: 'Envoyer le contexte',
    secondary: 'Voir les tarifs',
    capabilities: [
      { title: 'Cadrage technique', body: 'Arbitrage, revue, déblocage et cadrage avant d’engager du temps de build.', meta: '60 CHF / 15 min · 140 CHF / h' },
      { title: 'Systèmes & opérations', body: 'Infrastructure, backend léger, automatisation, supervision, intégrations et continuité.', meta: 'scope sur devis' },
      { title: 'Présence web cadrée', body: 'Présence web cadrée quand une build privée serait inutilement lourde.', meta: 'dès 999 CHF' },
      { title: 'Continuité technique', body: 'Support, incidents, DNS, monitoring, corrections et évolutions après livraison.', meta: 'selon besoin' },
    ],
    systemsKicker: 'Systèmes & opérations',
    systemsTitle: 'La couche avancée reste séparée du site standard.',
    systemsBody:
      'Quand il faut toucher à l’architecture, au backend, aux workflows ou à la continuité technique, le sujet est cadré comme un système, pas comme une option de site.',
    outcomesKicker: 'Sorties concrètes',
    outcomesTitle: 'Moins de théorie. Plus d’artefacts utiles.',
    outcomes: ['Décision technique plus nette', 'Périmètre de build défendable', 'Infrastructure plus propre', 'Workflows moins manuels', 'Présence web maintenable', 'Point de contact stable'],
    standardKicker: 'Présence web cadrée',
    standardTitle: 'Quand le standard suffit, il doit rester propre.',
    standardBody:
      'Le format 999 CHF est gardé comme une baseline de lancement: rapide, cadrée, maintenable, sans prétendre être une infrastructure sur mesure.',
    standardCta: 'Voir des projets livrés',
  },
  en: {
    metadata: {
      title: 'Services',
      description:
        'IOPartner services: technical scoping, systems & operations, scoped web presence, and technical continuity for SMEs.',
    },
    kicker: 'Services',
    heroTitle: 'Consulting, systems, and delivery at the right level.',
    heroBody:
      'IOPartner does not push every need into custom work. We clarify first, then deliver the useful form: scoping, systems & operations, or scoped web presence.',
    primary: 'Send the context',
    secondary: 'See pricing',
    capabilities: [
      { title: 'Technical scoping', body: 'Arbitration, review, unblock, and scoping before committing build time.', meta: 'CHF 60 / 15 min · CHF 140 / h' },
      { title: 'Systems & operations', body: 'Infrastructure, light backend, automation, supervision, integrations, and continuity.', meta: 'quoted scope' },
      { title: 'Scoped web presence', body: 'Scoped web presence when a private build would be unnecessarily heavy.', meta: 'from CHF 999' },
      { title: 'Technical continuity', body: 'Support, incidents, DNS, monitoring, fixes, and evolutions after delivery.', meta: 'as needed' },
    ],
    systemsKicker: 'Systems & operations',
    systemsTitle: 'The advanced layer stays separate from the standard site.',
    systemsBody:
      'When the topic touches architecture, backend, workflows, or technical continuity, it is scoped like a system, not sold as a website add-on.',
    outcomesKicker: 'Concrete outputs',
    outcomesTitle: 'Less theory. More useful artifacts.',
    outcomes: ['A clearer technical decision', 'A defensible build scope', 'Cleaner infrastructure', 'Less manual workflows', 'Maintainable web presence', 'A stable technical point of contact'],
    standardKicker: 'Scoped web presence',
    standardTitle: 'When standard is enough, it should stay clean.',
    standardBody:
      'The CHF 999 format remains a launch baseline: fast, scoped, maintainable, without pretending to be custom infrastructure.',
    standardCta: 'See delivered projects',
  },
  de: {
    metadata: {
      title: 'Services',
      description:
        'IOPartner Services: technisches Scoping, Systeme & Betrieb, klar abgegrenzte Web-Präsenz und technische Kontinuität für KMU.',
    },
    kicker: 'Services',
    heroTitle: 'Beratung, Systeme und Delivery auf dem richtigen Niveau.',
    heroBody:
      'IOPartner drängt nicht jeden Bedarf in Custom-Arbeit. Wir klären zuerst und liefern dann die nützliche Form: Scoping, Systeme & Betrieb oder klar abgegrenzte Web-Präsenz.',
    primary: 'Kontext senden',
    secondary: 'Preise ansehen',
    capabilities: [
      { title: 'Technisches Scoping', body: 'Abwägung, Review, Entblockung und Scoping, bevor Build-Zeit gebunden wird.', meta: 'CHF 60 / 15 Min. · CHF 140 / h' },
      { title: 'Systeme & Betrieb', body: 'Infrastruktur, leichtes Backend, Automatisierung, Überwachung, Integrationen und Kontinuität.', meta: 'Scope auf Anfrage' },
      { title: 'Klar abgegrenzte Web-Präsenz', body: 'Klar abgegrenzte Web-Präsenz, wenn ein privater Build unnötig schwer wäre.', meta: 'ab CHF 999' },
      { title: 'Technische Kontinuität', body: 'Support, Incidents, DNS, Monitoring, Korrekturen und Weiterentwicklungen nach der Lieferung.', meta: 'nach Bedarf' },
    ],
    systemsKicker: 'Systeme & Betrieb',
    systemsTitle: 'Die fortgeschrittene Ebene bleibt getrennt von der Standard-Website.',
    systemsBody:
      'Wenn Architektur, Backend, Workflows oder technische Kontinuität berührt werden, wird das Thema als System gescopt, nicht als Website-Option verkauft.',
    outcomesKicker: 'Konkrete Ergebnisse',
    outcomesTitle: 'Weniger Theorie. Mehr nützliche Artefakte.',
    outcomes: ['Klarere technische Entscheidung', 'Vertretbarer Build-Scope', 'Sauberere Infrastruktur', 'Weniger manuelle Workflows', 'Wartbare Web-Präsenz', 'Stabiler technischer Ansprechpartner'],
    standardKicker: 'Klar abgegrenzte Web-Präsenz',
    standardTitle: 'Wenn Standard reicht, sollte er sauber bleiben.',
    standardBody:
      'Das CHF-999-Format bleibt eine Launch-Basis: schnell, abgegrenzt, wartbar, ohne vorzugeben, Custom-Infrastruktur zu sein.',
    standardCta: 'Gelieferte Projekte ansehen',
  },
  it: {
    metadata: {
      title: 'Servizi',
      description:
        'Servizi IOPartner: inquadramento tecnico, sistemi & operazioni, presenza web strutturata e continuità tecnica per PMI.',
    },
    kicker: 'Servizi',
    heroTitle: 'Consulenza, sistemi e delivery al giusto livello.',
    heroBody:
      'IOPartner non spinge ogni bisogno verso il custom. Prima chiarisce, poi consegna la forma utile: inquadramento, sistemi & operazioni o presenza web strutturata.',
    primary: 'Inviare il contesto',
    secondary: 'Vedere i prezzi',
    capabilities: [
      { title: 'Inquadramento tecnico', body: 'Arbitraggio, review, sblocco e definizione prima di impegnare tempo di build.', meta: 'CHF 60 / 15 min · CHF 140 / h' },
      { title: 'Sistemi & operazioni', body: 'Infrastruttura, backend leggero, automazione, supervisione, integrazioni e continuità.', meta: 'scope su preventivo' },
      { title: 'Presenza web strutturata', body: 'Presenza web strutturata quando una build privata sarebbe inutilmente pesante.', meta: 'da CHF 999' },
      { title: 'Continuità tecnica', body: 'Supporto, incidenti, DNS, monitoring, correzioni ed evoluzioni dopo la consegna.', meta: 'secondo necessità' },
    ],
    systemsKicker: 'Sistemi & operazioni',
    systemsTitle: 'Il livello avanzato resta separato dal sito standard.',
    systemsBody:
      'Quando si toccano architettura, backend, workflow o continuità tecnica, il tema viene definito come sistema, non venduto come opzione del sito.',
    outcomesKicker: 'Output concreti',
    outcomesTitle: 'Meno teoria. Più artefatti utili.',
    outcomes: ['Decisione tecnica più chiara', 'Perimetro di build difendibile', 'Infrastruttura più pulita', 'Meno workflow manuali', 'Presenza web mantenibile', 'Punto di contatto tecnico stabile'],
    standardKicker: 'Presenza web strutturata',
    standardTitle: 'Quando lo standard basta, deve restare pulito.',
    standardBody:
      'Il formato da CHF 999 resta una baseline di lancio: rapido, definito, mantenibile, senza fingere di essere infrastruttura custom.',
    standardCta: 'Vedere i progetti consegnati',
  },
} as const;

const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
const metadata = copy.metadata;
const capabilities = copy.capabilities;
const outcomes = copy.outcomes;
---

<Layout metadata={metadata}>
  <main class="io-services">
    <section class="io-shell io-hero">
      <div>
        <p class="io-kicker">{copy.kicker}</p>
        <h1>{copy.heroTitle}</h1>
        <p>{copy.heroBody}</p>
        <div class="io-actions">
          <a class="io-btn io-btn-primary" href={`${localePrefix}/contact#form`}>{copy.primary}</a>
          <a class="io-btn io-btn-secondary" href={`${localePrefix}/pricing`}>{copy.secondary}</a>
        </div>
      </div>
      <IoBlueprintVisual variant="decision" />
    </section>

    <section class="io-shell io-capabilities">
      {
        capabilities.map((item) => (
          <article>
            <span>{item.meta}</span>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))
      }
    </section>

    <section class="io-systems-band">
      <div class="io-shell io-systems-grid">
        <div>
          <p class="io-kicker">{copy.systemsKicker}</p>
          <h2>{copy.systemsTitle}</h2>
          <p>{copy.systemsBody}</p>
          <div class="io-stack-line">Docker · VPS · DNS · SSL · monitoring · workflows · API · dashboards</div>
        </div>
        <Io02SvgLinesPathsCurves />
      </div>
    </section>

    <section class="io-shell io-outcomes">
      <div>
        <p class="io-kicker">{copy.outcomesKicker}</p>
        <h2>{copy.outcomesTitle}</h2>
      </div>
      <ul>
        {outcomes.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="io-shell io-standard">
      <div>
        <p class="io-kicker">{copy.standardKicker}</p>
        <h2>{copy.standardTitle}</h2>
        <p>{copy.standardBody}</p>
        <a class="io-btn io-btn-primary" href={`${localePrefix}/presence-web-cadree#modeles`}>{copy.standardCta}</a>
      </div>
      <IoBlueprintVisual variant="standard" />
    </section>
  </main>

  <style>
    .io-services {
      --io-ink: #0f172a;
      --io-muted: #5f6b7c;
      --io-line: rgba(148, 163, 184, 0.22);
      --io-blue: #0b63f6;
      background:
        linear-gradient(90deg, rgba(37, 99, 235, 0.045) 1px, transparent 1px),
        linear-gradient(rgba(37, 99, 235, 0.045) 1px, transparent 1px), #f8fbff;
      background-size:
        34px 34px,
        34px 34px,
        100% 100%;
      color: var(--io-ink);
    }

    .io-shell {
      width: min(100% - 2rem, 84rem);
      margin-inline: auto;
    }

    .io-hero,
    .io-systems-grid,
    .io-standard {
      display: grid;
      grid-template-columns: minmax(0, 0.88fr) minmax(26rem, 1fr);
      gap: 3rem;
      align-items: center;
    }

    .io-hero,
    .io-standard {
      padding: 5rem 0;
    }

    h1,
    h2 {
      margin: 0;
      font-weight: 850;
      line-height: 1.05;
    }

    h1 {
      max-width: 43rem;
      font-size: 4rem;
    }

    h2 {
      font-size: 2.4rem;
    }

    p {
      color: var(--io-muted);
      font-size: 1.1rem;
      line-height: 1.7;
    }

    .io-kicker {
      margin: 0 0 1rem;
      color: var(--io-blue);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .io-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 2rem;
    }

    .io-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3rem;
      border-radius: 999px;
      padding: 0.78rem 1.35rem;
      font-weight: 780;
      text-decoration: none;
    }

    .io-btn-primary {
      background: var(--io-blue);
      color: #fff;
    }

    .io-btn-secondary {
      border: 1px solid rgba(15, 23, 42, 0.22);
      color: var(--io-ink);
      background: rgba(255, 255, 255, 0.72);
    }

    .io-capabilities {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      padding-bottom: 5rem;
    }

    .io-capabilities article {
      min-height: 17rem;
      border: 1px solid var(--io-line);
      border-radius: 1rem;
      padding: 1.5rem;
      background: rgba(255, 255, 255, 0.8);
    }

    .io-capabilities span {
      color: var(--io-blue);
      font-size: 0.82rem;
      font-weight: 820;
      text-transform: uppercase;
    }

    .io-capabilities h2 {
      margin-top: 1.1rem;
      font-size: 1.55rem;
    }

    .io-systems-band {
      padding: 5rem 0;
      background: #061120;
      color: #f8fafc;
    }

    .io-systems-band h2 {
      color: #fff;
      font-size: 3rem;
    }

    .io-systems-band p {
      color: #cbd5e1;
      max-width: 38rem;
    }

    .io-stack-line {
      margin-top: 1.5rem;
      color: #93c5fd;
      font-weight: 760;
      line-height: 1.6;
    }

    .io-outcomes {
      display: grid;
      grid-template-columns: minmax(0, 0.8fr) minmax(24rem, 1fr);
      gap: 3rem;
      padding: 5rem 0 2rem;
      align-items: start;
    }

    .io-outcomes h2 {
      font-size: 3rem;
    }

    .io-outcomes ul {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.8rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .io-outcomes li {
      border: 1px solid var(--io-line);
      border-radius: 0.8rem;
      padding: 1rem;
      background: rgba(255, 255, 255, 0.74);
      font-weight: 730;
    }

    .io-standard {
      padding-bottom: 6rem;
    }

    @media (max-width: 1100px) {
      .io-hero,
      .io-systems-grid,
      .io-standard,
      .io-outcomes {
        grid-template-columns: 1fr;
      }

      .io-capabilities {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .io-shell {
        width: min(100% - 1rem, 84rem);
      }

      h1 {
        font-size: 2.65rem;
      }

      .io-systems-band h2,
      .io-outcomes h2 {
        font-size: 2.15rem;
      }

      .io-capabilities,
      .io-outcomes ul {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
