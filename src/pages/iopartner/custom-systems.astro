const selectedTrackMap = copy.selectedTrackMap as Record<string, string>;
const selectedTrackFallback = copy.selectedTrackFallback as string;
const selectedTrackLabel = selectedTrackMap[track] || selectedTrackFallback;
const diagnosticService =
  selectedTrackLabel === selectedTrackFallback
    ? selectedTrackFallback
    : `${selectedTrackFallback} — ${selectedTrackLabel}`;
---

<Layout metadata={{ title: copy.title }} brandKey="iopartner">
  <main class="min-h-screen bg-[linear-gradient(180deg,#f8fafc_0%,#eef2ff_42%,#f8fafc_100%)] py-12 px-4">
    <div class="max-w-6xl mx-auto space-y-10">
      <section class="rounded-[2rem] border border-slate-200 bg-white/90 shadow-xl shadow-slate-200/60 overflow-hidden">
        <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] p-8 md:p-10">
          <div class="space-y-5">
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-blue-700">{copy.eyebrow}</p>
            <h1 class="text-4xl md:text-5xl font-black tracking-tight text-slate-950">{copy.heroTitle}</h1>
            <p class="text-lg text-slate-600 max-w-2xl">{copy.heroLead}</p>
            <p class="text-sm text-slate-500 max-w-2xl">{copy.backing}</p>
            <div class="flex flex-wrap gap-3">
              <a
                href="#diagnostic"
                class="inline-flex items-center rounded-xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white hover:bg-blue-700 transition-colors"
              >
                {copy.diagnosticTitle}
              </a>
              <a
                href={pathFor('/choose-template?plan=essential1500')}
                class="inline-flex items-center rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 hover:border-slate-300 hover:bg-slate-50 transition-colors"
              >
                {copy.tiers[0].cta}
              </a>
            </div>
          </div>

          <div class="rounded-[1.5rem] bg-slate-950 p-6 md:p-7 text-white">
            <p class="text-xs uppercase tracking-[0.28em] text-blue-200/80">{copy.exactLadder}</p>
            <div class="mt-5 space-y-4">
              {copy.tiers.map((tier) => (
                <div class={`rounded-2xl border p-4 ${tier.key === track ? 'border-blue-300 bg-white/10' : 'border-white/10 bg-white/5'}`}>
                  <div class="flex items-baseline justify-between gap-3">
                    <h2 class="text-lg font-semibold">{tier.title}</h2>
                    <span class="text-sm font-semibold text-blue-200">{tier.price}</span>
                  </div>
                  <p class="mt-2 text-sm text-white/75">{tier.body}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {copy.tiers.map((tier) => (
          <article class={`rounded-[1.7rem] border bg-white p-6 shadow-sm ${tier.key === track ? 'border-blue-400 shadow-blue-100' : 'border-slate-200'}`}>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">{tier.price}</p>
            <h2 class="mt-3 text-2xl font-bold text-slate-950">{tier.title}</h2>
            <p class="mt-3 text-sm leading-6 text-slate-600">{tier.body}</p>
            <a
              href={tier.href}
              class={`mt-6 inline-flex rounded-xl px-4 py-3 text-sm font-semibold transition-colors ${
                tier.key === 'starter-1500'
                  ? 'bg-slate-950 text-white hover:bg-slate-800'
                  : 'bg-blue-600 text-white hover:bg-blue-700'
              }`}
            >
              {tier.cta}
            </a>
          </article>
        ))}

        <article class="rounded-[1.7rem] border border-slate-200 bg-slate-50 p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">{copy.belowTitle}</p>
          <h2 class="mt-3 text-2xl font-bold text-slate-950">{copy.belowHeadline}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">{copy.belowBody}</p>
          <div class="mt-6 flex flex-wrap gap-3">
            {copy.belowCtas.map((cta) => (
              <a
                href={cta.href}
                class="inline-flex rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 hover:border-slate-300 hover:bg-slate-100 transition-colors"
              >
                {cta.text}
              </a>
            ))}
          </div>
        </article>
      </section>

      <section class="rounded-[1.8rem] border border-slate-200 bg-white p-8 shadow-sm">
        <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-blue-700">{copy.architectureTitle}</p>
            <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950">{copy.diagnosticTitle}</h2>
            <p class="mt-4 text-slate-600 leading-7">{copy.architectureBody}</p>
            <div class="mt-6 rounded-2xl border border-blue-100 bg-blue-50 p-4">
              <p class="text-sm font-semibold text-blue-900">{copy.selectedTrackLabel}</p>
              <p class="mt-1 text-sm text-blue-800">{selectedTrackLabel}</p>
            </div>
            <p class="mt-6 text-sm text-slate-500">{copy.note}</p>
          </div>

          <div class="rounded-[1.6rem] border border-slate-200 bg-slate-50 p-6 md:p-7" id="diagnostic">
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-blue-700">{copy.diagnosticEyebrow}</p>
            <p class="mt-3 text-lg text-slate-600">{copy.diagnosticLead}</p>
            <div class="mt-5 rounded-2xl border border-slate-200 bg-white p-4">
              <p class="text-sm font-semibold text-slate-950">{copy.diagnosticIncludesTitle}</p>
              <ul class="mt-3 space-y-2 text-sm text-slate-600">
                {copy.diagnosticIncludes.map((item) => <li>• {item}</li>)}
              </ul>
            </div>

            <form action="/api/booking" method="post" class="mt-6 space-y-4">
              <BookingSlotPicker
                dateLabel={copy.form.dateLabel}
                slotLabel={copy.form.slotLabel}
                chooseDateText={copy.form.chooseDate}
                selectSlotText={copy.form.selectSlot}
                loadingText={copy.form.loading}
                unavailableText={copy.form.unavailable}
                missingSlotText={copy.form.missingSlot}
                theme="light"
                accent="blue"
                startHour={9}
                endHour={17}
                slotDurationMinutes={15}
                slotStepMinutes={15}
              />
              <input type="hidden" name="locale" value={locale} />
              <input type="hidden" name="service" value={diagnosticService} />
              <div class="grid gap-3 md:grid-cols-2">
                <div class="grid gap-2">
                  <label class="text-sm font-semibold text-slate-800">{copy.form.name}</label>
                  <input
                    type="text"
                    name="name"
                    required
                    class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400"
                  />
                </div>
                <div class="grid gap-2">
                  <label class="text-sm font-semibold text-slate-800">{copy.form.email}</label>
                  <input
                    type="email"
                    name="email"
                    required
                    class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400"
                  />
                </div>
              </div>
              <div class="grid gap-2">
                <label class="text-sm font-semibold text-slate-800">{copy.form.phone}</label>
                <input
                  type="tel"
                  name="phone"
                  required
                  class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400"
                />
              </div>
              <div class="grid gap-2">
                <label class="text-sm font-semibold text-slate-800">{copy.form.notes}</label>
                <textarea
                  name="notes"
                  rows={4}
                  placeholder={copy.form.notesPlaceholder}
                  class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400"
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700 transition-colors"
              >
                {copy.form.submit}
              </button>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>
