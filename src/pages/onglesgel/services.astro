---
import Shell from '~/tenants/onglesgel/Shell.astro';
import { ogServices } from '~/tenants/onglesgel/services';
import { onglesGelConfig } from '~/tenants/onglesgel/config';

const metadata = {
  title: 'Tarifs — Ongles Gel Lausanne',
  description: 'Pose gel, extensions, nail art et soins. Tous nos tarifs à Lausanne.',
  ignoreTitleTemplate: true,
};
---

<Shell page="services" metadata={metadata}>
  <div class="og-page">

    <header class="og-page-header">
      <p class="og-label">Tarifs</p>
      <h1 class="og-page-title">Nos prestations</h1>
      <p class="og-page-sub">Tous les prix indiqués sont donnés à titre indicatif. Le tarif définitif est établi lors de votre rendez-vous selon la longueur et l'état de vos ongles.</p>
    </header>

    <div class="og-service-table">
      {ogServices.map((group) => (
        <div class="og-service-group">
          <div class="og-group-head">
            <span class="og-group-num">{group.number}</span>
            <h2 class="og-group-name">{group.category}</h2>
          </div>
          <ul class="og-service-list">
            {group.items.map((item) => (
              <li>
                <div class="og-svc-text">
                  <span class="og-svc-name">{item.name}</span>
                  {item.detail && <span class="og-svc-detail">{item.detail}</span>}
                </div>
                <span class="og-svc-price">{item.price}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="og-cta-strip">
      <p class="og-cta-note">Réservation recommandée — disponibilités limitées.</p>
      <div class="og-cta-actions">
        <a class="og-btn og-btn-primary og-btn-lg" href={onglesGelConfig.bookingUrl} target="_blank" rel="noreferrer">
          Réserver un rendez-vous
        </a>
        <a class="og-btn og-btn-ghost og-btn-lg" href={onglesGelConfig.whatsappUrl} target="_blank" rel="noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.52 3.48A11.93 11.93 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.11.55 4.17 1.6 5.99L0 24l6.18-1.62A11.93 11.93 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.48-8.52zm-8.52 18.48a9.9 9.9 0 0 1-5.04-1.37l-.36-.21-3.67.96.98-3.58-.23-.37A9.9 9.9 0 0 1 2.1 12c0-5.46 4.44-9.9 9.9-9.9a9.9 9.9 0 0 1 0 19.8zm5.44-7.4c-.3-.15-1.77-.87-2.04-.97s-.47-.15-.67.15-.77.97-.94 1.17-.35.22-.64.07a8.12 8.12 0 0 1-2.39-1.47 8.98 8.98 0 0 1-1.65-2.05c-.17-.3-.02-.46.13-.6.13-.13.3-.35.44-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52s-.67-1.62-.92-2.22c-.24-.58-.48-.5-.67-.51h-.57c-.2 0-.52.07-.79.37s-1.04 1.02-1.04 2.48 1.07 2.88 1.21 3.08c.15.2 2.1 3.2 5.09 4.49.71.31 1.27.49 1.7.63.72.23 1.37.2 1.89.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
          </svg>
          Écrire sur WhatsApp
        </a>
      </div>
    </div>

  </div>
</Shell>

<style>
  .og-page {
    max-width: 960px;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) 2.5rem clamp(4rem, 8vw, 7rem);
    display: grid;
    gap: 3rem;
  }

  .og-label {
    font-family: var(--og-heading);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--og-accent);
  }

  .og-page-header {
    display: grid;
    gap: 0.75rem;
    border-bottom: 1px solid var(--og-line);
    padding-bottom: 2rem;
  }

  .og-page-title {
    font-family: var(--og-heading);
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.01em;
    margin: 0;
    color: var(--og-text);
  }

  .og-page-sub {
    color: var(--og-muted);
    font-size: 0.93rem;
    line-height: 1.65;
    max-width: 520px;
  }

  .og-service-table {
    display: grid;
    gap: 2.5rem;
  }

  .og-service-group {
    display: grid;
    gap: 0;
    border: 1px solid var(--og-line);
    border-radius: 12px;
    overflow: hidden;
  }

  .og-group-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: var(--og-surface);
    border-bottom: 1px solid var(--og-line);
  }

  .og-group-num {
    font-family: var(--og-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--og-accent);
    text-transform: uppercase;
  }

  .og-group-name {
    font-family: var(--og-heading);
    font-size: 1.15rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.01em;
    margin: 0;
    color: var(--og-text);
  }

  .og-service-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .og-service-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding: 0.9rem 1.5rem;
    border-bottom: 1px solid var(--og-line);
    transition: background 130ms;
  }
  .og-service-list li:last-child { border-bottom: none; }
  .og-service-list li:hover { background: var(--og-surface); }

  .og-svc-text { display: grid; gap: 0.1rem; }
  .og-svc-name { font-size: 0.92rem; font-weight: 500; color: var(--og-text); }
  .og-svc-detail { font-size: 0.79rem; color: var(--og-muted); }

  .og-svc-price {
    font-family: var(--og-heading);
    font-size: 1rem;
    font-weight: 400;
    font-style: italic;
    color: var(--og-accent);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .og-cta-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 2rem;
    border-radius: 12px;
    background: var(--og-surface);
    border: 1px solid var(--og-line);
  }

  .og-cta-note {
    font-family: var(--og-heading);
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 300;
    color: var(--og-text);
    margin: 0;
  }

  .og-cta-actions {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .og-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    font-family: var(--og-body);
    font-size: 0.855rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: background 140ms, border-color 140ms;
  }
  .og-btn-lg { padding: 0.6rem 1.4rem; font-size: 0.9rem; }
  .og-btn-primary {
    background: var(--og-accent);
    color: #fff;
    border: 1.5px solid var(--og-accent);
  }
  .og-btn-primary:hover { background: color-mix(in srgb, var(--og-accent) 88%, #1A1612 12%); }
  .og-btn-ghost {
    background: transparent;
    color: var(--og-text);
    border: 1.5px solid var(--og-line);
  }
  .og-btn-ghost:hover {
    border-color: color-mix(in srgb, var(--og-text) 25%, transparent);
    background: color-mix(in srgb, var(--og-text) 4%, transparent);
  }

  @media (max-width: 640px) {
    .og-page { padding: 2rem 1.25rem 4rem; }
    .og-cta-strip { flex-direction: column; align-items: flex-start; }
  }
</style>
