---
import { Image } from 'astro:assets';
import Shell from '~/tenants/onglesgel/Shell.astro';
import { getOgGalleryData } from '~/tenants/onglesgel/gallery';
import { onglesGelConfig } from '~/tenants/onglesgel/config';

const metadata = {
  title: 'Galerie — Ongles Gel Lausanne',
  description: 'Réalisations nail art, pose gel et extensions. Découvrez notre galerie photo.',
  ignoreTitleTemplate: true,
};

const { images } = await getOgGalleryData();

// Build a serialisable list of { src, alt, width, height } for the lightbox
const lightboxData = images.map((img) => ({
  src: img.src.src,
  alt: img.alt,
  width: img.src.width,
  height: img.src.height,
}));
---

<Shell page="galerie" metadata={metadata}>
  <div class="og-gallery-page">

    <header class="og-gallery-header">
      <p class="og-label">Galerie</p>
      <h1 class="og-gallery-title">Réalisations</h1>
      <p class="og-gallery-count">{images.length} créations</p>
    </header>

    <div class="og-grid" id="og-grid">
      {images.map((item, i) => (
        <button
          class="og-grid-item"
          data-index={i}
          aria-label={`Voir ${item.alt}`}
          type="button"
        >
          <Image
            src={item.src}
            alt={item.alt}
            loading={i < 6 ? 'eager' : 'lazy'}
            widths={[400, 700]}
            sizes="(max-width: 640px) 50vw, (max-width: 1100px) 33vw, 25vw"
            format="webp"
            quality={84}
          />
          <span class="og-grid-hover" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </span>
        </button>
      ))}
    </div>

  </div>

  <!-- LIGHTBOX -->
  <div class="og-lb" id="og-lb" role="dialog" aria-modal="true" aria-label="Galerie plein écran" hidden>
    <div class="og-lb-backdrop" id="og-lb-backdrop"></div>

    <div class="og-lb-stage">
      <figure class="og-lb-figure" id="og-lb-figure">
        <img id="og-lb-img" src="" alt="" />
      </figure>
    </div>

    <button class="og-lb-btn og-lb-close" id="og-lb-close" aria-label="Fermer" type="button">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>

    <button class="og-lb-btn og-lb-prev" id="og-lb-prev" aria-label="Image précédente" type="button">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>

    <button class="og-lb-btn og-lb-next" id="og-lb-next" aria-label="Image suivante" type="button">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>

    <div class="og-lb-counter" id="og-lb-counter" aria-live="polite"></div>
    <div class="og-lb-caption" id="og-lb-caption"></div>
  </div>

  <a class="og-book-float" href={onglesGelConfig.bookingUrl} target="_blank" rel="noreferrer">
    Réserver
  </a>
</Shell>

<script is:inline define:vars={{ lightboxData }}>
  (function () {
    const items = lightboxData;
    const total = items.length;
    let current = 0;
    let isOpen = false;

    const lb       = document.getElementById('og-lb');
    const lbImg    = document.getElementById('og-lb-img');
    const lbFigure = document.getElementById('og-lb-figure');
    const lbCount  = document.getElementById('og-lb-counter');
    const lbCap    = document.getElementById('og-lb-caption');
    const lbClose  = document.getElementById('og-lb-close');
    const lbPrev   = document.getElementById('og-lb-prev');
    const lbNext   = document.getElementById('og-lb-next');
    const backdrop = document.getElementById('og-lb-backdrop');

    function open(index) {
      current = ((index % total) + total) % total;
      lb.hidden = false;
      document.body.style.overflow = 'hidden';
      isOpen = true;
      render(true);
      requestAnimationFrame(() => lb.classList.add('og-lb-visible'));
    }

    function close() {
      lb.classList.remove('og-lb-visible');
      setTimeout(() => {
        lb.hidden = true;
        document.body.style.overflow = '';
        isOpen = false;
      }, 280);
    }

    function go(dir) {
      current = ((current + dir) + total) % total;
      render(false);
    }

    function render(first) {
      const item = items[current];
      if (!first) {
        lbFigure.classList.add('og-lb-fade');
      }
      const img = new window.Image();
      img.onload = () => {
        lbImg.src = item.src;
        lbImg.alt = item.alt;
        lbFigure.classList.remove('og-lb-fade');
      };
      img.src = item.src;
      lbCount.textContent = `${current + 1} / ${total}`;
      lbCap.textContent = item.alt;
    }

    // Grid click
    document.getElementById('og-grid').addEventListener('click', (e) => {
      const btn = e.target.closest('[data-index]');
      if (btn) open(parseInt(btn.dataset.index, 10));
    });

    lbClose.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    lbPrev.addEventListener('click', () => go(-1));
    lbNext.addEventListener('click', () => go(1));

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') go(-1);
      if (e.key === 'ArrowRight') go(1);
    });

    // Touch swipe
    let touchStartX = 0;
    lb.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) go(dx < 0 ? 1 : -1);
    });
  })();
</script>

<style>
  .og-gallery-page {
    max-width: var(--og-max);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) 2.5rem clamp(4rem, 8vw, 7rem);
    display: grid;
    gap: 2.5rem;
  }

  .og-label {
    font-family: var(--og-heading);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--og-accent);
  }

  .og-gallery-header {
    display: grid;
    gap: 0.5rem;
    border-bottom: 1px solid var(--og-line);
    padding-bottom: 1.75rem;
  }

  .og-gallery-title {
    font-family: var(--og-heading);
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.01em;
    margin: 0;
    color: var(--og-text);
  }

  .og-gallery-count {
    font-size: 0.83rem;
    color: var(--og-muted);
    letter-spacing: 0.04em;
  }

  /* ── GRID ── */
  .og-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }

  .og-grid-item {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    background: var(--og-surface);
    border: none;
    padding: 0;
    cursor: pointer;
    aspect-ratio: 3/4;
    display: block;
  }

  .og-grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 550ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .og-grid-item:hover img {
    transform: scale(1.04);
  }

  .og-grid-hover {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(26, 22, 18, 0);
    color: #fff;
    opacity: 0;
    transition: opacity 250ms ease, background 250ms ease;
  }

  .og-grid-item:hover .og-grid-hover,
  .og-grid-item:focus-visible .og-grid-hover {
    opacity: 1;
    background: rgba(26, 22, 18, 0.32);
  }

  /* ── LIGHTBOX ── */
  .og-lb[hidden] { display: none !important; }

  .og-lb {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 280ms ease;
  }

  .og-lb-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .og-lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(12, 10, 8, 0.96);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .og-lb-stage {
    position: relative;
    z-index: 1;
    max-width: min(90vw, 900px);
    max-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .og-lb-figure {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 220ms ease;
  }

  .og-lb-fade { opacity: 0; }

  .og-lb-figure img {
    max-width: 100%;
    max-height: 88vh;
    object-fit: contain;
    display: block;
    border-radius: 4px;
    box-shadow: 0 40px 120px -30px rgba(0,0,0,0.7);
  }

  /* Controls */
  .og-lb-btn {
    position: fixed;
    z-index: 2;
    background: rgba(26, 22, 18, 0.55);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.88);
    border-radius: 50%;
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 160ms, transform 140ms;
    padding: 0;
  }
  .og-lb-btn:hover {
    background: rgba(26, 22, 18, 0.85);
    transform: scale(1.06);
  }

  .og-lb-close { top: 1.5rem; right: 1.5rem; }
  .og-lb-prev  { left: 1.5rem; top: 50%; transform: translateY(-50%); }
  .og-lb-next  { right: 1.5rem; top: 50%; transform: translateY(-50%); }
  .og-lb-prev:hover { transform: translateY(-50%) scale(1.06); }
  .og-lb-next:hover { transform: translateY(-50%) scale(1.06); }

  .og-lb-counter {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--og-body);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.55);
  }

  .og-lb-caption {
    position: fixed;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--og-heading);
    font-style: italic;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 80vw;
    text-align: center;
  }

  /* Floating book CTA */
  .og-book-float {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 100;
    background: var(--og-accent);
    color: #fff;
    text-decoration: none;
    font-family: var(--og-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.65rem 1.4rem;
    border-radius: 999px;
    box-shadow: 0 8px 28px -8px rgba(184,124,106,0.5);
    transition: transform 150ms, background 150ms;
  }
  .og-book-float:hover {
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--og-accent) 88%, #1A1612 12%);
  }

  @media (max-width: 900px) {
    .og-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .og-gallery-page { padding: 2rem 1.25rem 5rem; }
    .og-grid { grid-template-columns: repeat(2, 1fr); gap: 3px; }
    .og-lb-prev { left: 0.75rem; }
    .og-lb-next { right: 0.75rem; }
  }
</style>
