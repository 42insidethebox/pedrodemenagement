---
import IoNodeIcon from '~/components/iopartner/IoNodeIcon.astro';
import { detectRequestLocale } from '~/lib/locale';

const locale = detectRequestLocale(Astro.request, Astro.url);

const COPY = {
  fr: {
    aria: 'Niveaux d’offre IOPartner',
    label: 'Offres structurées',
    line: '999 · 1 500 · 2 200+',
    axis: ['simple', 'niveau de scope', 'avancé'],
    layerMeta: { systems: 'à cadrer', other: 'prix lisible' },
    layers: [
      {
        key: 'standard',
        number: '01',
        title: '999 CHF',
        detail: 'Présence cadrée',
        meta: 'site stable',
        icon: 'standard',
        href: '/presence-web-cadree#offre-999',
      },
      {
        key: 'plus',
        number: '02',
        title: '1 500 CHF',
        detail: 'Plus de marge',
        meta: 'standard enrichi',
        icon: 'content',
        href: '/presence-web-cadree#offre-1500',
      },
      {
        key: 'systems',
        number: '03',
        title: '2 200+ CHF',
        detail: 'Éditable ou privé',
        meta: 'niveau 2',
        icon: 'build',
        href: '/presence-web-cadree#offre-2200',
      },
    ],
  },
  en: {
    aria: 'IOPartner offer levels',
    label: 'Structured offers',
    line: '999 · 1,500 · 2,200+',
    axis: ['simple', 'scope level', 'advanced'],
    layerMeta: { systems: 'to scope', other: 'clear price' },
    layers: [
      {
        key: 'standard',
        number: '01',
        title: 'CHF 999',
        detail: 'Scoped presence',
        meta: 'stable site',
        icon: 'standard',
        href: '/presence-web-cadree#offre-999',
      },
      {
        key: 'plus',
        number: '02',
        title: 'CHF 1,500',
        detail: 'More room',
        meta: 'enhanced standard',
        icon: 'content',
        href: '/presence-web-cadree#offre-1500',
      },
      {
        key: 'systems',
        number: '03',
        title: 'CHF 2,200+',
        detail: 'Editable or private',
        meta: 'level 2',
        icon: 'build',
        href: '/presence-web-cadree#offre-2200',
      },
    ],
  },
  de: {
    aria: 'IOPartner Angebotsebenen',
    label: 'Strukturierte Angebote',
    line: '999 · 1’500 · 2’200+',
    axis: ['einfach', 'Scope-Ebene', 'fortgeschritten'],
    layerMeta: { systems: 'zu scopen', other: 'klarer Preis' },
    layers: [
      {
        key: 'standard',
        number: '01',
        title: 'CHF 999',
        detail: 'Klare Präsenz',
        meta: 'stabile Site',
        icon: 'standard',
        href: '/presence-web-cadree#offre-999',
      },
      {
        key: 'plus',
        number: '02',
        title: 'CHF 1’500',
        detail: 'Mehr Spielraum',
        meta: 'erweiterter Standard',
        icon: 'content',
        href: '/presence-web-cadree#offre-1500',
      },
      {
        key: 'systems',
        number: '03',
        title: 'CHF 2’200+',
        detail: 'Editierbar oder privat',
        meta: 'Stufe 2',
        icon: 'build',
        href: '/presence-web-cadree#offre-2200',
      },
    ],
  },
  it: {
    aria: 'Livelli offerta IOPartner',
    label: 'Offerte strutturate',
    line: '999 · 1’500 · 2’200+',
    axis: ['semplice', 'livello di scope', 'avanzato'],
    layerMeta: { systems: 'da inquadrare', other: 'prezzo chiaro' },
    layers: [
      {
        key: 'standard',
        number: '01',
        title: 'CHF 999',
        detail: 'Presenza strutturata',
        meta: 'sito stabile',
        icon: 'standard',
        href: '/presence-web-cadree#offre-999',
      },
      {
        key: 'plus',
        number: '02',
        title: 'CHF 1’500',
        detail: 'Più margine',
        meta: 'standard evoluto',
        icon: 'content',
        href: '/presence-web-cadree#offre-1500',
      },
      {
        key: 'systems',
        number: '03',
        title: 'CHF 2’200+',
        detail: 'Modificabile o privato',
        meta: 'livello 2',
        icon: 'build',
        href: '/presence-web-cadree#offre-2200',
      },
    ],
  },
} as const;

const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;
---

<section class="io-pricing-layers" aria-label={copy.aria}>
  <div class="io-pricing-label">
    <strong>{copy.label}</strong>
    <span>{copy.line}</span>
  </div>

  <svg class="io-layer-routes" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
    <path class="route-ghost" d="M8 24 C27 8 73 8 92 26"></path>
    <path class="route-ghost" d="M8 80 C27 94 73 94 92 78"></path>
    <path class="route-ghost" d="M20 92 C31 66 52 42 80 16"></path>
    <path class="route-ghost" d="M8 52 C24 38 46 34 64 39"></path>
    <path class="route-main route-standard" d="M24 28 H40 C45 28 48 35 53 35 H75"></path>
    <path class="route-main route-consulting" d="M22 50 H75"></path>
    <path class="route-main route-systems" d="M24 72 H40 C45 72 48 65 53 65 H75"></path>
    <circle class="route-dot" cx="24" cy="28" r="0.58"></circle>
    <circle class="route-dot" cx="75" cy="35" r="0.58"></circle>
    <circle class="route-dot" cx="22" cy="50" r="0.58"></circle>
    <circle class="route-dot" cx="75" cy="50" r="0.58"></circle>
    <circle class="route-dot" cx="24" cy="72" r="0.58"></circle>
    <circle class="route-dot" cx="75" cy="65" r="0.58"></circle>
  </svg>

  <div class="scope-axis">
    <span>{copy.axis[0]}</span>
    <strong>{copy.axis[1]}</strong>
    <span>{copy.axis[2]}</span>
  </div>

  <div class="layer-stack">
    {
      copy.layers.map((layer: any) => (
        <a class={`offer-layer layer-${layer.key}`} href={layer.href}>
          <div class="layer-copy">
            <span>{layer.number}</span>
            <div>
              <strong>{layer.title}</strong>
              <small>{layer.detail}</small>
            </div>
          </div>
          <div class="layer-sheet" aria-hidden="true">
            <span class="sheet-icon">
              <IoNodeIcon name={layer.icon} />
            </span>
            <span class="sheet-line sheet-title" />
            <span class="sheet-line sheet-a" />
            <span class="sheet-line sheet-b" />
          </div>
          <div class="layer-meta">
            <strong>{layer.meta}</strong>
            <small>{layer.key === 'systems' ? copy.layerMeta.systems : copy.layerMeta.other}</small>
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .io-pricing-layers {
    --blue: #0b63f6;
    --ink: #0f172a;
    --muted: #64748b;
    position: relative;
    min-height: 25rem;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 1.25rem;
    background:
      linear-gradient(90deg, rgba(37, 99, 235, 0.05) 1px, transparent 1px),
      linear-gradient(rgba(37, 99, 235, 0.05) 1px, transparent 1px),
      radial-gradient(circle at 80% 20%, rgba(37, 99, 235, 0.1), transparent 30%), #f8fbff;
    background-size:
      32px 32px,
      32px 32px,
      auto,
      auto;
    box-shadow: 0 30px 82px -68px rgba(15, 23, 42, 0.45);
  }

  .io-pricing-layers::before {
    content: '';
    position: absolute;
    inset: 1.5rem;
    border: 1px dashed rgba(37, 99, 235, 0.13);
    border-radius: 0.95rem;
    pointer-events: none;
  }

  .io-pricing-label,
  .scope-axis,
  .layer-stack {
    position: relative;
    z-index: 2;
  }

  .io-pricing-label {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.35rem 1.45rem 0;
    color: var(--ink);
    font-size: 0.82rem;
  }

  .io-pricing-label span {
    color: var(--muted);
  }

  .io-layer-routes {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .io-layer-routes path {
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .route-ghost {
    stroke: rgba(37, 99, 235, 0.12);
    stroke-width: 0.55;
    stroke-dasharray: 3 7;
  }

  .route-main {
    stroke: rgba(37, 99, 235, 0.36);
    stroke-width: 0.85;
  }

  .route-dot {
    fill: var(--blue);
    stroke: #f8fbff;
    stroke-width: 0.35;
  }

  .scope-axis {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.7rem;
    align-items: center;
    margin: 1rem 1.45rem 0;
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .scope-axis strong {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.6rem;
    align-items: center;
    color: var(--blue);
  }

  .scope-axis strong::before,
  .scope-axis strong::after {
    content: '';
    height: 1px;
    background: rgba(37, 99, 235, 0.22);
  }

  .layer-stack {
    display: grid;
    gap: 0.72rem;
    padding: 1.2rem 1.45rem 1.45rem;
  }

  .offer-layer {
    display: grid;
    grid-template-columns: minmax(8.5rem, 0.9fr) minmax(9rem, 1fr) minmax(7.5rem, 0.7fr);
    gap: 1rem;
    align-items: center;
    min-height: 5.2rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 0.95rem;
    padding: 0.85rem;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 18px 48px -44px rgba(15, 23, 42, 0.48);
    color: inherit;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .offer-layer:hover,
  .offer-layer:focus-within {
    transform: translateY(-2px);
    border-color: rgba(37, 99, 235, 0.34);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 24px 54px -42px rgba(15, 23, 42, 0.52);
  }

  .offer-layer:active {
    transform: translateY(0) scale(0.997);
    background: rgba(255, 255, 255, 0.98);
  }

  .offer-layer:focus-visible {
    outline: 2px solid rgba(37, 99, 235, 0.38);
    outline-offset: 2px;
  }

  .layer-copy {
    display: flex;
    gap: 0.7rem;
    align-items: center;
  }

  .layer-copy > span {
    display: grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    border: 1px solid rgba(37, 99, 235, 0.2);
    border-radius: 0.65rem;
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 850;
  }

  .layer-copy strong,
  .layer-meta strong {
    display: block;
    color: var(--ink);
    font-size: 0.92rem;
    line-height: 1.16;
  }

  .layer-copy small,
  .layer-meta small {
    display: block;
    margin-top: 0.18rem;
    color: var(--muted);
    font-size: 0.72rem;
  }

  .layer-sheet {
    position: relative;
    display: grid;
    gap: 0.42rem;
    padding: 0.85rem 0.85rem 0.85rem 3.15rem;
    border: 1px solid rgba(37, 99, 235, 0.16);
    border-radius: 0.75rem;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(255, 255, 255, 0.72));
    transform-origin: center;
    transition:
      transform 190ms ease,
      border-color 190ms ease,
      background-color 190ms ease,
      box-shadow 190ms ease;
  }

  .offer-layer:hover .layer-sheet,
  .offer-layer:focus-visible .layer-sheet {
    transform: translateX(0.25rem) rotate(-0.65deg);
    border-color: rgba(37, 99, 235, 0.28);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(255, 255, 255, 0.9));
    box-shadow: 0 18px 38px -34px rgba(15, 23, 42, 0.45);
  }

  .offer-layer:active .layer-sheet {
    transform: translateX(0.1rem) scale(0.99);
  }

  .layer-plus:hover .layer-sheet,
  .layer-plus:focus-visible .layer-sheet {
    transform: translateX(0.35rem) rotate(0.65deg);
  }

  .layer-systems:hover .layer-sheet,
  .layer-systems:focus-visible .layer-sheet {
    transform: translateX(0.45rem) rotate(-0.35deg);
  }

  .sheet-icon {
    position: absolute;
    left: 0.82rem;
    top: 50%;
    display: grid;
    width: 1.78rem;
    height: 1.78rem;
    place-items: center;
    transform: translateY(-50%);
    border: 1px solid rgba(37, 99, 235, 0.22);
    border-radius: 0.5rem;
    color: var(--blue);
    background: #fff;
  }

  .sheet-line {
    display: block;
    height: 0.45rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.12);
    transition:
      width 190ms ease,
      background-color 190ms ease;
  }

  .sheet-title {
    width: 58%;
    height: 0.65rem;
    background: rgba(37, 99, 235, 0.2);
  }

  .sheet-a {
    width: 88%;
  }

  .sheet-b {
    width: 68%;
  }

  .offer-layer:hover .sheet-title,
  .offer-layer:focus-visible .sheet-title {
    width: 66%;
    background: rgba(37, 99, 235, 0.26);
  }

  .offer-layer:hover .sheet-a,
  .offer-layer:focus-visible .sheet-a {
    width: 78%;
  }

  .offer-layer:hover .sheet-b,
  .offer-layer:focus-visible .sheet-b {
    width: 82%;
  }

  .layer-meta {
    justify-self: end;
    text-align: right;
  }

  .layer-plus {
    margin-left: 1.35rem;
  }

  .layer-systems {
    margin-left: 2.7rem;
  }

  @media (max-width: 760px) {
    .io-pricing-layers {
      min-height: 0;
    }

    .io-pricing-label,
    .scope-axis {
      display: none;
    }

    .layer-stack {
      padding: 1rem;
    }

    .offer-layer {
      grid-template-columns: 1fr;
    }

    .layer-plus,
    .layer-systems {
      margin-left: 0;
    }

    .layer-meta {
      justify-self: start;
      text-align: left;
    }
  }
</style>
