---
import { detectRequestLocale } from '~/lib/locale';

type Variant = 'hero' | 'pricing' | 'systems' | 'standard' | 'decision';

interface Props {
  variant?: Variant;
  locale?: string;
}

const { variant = 'hero', locale: localeProp } = Astro.props as Props;
const locale = localeProp || detectRequestLocale(Astro.request, Astro.url);

const COPY = {
  fr: {
    heroNodes: [
      { label: 'DNS', detail: 'Domaine & routage', className: 'node-dns', icon: 'dns' },
      { label: 'CRM', detail: 'Données clients', className: 'node-crm', icon: 'crm' },
      { label: 'VPS', detail: 'Hébergement', className: 'node-vps', icon: 'server' },
      { label: 'Automations', detail: 'Workflows métier', className: 'node-automation', icon: 'automation' },
      { label: 'Website', detail: 'Site & contenu', className: 'node-website', icon: 'website' },
      { label: 'Monitoring', detail: 'Santé système', className: 'node-monitoring', icon: 'monitoring' },
      { label: 'Backup', detail: 'Sauvegardes', className: 'node-backup', icon: 'backup' },
    ],
    pricingLayers: [
      { label: '1. STANDARD', detail: 'Déploiement rapide', className: 'layer-standard' },
      { label: '2. CONSULTING', detail: 'Arbitrage & cadrage', className: 'layer-consulting' },
      { label: '3. SYSTEMS', detail: 'Architecture & opérations', className: 'layer-systems' },
    ],
    systemsLabel: ['Architecture opérationnelle', 'Infra · backend · continuité'],
    systemsBlocks: [
      { label: 'Web', detail: 'Sites & contenus', className: 'system-web', icon: 'website' },
      { label: 'API', detail: 'Routes métier', className: 'system-api', icon: 'api' },
      { label: 'Workers', detail: 'Jobs & workflows', className: 'system-workers', icon: 'automation' },
      { label: 'Data', detail: 'Sauvegardes', className: 'system-data', icon: 'backup' },
      { label: 'Monitoring', detail: 'Alertes & santé', className: 'system-monitoring', icon: 'monitoring' },
    ],
    systemsRows: [
      ['DNS + SSL', 'Routage propre'],
      ['Deploy', 'Versionnement clair'],
      ['Watch', 'Supervision active'],
    ],
    decision: ['Besoin', 'Standard', 'Consulting', 'Systems'],
  },
  en: {
    heroNodes: [
      { label: 'DNS', detail: 'Domain & routing', className: 'node-dns', icon: 'dns' },
      { label: 'CRM', detail: 'Client data', className: 'node-crm', icon: 'crm' },
      { label: 'VPS', detail: 'Hosting', className: 'node-vps', icon: 'server' },
      { label: 'Automations', detail: 'Business workflows', className: 'node-automation', icon: 'automation' },
      { label: 'Website', detail: 'Site & content', className: 'node-website', icon: 'website' },
      { label: 'Monitoring', detail: 'System health', className: 'node-monitoring', icon: 'monitoring' },
      { label: 'Backup', detail: 'Backups', className: 'node-backup', icon: 'backup' },
    ],
    pricingLayers: [
      { label: '1. STANDARD', detail: 'Fast deployment', className: 'layer-standard' },
      { label: '2. CONSULTING', detail: 'Arbitration & scoping', className: 'layer-consulting' },
      { label: '3. SYSTEMS', detail: 'Architecture & operations', className: 'layer-systems' },
    ],
    systemsLabel: ['Operational architecture', 'Infra · backend · continuity'],
    systemsBlocks: [
      { label: 'Web', detail: 'Sites & content', className: 'system-web', icon: 'website' },
      { label: 'API', detail: 'Business routes', className: 'system-api', icon: 'api' },
      { label: 'Workers', detail: 'Jobs & workflows', className: 'system-workers', icon: 'automation' },
      { label: 'Data', detail: 'Backups', className: 'system-data', icon: 'backup' },
      { label: 'Monitoring', detail: 'Alerts & health', className: 'system-monitoring', icon: 'monitoring' },
    ],
    systemsRows: [
      ['DNS + SSL', 'Clean routing'],
      ['Deploy', 'Clear versioning'],
      ['Watch', 'Active supervision'],
    ],
    decision: ['Need', 'Standard', 'Consulting', 'Systems'],
  },
  de: {
    heroNodes: [
      { label: 'DNS', detail: 'Domain & Routing', className: 'node-dns', icon: 'dns' },
      { label: 'CRM', detail: 'Kundendaten', className: 'node-crm', icon: 'crm' },
      { label: 'VPS', detail: 'Hosting', className: 'node-vps', icon: 'server' },
      { label: 'Automations', detail: 'Geschäfts-Workflows', className: 'node-automation', icon: 'automation' },
      { label: 'Website', detail: 'Site & Inhalte', className: 'node-website', icon: 'website' },
      { label: 'Monitoring', detail: 'Systemzustand', className: 'node-monitoring', icon: 'monitoring' },
      { label: 'Backup', detail: 'Backups', className: 'node-backup', icon: 'backup' },
    ],
    pricingLayers: [
      { label: '1. STANDARD', detail: 'Schnelles Deployment', className: 'layer-standard' },
      { label: '2. CONSULTING', detail: 'Abwägung & Scoping', className: 'layer-consulting' },
      { label: '3. SYSTEMS', detail: 'Architektur & Betrieb', className: 'layer-systems' },
    ],
    systemsLabel: ['Betriebsarchitektur', 'Infra · Backend · Kontinuität'],
    systemsBlocks: [
      { label: 'Web', detail: 'Sites & Inhalte', className: 'system-web', icon: 'website' },
      { label: 'API', detail: 'Business-Routen', className: 'system-api', icon: 'api' },
      { label: 'Workers', detail: 'Jobs & Workflows', className: 'system-workers', icon: 'automation' },
      { label: 'Data', detail: 'Backups', className: 'system-data', icon: 'backup' },
      { label: 'Monitoring', detail: 'Alarme & Zustand', className: 'system-monitoring', icon: 'monitoring' },
    ],
    systemsRows: [
      ['DNS + SSL', 'Sauberes Routing'],
      ['Deploy', 'Klares Versioning'],
      ['Watch', 'Aktive Überwachung'],
    ],
    decision: ['Bedarf', 'Standard', 'Consulting', 'Systems'],
  },
  it: {
    heroNodes: [
      { label: 'DNS', detail: 'Dominio & routing', className: 'node-dns', icon: 'dns' },
      { label: 'CRM', detail: 'Dati clienti', className: 'node-crm', icon: 'crm' },
      { label: 'VPS', detail: 'Hosting', className: 'node-vps', icon: 'server' },
      { label: 'Automations', detail: 'Workflow di business', className: 'node-automation', icon: 'automation' },
      { label: 'Website', detail: 'Sito & contenuti', className: 'node-website', icon: 'website' },
      { label: 'Monitoring', detail: 'Salute del sistema', className: 'node-monitoring', icon: 'monitoring' },
      { label: 'Backup', detail: 'Backup', className: 'node-backup', icon: 'backup' },
    ],
    pricingLayers: [
      { label: '1. STANDARD', detail: 'Deploy rapido', className: 'layer-standard' },
      { label: '2. CONSULTING', detail: 'Arbitraggio & scoping', className: 'layer-consulting' },
      { label: '3. SYSTEMS', detail: 'Architettura & operazioni', className: 'layer-systems' },
    ],
    systemsLabel: ['Architettura operativa', 'Infra · backend · continuità'],
    systemsBlocks: [
      { label: 'Web', detail: 'Siti & contenuti', className: 'system-web', icon: 'website' },
      { label: 'API', detail: 'Rotte di business', className: 'system-api', icon: 'api' },
      { label: 'Workers', detail: 'Job & workflow', className: 'system-workers', icon: 'automation' },
      { label: 'Data', detail: 'Backup', className: 'system-data', icon: 'backup' },
      { label: 'Monitoring', detail: 'Alert & salute', className: 'system-monitoring', icon: 'monitoring' },
    ],
    systemsRows: [
      ['DNS + SSL', 'Routing pulito'],
      ['Deploy', 'Versioning chiaro'],
      ['Watch', 'Supervisione attiva'],
    ],
    decision: ['Bisogno', 'Standard', 'Consulting', 'Systems'],
  },
} as const;

const copy = COPY[locale as keyof typeof COPY] ?? COPY.fr;

const heroNodes = copy.heroNodes;

const pricingLayers = copy.pricingLayers;

const systemsBlocks = copy.systemsBlocks;

const systemsRows = copy.systemsRows;
---

<div class={`io-blueprint io-blueprint-${variant}`} aria-hidden="true">
  {
    variant === 'hero' && (
      <div class="io-hero-map">
        <svg class="io-topology-routes" viewBox="0 0 100 100" preserveAspectRatio="none">
          <path d="M50 48 C48 38 41 30 31 26" />
          <path d="M50 48 C40 48 30 52 21 55" />
          <path d="M50 48 C56 34 66 21 78 16" />
          <path d="M50 48 C61 43 75 41 88 43" />
          <path d="M50 48 C62 56 77 66 88 72" />
          <path d="M50 48 C44 63 37 75 31 83" />
          <path d="M50 48 C54 65 63 79 71 86" />

          {/* faint architectural arcs */}
          <path class="route-ghost" d="M18 22 C36 8 66 8 84 24" />
          <path class="route-ghost" d="M15 78 C34 95 66 95 86 76" />
          <path class="route-ghost" d="M8 50 C22 34 35 26 50 22" />
        </svg>
        <div class="io-core">API</div>
        {heroNodes.map((node) => (
          <div class={`io-node ${node.className}`}>
            <span class="io-node-icon">
              <svg viewBox="0 0 24 24">
                {node.icon === 'dns' && (
                  <path d="M12 3a9 9 0 1 0 0 18a9 9 0 0 0 0-18Zm0 0c2.4 2.5 3.4 5.4 3.4 9S14.4 18.5 12 21M12 3c-2.4 2.5-3.4 5.4-3.4 9s1 6.5 3.4 9M3.6 9h16.8M3.6 15h16.8" />
                )}
                {node.icon === 'crm' && <path d="M12 12a4 4 0 1 0-4-4a4 4 0 0 0 4 4Zm-7 8a7 7 0 0 1 14 0" />}
                {node.icon === 'server' && <path d="M5 4h14v5H5Zm0 11h14v5H5Zm3-8h.01M8 18h.01M11 7h5M11 18h5" />}
                {node.icon === 'automation' && (
                  <path d="M6 8a2 2 0 1 0 0-4a2 2 0 0 0 0 4Zm12 6a2 2 0 1 0 0-4a2 2 0 0 0 0 4ZM7.7 7l8.6 4M8 6h4a3 3 0 0 1 3 3v2M18 14v2a3 3 0 0 1-3 3h-4M6 20a2 2 0 1 0 0-4a2 2 0 0 0 0 4Z" />
                )}
                {node.icon === 'website' && <path d="M4 5h16v14H4Zm0 4h16M7 7h.01M10 7h.01M8 13h8M8 16h5" />}
                {node.icon === 'monitoring' && <path d="M4 13h4l2-6l4 11l2-5h4" />}
                {node.icon === 'backup' && (
                  <path d="M12 5c4.4 0 8 1.3 8 3s-3.6 3-8 3s-8-1.3-8-3s3.6-3 8-3Zm-8 3v8c0 1.7 3.6 3 8 3s8-1.3 8-3V8M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3" />
                )}
              </svg>
            </span>
            <span>
              <strong>{node.label}</strong>
              <small>{node.detail}</small>
            </span>
          </div>
        ))}
      </div>
    )
  }

  {
    variant === 'pricing' && (
      <div class="io-layer-map">
        {pricingLayers.map((layer) => (
          <div class={`io-layer-row ${layer.className}`}>
            <div class="io-layer-copy">
              <strong>{layer.label}</strong>
              <small>{layer.detail}</small>
            </div>
            <span class="io-layer-dot" />
            <div class="io-layer-sheet">
              <span />
              <span />
              <span />
            </div>
          </div>
        ))}
      </div>
    )
  }

  {
    variant === 'systems' && (
      <div class="io-systems-map">
        <div class="io-systems-label">
          <strong>{copy.systemsLabel[0]}</strong>
          <span>{copy.systemsLabel[1]}</span>
        </div>
        <svg class="io-systems-routes" viewBox="0 0 100 100" preserveAspectRatio="none">
          <path d="M20 34 H47" />
          <path d="M53 34 H81" />
          <path d="M50 39 V63" />
          <path d="M50 63 H22" />
          <path d="M50 63 H79" />
        </svg>
        <div class="io-systems-flow">
          {systemsBlocks.map((block) => (
            <div class={`system-block ${block.className}`}>
              <span class="system-icon">
                <svg viewBox="0 0 24 24">
                  {block.icon === 'website' && <path d="M4 5h16v14H4Zm0 4h16M7 7h.01M10 7h.01M8 13h8M8 16h5" />}
                  {block.icon === 'api' && <path d="M8 8l-4 4l4 4M16 8l4 4l-4 4M14 5l-4 14" />}
                  {block.icon === 'automation' && (
                    <path d="M6 8a2 2 0 1 0 0-4a2 2 0 0 0 0 4Zm12 6a2 2 0 1 0 0-4a2 2 0 0 0 0 4ZM7.7 7l8.6 4M8 6h4a3 3 0 0 1 3 3v2M6 20a2 2 0 1 0 0-4a2 2 0 0 0 0 4Z" />
                  )}
                  {block.icon === 'backup' && (
                    <path d="M12 5c4.4 0 8 1.3 8 3s-3.6 3-8 3s-8-1.3-8-3s3.6-3 8-3Zm-8 3v8c0 1.7 3.6 3 8 3s8-1.3 8-3V8" />
                  )}
                  {block.icon === 'monitoring' && <path d="M4 13h4l2-6l4 11l2-5h4" />}
                </svg>
              </span>
              <strong>{block.label}</strong>
              <small>{block.detail}</small>
            </div>
          ))}
        </div>
        <div class="io-systems-rows">
          {systemsRows.map(([label, detail]) => (
            <div>
              <span />
              <strong>{label}</strong>
              <small>{detail}</small>
            </div>
          ))}
        </div>
      </div>
    )
  }

  {
    variant === 'standard' && (
      <div class="io-standard-preview">
        <div class="site-frame frame-a">
          <span />
          <span />
          <span />
        </div>
        <div class="site-frame frame-b">
          <span />
          <span />
          <span />
        </div>
        <div class="site-frame frame-c">
          <span />
          <span />
          <span />
        </div>
      </div>
    )
  }

  {
    variant === 'decision' && (
      <div class="io-decision-map">
        <svg class="io-decision-routes" viewBox="0 0 100 100" preserveAspectRatio="none">
          <path d="M31 52 C44 52 52 32 65 32" />
          <path d="M31 52 H65" />
          <path d="M31 52 C44 52 52 72 65 72" />
          <circle cx="31" cy="52" r="0.7" />
          <circle cx="65" cy="32" r="0.7" />
          <circle cx="65" cy="52" r="0.7" />
          <circle cx="65" cy="72" r="0.7" />
        </svg>
        <div class="decision-root">{copy.decision[0]}</div>
        <div class="decision-branch branch-a">{copy.decision[1]}</div>
        <div class="decision-branch branch-b">{copy.decision[2]}</div>
        <div class="decision-branch branch-c">{copy.decision[3]}</div>
      </div>
    )
  }
</div>

<style>
  .io-blueprint {
    position: relative;
    aspect-ratio: 5 / 3;
    min-height: unset;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 1.25rem;
    background:
      linear-gradient(90deg, rgba(37, 99, 235, 0.055) 1px, transparent 1px),
      linear-gradient(rgba(37, 99, 235, 0.055) 1px, transparent 1px), #f8fbff;
    background-size: 32px 32px;
    box-shadow: 0 28px 80px -60px rgba(15, 23, 42, 0.38);
  }

  .io-blueprint::before,
  .io-blueprint::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }

  .io-blueprint::before {
    inset: 2rem;
    border: 1px dashed rgba(37, 99, 235, 0.14);
  }

  .io-blueprint::after {
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.7), transparent 46%, rgba(37, 99, 235, 0.04));
  }

  .io-blueprint-systems {
    min-height: 22rem;
    border-color: rgba(125, 211, 252, 0.16);
    background:
      linear-gradient(90deg, rgba(125, 211, 252, 0.055) 1px, transparent 1px),
      linear-gradient(rgba(125, 211, 252, 0.055) 1px, transparent 1px), #061120;
    background-size: 28px 28px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .io-hero-map,
  .io-layer-map,
  .io-systems-map,
  .io-standard-preview,
  .io-decision-map {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .io-core {
    position: absolute;
    left: 50%;
    top: 48%;
    display: grid;
    width: 5.4rem;
    height: 5.4rem;
    place-items: center;
    transform: translate(-50%, -50%);
    border: 1px solid rgba(15, 23, 42, 0.18);
    border-radius: 0.85rem;
    background: linear-gradient(180deg, #ffffff, #f1f5f9);
    box-shadow:
      0 18px 42px -28px rgba(15, 23, 42, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
    color: #0f172a;
    font-weight: 800;
  }

  .io-topology-routes {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .io-topology-routes path,
  .io-systems-routes path,
  .io-decision-routes path {
    fill: none;
    stroke: rgba(37, 99, 235, 0.36);
    stroke-width: 0.38;
    vector-effect: non-scaling-stroke;
  }

  .io-decision-routes circle {
    fill: #2563eb;
    stroke: #f8fbff;
    stroke-width: 0.35;
    vector-effect: non-scaling-stroke;
  }

  .io-topology-routes path:nth-child(2n),
  .io-systems-routes path:nth-child(2n) {
    stroke-dasharray: 4 4;
    stroke-opacity: 0.55;
  }

  .io-node {
    position: absolute;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.62rem;
    align-items: center;
    min-width: 9.4rem;
    padding: 0.62rem 0.72rem;
    border: 1px solid rgba(37, 99, 235, 0.16);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 18px 38px -34px rgba(15, 23, 42, 0.5);
    color: #0f172a;
  }

  .io-node-icon {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid rgba(37, 99, 235, 0.26);
    border-radius: 0.55rem;
    background: rgba(37, 99, 235, 0.06);
    color: #2563eb;
  }

  .io-node-icon svg,
  .system-icon svg {
    width: 1.16rem;
    height: 1.16rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  .io-node strong,
  .io-layer-copy strong {
    font-size: 0.76rem;
    font-weight: 800;
  }

  .io-node small,
  .io-layer-copy small {
    color: #475569;
    font-size: 0.68rem;
  }

  .node-dns {
    left: 21%;
    top: 21%;
  }

  .node-crm {
    left: 7%;
    top: 49%;
  }

  .node-vps {
    right: 11%;
    top: 9%;
  }

  .node-automation {
    right: 4%;
    top: 35%;
  }

  .node-website {
    right: 5%;
    bottom: 20%;
  }

  .node-monitoring {
    left: 20%;
    bottom: 8%;
  }

  .node-backup {
    right: 20%;
    bottom: 5%;
  }

  .io-layer-map {
    padding: 4rem 2rem 2rem;
  }

  .io-layer-row {
    position: relative;
    display: grid;
    grid-template-columns: 10rem 1rem minmax(8rem, 1fr);
    align-items: center;
    gap: 1rem;
    margin-bottom: -1.6rem;
  }

  .io-layer-copy {
    display: grid;
    gap: 0.25rem;
    color: #0f172a;
  }

  .io-layer-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: #2563eb;
    box-shadow: 0 0 0 0.35rem rgba(37, 99, 235, 0.08);
  }

  .io-layer-sheet {
    position: relative;
    min-height: 5.8rem;
    transform: skewY(-12deg);
    border: 1px solid rgba(37, 99, 235, 0.16);
    border-radius: 0.8rem;
    background: rgba(255, 255, 255, 0.62);
  }

  .io-layer-sheet span {
    position: absolute;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 0.35rem;
  }

  .io-layer-sheet span:nth-child(1) {
    inset: 1rem auto auto 1.1rem;
    width: 34%;
    height: 1.25rem;
  }

  .io-layer-sheet span:nth-child(2) {
    inset: 2.8rem 1.1rem auto auto;
    width: 28%;
    height: 1.3rem;
  }

  .io-layer-sheet span:nth-child(3) {
    left: 42%;
    bottom: 1rem;
    width: 18%;
    height: 1rem;
  }

  .io-systems-label {
    position: absolute;
    top: 1.25rem;
    left: 1.35rem;
    display: grid;
    gap: 0.22rem;
    color: #f8fafc;
  }

  .io-systems-label strong {
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .io-systems-label span {
    color: #93c5fd;
    font-size: 0.72rem;
  }

  .io-systems-routes {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .io-systems-routes path {
    stroke: rgba(125, 211, 252, 0.42);
  }

  .io-systems-flow {
    position: absolute;
    inset: 4.8rem 1.25rem 5rem;
  }

  .system-block {
    position: absolute;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.52rem 0.62rem;
    align-items: center;
    width: 8.9rem;
    padding: 0.72rem;
    border: 1px solid rgba(125, 211, 252, 0.18);
    border-radius: 0.82rem;
    background: rgba(15, 23, 42, 0.82);
    box-shadow: 0 20px 48px -36px rgba(2, 6, 23, 0.9);
    color: #e2e8f0;
  }

  .system-icon {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid rgba(125, 211, 252, 0.3);
    border-radius: 0.56rem;
    color: #93c5fd;
    background: rgba(14, 165, 233, 0.08);
  }

  .system-block strong,
  .system-block small {
    display: block;
  }

  .system-block strong {
    font-size: 0.78rem;
  }

  .system-block small {
    grid-column: 2;
    color: #94a3b8;
    font-size: 0.66rem;
    line-height: 1.25;
  }

  .system-web {
    left: 0;
    top: 18%;
  }

  .system-api {
    left: 50%;
    top: 16%;
    transform: translateX(-50%);
  }

  .system-workers {
    right: 0;
    top: 18%;
  }

  .system-data {
    left: 12%;
    bottom: 4%;
  }

  .system-monitoring {
    right: 8%;
    bottom: 4%;
  }

  .io-systems-rows {
    position: absolute;
    right: 1.25rem;
    bottom: 1.15rem;
    left: 1.25rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
