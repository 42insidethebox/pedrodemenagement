---
import type { IoIconName } from '~/components/iopartner/ioNodeIconTypes';

interface Props {
  name: IoIconName;
  title?: string;
}

const { name, title } = Astro.props as Props;
---

<svg
  class="io-node-icon-svg"
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden={title ? undefined : 'true'}
  role={title ? 'img' : undefined}
>
  {title && <title>{title}</title>}
  {
    name === 'api' && (
      <g>
        <path d="M8 8 4 12l4 4" />
        <path d="m16 8 4 4-4 4" />
        <path d="m14 5-4 14" />
      </g>
    )
  }
  {
    name === 'automation' && (
      <g>
        <path d="M6 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
        <path d="M18 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
        <path d="M6 20a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
        <path d="m7.7 7 8.6 4" />
        <path d="M8 6h4a3 3 0 0 1 3 3v2" />
        <path d="M18 14v2a3 3 0 0 1-3 3h-4" />
      </g>
    )
  }
  {
    name === 'build' && (
      <g>
        <path d="M12 3 4.5 7.2 12 11.4l7.5-4.2Z" />
        <path d="M4.5 7.2v8.4L12 20l7.5-4.4V7.2" />
        <path d="M12 11.4V20" />
      </g>
    )
  }
  {
    name === 'check' && (
      <g>
        <path d="M20 6 9 17l-5-5" />
        <path d="M12 21a9 9 0 1 1 8.1-5.1" />
      </g>
    )
  }
  {
    name === 'clock' && (
      <g>
        <path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
        <path d="M12 7v5l3 2" />
      </g>
    )
  }
  {
    name === 'communication' && (
      <g>
        <path d="M7 18.5 4 20l1-3.3A8 8 0 1 1 7 18.5Z" />
        <path d="M8.5 10.5h.01" />
        <path d="M12 10.5h.01" />
        <path d="M15.5 10.5h.01" />
      </g>
    )
  }
  {
    name === 'consulting' && (
      <g>
        <path d="M5 5h14v14H5Z" />
        <path d="M8 9h8" />
        <path d="M8 13h5" />
        <path d="M8 17h7" />
        <path d="M16 3v4" />
      </g>
    )
  }
  {
    name === 'content' && (
      <g>
        <path d="M6 4h12v16H6Z" />
        <path d="M9 8h6" />
        <path d="M9 12h6" />
        <path d="M9 16h3" />
      </g>
    )
  }
  {
    name === 'continuity' && (
      <g>
        <path d="M4 13h4l2-6 4 11 2-5h4" />
        <path d="M5 5h14v14H5Z" />
      </g>
    )
  }
  {
    name === 'deploy' && (
      <g>
        <path d="M12 3v11" />
        <path d="m7 8 5-5 5 5" />
        <path d="M5 21h14" />
        <path d="M7 17h10" />
      </g>
    )
  }
  {
    name === 'diagnostic' && (
      <g>
        <path d="M12 3a7 7 0 0 0-4 12.75V18h8v-2.25A7 7 0 0 0 12 3Z" />
        <path d="M9 18h6" />
        <path d="M9 21h6" />
      </g>
    )
  }
  {
    name === 'handoff' && (
      <g>
        <path d="M7 7h10" />
        <path d="M7 12h7" />
        <path d="M7 17h4" />
        <path d="M15 15l2 2 4-5" />
        <path d="M5 4h14v16H5Z" />
      </g>
    )
  }
  {
    name === 'scope' && (
      <g>
        <path d="M4 6h16" />
        <path d="M7 12h10" />
        <path d="M10 18h4" />
      </g>
    )
  }
  {
    name === 'standard' && (
      <g>
        <path d="M4 5h16v14H4Z" />
        <path d="M4 9h16" />
        <path d="M7 7h.01" />
        <path d="M10 7h.01" />
        <path d="M8 13h8" />
        <path d="M8 16h5" />
      </g>
    )
  }
  {
    name === 'systems' && (
      <g>
        <path d="M5 4h14v5H5Z" />
        <path d="M5 15h14v5H5Z" />
        <path d="M8 7h.01" />
        <path d="M8 18h.01" />
        <path d="M11 7h5" />
        <path d="M11 18h5" />
      </g>
    )
  }
</svg>

<style>
  .io-node-icon-svg {
    display: block;
    width: 1.25rem;
    height: 1.25rem;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.75;
  }
</style>
